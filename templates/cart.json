{
  "sections": {
    "cart-section": {
      "type": "main-cart",
      "blocks": {
        "cart-page-title": {
          "type": "_cart-title",
          "static": true,
          "settings": {
            "title": "Your Cart",
            "show_count": true,
            "type_preset": "h3",
            "alignment": "left",
            "padding-block-start": 0,
            "padding-block-end": 0,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {}
        },
        "cart-page-items": {
          "type": "_cart-products",
          "static": true,
          "settings": {
            "gap": 24,
            "image_ratio": "portrait",
            "dividers": true,
            "vendor": false,
            "padding-block-start": 0,
            "padding-block-end": 0,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {}
        },
        "cart-page-summary": {
          "type": "_cart-summary",
          "static": true,
          "settings": {
            "extend_summary": true,
            "inherit_color_scheme": false,
            "color_scheme": "scheme-2",
            "border": "none",
            "border_width": 1,
            "border_opacity": 100,
            "border_radius": 0
          },
          "blocks": {}
        }
      },
      "settings": {
        "section_width": "page-width",
        "color_scheme": "scheme-1",
        "padding-block-start": 24,
        "padding-block-end": 0
      }
    },
    "cart_recommendations": {
      "type": "product-list",
      "blocks": {
        "static-header": {
          "type": "_product-list-content",
          "name": "t:names.header",
          "static": true,
          "settings": {
            "content_direction": "row",
            "vertical_on_mobile": false,
            "horizontal_alignment": "space-between",
            "vertical_alignment": "flex-end",
            "align_baseline": true,
            "gap": 12,
            "width": "fill",
            "inherit_color_scheme": true
          },
          "blocks": {
            "heading": {
              "type": "_product-list-text",
              "settings": {
                "text": "<h3>You may also like<\/h3>",
                "width": "fit-content",
                "alignment": "left",
                "type_preset": "h4"
              },
              "blocks": {}
            },
            "view_all": {
              "type": "_product-list-button",
              "settings": {
                "label": "View all",
                "style_class": "link",
                "width": "fit-content"
              },
              "blocks": {}
            }
          },
          "block_order": ["heading", "view_all"]
        },
        "static-product-card": {
          "type": "_product-card",
          "name": "t:names.product_card",
          "static": true,
          "settings": {
            "product_card_gap": 4,
            "inherit_color_scheme": true,
            "border": "none",
            "border_radius": 0
          },
          "blocks": {
            "gallery": {
              "type": "_product-card-gallery",
              "settings": {
                "image_ratio": "adapt",
                "border": "none",
                "border_radius": 0
              },
              "blocks": {}
            },
            "title": {
              "type": "product-title",
              "settings": {
                "width": "100%",
                "alignment": "left",
                "type_preset": "rte",
                "font_size": "1rem",
                "padding-block-start": 4
              },
              "blocks": {}
            },
            "price": {
              "type": "price",
              "settings": {
                "show_sale_price_first": true,
                "type_preset": "h6",
                "width": "100%",
                "alignment": "left",
                "font_size": "1rem"
              },
              "blocks": {}
            }
          },
          "block_order": ["gallery", "title", "price"]
        }
      },
      "settings": {
        "collection": "all",
        "layout_type": "grid",
        "carousel_on_mobile": false,
        "max_products": 4,
        "columns": 4,
        "mobile_columns": "2",
        "columns_gap": 12,
        "rows_gap": 24,
        "section_width": "page-width",
        "gap": 28,
        "color_scheme": "scheme-1",
        "padding-block-start": 48,
        "padding-block-end": 48
      }
    }
  },
  "order": ["cart-section", "cart_recommendations"]
}
