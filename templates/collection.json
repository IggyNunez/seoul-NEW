{
  "sections": {
    "collection_header": {
      "type": "section",
      "blocks": {
        "col_title": {
          "type": "text",
          "settings": {
            "text": "<h1>{{ closest.collection.title }}<\/h1>",
            "width": "fit-content",
            "alignment": "left",
            "type_preset": "h1",
            "case": "uppercase"
          },
          "blocks": {}
        },
        "col_description": {
          "type": "text",
          "settings": {
            "text": "{{ closest.collection.description }}",
            "width": "fill",
            "alignment": "left",
            "type_preset": "rte"
          },
          "blocks": {}
        }
      },
      "block_order": ["col_title", "col_description"],
      "settings": {
        "content_direction": "column",
        "vertical_on_mobile": true,
        "horizontal_alignment": "flex-start",
        "vertical_alignment": "center",
        "horizontal_alignment_flex_direction_column": "flex-start",
        "vertical_alignment_flex_direction_column": "center",
        "gap": 12,
        "section_width": "page-width",
        "color_scheme": "scheme-1",
        "background_media": "none",
        "border": "none",
        "toggle_overlay": false,
        "padding-block-start": 48,
        "padding-block-end": 32
      }
    },
    "main": {
      "type": "main-collection",
      "blocks": {
        "filters": {
          "type": "filters",
          "static": true,
          "settings": {
            "enable_filtering": true,
            "filter_style": "horizontal",
            "filter_width": "centered",
            "text_label_case": "default",
            "show_swatch_label": false,
            "show_filter_label": false,
            "enable_sorting": true,
            "enable_grid_density": true,
            "inherit_color_scheme": true,
            "color_scheme": "",
            "padding-block-start": 8,
            "padding-block-end": 8,
            "padding-inline-start": 0,
            "padding-inline-end": 0,
            "facets_margin_bottom": 8,
            "facets_margin_right": 20
          },
          "blocks": {}
        },
        "product-card": {
          "type": "_product-card",
          "static": true,
          "settings": {
            "product_card_gap": 4,
            "inherit_color_scheme": true,
            "color_scheme": "",
            "border": "none",
            "border_width": 1,
            "border_opacity": 100,
            "border_radius": 0,
            "padding-block-start": 0,
            "padding-block-end": 0,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {
            "card-gallery": {
              "type": "_product-card-gallery",
              "settings": {
                "image_ratio": "adapt",
                "border": "none",
                "border_width": 1,
                "border_opacity": 100,
                "border_radius": 0
              },
              "blocks": {}
            },
            "product_title": {
              "type": "product-title",
              "settings": {
                "width": "100%",
                "alignment": "left",
                "type_preset": "rte",
                "font_size": "1rem",
                "padding-block-start": 4,
                "padding-block-end": 0
              },
              "blocks": {}
            },
            "product_price": {
              "type": "price",
              "settings": {
                "show_sale_price_first": true,
                "show_installments": false,
                "type_preset": "h6",
                "width": "100%",
                "alignment": "left",
                "font_size": "1rem"
              },
              "blocks": {}
            }
          },
          "block_order": ["card-gallery", "product_title", "product_price"]
        }
      },
      "settings": {
        "layout_type": "grid",
        "product_card_size": "medium",
        "mobile_product_card_size": "small",
        "enable_infinite_scroll": true,
        "products_per_page": 24,
        "product_grid_width": "centered",
        "full_width_on_mobile": true,
        "columns_gap_horizontal": 16,
        "columns_gap_vertical": 24,
        "padding-inline-start": 0,
        "padding-inline-end": 0,
        "color_scheme": "scheme-1",
        "padding-block-start": 0,
        "padding-block-end": 32
      }
    },
    "collection_faq": {
      "type": "section",
      "blocks": {
        "faq_heading": {
          "type": "text",
          "settings": {
            "text": "<h2>Frequently Asked Questions<\/h2>",
            "width": "fill",
            "alignment": "left",
            "type_preset": "h2"
          },
          "blocks": {}
        },
        "faq_accordion": {
          "type": "accordion",
          "settings": {
            "icon": "caret",
            "dividers": true,
            "type_preset": "h5",
            "inherit_color_scheme": true
          },
          "blocks": {
            "faq_1": {
              "type": "_accordion-row",
              "settings": {
                "heading": "When will my order ship?"
              },
              "blocks": {
                "faq_1_body": {
                  "type": "text",
                  "settings": {
                    "text": "<p>Orders are processed within 1–3 business days. You'll receive an email confirmation with tracking info once your order ships.<\/p>",
                    "type_preset": "rte"
                  },
                  "blocks": {}
                }
              },
              "block_order": ["faq_1_body"]
            },
            "faq_2": {
              "type": "_accordion-row",
              "settings": {
                "heading": "What is your return policy?"
              },
              "blocks": {
                "faq_2_body": {
                  "type": "text",
                  "settings": {
                    "text": "<p>We accept returns within 30 days of delivery for unused, unopened products. Please contact us at help@seoulglowlab.com to start a return.<\/p>",
                    "type_preset": "rte"
                  },
                  "blocks": {}
                }
              },
              "block_order": ["faq_2_body"]
            },
            "faq_3": {
              "type": "_accordion-row",
              "settings": {
                "heading": "Are your products cruelty-free?"
              },
              "blocks": {
                "faq_3_body": {
                  "type": "text",
                  "settings": {
                    "text": "<p>Yes. All Seoul Glow Lab products are cruelty-free. We never test on animals and we carefully vet our ingredient suppliers for the same standard.<\/p>",
                    "type_preset": "rte"
                  },
                  "blocks": {}
                }
              },
              "block_order": ["faq_3_body"]
            },
            "faq_4": {
              "type": "_accordion-row",
              "settings": {
                "heading": "Can I use these products if I have sensitive skin?"
              },
              "blocks": {
                "faq_4_body": {
                  "type": "text",
                  "settings": {
                    "text": "<p>Most of our formulas are designed with sensitive skin in mind — fragrance-free and with gentle, science-backed ingredients. Check each product page for specific skin type guidance.<\/p>",
                    "type_preset": "rte"
                  },
                  "blocks": {}
                }
              },
              "block_order": ["faq_4_body"]
            }
          },
          "block_order": ["faq_1", "faq_2", "faq_3", "faq_4"]
        }
      },
      "block_order": ["faq_heading", "faq_accordion"],
      "settings": {
        "content_direction": "column",
        "vertical_on_mobile": true,
        "horizontal_alignment": "flex-start",
        "vertical_alignment": "flex-start",
        "horizontal_alignment_flex_direction_column": "flex-start",
        "vertical_alignment_flex_direction_column": "flex-start",
        "gap": 32,
        "section_width": "page-width",
        "color_scheme": "scheme-2",
        "background_media": "none",
        "border": "none",
        "toggle_overlay": false,
        "padding-block-start": 64,
        "padding-block-end": 64
      }
    }
  },
  "order": ["collection_header", "main", "collection_faq"]
}
