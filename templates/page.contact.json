{
  "sections": {
    "contact_hero": {
      "type": "section",
      "blocks": {
        "eyebrow": {
          "type": "text",
          "settings": {
            "text": "<p>Get in Touch</p>",
            "width": "100%",
            "alignment": "center",
            "type_preset": "rte",
            "case": "uppercase",
            "letter_spacing": "loose"
          },
          "blocks": {}
        },
        "heading": {
          "type": "text",
          "settings": {
            "text": "<h1>We\u2019d love to hear from you</h1>",
            "width": "100%",
            "alignment": "center",
            "type_preset": "h2"
          },
          "blocks": {}
        },
        "subheading": {
          "type": "text",
          "settings": {
            "text": "<p>Questions about your order, our products, or your skin? Our team typically responds within 1\u20132 business days.</p>",
            "width": "narrow",
            "alignment": "center",
            "type_preset": "rte"
          },
          "blocks": {}
        }
      },
      "block_order": ["eyebrow", "heading", "subheading"],
      "settings": {
        "content_direction": "column",
        "horizontal_alignment_flex_direction_column": "center",
        "vertical_alignment_flex_direction_column": "center",
        "gap": 20,
        "section_width": "page-width",
        "color_scheme": "scheme-1",
        "padding-block-start": 64,
        "padding-block-end": 48
      }
    },
    "form": {
