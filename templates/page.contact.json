    "contact_faq": {
      "type": "section",
      "blocks": {
        "faq_heading": {
          "type": "text",
          "settings": {
            "text": "<h2>Frequently Asked Questions</h2>",
            "width": "100%",
            "alignment": "center",
            "type_preset": "h3"
          },
          "blocks": {}
        },
        "faq_accordion": {
          "type": "accordion",
          "settings": {
            "icon": "caret",
            "dividers": true,
            "type_preset": "h6",
            "inherit_color_scheme": true
          },
          "blocks": {
            "faq_orders": {
              "type": "_accordion-row",
              "settings": {
                "heading": "Where is my order?"
              },
              "blocks": {
                "faq_orders_body": {
                  "type": "text",
                  "settings": {
                    "text": "<p>Once your order ships, you\u2019ll receive a tracking email. Orders typically ship within 1\u20133 business days. If it\u2019s been longer, please reach out using the form above and we\u2019ll look into it right away.</p>",
                    "type_preset": "rte"
                  },
                  "blocks": {}
                }
              },
              "block_order": ["faq_orders_body"]
            },
            "faq_returns": {
              "type": "_accordion-row",
              "settings": {
                "heading": "What is your return policy?"
              },
              "blocks": {
                "faq_returns_body": {
                  "type": "text",
                  "settings": {
                    "text": "<p>We accept returns within 30 days of delivery for unused, unopened items in their original packaging. If a product arrived damaged or defective, contact us and we\u2019ll make it right.</p>",
                    "type_preset": "rte"
                  },
                  "blocks": {}
                }
              },
              "block_order": ["faq_returns_body"]
            },
            "faq_skin_type": {
              "type": "_accordion-row",
              "settings": {
                "heading": "Which products are right for my skin type?"
              },
              "blocks": {
                "faq_skin_type_body": {
                  "type": "text",
                  "settings": {
                    "text": "<p>All Seoul Glow Lab products list their intended skin types on the product page. If you\u2019re unsure where to start, feel free to send us a message describing your skin concerns and we\u2019ll help you build a routine.</p>",
                    "type_preset": "rte"
                  },
                  "blocks": {}
                }
              },
              "block_order": ["faq_skin_type_body"]
            },
            "faq_international": {
              "type": "_accordion-row",
              "settings": {
                "heading": "Do you ship internationally?"
              },
              "blocks": {
                "faq_international_body": {
                  "type": "text",
                  "settings": {
                    "text": "<p>We currently ship within the United States. International shipping is coming soon\u2014sign up for our newsletter to be notified when your country is available.</p>",
                    "type_preset": "rte"
                  },
                  "blocks": {}
                }
              },
              "block_order": ["faq_international_body"]
            }
          },
          "block_order": ["faq_orders", "faq_returns", "faq_skin_type", "faq_international"]
        }
      },
      "block_order": ["faq_heading", "faq_accordion"],
      "settings": {
        "content_direction": "column",
        "horizontal_alignment_flex_direction_column": "center",
        "vertical_alignment_flex_direction_column": "flex-start",
        "gap": 32,
        "section_width": "content-center-aligned",
        "color_scheme": "scheme-1",
        "padding-block-start": 64,
        "padding-block-end": 80
      }
    }
