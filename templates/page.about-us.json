          "blocks": {}
        },
        "value_1_body": {
          "type": "text",
          "settings": {
            "text": "<p>Every Seoul Glow Lab product is cruelty-free, dermatologist-tested, and formulated without parabens, sulfates, or artificial fragrances. Clean beauty isn\u2019t a trend for us\u2014it\u2019s a baseline.</p>",
            "width": "100%",
            "alignment": "left",
            "type_preset": "rte"
          },
          "blocks": {}
        },
        "value_2_heading": {
          "type": "text",
          "settings": {
            "text": "<h3>K-Beauty Science</h3>",
            "width": "100%",
            "alignment": "left",
            "type_preset": "h5"
          },
          "blocks": {}
        },
        "value_2_body": {
          "type": "text",
          "settings": {
            "text": "<p>We draw on Korea\u2019s decades of skincare innovation\u2014from fermented ingredients and ceramide complexes to cushion textures and multi-step layering\u2014to bring you formulas that actually work.</p>",
            "width": "100%",
            "alignment": "left",
            "type_preset": "rte"
          },
          "blocks": {}
        },
        "value_3_heading": {
          "type": "text",
          "settings": {
            "text": "<h3>Inclusive Skin Care</h3>",
            "width": "100%",
            "alignment": "left",
            "type_preset": "h5"
          },
          "blocks": {}
        },
        "value_3_body": {
          "type": "text",
          "settings": {
            "text": "<p>Your glow is unique. Our products are designed and tested for all skin tones and types\u2014because glass skin isn\u2019t a look, it\u2019s a feeling.</p>",
            "width": "100%",
            "alignment": "left",
            "type_preset": "rte"
          },
          "blocks": {}
        }
