{%- doc -%}
  Mini Reviews Block
  Displays 1-3 customer testimonial cards with star ratings and verified badges.
{%- enddoc -%}

{%- assign block_settings = block.settings -%}

<div
  class="casa-mini-reviews spacing-style"
  style="{% render 'spacing-style', settings: block_settings %}"
  {{ block.shopify_attributes }}
>
  {%- if block_settings.heading != blank -%}
    <h3 class="casa-mini-reviews__heading">{{ block_settings.heading }}</h3>
  {%- endif -%}

  <div class="casa-mini-reviews__cards">
    {%- if block_settings.review_1_text != blank -%}
      <div class="casa-mini-reviews__card">
        <div class="casa-mini-reviews__stars" aria-label="{{ block_settings.review_1_rating }} out of 5 stars">
          {%- for i in (1..5) -%}
            <svg class="casa-mini-reviews__star{% if i <= block_settings.review_1_rating %} casa-mini-reviews__star--filled{% endif %}" width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M7 1L8.854 4.756L13 5.362L10 8.284L10.708 12.412L7 10.462L3.292 12.412L4 8.284L1 5.362L5.146 4.756L7 1Z" fill="currentColor"/>
            </svg>
          {%- endfor -%}
        </div>
        <p class="casa-mini-reviews__text">"{{ block_settings.review_1_text }}"</p>
        <div class="casa-mini-reviews__author">
          <span class="casa-mini-reviews__name">{{ block_settings.review_1_name }}</span>
          {%- if block_settings.review_1_verified -%}
            <span class="casa-mini-reviews__verified">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M10.5 5.54V6.0C10.4994 7.0976 10.1503 8.1671 9.5056 9.0576 8.8609 9.9481 7.9521 10.6143 6.9111 10.9593 5.8700 11.3043 4.7482 11.3106 3.7034 10.9772 2.6586 10.6438 1.7427 9.9876 1.0888 9.1043 0.4349 8.2211 0.0747 7.1563 0.0612 6.0589 0.0477 4.9615 0.3812 3.8883 1.0128 2.9895 1.6444 2.0907 2.5432 1.4121 3.5789 1.0517 4.6146 0.6913 5.7357 0.6663 6.7834 0.9766" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M10.5 2L6 6.505L4.5 5.005" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Verified
            </span>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

    {%- if block_settings.review_2_text != blank -%}
      <div class="casa-mini-reviews__card">
        <div class="casa-mini-reviews__stars" aria-label="{{ block_settings.review_2_rating }} out of 5 stars">
          {%- for i in (1..5) -%}
            <svg class="casa-mini-reviews__star{% if i <= block_settings.review_2_rating %} casa-mini-reviews__star--filled{% endif %}" width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M7 1L8.854 4.756L13 5.362L10 8.284L10.708 12.412L7 10.462L3.292 12.412L4 8.284L1 5.362L5.146 4.756L7 1Z" fill="currentColor"/>
            </svg>
          {%- endfor -%}
        </div>
        <p class="casa-mini-reviews__text">"{{ block_settings.review_2_text }}"</p>
        <div class="casa-mini-reviews__author">
          <span class="casa-mini-reviews__name">{{ block_settings.review_2_name }}</span>
          {%- if block_settings.review_2_verified -%}
            <span class="casa-mini-reviews__verified">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M10.5 5.54V6.0C10.4994 7.0976 10.1503 8.1671 9.5056 9.0576 8.8609 9.9481 7.9521 10.6143 6.9111 10.9593 5.8700 11.3043 4.7482 11.3106 3.7034 10.9772 2.6586 10.6438 1.7427 9.9876 1.0888 9.1043 0.4349 8.2211 0.0747 7.1563 0.0612 6.0589 0.0477 4.9615 0.3812 3.8883 1.0128 2.9895 1.6444 2.0907 2.5432 1.4121 3.5789 1.0517 4.6146 0.6913 5.7357 0.6663 6.7834 0.9766" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M10.5 2L6 6.505L4.5 5.005" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Verified
            </span>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

    {%- if block_settings.review_3_text != blank -%}
      <div class="casa-mini-reviews__card">
        <div class="casa-mini-reviews__stars" aria-label="{{ block_settings.review_3_rating }} out of 5 stars">
          {%- for i in (1..5) -%}
            <svg class="casa-mini-reviews__star{% if i <= block_settings.review_3_rating %} casa-mini-reviews__star--filled{% endif %}" width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M7 1L8.854 4.756L13 5.362L10 8.284L10.708 12.412L7 10.462L3.292 12.412L4 8.284L1 5.362L5.146 4.756L7 1Z" fill="currentColor"/>
            </svg>
          {%- endfor -%}
        </div>
        <p class="casa-mini-reviews__text">"{{ block_settings.review_3_text }}"</p>
        <div class="casa-mini-reviews__author">
          <span class="casa-mini-reviews__name">{{ block_settings.review_3_name }}</span>
          {%- if block_settings.review_3_verified -%}
            <span class="casa-mini-reviews__verified">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M10.5 5.54V6.0C10.4994 7.0976 10.1503 8.1671 9.5056 9.0576 8.8609 9.9481 7.9521 10.6143 6.9111 10.9593 5.8700 11.3043 4.7482 11.3106 3.7034 10.9772 2.6586 10.6438 1.7427 9.9876 1.0888 9.1043 0.4349 8.2211 0.0747 7.1563 0.0612 6.0589 0.0477 4.9615 0.3812 3.8883 1.0128 2.9895 1.6444 2.0907 2.5432 1.4121 3.5789 1.0517 4.6146 0.6913 5.7357 0.6663 6.7834 0.9766" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M10.5 2L6 6.505L4.5 5.005" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Verified
            </span>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Mini reviews",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What customers say"
    },
    {
      "type": "header",
      "content": "Review 1"
    },
    {
      "type": "text",
      "id": "review_1_name",
      "label": "Name",
      "default": "Sarah M."
    },
    {
      "type": "text",
      "id": "review_1_text",
      "label": "Review text",
      "default": "Absolutely stunning piece. The light quality is incredible and it transforms the whole room."
    },
    {
      "type": "range",
      "id": "review_1_rating",
      "label": "Rating",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 5
    },
    {
      "type": "checkbox",
      "id": "review_1_verified",
      "label": "Verified buyer",
      "default": true
    },
    {
      "type": "header",
      "content": "Review 2"
    },
    {
      "type": "text",
      "id": "review_2_name",
      "label": "Name",
      "default": "James K."
    },
    {
      "type": "text",
      "id": "review_2_text",
      "label": "Review text",
      "default": "Perfect addition to our living room. The quality exceeded my expectations."
    },
    {
      "type": "range",
      "id": "review_2_rating",
      "label": "Rating",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 5
    },
    {
      "type": "checkbox",
      "id": "review_2_verified",
      "label": "Verified buyer",
      "default": true
    },
    {
      "type": "header",
      "content": "Review 3"
    },
    {
      "type": "text",
      "id": "review_3_name",
      "label": "Name"
    },
    {
      "type": "text",
      "id": "review_3_text",
      "label": "Review text"
    },
    {
      "type": "range",
      "id": "review_3_rating",
      "label": "Rating",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 5
    },
    {
      "type": "checkbox",
      "id": "review_3_verified",
      "label": "Verified buyer",
      "default": true
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Mini reviews",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
