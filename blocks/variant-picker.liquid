<style>
.casa-vp-container {
  transition: border-color 0.2s, box-shadow 0.2s;
}
.casa-vp-title {
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 10px;
}
</style>

{%- comment -%} Variant card border color overrides {%- endcomment -%}
{%- assign _sel_border = block.settings.selected_border_color | default: '#9333ea' -%}
{%- assign _sel_glow = block.settings.selected_glow_color | default: '#9333ea' -%}
{%- assign _hover_border = block.settings.hover_border_color | default: '#7c3aed' -%}
{%- assign _unsel_border = block.settings.unselected_border_color | default: '#e5e7eb' -%}
{%- assign _badge_bg = block.settings.badge_default_bg | default: '#9333ea' -%}
{%- assign _badge_text = block.settings.badge_text_color | default: '#ffffff' -%}
{%- assign _badge_fs = block.settings.badge_font_size | default: 10 -%}
<style>
  /* Unselected variant cards — Horizon uses .variant-option__button-label */
  .cdl-vp-{{ block.id }} .variant-option__button-label {
    border-color: {{ _unsel_border }} !important;
  }

  /* Hover state */
  .cdl-vp-{{ block.id }} .variant-option__button-label:hover {
    border-color: {{ _hover_border }} !important;
  }

  /* Selected/checked variant card — Horizon uses :has(input:checked) */
  .cdl-vp-{{ block.id }} .variant-option__button-label:has(input:checked) {
    border-color: {{ _sel_border }} !important;
    box-shadow: 0 0 0 1px {{ _sel_border }}, 0 4px 16px {{ _sel_glow }}40 !important;
  }

  /* Fallback for browsers without :has() — uses sibling selector */
  .cdl-vp-{{ block.id }} input:checked + .variant-option__button-label,
  .cdl-vp-{{ block.id }} input:checked + label {
    border-color: {{ _sel_border }} !important;
    box-shadow: 0 0 0 1px {{ _sel_border }}, 0 4px 16px {{ _sel_glow }}40 !important;
  }

  /* Swatch variant style */
  .cdl-vp-{{ block.id }} .variant-option--swatches .swatch:has(input:checked) {
    box-shadow: 0 0 0 2px {{ _sel_border }} !important;
  }
  .cdl-vp-{{ block.id }} .variant-option--swatches .swatch:hover {
    box-shadow: 0 0 0 2px {{ _hover_border }} !important;
  }

  /* Casa VDD (custom dropdown) selected state */
  .cdl-vp-{{ block.id }} .casa-vdd__option--selected {
    border-color: {{ _sel_border }} !important;
    background: {{ _sel_border }}10 !important;
  }
  .cdl-vp-{{ block.id }} .casa-vdd__trigger {
    border-color: {{ _unsel_border }} !important;
  }
  .cdl-vp-{{ block.id }} .casa-vdd__trigger:hover {
    border-color: {{ _hover_border }} !important;
  }
  .cdl-vp-{{ block.id }} .casa-vdd__check {
    color: {{ _sel_border }} !important;
  }

  /* Badge colors */
  .cdl-vp-{{ block.id }} .casa-vdd__option-badge {
    background: {{ _badge_bg }} !important;
    color: {{ _badge_text }} !important;
    font-size: {{ _badge_fs }}px !important;
  }
</style>
