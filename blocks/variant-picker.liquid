

{% liquid
  assign product_resource = closest.product
  if request.visual_preview_mode and product_resource == blank
    assign product_resource = collections.all.products.first
  endif
-%}

{%- liquid
  assign vp_bg = block.settings.container_bg | default: ''
  assign vp_border_color = block.settings.container_border_color | default: ''
  assign vp_border_width = block.settings.container_border_width | default: 0
  assign vp_border_radius = block.settings.container_border_radius | default: 0
  assign vp_inner_padding = block.settings.container_inner_padding | default: 0
  assign vp_shadow = block.settings.container_shadow | default: 'none'
  assign vp_title = block.settings.section_title | default: ''
  assign vp_title_size = block.settings.section_title_size | default: 14
  assign vp_title_color = block.settings.section_title_color | default: ''
  assign has_container = false
  if vp_bg != blank or vp_border_width > 0 or vp_border_radius > 0 or vp_inner_padding > 0
    assign has_container = true
  endif
-%}

{% unless product_resource == blank %}
  {%- if has_container -%}
    <div class="casa-vp-container" style="
      {%- if vp_bg != blank %}background: {{ vp_bg }};{% endif -%}
      {%- if vp_border_width > 0 %}border: {{ vp_border_width }}px solid {{ vp_border_color | default: 'rgba(255,255,255,0.1)' }};{% endif -%}
      {%- if vp_border_radius > 0 %}border-radius: {{ vp_border_radius }}px;{% endif -%}
      {%- if vp_inner_padding > 0 %}padding: {{ vp_inner_padding }}px;{% endif -%}
      {%- if vp_shadow == 'subtle' %}box-shadow: 0 2px 8px rgba(0,0,0,0.1);{% endif -%}
      {%- if vp_shadow == 'medium' %}box-shadow: 0 4px 16px rgba(0,0,0,0.15);{% endif -%}
      {%- if vp_shadow == 'glow' %}box-shadow: 0 4px 24px rgba(147,51,234,0.15);{% endif -%}
    ">
    {%- if vp_title != blank -%}
      <div class="casa-vp-title" style="font-size: {{ vp_title_size }}px;{%- if vp_title_color != blank %}color: {{ vp_title_color }};{% endif -%}">{{ vp_title }}</div>
    {%- endif -%}
  {%- endif -%}
  {% render 'variant-main-picker',
    product_resource: product_resource,
    card_font_size: block.settings.card_font_size,
    card_price_font_size: block.settings.card_price_font_size,
    border_animation: block.settings.border_animation,
    info_layout: block.settings.info_layout,
    cards_per_row: block.settings.cards_per_row,
    image_width: block.settings.image_width,
    image_ratio: block.settings.image_ratio,
    image_height: block.settings.image_height,
    card_min_height: block.settings.card_min_height,
    hide_text: block.settings.hide_text,
    hide_price: block.settings.hide_price,
    card_padding: block.settings.card_padding,
    cards_per_row_mobile: block.settings.cards_per_row_mobile,
    image_width_mobile: block.settings.image_width_mobile,
    image_ratio_mobile: block.settings.image_ratio_mobile,
    image_height_mobile: block.settings.image_height_mobile,
    card_min_height_mobile: block.settings.card_min_height_mobile,
    hide_text_mobile: block.settings.hide_text_mobile,
    hide_price_mobile: block.settings.hide_price_mobile,
    card_padding_mobile: block.settings.card_padding_mobile,
    badge_default_bg: block.settings.badge_default_bg,
    badge_text_color: block.settings.badge_text_color,
    badge_font_size: block.settings.badge_font_size,
    selected_border_color: block.settings.selected_border_color,
    selected_glow_color: block.settings.selected_glow_color,
    hover_border_color: block.settings.hover_border_color,
    unselected_border_color: block.settings.unselected_border_color
  %}
  {%- if has_container -%}</div>{%- endif -%}
{% endunless %}

