{%- doc -%}
  Video Testimonials Block
  Horizontal scroll row of portrait video thumbnail cards with play buttons.
  Clicking opens a sticky modal with the video (YouTube, Vimeo, or direct URL).
  Modal stays fixed on scroll until X / backdrop / Escape closes it.
  Optional product link per card shown on hover.
  Video sources (priority): Shopify-hosted video > video_url picker > manual URL text.
{%- enddoc -%}

{%- assign s = block.settings -%}
{%- assign video_ids = "1,2,3,4,5,6,7,8" | split: "," -%}

<div
  class="casa-vtm spacing-style"
  id="casa-vtm-{{ block.id }}"
  style="{% render 'spacing-style', settings: s %}"
  {{ block.shopify_attributes }}
>
  {%- if s.heading != blank -%}
    <h3 class="casa-vtm__heading">{{ s.heading }}</h3>
  {%- endif -%}

  <div class="casa-vtm__row-wrap">
    <button type="button" class="casa-vtm__arrow casa-vtm__arrow--prev" aria-label="Previous">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <button type="button" class="casa-vtm__arrow casa-vtm__arrow--next" aria-label="Next">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
  <div class="casa-vtm__row">
    {%- for vid in video_ids -%}
      {%- assign thumb_key      = "thumbnail_"      | append: vid -%}
      {%- assign hosted_key     = "video_hosted_"    | append: vid -%}
      {%- assign picker_key     = "video_picker_"    | append: vid -%}
      {%- assign url_key        = "video_url_"       | append: vid -%}
      {%- assign name_key       = "author_"          | append: vid -%}
      {%- assign prod_key       = "product_"         | append: vid -%}

      {%- assign thumb   = s[thumb_key] -%}
      {%- assign hosted  = s[hosted_key] -%}
      {%- assign picker  = s[picker_key] -%}
      {%- assign vurl    = s[url_key] -%}
      {%- assign name    = s[name_key] -%}
      {%- assign prod    = s[prod_key] -%}

      {%- comment -%} Resolve the best video source {%- endcomment -%}
      {%- assign resolved_url = "" -%}
      {%- assign resolved_type = "" -%}

      {%- if hosted != blank and hosted.sources.size > 0 -%}
        {%- comment -%} Shopify-hosted video — prefer MP4 over HLS {%- endcomment -%}
        {%- assign resolved_url = "" -%}
        {%- for src in hosted.sources -%}
          {%- if src.mime_type == "video/mp4" and resolved_url == "" -%}
            {%- assign resolved_url = src.url -%}
          {%- endif -%}
        {%- endfor -%}
        {%- if resolved_url == "" -%}
          {%- assign resolved_url = hosted.sources[0].url -%}
        {%- endif -%}
        {%- assign resolved_type = "hosted" -%}
      {%- elsif picker != blank -%}
        {%- comment -%} Shopify video_url picker (YouTube/Vimeo) {%- endcomment -%}
        {%- assign resolved_url = picker | external_video_url -%}
        {%- assign resolved_type = "external" -%}
      {%- elsif vurl != blank -%}
        {%- comment -%} Manual URL fallback {%- endcomment -%}
        {%- assign resolved_url = vurl -%}
        {%- assign resolved_type = "manual" -%}
      {%- endif -%}

      {%- comment -%} Auto-thumbnail from YouTube if no image uploaded {%- endcomment -%}
      {%- assign auto_thumb = "" -%}
      {%- if thumb == blank and resolved_url != blank -%}
        {%- if resolved_url contains "youtube.com" or resolved_url contains "youtu.be" -%}
          {%- assign yt_parts = resolved_url | split: "v=" -%}
          {%- if yt_parts.size > 1 -%}
            {%- assign yt_id = yt_parts[1] | split: "&" | first -%}
          {%- else -%}
            {%- assign yt_id = resolved_url | split: "youtu.be/" | last | split: "?" | first -%}
          {%- endif -%}
          {%- if yt_id != blank -%}
            {%- assign auto_thumb = "https://img.youtube.com/vi/" | append: yt_id | append: "/hqdefault.jpg" -%}
          {%- endif -%}
        {%- endif -%}
      {%- endif -%}

      {%- if thumb != blank or resolved_url != blank -%}
        <button
          type="button"
          class="casa-vtm__card"
          data-vtm-url="{{ resolved_url }}"
          data-vtm-type="{{ resolved_type }}"
          {%- if hosted != blank and hosted.sources.size > 0 -%}
            data-vtm-hosted-sources="[{%- for source in hosted.sources -%}{&quot;url&quot;:&quot;{{ source.url }}&quot;,&quot;mime&quot;:&quot;{{ source.mime_type }}&quot;}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}]"
          {%- endif -%}
          {%- if prod != blank -%}
            data-vtm-product-url="{{ prod.url | escape }}"
            data-vtm-product-title="{{ prod.title | escape }}"
          {%- endif -%}
          aria-label="Play video{% if name != blank %} from {{ name | escape }}{% endif %}"
        >
          {%- if thumb != blank -%}
            <img
              src="{{ thumb | image_url: width: 400 }}"
              alt="{{ name | default: 'Video testimonial' | escape }}"
              class="casa-vtm__thumb"
              loading="lazy"
              width="180"
              height="320"
            >
          {%- elsif auto_thumb != blank -%}
            <img
              src="{{ auto_thumb }}"
              alt="{{ name | default: 'Video testimonial' | escape }}"
              class="casa-vtm__thumb"
              loading="lazy"
              width="180"
              height="320"
            >
          {%- elsif hosted != blank and hosted.preview_image -%}
            <img
              src="{{ hosted.preview_image | image_url: width: 400 }}"
              alt="{{ name | default: 'Video testimonial' | escape }}"
              class="casa-vtm__thumb"
              loading="lazy"
              width="180"
              height="320"
            >
          {%- else -%}
            <div class="casa-vtm__thumb casa-vtm__thumb--placeholder"></div>
          {%- endif -%}

          <span class="casa-vtm__play" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M8 5.14v14l11-7-11-7z"/>
            </svg>
          </span>

          {%- if name != blank -%}
            <span class="casa-vtm__name">{{ name }}</span>
          {%- endif -%}

          {%- if prod != blank -%}
            <span class="casa-vtm__product-badge" aria-hidden="true">
              {{ prod.title | truncate: 20 }}
            </span>
          {%- endif -%}
        </button>
      {%- endif -%}
    {%- endfor -%}
  </div>
  </div>
</div>

{%- comment -%} Modal — rendered once, populated by JS {%- endcomment -%}
<div class="casa-vtm__modal" id="casa-vtm-modal-{{ block.id }}" aria-hidden="true">
  <div class="casa-vtm__backdrop"></div>
  <div class="casa-vtm__player">
    <button type="button" class="casa-vtm__close" aria-label="Close video">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
    <button type="button" class="casa-vtm__modal-prev" aria-label="Previous video">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <button type="button" class="casa-vtm__modal-next" aria-label="Next video">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
    <div class="casa-vtm__video-wrap"></div>
    <button type="button" class="casa-vtm__mute" aria-label="Toggle mute" style="display:none;">
      <svg class="casa-vtm__mute-on" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/>
      </svg>
      <svg class="casa-vtm__mute-off" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
        <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/>
      </svg>
    </button>
    <a class="casa-vtm__modal-product" href="#" style="display:none;">
      <span class="casa-vtm__modal-product-title"></span>
      <span class="casa-vtm__modal-product-cta">Shop &rarr;</span>
    </a>
  </div>
</div>

<script>
(function() {
  var root = document.getElementById('casa-vtm-{{ block.id }}');
  var modal = document.getElementById('casa-vtm-modal-{{ block.id }}');
  if (!root || !modal) return;

  /* ── Carousel row arrows ── */
  var row = root.querySelector('.casa-vtm__row');
  var rowPrev = root.querySelector('.casa-vtm__arrow--prev');
  var rowNext = root.querySelector('.casa-vtm__arrow--next');

  function updateRowArrows() {
    if (!row || !rowPrev || !rowNext) return;
    var scrollable = row.scrollWidth > row.clientWidth + 4;
    if (!scrollable) { rowPrev.style.display = 'none'; rowNext.style.display = 'none'; return; }
    rowPrev.style.display = ''; rowNext.style.display = '';
    rowPrev.disabled = row.scrollLeft <= 2;
    rowNext.disabled = row.scrollLeft + row.clientWidth >= row.scrollWidth - 2;
  }
  if (row) {
    row.addEventListener('scroll', updateRowArrows, { passive: true });
    updateRowArrows();
    if (rowPrev) rowPrev.addEventListener('click', function() { row.scrollBy({ left: -(row.clientWidth * 0.6), behavior: 'smooth' }); });
    if (rowNext) rowNext.addEventListener('click', function() { row.scrollBy({ left: row.clientWidth * 0.6, behavior: 'smooth' }); });
  }

  var backdrop = modal.querySelector('.casa-vtm__backdrop');
  var closeBtn = modal.querySelector('.casa-vtm__close');
  var wrap = modal.querySelector('.casa-vtm__video-wrap');
  var muteBtn = modal.querySelector('.casa-vtm__mute');
  var muteOn = muteBtn.querySelector('.casa-vtm__mute-on');
  var muteOff = muteBtn.querySelector('.casa-vtm__mute-off');
  var productBar = modal.querySelector('.casa-vtm__modal-product');
  var productTitle = modal.querySelector('.casa-vtm__modal-product-title');
  var modalPrev = modal.querySelector('.casa-vtm__modal-prev');
  var modalNext = modal.querySelector('.casa-vtm__modal-next');
  var allCards = root.querySelectorAll('.casa-vtm__card');
  var currentVideo = null;
  var currentCardIndex = 0;

  function updateModalNav() {
    if (modalPrev) modalPrev.disabled = currentCardIndex <= 0;
    if (modalNext) modalNext.disabled = currentCardIndex >= allCards.length - 1;
  }
  function openCardByIndex(idx) {
    if (idx < 0 || idx >= allCards.length) return;
    currentCardIndex = idx;
    allCards[idx].click();
  }
  if (modalPrev) modalPrev.addEventListener('click', function(e) { e.stopPropagation(); openCardByIndex(currentCardIndex - 1); });
  if (modalNext) modalNext.addEventListener('click', function(e) { e.stopPropagation(); openCardByIndex(currentCardIndex + 1); });

  /* ── Detect URL type ── */
  function parseUrl(url) {
    var yt = url.match(/(?:youtube\.com\/(?:watch\?v=|embed\/|shorts\/)|youtu\.be\/)([\w-]{11})/);
    if (yt) return { type: 'youtube', id: yt[1] };
    var vm = url.match(/vimeo\.com\/(\d+)/);
    if (vm) return { type: 'vimeo', id: vm[1] };
    return { type: 'direct', id: url };
  }

  /* ── Open modal ── */
  function open(url) {
    var info = parseUrl(url);
    wrap.innerHTML = '';
    muteBtn.style.display = 'none';

    if (info.type === 'youtube') {
      var iframe = document.createElement('iframe');
      iframe.src = 'https://www.youtube.com/embed/' + info.id + '?autoplay=1&rel=0&modestbranding=1&playsinline=1';
      iframe.allow = 'autoplay; encrypted-media; picture-in-picture';
      iframe.allowFullscreen = true;
      iframe.className = 'casa-vtm__video';
      wrap.appendChild(iframe);
    } else if (info.type === 'vimeo') {
      var iframe2 = document.createElement('iframe');
      iframe2.src = 'https://player.vimeo.com/video/' + info.id + '?autoplay=1&title=0&byline=0&portrait=0';
      iframe2.allow = 'autoplay; fullscreen; picture-in-picture';
      iframe2.allowFullscreen = true;
      iframe2.className = 'casa-vtm__video';
      wrap.appendChild(iframe2);
    } else {
      var vid = document.createElement('video');
      vid.src = info.id;
      vid.autoplay = true;
      vid.playsInline = true;
      vid.loop = true;
      vid.muted = true;
      vid.className = 'casa-vtm__video';
      wrap.appendChild(vid);
      currentVideo = vid;
      muteBtn.style.display = 'flex';
      updateMuteIcon(true);
    }

    modal.classList.add('casa-vtm__modal--open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  /* ── Open modal with Shopify-hosted video ── */
  function openHosted(sourcesJson) {
    wrap.innerHTML = '';
    muteBtn.style.display = 'flex';
    var vid = document.createElement('video');
    vid.autoplay = true;
    vid.playsInline = true;
    vid.loop = true;
    vid.muted = true;
    vid.className = 'casa-vtm__video';
    try {
      var sources = JSON.parse(sourcesJson);
      /* Prefer MP4 over HLS (.m3u8) for cross-browser compat */
      var mp4Sources = sources.filter(function(s) { return s.mime === 'video/mp4'; });
      var otherSources = sources.filter(function(s) { return s.mime !== 'video/mp4'; });
      var ordered = mp4Sources.concat(otherSources);
      ordered.forEach(function(src) {
        if (src.url.indexOf('.m3u8') !== -1) return;
        var el = document.createElement('source');
        el.src = src.url;
        el.type = src.mime;
        vid.appendChild(el);
      });
      if (!vid.querySelectorAll('source').length && sources.length) {
        vid.src = sources[0].url;
      }
    } catch(e) { /* fallback: won't play */ }
    wrap.appendChild(vid);
    currentVideo = vid;
    updateMuteIcon(true);
    modal.classList.add('casa-vtm__modal--open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  /* ── Close modal ── */
  function close() {
    modal.classList.remove('casa-vtm__modal--open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    wrap.innerHTML = '';
    currentVideo = null;
    muteBtn.style.display = 'none';
    productBar.style.display = 'none';
  }

  /* ── Mute toggle ── */
  function updateMuteIcon(muted) {
    muteOn.style.display = muted ? 'block' : 'none';
    muteOff.style.display = muted ? 'none' : 'block';
  }

  muteBtn.addEventListener('click', function(e) {
    e.stopPropagation();
    if (!currentVideo) return;
    currentVideo.muted = !currentVideo.muted;
    updateMuteIcon(currentVideo.muted);
  });

  /* ── Show/hide product link in modal ── */
  function showProductBar(card) {
    var pUrl = card.getAttribute('data-vtm-product-url');
    var pTitle = card.getAttribute('data-vtm-product-title');
    if (pUrl && pTitle) {
      productBar.href = pUrl;
      productTitle.textContent = pTitle;
      productBar.style.display = 'flex';
    } else {
      productBar.style.display = 'none';
    }
  }

  /* ── Event listeners ── */
  root.querySelectorAll('.casa-vtm__card').forEach(function(card, idx) {
    card.addEventListener('click', function() {
      currentCardIndex = idx;
      var url = card.getAttribute('data-vtm-url');
      var type = card.getAttribute('data-vtm-type');
      var hostedSrc = card.getAttribute('data-vtm-hosted-sources');
      if (type === 'hosted' && hostedSrc) {
        openHosted(hostedSrc);
      } else if (url) {
        open(url);
      }
      showProductBar(card);
      updateModalNav();
    });
  });

  backdrop.addEventListener('click', close);
  closeBtn.addEventListener('click', close);

  document.addEventListener('keydown', function(e) {
    if (!modal.classList.contains('casa-vtm__modal--open')) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowLeft') openCardByIndex(currentCardIndex - 1);
    if (e.key === 'ArrowRight') openCardByIndex(currentCardIndex + 1);
  });
})();
</script>

{% stylesheet %}
/* ══════════════════════════════════════════════════════════════════════
   CASA VIDEO TESTIMONIALS — Ambassador video row + sticky modal
   ══════════════════════════════════════════════════════════════════════ */

.casa-vtm {
  width: 100%;
  min-width: 0;
}

/* ── Heading ── */
.casa-vtm__heading {
  font-size: 20px;
  font-weight: 600;
  margin: 0 0 16px;
  line-height: 1.3;
}

/* ── Row wrapper with arrows ── */
.casa-vtm__row-wrap {
  position: relative;
}

/* ── Carousel arrows ── */
.casa-vtm__arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 3;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: 1px solid rgba(255,255,255,0.15);
  background: rgba(0,0,0,0.5);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.2s;
}
.casa-vtm__arrow--prev { left: -16px; }
.casa-vtm__arrow--next { right: -16px; }
.casa-vtm__arrow:hover { background: rgba(147,51,234,0.5); border-color: rgba(147,51,234,0.5); }
.casa-vtm__arrow:disabled { opacity: 0.3; cursor: default; }

/* ── Horizontal scroll row ── */
.casa-vtm__row {
  display: flex;
  justify-content: center;
  gap: 12px;
  overflow-x: auto;
  overflow-y: hidden;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  padding-bottom: 4px;
  scrollbar-width: none;
}
.casa-vtm__row::-webkit-scrollbar {
  display: none;
}

/* ── Card ── */
.casa-vtm__card {
  position: relative;
  flex-shrink: 0;
  width: 140px;
  aspect-ratio: 9 / 16;
  border-radius: 12px;
  overflow: hidden;
  cursor: pointer;
  border: none;
  padding: 0;
  background: #f0f0f0;
  scroll-snap-align: start;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.casa-vtm__card:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(0,0,0,0.12);
}

/* ── Thumbnail ── */
.casa-vtm__thumb {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.casa-vtm__thumb--placeholder {
  background: linear-gradient(135deg, #e5e7eb 0%, #d1d5db 100%);
}

/* ── Play button ── */
.casa-vtm__play {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: rgba(255,255,255,0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0a0a0a;
  box-shadow: 0 2px 8px rgba(0,0,0,0.15);
  transition: transform 0.2s ease, background 0.2s ease;
  pointer-events: none;
}
.casa-vtm__play svg {
  margin-left: 2px; /* optical center for play triangle */
}
.casa-vtm__card:hover .casa-vtm__play {
  transform: translate(-50%, -50%) scale(1.1);
  background: #fff;
}

/* ── Author name ── */
.casa-vtm__name {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24px 8px 8px;
  background: linear-gradient(transparent, rgba(0,0,0,0.6));
  color: #fff;
  font-size: 11px;
  font-weight: 600;
  text-align: left;
  pointer-events: none;
  line-height: 1.3;
}

/* ── Product badge on card ── */
.casa-vtm__product-badge {
  position: absolute;
  top: 8px;
  left: 8px;
  right: 8px;
  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  color: #fff;
  font-size: 9px;
  font-weight: 600;
  padding: 3px 6px;
  border-radius: 6px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  pointer-events: none;
  line-height: 1.3;
  opacity: 0;
  transition: opacity 0.2s ease;
}
.casa-vtm__card:hover .casa-vtm__product-badge {
  opacity: 1;
}

/* ── Product link in modal ── */
.casa-vtm__modal-product {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 3;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 56px 12px 16px; /* right padding clears the mute button */
  background: linear-gradient(transparent, rgba(0,0,0,0.7));
  color: #fff;
  text-decoration: none;
  font-size: 13px;
  transition: opacity 0.2s ease;
}
.casa-vtm__modal-product:hover {
  opacity: 0.85;
}
.casa-vtm__modal-product-title {
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex: 1;
  min-width: 0;
}
.casa-vtm__modal-product-cta {
  font-weight: 500;
  flex-shrink: 0;
  margin-left: 12px;
  text-decoration: underline;
  text-underline-offset: 2px;
}

/* ══════════════════════════════════════════════════════════════════════
   MODAL
   ══════════════════════════════════════════════════════════════════════ */

.casa-vtm__modal {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}
.casa-vtm__modal--open {
  opacity: 1;
  pointer-events: auto;
}

/* ── Backdrop ── */
.casa-vtm__backdrop {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

/* ── Player card ── */
.casa-vtm__player {
  position: relative;
  width: 90vw;
  max-width: 400px;
  aspect-ratio: 9 / 16;
  border-radius: 20px;
  overflow: hidden;
  background: #000;
  box-shadow: 0 24px 64px rgba(0,0,0,0.4);
  z-index: 1;
  transform: scale(0.92);
  transition: transform 0.3s ease;
}
.casa-vtm__modal--open .casa-vtm__player {
  transform: scale(1);
}

/* ── Video element ── */
.casa-vtm__video-wrap {
  width: 100%;
  height: 100%;
}
.casa-vtm__video {
  width: 100%;
  height: 100%;
  border: none;
  object-fit: cover;
  display: block;
}

/* ── Close button ── */
.casa-vtm__close {
  position: absolute;
  top: 12px;
  right: 12px;
  z-index: 2;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  border: none;
  background: rgba(255,255,255,0.15);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: background 0.2s ease;
}
/* ── Modal prev/next ── */
.casa-vtm__modal-prev,
.casa-vtm__modal-next {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 3;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  border: none;
  background: rgba(255,255,255,0.12);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: background 0.2s;
}
.casa-vtm__modal-prev { left: 12px; }
.casa-vtm__modal-next { right: 12px; }
.casa-vtm__modal-prev:hover, .casa-vtm__modal-next:hover { background: rgba(255,255,255,0.25); }
.casa-vtm__modal-prev:disabled, .casa-vtm__modal-next:disabled { opacity: 0.3; cursor: default; }
.casa-vtm__close:hover {
  background: rgba(255,255,255,0.3);
}

/* ── Mute button ── */
.casa-vtm__mute {
  position: absolute;
  bottom: 12px;
  right: 12px;
  z-index: 4;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  border: none;
  background: rgba(255,255,255,0.15);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: background 0.2s ease;
}
.casa-vtm__mute:hover {
  background: rgba(255,255,255,0.3);
}

/* ══════════════════════════════════════════════════════════════════════
   RESPONSIVE
   ══════════════════════════════════════════════════════════════════════ */

@media (max-width: 749px) {
  .casa-vtm__heading {
    font-size: 17px;
    margin-bottom: 12px;
  }

  .casa-vtm__row {
    gap: 10px;
  }

  .casa-vtm__card {
    width: 120px;
  }

  .casa-vtm__play {
    width: 34px;
    height: 34px;
  }
  .casa-vtm__play svg {
    width: 16px;
    height: 16px;
  }

  .casa-vtm__player {
    width: 92vw;
    max-width: 360px;
    border-radius: 16px;
  }
}

@media (max-width: 480px) {
  .casa-vtm__card {
    width: 110px;
    border-radius: 10px;
  }

  .casa-vtm__name {
    font-size: 10px;
    padding: 20px 6px 6px;
  }

  .casa-vtm__player {
    width: 95vw;
    border-radius: 14px;
  }
}
{% endstylesheet %}

