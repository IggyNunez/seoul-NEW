{%- comment -%} Casa Delivery Estimate — standalone block for Horizon product-information {%- endcomment -%}

{% render 'casa-pdp-delivery-estimate', block: block %}

{% schema %}
{
  "name": "Casa Delivery Estimate",
  "tag": null,
  "settings": [
    { "type": "range", "id": "delivery_days_min", "label": "Min delivery days", "min": 1, "max": 14, "step": 1, "default": 5 },
    { "type": "range", "id": "delivery_days_max", "label": "Max delivery days", "min": 3, "max": 21, "step": 1, "default": 8 },
    { "type": "range", "id": "cutoff_hour", "label": "Order cutoff hour (24h)", "min": 8, "max": 23, "step": 1, "default": 17, "info": "Orders after this hour ship next business day" }
  ],
  "presets": [
    {
      "name": "Casa Delivery Estimate",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
