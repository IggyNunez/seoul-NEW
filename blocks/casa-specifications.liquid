{%- comment -%} Casa Specifications — standalone block for Horizon product-information {%- endcomment -%}

{%- if block.settings.specs_content != blank -%}
  {% render 'casa-pdp-specifications', block: block, product: closest.product %}
{%- endif -%}

{% schema %}
{
  "name": "Casa Specifications",
  "tag": null,
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Specifications" },
    { "type": "checkbox", "id": "open_by_default", "label": "Open by default", "default": false },
    {
      "type": "textarea", "id": "specs_content", "label": "Specifications (one per line: Label | Value)",
      "default": "Dimensions | 20\" x 20\" x 2\"\nWeight | 8 lbs\nPower | 12V DC, 2A\nLED Count | 300+ LEDs\nControl | App, Remote, Voice"
    }
  ],
  "presets": [
    {
      "name": "Casa Specifications",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
