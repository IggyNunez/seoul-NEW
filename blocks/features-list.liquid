{%- doc -%}
  Features List Block
  Displays product features as pill badges with checkmark icons.
  Pill style presets: minimal, gradient, glow, pulse, shimmer, neon-border.
  Per-pill color overrides. Separate desktop / mobile layout controls.
{%- enddoc -%}

{%- assign s = block.settings -%}
{%- assign feature_ids = "1,2,3,4,5,6,7,8" | split: "," -%}
{%- assign show_desktop = s.show_count_desktop | default: 8 -%}
{%- assign show_mobile  = s.show_count_mobile  | default: 4 -%}

{%- assign use_grid = false -%}
{%- if s.per_row_desktop > 0 or s.per_row_mobile > 0 -%}{%- assign use_grid = true -%}{%- endif -%}

<link rel="stylesheet" href="{{ 'casa-features-list.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript><link rel="stylesheet" href="{{ 'casa-features-list.css' | asset_url }}"></noscript>
<style>
  .fl-block-{{ block.id }} .casa-features-list__text,
  .fl-block-{{ block.id }} .casa-features-list__pill {
    font-size: {{ s.font_size_desktop }}px !important;
  }
  .fl-block-{{ block.id }} .casa-features-list__icon svg {
    width: {{ s.icon_size_desktop }}px !important;
    height: {{ s.icon_size_desktop }}px !important;
  }
  @media (max-width: 749px) {
    .fl-block-{{ block.id }} .casa-features-list__text,
    .fl-block-{{ block.id }} .casa-features-list__pill {
      font-size: {{ s.font_size_mobile }}px !important;
    }
    .fl-block-{{ block.id }} .casa-features-list__icon svg {
      width: {{ s.icon_size_mobile }}px !important;
      height: {{ s.icon_size_mobile }}px !important;
    }
  }
  {%- if s.color_mode == 'light' -%}
  .fl-block-{{ block.id }} .casa-features-list__pill {
    color: #1a1a2e !important;
  }
  .fl-block-{{ block.id }} .fl-style-minimal {
    background-color: rgba(0,0,0,0.04) !important;
    border-color: rgba(0,0,0,0.15) !important;
  }
  .fl-block-{{ block.id }} .fl-style-solid {
    background-color: rgba(0,0,0,0.06) !important;
    border-color: rgba(0,0,0,0.1) !important;
  }
  .fl-block-{{ block.id }} .fl-style-glow {
    background-color: rgba(147,51,234,0.08) !important;
    border-color: rgba(147,51,234,0.3) !important;
    box-shadow: 0 0 10px rgba(147,51,234,0.15) !important;
  }
  .fl-block-{{ block.id }} .fl-style-glass {
    background-color: rgba(255,255,255,0.7) !important;
    border-color: rgba(0,0,0,0.1) !important;
  }
  .fl-block-{{ block.id }} .fl-style-shimmer {
    background-color: rgba(0,0,0,0.04) !important;
    border-color: rgba(0,0,0,0.1) !important;
  }
  .fl-block-{{ block.id }} .fl-style-neon-border {
    background-color: rgba(255,255,255,0.8) !important;
    color: #1a1a2e !important;
  }
  .fl-block-{{ block.id }} .fl-style-pulse {
    background-color: rgba(147,51,234,0.06) !important;
    border-color: rgba(147,51,234,0.25) !important;
  }
  {%- elsif s.color_mode == 'custom' -%}
  .fl-block-{{ block.id }} .casa-features-list__pill {
    {%- if s.custom_text_color != blank %}color: {{ s.custom_text_color }} !important;{% endif -%}
    {%- if s.custom_pill_bg != blank %}background: {{ s.custom_pill_bg }} !important;{% endif -%}
    {%- if s.custom_pill_border != blank %}border-color: {{ s.custom_pill_border }} !important;{% endif -%}
  }
  {%- endif -%}
</style>

<div
  class="casa-features-list fl-block-{{ block.id }} fl-mode-{{ s.color_mode | default: 'dark' }}{% if use_grid %} casa-features-list--grid{% endif %} spacing-style"
  style="
    {% render 'spacing-style', settings: s %}
    --fl-gap-desktop: {{ s.gap_desktop }}px;
    --fl-gap-mobile: {{ s.gap_mobile }}px;
    --fl-font-size-desktop: {{ s.font_size_desktop }}px;
    --fl-font-size-mobile: {{ s.font_size_mobile }}px;
    --fl-icon-size-desktop: {{ s.icon_size_desktop }}px;
    --fl-icon-size-mobile: {{ s.icon_size_mobile }}px;
    --fl-pill-radius: {{ s.pill_radius }}px;
    --fl-pill-padding-v: {{ s.pill_padding_v }}px;
    --fl-pill-padding-h: {{ s.pill_padding_h }}px;
    --fl-per-row-desktop: {{ s.per_row_desktop }};
    --fl-per-row-mobile: {{ s.per_row_mobile }};
    {%- if s.custom_text_color != blank %}--fl-text: {{ s.custom_text_color }};{% endif -%}
    {%- if s.custom_pill_bg != blank %}--fl-bg: {{ s.custom_pill_bg }};{% endif -%}
    {%- if s.custom_pill_border != blank %}--fl-border: {{ s.custom_pill_border }};{% endif -%}
  "
  {{ block.shopify_attributes }}
>
  <div class="casa-features-list__pills">
    {%- assign pill_index = 0 -%}
    {%- for fid in feature_ids -%}
      {%- assign text_key  = "feature_"   | append: fid -%}
      {%- assign color_key = "pill_color_" | append: fid -%}
      {%- assign text_val  = s[text_key] -%}
      {%- if text_val != blank -%}
        {%- assign pill_index = pill_index | plus: 1 -%}

        {%- assign hide_class = "" -%}
        {%- if pill_index > show_desktop -%}{%- assign hide_class = hide_class | append: " fl-hide-desktop" -%}{%- endif -%}
        {%- if pill_index > show_mobile  -%}{%- assign hide_class = hide_class | append: " fl-hide-mobile"  -%}{%- endif -%}

        {%- assign pill_color = s[color_key] -%}
        {%- assign has_custom_color = false -%}
        {%- if pill_color != blank and pill_color != "#000000" -%}{%- assign has_custom_color = true -%}{%- endif -%}

        <div
          class="casa-features-list__pill fl-style-{{ s.pill_style }}{{ hide_class }}{% if has_custom_color %} fl-custom-color{% endif %}"
          style="{% if has_custom_color %}--fl-pill-custom: {{ pill_color }};{% endif %}"
        >
          <span class="casa-features-list__icon" aria-hidden="true">
            <svg viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.5"/>
              <path d="M4.5 7L6.25 8.75L9.5 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <span class="casa-features-list__text">{{ text_val }}</span>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
