    {
      "type": "select",
      "id": "pill_style",
      "label": "Style preset",
      "info": "Per-pill colors below override the background on any preset",
      "options": [
        { "value": "minimal",      "label": "Minimal — subtle border" },
        { "value": "solid",        "label": "Solid — filled background" },
        { "value": "gradient",     "label": "Gradient — purple → pink" },
        { "value": "glow",         "label": "Glow — static purple glow" },
        { "value": "pulse",        "label": "Pulse — breathing glow" },
        { "value": "shimmer",      "label": "Shimmer — light sweep" },
        { "value": "neon-border",  "label": "Neon border — animated border" },
        { "value": "glass",        "label": "Glass — frosted blur" }
      ],
      "default": "minimal"
    },
    {
      "type": "select",
      "id": "color_mode",
      "label": "Color mode",
      "info": "Controls pill colors for light or dark backgrounds",
