        { "value": "dark", "label": "Dark background (light pills)" },
        { "value": "light", "label": "Light background (dark pills)" },
        { "value": "custom", "label": "Custom colors" }
      ],
      "default": "dark"
    },
    {
      "type": "color",
      "id": "custom_text_color",
      "label": "Text / icon color",
      "info": "Only used in Custom color mode"
    },
    {
      "type": "color",
      "id": "custom_pill_bg",
      "label": "Pill background",
      "info": "Only used in Custom color mode"
    },
    {
      "type": "color",
      "id": "custom_pill_border",
      "label": "Pill border",
      "info": "Only used in Custom color mode"
    },
    {
      "type": "header",
      "content": "Per-pill Color Override"
    },
    {
      "type": "paragraph",
      "content": "Black = use preset style. Any other color overrides the pill background."
    },
    {
      "type": "color",
      "id": "pill_color_1",
      "label": "Feature 1",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "pill_color_2",
      "label": "Feature 2",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "pill_color_3",
      "label": "Feature 3",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "pill_color_4",
      "label": "Feature 4",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "pill_color_5",
      "label": "Feature 5",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "pill_color_6",
      "label": "Feature 6",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "pill_color_7",
      "label": "Feature 7",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "pill_color_8",
      "label": "Feature 8",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Desktop Layout"
