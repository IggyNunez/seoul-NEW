  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Features"
    },
    {
      "type": "text",
      "id": "feature_1",
      "label": "Feature 1",
      "default": "16M Colors"
    },
    {
      "type": "text",
      "id": "feature_2",
      "label": "Feature 2",
      "default": "App Control"
    },
    {
      "type": "text",
      "id": "feature_3",
      "label": "Feature 3",
      "default": "Music Sync"
    },
    {
      "type": "text",
      "id": "feature_4",
      "label": "Feature 4",
      "default": "Voice Control"
    },
    {
      "type": "text",
      "id": "feature_5",
      "label": "Feature 5"
    },
    {
      "type": "text",
      "id": "feature_6",
      "label": "Feature 6"
    },
    {
      "type": "text",
      "id": "feature_7",
