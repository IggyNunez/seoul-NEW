{%- doc -%}
  Urgency Block — Fully customizable
  Shows stock urgency, real-time viewers, and countdown timer.
{%- enddoc -%}

{%- liquid
  assign product_resource = closest.product
  assign block_settings = block.settings
  assign selected_variant = product_resource.selected_or_first_available_variant

  assign dot_color = block_settings.dot_color | default: '#ef4444'
  assign text_color = block_settings.text_color | default: ''
  assign icon_color = block_settings.icon_color | default: ''
  assign bg_color = block_settings.bg_color | default: ''
  assign border_color = block_settings.border_color | default: ''
  assign font_size = block_settings.font_size | default: 14
  assign stock_threshold = block_settings.stock_threshold | default: 10
  assign viewers_min = block_settings.viewers_min | default: 15
  assign viewers_max = block_settings.viewers_max | default: 35
-%}

<div
  class="casa-urgency spacing-style{% if bg_color != blank %} casa-urgency--has-bg{% endif %}"
  style="
    {% render 'spacing-style', settings: block_settings %}
    --cu-dot: {{ dot_color }};
    --cu-font-size: {{ font_size }}px;
    {%- if text_color != blank %}--cu-text: {{ text_color }};{% endif -%}
    {%- if icon_color != blank %}--cu-icon: {{ icon_color }};{% endif -%}
    {%- if bg_color != blank %}--cu-bg: {{ bg_color }};{% endif -%}
    {%- if border_color != blank %}--cu-border: {{ border_color }};{% endif -%}
  "
  {{ block.shopify_attributes }}
>
  {%- comment -%} Stock count {%- endcomment -%}
  {%- if block_settings.show_stock_count and selected_variant.inventory_management == 'shopify' and selected_variant.inventory_policy == 'deny' -%}
    {%- if selected_variant.inventory_quantity > 0 and selected_variant.inventory_quantity <= stock_threshold -%}
      <div class="casa-urgency__row">
        <span class="casa-urgency__dot" aria-hidden="true"></span>
        <span class="casa-urgency__text">
          {{ block_settings.stock_text_before | default: 'Only' }}
          <strong>{{ selected_variant.inventory_quantity }}</strong>
          {{ block_settings.stock_text_after | default: 'left in stock' }}
        </span>
      </div>
    {%- endif -%}
  {%- endif -%}

  {%- comment -%} Viewers {%- endcomment -%}
  {%- if block_settings.show_viewers -%}
    <div class="casa-urgency__row">
      <span class="casa-urgency__icon" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M1 8C1 8 3.5 3 8 3C12.5 3 15 8 15 8C15 8 12.5 13 8 13C3.5 13 1 8 1 8Z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="8" cy="8" r="2" stroke="currentColor" stroke-width="1.2"/>
        </svg>
      </span>
      <span class="casa-urgency__text" data-urgency-viewers data-min="{{ viewers_min }}" data-max="{{ viewers_max }}">
        {{ block_settings.viewers_text_before | default: '' }}
        <strong data-urgency-count>{{ viewers_min | plus: viewers_max | divided_by: 2 }}</strong>
        {{ block_settings.viewers_text_after | default: 'people are viewing this right now' }}
      </span>
    </div>
  {%- endif -%}

  {%- comment -%} Custom text line {%- endcomment -%}
  {%- if block_settings.custom_text != blank -%}
    <div class="casa-urgency__row">
      {%- if block_settings.custom_icon != blank -%}
        <span class="casa-urgency__icon" aria-hidden="true">
          {%- if block_settings.custom_icon == 'fire' -%}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 12c2-2.96 0-7-1-8 0 3.038-1.773 4.741-3 6-1.226 1.26-2 3.24-2 5a6 6 0 1 0 12 0c0-1.532-1.056-3.94-2-5-1.786 3-2.791 3-4 2z"></path></svg>
          {%- elsif block_settings.custom_icon == 'clock' -%}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
          {%- elsif block_settings.custom_icon == 'truck' -%}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
          {%- elsif block_settings.custom_icon == 'tag' -%}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path><line x1="7" y1="7" x2="7.01" y2="7"></line></svg>
          {%- elsif block_settings.custom_icon == 'zap' -%}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
          {%- elsif block_settings.custom_icon == 'shield' -%}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><polyline points="9 12 11 14 15 10"></polyline></svg>
          {%- elsif block_settings.custom_icon == 'dot' -%}
            <span class="casa-urgency__dot"></span>
          {%- endif -%}
        </span>
      {%- endif -%}
      <span class="casa-urgency__text">{{ block_settings.custom_text }}</span>
    </div>
  {%- endif -%}
</div>

<script>
  (function() {
    var el = document.querySelector('[data-urgency-viewers]');
    if (!el) return;
    var min = parseInt(el.dataset.min) || 15;
    var max = parseInt(el.dataset.max) || 35;
    var countEl = el.querySelector('[data-urgency-count]');
    if (!countEl) return;
    function randomCount() {
      return Math.floor(Math.random() * (max - min + 1)) + min;
    }
    countEl.textContent = randomCount();
    setInterval(function() {
      var current = parseInt(countEl.textContent);
      var change = Math.random() > 0.5 ? 1 : -1;
      var next = Math.max(min, Math.min(max, current + change));
      countEl.textContent = next;
    }, 5000 + Math.random() * 5000);
  })();
</script>

{% schema %}
{
  "name": "Urgency",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Stock Warning"
    },
    {
      "type": "checkbox",
      "id": "show_stock_count",
      "label": "Show low stock warning",
      "default": true
    },
    {
      "type": "range",
      "id": "stock_threshold",
      "label": "Stock threshold",
      "info": "Show warning when inventory is at or below this number",
      "min": 1,
      "max": 50,
      "step": 1,
      "default": 10
    },
    {
      "type": "text",
      "id": "stock_text_before",
      "label": "Text before count",
      "default": "Only"
    },
    {
      "type": "text",
      "id": "stock_text_after",
      "label": "Text after count",
      "default": "left in stock"
    },
    {
      "type": "header",
      "content": "Live Viewers"
    },
    {
      "type": "checkbox",
      "id": "show_viewers",
      "label": "Show viewer count",
      "default": true
    },
    {
      "type": "range",
      "id": "viewers_min",
      "label": "Min viewers",
      "min": 1,
      "max": 100,
      "step": 1,
      "default": 15
    },
    {
      "type": "range",
      "id": "viewers_max",
      "label": "Max viewers",
      "min": 5,
      "max": 200,
      "step": 5,
      "default": 35
    },
    {
      "type": "text",
      "id": "viewers_text_before",
      "label": "Text before count",
      "info": "Leave blank for none"
    },
    {
      "type": "text",
      "id": "viewers_text_after",
      "label": "Text after count",
      "default": "people are viewing this right now"
    },
    {
      "type": "header",
      "content": "Custom Text Line"
    },
    {
      "type": "text",
      "id": "custom_text",
      "label": "Custom urgency text",
      "info": "Extra line e.g. 'Order within 2hrs for same-day dispatch'",
      "placeholder": "e.g. Order within 2hrs for same-day dispatch"
    },
    {
      "type": "select",
      "id": "custom_icon",
      "label": "Custom text icon",
      "options": [
        { "value": "", "label": "None" },
        { "value": "dot", "label": "Pulsing dot" },
        { "value": "fire", "label": "Fire" },
        { "value": "clock", "label": "Clock" },
        { "value": "truck", "label": "Truck" },
        { "value": "tag", "label": "Tag" },
        { "value": "zap", "label": "Lightning" },
        { "value": "shield", "label": "Shield" }
      ],
      "default": ""
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 10,
      "max": 18,
      "step": 1,
      "default": 14,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "info": "Leave blank for default"
    },
    {
      "type": "color",
      "id": "dot_color",
      "label": "Pulsing dot color",
      "default": "#ef4444"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "info": "Leave blank for default"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "info": "Leave blank for transparent"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "info": "Leave blank for no border"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 4
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 4
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Urgency",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}

<style>
.casa-urgency {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.casa-urgency--has-bg {
  background: var(--cu-bg);
  border: 1px solid var(--cu-border, transparent);
  border-radius: 8px;
  padding: 10px 14px;
}
.casa-urgency__row {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: var(--cu-font-size, 14px);
  color: var(--cu-text, inherit);
  line-height: 1.4;
}
.casa-urgency__dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--cu-dot, #ef4444);
  flex-shrink: 0;
  animation: casaUrgencyPulse 1.5s ease-in-out infinite;
}
@keyframes casaUrgencyPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(0.8); }
}
.casa-urgency__icon {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  color: var(--cu-icon, var(--cu-text, inherit));
}
.casa-urgency__text strong {
  font-weight: 700;
}
</style>
