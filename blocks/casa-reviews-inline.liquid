{%- comment -%} Casa Inline Review — standalone block for Horizon product-information {%- endcomment -%}

{%- assign product = closest.product -%}
{% render 'casa-pdp-reviews', block: block, product: product %}

{% schema %}
{
  "name": "Casa Inline Review",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "review_text",
      "label": "Review text"
    },
    {
      "type": "text",
      "id": "reviewer_name",
      "label": "Reviewer name"
    },
    {
      "type": "text",
      "id": "reviewer_initials",
      "label": "Reviewer initials",
      "info": "Displayed in the avatar circle"
    }
  ],
  "presets": [
    {
      "name": "Casa Inline Review",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
