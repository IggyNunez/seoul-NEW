{%- comment -%} Casa Installation — standalone block for Horizon product-information {%- endcomment -%}

{%- if block.settings.content != blank -%}
  {% render 'casa-pdp-installation', block: block %}
{%- endif -%}

{% schema %}
{
  "name": "Casa Installation",
  "tag": null,
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Installation Guide" },
    { "type": "checkbox", "id": "open_by_default", "label": "Open by default", "default": false },
    {
      "type": "richtext", "id": "content", "label": "Content",
      "default": "<p><strong>Step 1:</strong> Choose your location and mark the mounting points.</p><p><strong>Step 2:</strong> Install the mounting bracket using the included hardware.</p><p><strong>Step 3:</strong> Hang the mirror on the bracket and secure.</p><p><strong>Step 4:</strong> Connect the power adapter and download the app.</p>"
    }
  ],
  "presets": [
    {
      "name": "Casa Installation",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
