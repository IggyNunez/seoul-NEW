{%- comment -%} Casa Rating — standalone block for Horizon product-information {%- endcomment -%}

{%- assign product = closest.product -%}
{% render 'casa-pdp-rating', block: block, product: product %}

{% schema %}
{
  "name": "Casa Rating",
  "tag": null,
  "settings": [
    {
      "type": "checkbox",
      "id": "show_count",
      "label": "Show review count",
      "default": true
    },
    {
      "type": "text",
      "id": "sold_count",
      "label": "Sold count text",
      "placeholder": "10K+",
      "info": "Displays as a pill next to stars"
    }
  ],
  "presets": [
    {
      "name": "Casa Rating",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
