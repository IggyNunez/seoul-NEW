{%- comment -%}
  Casa PDP Extras Block
  Renders delivery estimate, feature highlights, accordion (Specs, What's Included,
  Installation, Care & Maintenance), and inline reviews below the buy buttons.
  Works as a @theme block inside _product-details.
{%- endcomment -%}

<div class="casa-pdp-extras" {{ block.shopify_attributes }}>

  {%- comment -%} ── Delivery Estimate ── {%- endcomment -%}
  {%- if block.settings.show_delivery != false -%}
  <div class="casa-pdp-delivery">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
    </svg>
    <span>Order in <strong id="casa-countdown">--h --m</strong> for delivery <strong id="casa-delivery-date">5–8 days</strong></span>
  </div>

  {%- endif -%}

  {%- comment -%} ── Feature Highlights (2×2 grid) ── {%- endcomment -%}
  {%- if block.settings.show_features != false and block.settings.feature_1 != blank -%}
  <div class="casa-pdp-features">
    <div class="casa-pdp-features__item">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#9333ea" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      <span>{{ block.settings.feature_1 }}</span>
    </div>
    <div class="casa-pdp-features__item">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#9333ea" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      <span>{{ block.settings.feature_2 }}</span>
    </div>
    <div class="casa-pdp-features__item">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#9333ea" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      <span>{{ block.settings.feature_3 }}</span>
    </div>
    <div class="casa-pdp-features__item">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#9333ea" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      <span>{{ block.settings.feature_4 }}</span>
    </div>
  </div>

  {%- endif -%}

  {%- comment -%}
    ── Accordions: all pull from product metafields (Rich text).
       Same pattern as live theme: {{ metafield | metafield_tag }}
       Hidden automatically when the metafield is empty for a product.
       Each has a visibility toggle in block settings to force-hide.
  {%- endcomment -%}

  {%- comment -%} ── Description (product.description) ── {%- endcomment -%}
  {%- if block.settings.show_description != false and product.description != blank -%}
  <details class="casa-pdp-acc">
    <summary class="casa-pdp-acc__header">
      <span class="casa-pdp-acc__title">Description</span>
      <span class="casa-pdp-acc__chevron">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </span>
    </summary>
    <div class="casa-pdp-acc__body">
      <div class="casa-pdp-richtext rte">{{ product.description }}</div>
    </div>
  </details>
  {%- endif -%}

  {%- comment -%} ── Specifications ── {%- endcomment -%}
  {%- assign _specs = product.metafields.custom.product_page_specifications -%}
  {%- if block.settings.show_specs != false and _specs != blank -%}
  <details class="casa-pdp-acc" open>
    <summary class="casa-pdp-acc__header">
      <span class="casa-pdp-acc__title">Specifications</span>
      <span class="casa-pdp-acc__chevron">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </span>
    </summary>
    <div class="casa-pdp-acc__body">
      <div class="casa-pdp-richtext rte">{{ _specs | metafield_tag }}</div>
    </div>
  </details>
  {%- endif -%}

  {%- comment -%} ── Product Details ── {%- endcomment -%}
  {%- assign _details = product.metafields.custom.product_item_details -%}
  {%- if block.settings.show_product_details != false and _details != blank -%}
  <details class="casa-pdp-acc">
    <summary class="casa-pdp-acc__header">
      <span class="casa-pdp-acc__title">Product Details</span>
      <span class="casa-pdp-acc__chevron">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </span>
    </summary>
    <div class="casa-pdp-acc__body">
      <div class="casa-pdp-richtext rte">{{ _details | metafield_tag }}</div>
    </div>
  </details>
  {%- endif -%}

  {%- comment -%} ── Sizing ── {%- endcomment -%}
  {%- assign _sizing = product.metafields.custom.sizing -%}
  {%- if block.settings.show_sizing != false and _sizing != blank -%}
  <details class="casa-pdp-acc">
    <summary class="casa-pdp-acc__header">
      <span class="casa-pdp-acc__title">Sizing</span>
      <span class="casa-pdp-acc__chevron">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </span>
    </summary>
    <div class="casa-pdp-acc__body">
      <div class="casa-pdp-richtext rte">{{ _sizing | metafield_tag }}</div>
    </div>
  </details>
  {%- endif -%}

  {%- comment -%} ── What's Included / In The Box ── {%- endcomment -%}
  {%- assign _inbox = product.metafields.custom.in_the_box -%}
  {%- if block.settings.show_whats_included != false and _inbox != blank -%}
  <details class="casa-pdp-acc">
    <summary class="casa-pdp-acc__header">
      <span class="casa-pdp-acc__title">What's Included</span>
      <span class="casa-pdp-acc__chevron">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </span>
    </summary>
    <div class="casa-pdp-acc__body">
      <div class="casa-pdp-richtext rte">{{ _inbox | metafield_tag }}</div>
    </div>
  </details>
  {%- endif -%}

  {%- comment -%} ── Installation ── {%- endcomment -%}
  {%- assign _install = product.metafields.custom.installation -%}
  {%- if block.settings.show_installation != false and _install != blank -%}
  <details class="casa-pdp-acc">
    <summary class="casa-pdp-acc__header">
      <span class="casa-pdp-acc__title">Installation</span>
      <span class="casa-pdp-acc__chevron">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </span>
    </summary>
    <div class="casa-pdp-acc__body">
      <div class="casa-pdp-richtext rte">{{ _install | metafield_tag }}</div>
    </div>
  </details>
  {%- endif -%}

  {%- comment -%} ── Care & Maintenance (no metafield — uses block settings) ── {%- endcomment -%}
  {%- if block.settings.show_care != false and block.settings.care_text != blank -%}
  <details class="casa-pdp-acc">
    <summary class="casa-pdp-acc__header">
      <span class="casa-pdp-acc__title">Care & Maintenance</span>
      <span class="casa-pdp-acc__chevron">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </span>
    </summary>
    <div class="casa-pdp-acc__body">
      <p class="casa-pdp-care">{{ block.settings.care_text }}</p>
    </div>
  </details>
  {%- endif -%}

  {%- comment -%} ── Shipping & Delivery ── {%- endcomment -%}
  {%- assign _shipping = product.metafields.custom.shipping_delivery_product_tab -%}
  {%- if block.settings.show_shipping != false and _shipping != blank -%}
  <details class="casa-pdp-acc">
    <summary class="casa-pdp-acc__header">
      <span class="casa-pdp-acc__title">Shipping & Delivery</span>
      <span class="casa-pdp-acc__chevron">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </span>
    </summary>
    <div class="casa-pdp-acc__body">
      <div class="casa-pdp-richtext rte">{{ _shipping | metafield_tag }}</div>
    </div>
  </details>
  {%- endif -%}

  {%- comment -%} ── Refunds & Returns ── {%- endcomment -%}
  {%- assign _returns = product.metafields.custom.refunds_returns_product_tab -%}
  {%- if block.settings.show_returns != false and _returns != blank -%}
  <details class="casa-pdp-acc">
    <summary class="casa-pdp-acc__header">
      <span class="casa-pdp-acc__title">Refunds & Returns</span>
      <span class="casa-pdp-acc__chevron">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </span>
    </summary>
    <div class="casa-pdp-acc__body">
      <div class="casa-pdp-richtext rte">{{ _returns | metafield_tag }}</div>
    </div>
  </details>
  {%- endif -%}

  {%- comment -%} ── Inline Reviews ── {%- endcomment -%}
  {%- if block.settings.show_inline_review != false and block.settings.review_text != blank -%}
  <div class="casa-pdp-reviews-inline" id="reviews">
    <div class="casa-pdp-reviews-inline__header">
      <span class="casa-pdp-reviews-inline__title">What Customers Say</span>
      <a href="#reviews" class="casa-pdp-reviews-inline__link">See All</a>
    </div>
    <div class="casa-pdp-reviews-inline__card">
      <div class="casa-pdp-reviews-inline__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
      <p class="casa-pdp-reviews-inline__text">{{ block.settings.review_text }}</p>
      <div class="casa-pdp-reviews-inline__author">
        <div class="casa-pdp-reviews-inline__avatar">{{ block.settings.reviewer_initials }}</div>
        <div class="casa-pdp-reviews-inline__info">
          <span class="casa-pdp-reviews-inline__name">{{ block.settings.reviewer_name }}</span>
          <span class="casa-pdp-reviews-inline__verified">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            Verified
          </span>
        </div>
      </div>
    </div>
  </div>
  {%- endif -%}
</div>

<script>
  (function(){
    var c = document.getElementById('casa-countdown');
    var d = document.getElementById('casa-delivery-date');
    if (!c) return;
    var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    function fmt(dt){ return months[dt.getMonth()] + ' ' + dt.getDate(); }
    function tick(){
      var now = new Date();
      var cutoff = new Date(now);
      cutoff.setHours(14,0,0,0);
      if (now >= cutoff) cutoff.setDate(cutoff.getDate() + 1);
      var diff = cutoff - now;
      c.textContent = Math.floor(diff/36e5) + 'h ' + Math.floor((diff%36e5)/6e4) + 'm';
      var base = now >= cutoff ? new Date(now.getTime()+864e5) : now;
      var mn = new Date(base); mn.setDate(mn.getDate()+5);
      var mx = new Date(base); mx.setDate(mx.getDate()+8);
      d.textContent = fmt(mn) + '-' + mx.getDate();
    }
    tick(); setInterval(tick, 60000);
  })();
</script>

{% stylesheet %}
/* ── Container ── */
.casa-pdp-extras {
  width: 100%;
  min-width: 0;
}

/* ── Delivery Estimate ── */
.casa-pdp-delivery {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px 16px;
  background: #f5f5f5;
  border-radius: 10px;
  font-size: 13px;
  color: #555;
  line-height: 1.4;
}
.casa-pdp-delivery strong {
  color: #0a0a0a;
  font-weight: 600;
}

/* ── Feature Highlights ── */
.casa-pdp-features {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px 16px;
  padding: 4px 0;
}
.casa-pdp-features__item {
  display: flex;
  align-items: flex-start;
  gap: 8px;
  font-size: 13px;
  color: #333;
  line-height: 1.4;
}
.casa-pdp-features__item svg {
  flex-shrink: 0;
  margin-top: 1px;
}

/* ── Accordion ── */
.casa-pdp-features + .casa-pdp-acc {
  border-top: 1px solid #e5e5e5;
  margin-top: 4px;
}
.casa-pdp-acc {
  border-bottom: 1px solid #e5e5e5;
}
.casa-pdp-acc__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 0;
  cursor: pointer;
  list-style: none;
}
.casa-pdp-acc__header::-webkit-details-marker {
  display: none;
}
.casa-pdp-acc__title {
  font-size: 15px;
  font-weight: 600;
  color: #0a0a0a;
}
.casa-pdp-acc__chevron {
  display: flex;
  color: #999;
  transition: transform 0.2s ease;
}
.casa-pdp-acc[open] .casa-pdp-acc__chevron {
  transform: rotate(180deg);
}
.casa-pdp-acc__body {
  padding: 0 0 20px 0;
}

/* ── Rich text from metafields ── */
.casa-pdp-richtext {
  font-size: 14px;
  line-height: 1.7;
  color: #555;
}
.casa-pdp-richtext p { margin: 0 0 8px; }
.casa-pdp-richtext p:last-child { margin-bottom: 0; }
.casa-pdp-richtext ul,
.casa-pdp-richtext ol { margin: 0 0 8px; padding-left: 20px; }
.casa-pdp-richtext li { margin-bottom: 4px; }
.casa-pdp-richtext strong { color: #0a0a0a; }

/* ── Care ── */
.casa-pdp-care {
  font-size: 14px;
  line-height: 1.7;
  color: #555;
  margin: 0;
}

/* ── Reviews Inline ── */
.casa-pdp-reviews-inline {
  border-top: 1px solid #e5e5e5;
  padding-top: 20px;
}
.casa-pdp-reviews-inline__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
}
.casa-pdp-reviews-inline__title {
  font-size: 15px;
  font-weight: 600;
  color: #0a0a0a;
}
.casa-pdp-reviews-inline__link {
  font-size: 13px;
  font-weight: 500;
  color: #9333ea;
  text-decoration: none;
}
.casa-pdp-reviews-inline__link:hover { text-decoration: underline; }
.casa-pdp-reviews-inline__card {
  background: #fafafa;
  border-radius: 12px;
  padding: 16px;
}
.casa-pdp-reviews-inline__stars {
  font-size: 14px;
  color: #fbbf24;
  letter-spacing: 1px;
  margin-bottom: 8px;
}
.casa-pdp-reviews-inline__text {
  font-size: 13px;
  color: #555;
  line-height: 1.5;
  margin: 0 0 12px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.casa-pdp-reviews-inline__author {
  display: flex;
  align-items: center;
  gap: 10px;
}
.casa-pdp-reviews-inline__avatar {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: #22c55e;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 11px;
  font-weight: 700;
  flex-shrink: 0;
}
.casa-pdp-reviews-inline__info {
  display: flex;
  flex-direction: column;
}
.casa-pdp-reviews-inline__name {
  font-size: 13px;
  font-weight: 600;
  color: #0a0a0a;
}
.casa-pdp-reviews-inline__verified {
  display: flex;
  align-items: center;
  gap: 3px;
  font-size: 11px;
  color: #22c55e;
}

/* ── Mobile ── */
@media (max-width: 480px) {
  .casa-pdp-acc__title { font-size: 14px; }
  .casa-pdp-specs__label { font-size: 11px; }
  .casa-pdp-specs__value { font-size: 12px; }
  .casa-pdp-reviews-inline__card { padding: 14px; }
  .casa-pdp-reviews-inline__text { font-size: 12px; }
}
{% endstylesheet %}

