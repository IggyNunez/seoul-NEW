{%- comment -%} Casa Feature Highlights — standalone block for Horizon product-information {%- endcomment -%}

{%- assign _has_highlights = false -%}
{%- assign _highlight_ids = "1,2,3,4,5,6,7,8" | split: "," -%}
{%- for hid in _highlight_ids -%}
  {%- assign _hkey = "highlight_" | append: hid -%}
  {%- if block.settings[_hkey] != blank -%}
    {%- assign _has_highlights = true -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}

{%- if _has_highlights -%}
<div class="casa-fh" {{ block.shopify_attributes }}>
  <div class="casa-fh__grid">
    {%- for hid in _highlight_ids -%}
      {%- assign _hkey = "highlight_" | append: hid -%}
      {%- assign _ikey = "icon_" | append: hid -%}
      {%- assign _cikey = "custom_icon_" | append: hid -%}
      {%- assign _text = block.settings[_hkey] -%}
      {%- assign _icon = block.settings[_ikey] | default: 'check' -%}
      {%- assign _cicon = block.settings[_cikey] -%}
      {%- if _text != blank -%}
        <div class="casa-fh__item">
          {%- if _icon != 'none' -%}
            <span class="casa-fh__icon">
              {%- if _cicon != blank -%}
                <img src="{{ _cicon | image_url: width: 40 }}" alt="" width="16" height="16" loading="lazy">
              {%- elsif _icon == 'check' -%}
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="12" fill="currentColor"/><polyline points="7 12.5 10.5 16 17 9" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {%- elsif _icon == 'palette' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/></svg>
              {%- elsif _icon == 'smartphone' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="20" x="5" y="2" rx="2"/><line x1="12" x2="12.01" y1="18" y2="18"/></svg>
              {%- elsif _icon == 'music' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
              {%- elsif _icon == 'wifi' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><line x1="12" x2="12.01" y1="20" y2="20"/></svg>
              {%- elsif _icon == 'zap' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
              {%- elsif _icon == 'clock' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              {%- elsif _icon == 'shield' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
              {%- elsif _icon == 'truck' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              {%- elsif _icon == 'star' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              {%- elsif _icon == 'heart' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              {%- elsif _icon == 'eye' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              {%- elsif _icon == 'mic' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/></svg>
              {%- elsif _icon == 'globe' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              {%- elsif _icon == 'refresh' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M8 16H3v5"/></svg>
              {%- elsif _icon == 'gift' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
              {%- endif -%}
            </span>
          {%- endif -%}
          <span class="casa-fh__text">{{ _text }}</span>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>
{%- endif -%}

<style>
.casa-fh {
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
}
.casa-fh__grid {
  display: grid;
  grid-template-columns: repeat({{ block.settings.columns | default: 2 }}, minmax(0, 1fr));
  gap: {{ block.settings.gap | default: 8 }}px;
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
}
.casa-fh__item {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: {{ block.settings.font_size | default: 13 }}px;
  color: {{ block.settings.text_color | default: 'var(--cpm-text-muted, #6b7280)' }};
  line-height: 1.4;
  border-radius: {{ block.settings.pill_radius | default: 8 }}px;
  width: 100%;
  min-width: 0;
  box-sizing: border-box;
  justify-content: {{ block.settings.item_alignment | default: 'flex-start' }};
}
/* Pill style */
{%- case block.settings.style -%}
  {%- when 'pill' -%}
    .casa-fh__item {
      padding: 8px 14px;
      background: {{ block.settings.pill_bg | default: 'rgba(255,255,255,0.04)' }};
      border: 1px solid {{ block.settings.pill_border | default: 'rgba(255,255,255,0.1)' }};
    }
  {%- when 'gradient' -%}
    .casa-fh__item {
      padding: 8px 14px;
      background: linear-gradient(135deg, rgba(147,51,234,0.15), rgba(236,72,153,0.1));
      border: 1px solid rgba(147,51,234,0.2);
      color: {{ block.settings.text_color | default: '#ffffff' }};
    }
  {%- when 'glow' -%}
    .casa-fh__item {
      padding: 8px 14px;
      background: rgba(147,51,234,0.08);
      border: 1px solid rgba(147,51,234,0.25);
      box-shadow: 0 0 12px rgba(147,51,234,0.15);
      color: {{ block.settings.text_color | default: '#ffffff' }};
    }
  {%- when 'glass' -%}
    .casa-fh__item {
      padding: 8px 14px;
      background: {{ block.settings.pill_bg | default: 'rgba(255,255,255,0.08)' }};
      border: 1px solid rgba(255,255,255,0.12);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }
  {%- when 'solid' -%}
    .casa-fh__item {
      padding: 8px 14px;
      background: {{ block.settings.pill_bg | default: 'rgba(255,255,255,0.06)' }};
      border: 1px solid {{ block.settings.pill_border | default: 'transparent' }};
    }
{%- endcase -%}
.casa-fh__icon {
  flex-shrink: 0;
  width: {{ block.settings.icon_size | default: 16 }}px;
  height: {{ block.settings.icon_size | default: 16 }}px;
  color: {{ block.settings.icon_color | default: 'var(--cpm-accent-1, #9333ea)' }};
}
.casa-fh__icon svg { width: 100%; height: 100%; }
.casa-fh__icon img { width: 100%; height: 100%; object-fit: contain; }
@media (max-width: 480px) {
  .casa-fh__grid { grid-template-columns: repeat({% if block.settings.columns > 2 %}2{% else %}{{ block.settings.columns }}{% endif %}, minmax(0, 1fr)); }
}
</style>

{% schema %}
