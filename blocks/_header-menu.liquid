  "info": "Menu items shown as text links below"
},
{
  "type": "color",
  "id": "drawer_bg_color",
  "label": "Drawer background",
  "default": "#C6D76B"
},
{
  "type": "color",
  "id": "drawer_text_color",
  "label": "Drawer text color",
  "default": "#1a1a1a"
},
{
  "type": "color",
  "id": "drawer_border_color",
  "label": "Image hover border",
  "default": "#1a1a1a"
},
{
  "type": "range",
  "id": "drawer_border_radius",
  "label": "Image border radius",
  "min": 0,
  "max": 24,
  "step": 2,
  "default": 16,
  "unit": "px"
},
{
