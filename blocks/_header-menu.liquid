  "id": "drawer_bg_gradient",
  "label": "Enable gradient background",
  "default": false
},
{
  "type": "color",
  "id": "drawer_bg_color_2",
  "label": "Gradient end color",
  "default": "#a8c054"
},
{
  "type": "select",
  "id": "drawer_gradient_direction",
  "label": "Gradient direction",
