{% doc %}
  Casa Cart Trust Signals

  Renders inline trust badges row: Secure Checkout, Free Shipping, 30-Day Returns.
  Reads settings.cart_show_trust_badges and cart_trust_badge_1/2/3.
{% enddoc %}

{%- if settings.cart_show_trust_badges -%}
  <div class="casa-cart-trust">
    {%- if settings.cart_trust_badge_1 != blank -%}
      <div class="casa-cart-trust__badge">
        <span class="casa-cart-trust__icon">
          {%- render 'casa-icon', icon: 'lock', size: 14 -%}
        </span>
        <span class="casa-cart-trust__label">{{ settings.cart_trust_badge_1 }}</span>
      </div>
    {%- else -%}
      <div class="casa-cart-trust__badge">
        <span class="casa-cart-trust__icon">
          {%- render 'casa-icon', icon: 'lock', size: 14 -%}
        </span>
        <span class="casa-cart-trust__label">Secure Checkout</span>
      </div>
    {%- endif -%}

    {%- if settings.cart_trust_badge_2 != blank -%}
      <div class="casa-cart-trust__badge">
        <span class="casa-cart-trust__icon">
          {%- render 'casa-icon', icon: 'truck', size: 14 -%}
        </span>
        <span class="casa-cart-trust__label">{{ settings.cart_trust_badge_2 }}</span>
      </div>
    {%- else -%}
      <div class="casa-cart-trust__badge">
        <span class="casa-cart-trust__icon">
          {%- render 'casa-icon', icon: 'truck', size: 14 -%}
        </span>
        <span class="casa-cart-trust__label">Free Shipping</span>
      </div>
    {%- endif -%}

    {%- if settings.cart_trust_badge_3 != blank -%}
      <div class="casa-cart-trust__badge">
        <span class="casa-cart-trust__icon">
          {%- render 'casa-icon', icon: 'refresh', size: 14 -%}
        </span>
        <span class="casa-cart-trust__label">{{ settings.cart_trust_badge_3 }}</span>
      </div>
    {%- else -%}
      <div class="casa-cart-trust__badge">
        <span class="casa-cart-trust__icon">
          {%- render 'casa-icon', icon: 'refresh', size: 14 -%}
        </span>
        <span class="casa-cart-trust__label">30-Day Returns</span>
      </div>
    {%- endif -%}
  </div>
{%- endif -%}

{% stylesheet %}
  .casa-cart-trust {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(4px, 1vw, var(--casa-space-4));
    padding-top: var(--casa-space-6);
    flex-wrap: nowrap;
  }

  .casa-cart-trust__badge {
    display: flex;
    align-items: center;
    gap: 3px;
    padding: 3px 6px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--casa-radius-full);
    transition: all var(--casa-transition-fast);
    white-space: nowrap;
  }

  .casa-cart-trust__badge:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.1);
    transform: translateY(-1px);
  }

  .casa-cart-trust__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    background: linear-gradient(135deg, var(--cart-accent-1, var(--casa-purple)), var(--cart-accent-2, var(--casa-pink)));
    border-radius: 50%;
    color: #fff;
    padding: 2px;
    flex-shrink: 0;
  }

  .casa-cart-trust__icon svg {
    width: 10px;
    height: 10px;
  }

  .casa-cart-trust__label {
    font-size: 8px;
    color: var(--cart-text-muted, var(--casa-text-secondary));
    letter-spacing: 0.2px;
    text-transform: uppercase;
    font-weight: 600;
  }

  @media (max-width: 400px) {
    .casa-cart-trust {
      gap: 4px;
    }
    .casa-cart-trust__icon {
      width: 16px;
      height: 16px;
      padding: 2px;
    }
    .casa-cart-trust__icon svg {
      width: 10px;
      height: 10px;
    }
    .casa-cart-trust__label {
      font-size: 8px;
      letter-spacing: 0.2px;
    }
  }
{% endstylesheet %}
