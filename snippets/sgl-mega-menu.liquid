{%- comment -%}
  Seoul Glow Lab - Desktop Mega Menu (3 Variants + 6 Themes, Fully Customizable)

  VARIANT = content layout (glow/lifestyle/support)
  THEME = visual styling (dark-glow/white/gold/midnight/emerald/rose)

  All text, URLs, video, product limits, and quick links are controlled via
  the SGL Header section schema. Quick links are pre-rendered block HTML.
{%- endcomment -%}

{%- liquid
  comment
    ═══════════════════════════════════════════════════════
    STEP 1: Detect VARIANT (content layout)
    ═══════════════════════════════════════════════════════
  endcomment
  assign menu_variant = 'glow'
  assign _title_handle = link.title | downcase | handle

  case _title_handle
    when 'shop', 'shop-all', 'cleansers', 'serums', 'moisturizers', 'best-sellers', 'skincare'
      assign menu_variant = 'glow'
    when 'new-arrivals', 'collections', 'toners', 'essences', 'treatments', 'sunscreens', 'routines'
      assign menu_variant = 'lifestyle'
    when 'about', 'contact', 'customer-care', 'support', 'help', 'faq', 'our-story'
      assign menu_variant = 'support'
  endcase

  assign _collection = collections[link.handle]
  if _collection and _collection.metafields.sgl.menu_style != blank
    assign menu_variant = _collection.metafields.sgl.menu_style
  endif

  comment
    ═══════════════════════════════════════════════════════
    STEP 2: Detect THEME (visual styling)
    Themes: periwinkle (default), cream, mindaro, deep, forest, peach
    ═══════════════════════════════════════════════════════
  endcomment
  assign menu_theme = 'periwinkle'

  comment
    Check for custom_menu_theme passed from header (block override)
  endcomment
  if custom_menu_theme != blank and custom_menu_theme != nil
    assign menu_theme = custom_menu_theme
  else
    comment
      Auto-detect theme by menu handle
    endcomment
    case _title_handle
      when 'shop', 'shop-all', 'skincare', 'cleansers', 'serums', 'moisturizers'
        assign menu_theme = 'periwinkle'
      when 'essences', 'toners', 'exfoliators', 'eye-cream'
        assign menu_theme = 'cream'
      when 'new-arrivals', 'new', 'trending', 'featured'
        assign menu_theme = 'mindaro'
      when 'treatments', 'sunscreens', 'masks', 'sets', 'routines'
        assign menu_theme = 'deep'
      when 'treatments', 'sunscreens', 'masks', 'sets'
        assign menu_theme = 'forest'
      when 'sale', 'clearance', 'deals', 'offers'
        assign menu_theme = 'peach'
      when 'customer-care', 'support', 'help', 'faq', 'contact', 'about'
        assign menu_theme = 'periwinkle'
    endcase

    comment
      Check collection metafield override
    endcomment
    if _collection and _collection.metafields.sgl.menu_theme != blank
      assign menu_theme = _collection.metafields.sgl.menu_theme
    endif
  endif

  assign has_custom_colors = false
  if custom_accent_primary != blank and custom_accent_primary != nil
    assign has_custom_colors = true
  endif
-%}

{%- comment -%} Generate inline style for custom colors if provided {%- endcomment -%}
{%- capture custom_color_style -%}
  {%- if has_custom_colors -%}
    --mega-accent-1: {{ custom_accent_primary }};
    --mega-accent-2: {{ custom_accent_secondary | default: custom_accent_primary }};
    --mega-accent-3: {{ custom_accent_tertiary | default: custom_accent_secondary | default: custom_accent_primary }};
    --mega-accent-1-rgb: {{ custom_accent_primary | color_extract: 'red' }}, {{ custom_accent_primary | color_extract: 'green' }}, {{ custom_accent_primary | color_extract: 'blue' }};
    --mega-accent-2-rgb: {{ custom_accent_secondary | default: custom_accent_primary | color_extract: 'red' }}, {{ custom_accent_secondary | default: custom_accent_primary | color_extract: 'green' }}, {{ custom_accent_secondary | default: custom_accent_primary | color_extract: 'blue' }};
    --mega-glow-1: rgba({{ custom_accent_primary | color_extract: 'red' }}, {{ custom_accent_primary | color_extract: 'green' }}, {{ custom_accent_primary | color_extract: 'blue' }}, 0.15);
    --mega-glow-2: rgba({{ custom_accent_secondary | default: custom_accent_primary | color_extract: 'red' }}, {{ custom_accent_secondary | default: custom_accent_primary | color_extract: 'green' }}, {{ custom_accent_secondary | default: custom_accent_primary | color_extract: 'blue' }}, 0.1);
    --mega-cat-hover-bg: linear-gradient(135deg, rgba({{ custom_accent_primary | color_extract: 'red' }}, {{ custom_accent_primary | color_extract: 'green' }}, {{ custom_accent_primary | color_extract: 'blue' }}, 0.15), rgba({{ custom_accent_secondary | default: custom_accent_primary | color_extract: 'red' }}, {{ custom_accent_secondary | default: custom_accent_primary | color_extract: 'green' }}, {{ custom_accent_secondary | default: custom_accent_primary | color_extract: 'blue' }}, 0.1));
    --mega-cat-icon-bg: linear-gradient(135deg, rgba({{ custom_accent_primary | color_extract: 'red' }}, {{ custom_accent_primary | color_extract: 'green' }}, {{ custom_accent_primary | color_extract: 'blue' }}, 0.2), rgba({{ custom_accent_secondary | default: custom_accent_primary | color_extract: 'red' }}, {{ custom_accent_secondary | default: custom_accent_primary | color_extract: 'green' }}, {{ custom_accent_secondary | default: custom_accent_primary | color_extract: 'blue' }}, 0.15));
    --mega-cat-icon-hover: linear-gradient(135deg, {{ custom_accent_primary }}, {{ custom_accent_secondary | default: custom_accent_primary }});
    --mega-featured-bg: linear-gradient(135deg, rgba({{ custom_accent_primary | color_extract: 'red' }}, {{ custom_accent_primary | color_extract: 'green' }}, {{ custom_accent_primary | color_extract: 'blue' }}, 0.15), rgba({{ custom_accent_secondary | default: custom_accent_primary | color_extract: 'red' }}, {{ custom_accent_secondary | default: custom_accent_primary | color_extract: 'green' }}, {{ custom_accent_secondary | default: custom_accent_primary | color_extract: 'blue' }}, 0.1));
    --mega-featured-label-color: {{ custom_accent_secondary | default: custom_accent_primary }};
    --mega-featured-top-bar: linear-gradient(90deg, {{ custom_accent_primary }}, {{ custom_accent_secondary | default: custom_accent_primary }}, {{ custom_accent_tertiary | default: custom_accent_secondary | default: custom_accent_primary }});
    --mega-card-hover-border: rgba({{ custom_accent_primary | color_extract: 'red' }}, {{ custom_accent_primary | color_extract: 'green' }}, {{ custom_accent_primary | color_extract: 'blue' }}, 0.3);
    --mega-link-color: {{ custom_accent_primary }};
  {%- endif -%}
{%- endcapture -%}

<div class="sgl-mega-menu sgl-mega-menu--{{ menu_variant }} sgl-mega-theme--{{ menu_theme }}"{% if has_custom_colors %} style="{{ custom_color_style | strip_newlines }}"{% endif %}>
  <div class="sgl-mega-inner">

    {%- comment -%} ── Left Column: Categories ── {%- endcomment -%}
    <div class="sgl-mega-categories">
      <div class="sgl-mega-section-title">
        {%- if menu_variant == 'support' -%}{{ categories_title_support | default: 'Help Topics' }}
        {%- elsif menu_variant == 'lifestyle' -%}{{ categories_title_lifestyle | default: 'Collections' }}
        {%- else -%}{{ categories_title_glow | default: 'Categories' }}
        {%- endif -%}
      </div>
      <div class="sgl-mega-cat-list">
        {%- for child_link in link.links -%}
          {%- comment -%} Extract real handle from URL (more reliable than link.handle which derives from title) {%- endcomment -%}
          {%- assign _child_url_parts = child_link.url | split: '/' -%}
          {%- assign _child_url_handle = _child_url_parts | last -%}
          {%- assign child_collection = collections[_child_url_handle] -%}
          {%- assign child_page = pages[_child_url_handle] -%}
          {%- assign child_cat_image = nil -%}
          {%- if child_collection != blank and child_collection.image != blank -%}
            {%- assign child_cat_image = child_collection.image -%}
          {%- endif -%}
          {%- if child_cat_image == blank and child_page != blank and child_page.metafields.custom.page_image != blank -%}
            {%- assign child_cat_image = child_page.metafields.custom.page_image.value -%}
          {%- endif -%}
          {%- assign child_icon = 'hexagon' -%}
          {%- assign badge_text = '' -%}
          {%- if child_collection.metafields.sgl.badge != blank -%}
            {%- assign badge_text = child_collection.metafields.sgl.badge -%}
          {%- endif -%}
          {%- if child_collection.metafields.sgl.icon != blank -%}
            {%- assign child_icon = child_collection.metafields.sgl.icon -%}
          {%- endif -%}

          {%- comment -%} Auto-assign glow/lifestyle icons based on handle {%- endcomment -%}
          {%- if menu_variant != 'support' and child_collection.metafields.sgl.icon == blank -%}
            {%- case _child_url_handle -%}
              {%- when 'all-lighting', 'all', 'lighting', 'shop-all' -%}{%- assign child_icon = 'sun' -%}
              {%- when 'infinity-mirrors', 'mirrors', 'infinity' -%}{%- assign child_icon = 'hexagon' -%}
              {%- when 'floor-lamps', 'floor-lamp' -%}{%- assign child_icon = 'lamp' -%}
              {%- when 'table-lamps', 'table-lamp', 'desk-lamps' -%}{%- assign child_icon = 'lamp' -%}
              {%- when 'wall-lamps', 'wall-lamp', 'wall-lights', 'sconces' -%}{%- assign child_icon = 'sun' -%}
              {%- when 'led-neon-signs', 'neon-signs', 'neon', 'led-signs' -%}{%- assign child_icon = 'zap' -%}
              {%- when 'bubble-girl-lamps', 'bubble-girls', 'bubble-lamps' -%}{%- assign child_icon = 'sparkles' -%}
              {%- when 'mushroom-lamps', 'mushroom' -%}{%- assign child_icon = 'moon' -%}
              {%- when 'new-arrivals', 'new' -%}{%- assign child_icon = 'sparkles' -%}
              {%- when 'best-sellers', 'bestsellers', 'popular' -%}{%- assign child_icon = 'star' -%}
              {%- when 'sale', 'on-sale', 'clearance' -%}{%- assign child_icon = 'tag' -%}
              {%- when 'home-decor', 'decor', 'decoration' -%}{%- assign child_icon = 'home' -%}
              {%- when 'furniture', 'tables', 'chairs' -%}{%- assign child_icon = 'box' -%}
              {%- when 'accessories', 'accents' -%}{%- assign child_icon = 'grid' -%}
            {%- endcase -%}
          {%- endif -%}

          {%- comment -%} Auto-assign support icons based on handle {%- endcomment -%}
          {%- if menu_variant == 'support' -%}
            {%- case _child_url_handle -%}
              {%- when 'contact', 'contact-us' -%}{%- assign child_icon = 'headphones' -%}
              {%- when 'shipping', 'shipping-policy' -%}{%- assign child_icon = 'truck' -%}
              {%- when 'returns', 'refund-policy', 'refunds-returns' -%}{%- assign child_icon = 'refresh' -%}
              {%- when 'warranty' -%}{%- assign child_icon = 'shield-check' -%}
              {%- when 'faq' -%}{%- assign child_icon = 'search' -%}
              {%- when 'our-story', 'about', 'about-us' -%}{%- assign child_icon = 'users' -%}
              {%- when 'track-order', 'order-status' -%}{%- assign child_icon = 'package' -%}
              {%- when 'customer-reviews', 'reviews' -%}{%- assign child_icon = 'star' -%}
              {%- when 'installation', 'apollo-installation' -%}{%- assign child_icon = 'zap' -%}
            {%- endcase -%}
          {%- endif -%}

          <a href="{{ child_link.url }}" class="sgl-mega-cat-item">
            {%- assign child_cat_image_url = child_cat_image | image_url: width: 88, height: 88, crop: 'center' -%}
            <div class="sgl-mega-cat-icon{% if child_cat_image_url != blank %} sgl-mega-cat-icon--has-image{% endif %}">
              {%- if child_cat_image_url != blank -%}
                <img
                  src="{{ child_cat_image_url }}"
                  alt="{{ child_link.title | escape }}"
                  width="44"
                  height="44"
                  loading="lazy"
                  class="sgl-mega-cat-img"
                >
              {%- else -%}
                {%- render 'sgl-icon', icon: child_icon, size: 22 -%}
              {%- endif -%}
            </div>
            <div class="sgl-mega-cat-content">
              <div class="sgl-mega-cat-name">{{ child_link.title }}</div>
              {%- if menu_variant == 'support' -%}
                <div class="sgl-mega-cat-count">
                  {%- if child_collection.metafields.sgl.description != blank -%}
                    {{ child_collection.metafields.sgl.description }}
                  {%- else -%}
                    {{ support_fallback_description | default: 'Learn more' }}
                  {%- endif -%}
                </div>
              {%- elsif child_collection -%}
                <div class="sgl-mega-cat-count">{{ child_collection.products_count }} products</div>
              {%- endif -%}
            </div>
            {%- if badge_text != blank -%}
              <span class="sgl-mega-cat-badge sgl-mega-cat-badge--{{ badge_text | downcase }}">{{ badge_text }}</span>
            {%- endif -%}
            <div class="sgl-mega-cat-arrow">
              {%- render 'sgl-icon', icon: 'chevron-right', size: 20 -%}
            </div>
          </a>
        {%- endfor -%}
      </div>
    </div>

    {%- comment -%} ── Center Column ── {%- endcomment -%}
    <div class="sgl-mega-products">
      {%- if menu_variant == 'support' -%}
        {%- comment -%} ── Support: FAQ / Help Cards ── {%- endcomment -%}
        <div class="sgl-mega-products-header">
          <span class="sgl-mega-section-title" style="margin-bottom:0;">{{ quick_help_title | default: 'Quick Help' }}</span>
        </div>
        <div class="sgl-mega-faq-grid">
          {%- for child_link in link.links limit: 4 -%}
            {%- assign faq_icon = 'search' -%}
            {%- assign faq_collection = collections[child_link.handle] -%}
            {%- case _child_url_handle -%}
              {%- when 'contact', 'contact-us' -%}{%- assign faq_icon = 'headphones' -%}
              {%- when 'shipping', 'shipping-policy' -%}{%- assign faq_icon = 'truck' -%}
              {%- when 'returns', 'refund-policy', 'refunds-returns' -%}{%- assign faq_icon = 'refresh' -%}
              {%- when 'warranty' -%}{%- assign faq_icon = 'shield-check' -%}
              {%- when 'faq' -%}{%- assign faq_icon = 'search' -%}
              {%- when 'our-story', 'about' -%}{%- assign faq_icon = 'users' -%}
              {%- when 'customer-reviews', 'reviews' -%}{%- assign faq_icon = 'star' -%}
              {%- when 'installation', 'apollo-installation' -%}{%- assign faq_icon = 'zap' -%}
            {%- endcase -%}
            <a href="{{ child_link.url }}" class="sgl-mega-faq-card">
              <div class="sgl-mega-faq-icon">
                {%- render 'sgl-icon', icon: faq_icon, size: 20 -%}
              </div>
              <div class="sgl-mega-faq-title">{{ child_link.title }}</div>
              <div class="sgl-mega-faq-desc">
                {%- if faq_collection.metafields.sgl.description != blank -%}
                  {{ faq_collection.metafields.sgl.description }}
                {%- else -%}
                  {{ support_fallback_description | default: 'Quick help & resources' }}
                {%- endif -%}
              </div>
              <span class="sgl-mega-faq-arrow">
                {%- render 'sgl-icon', icon: 'arrow-right', size: 14 -%}
              </span>
            </a>
          {%- endfor -%}
        </div>

      {%- else -%}
        {%- comment -%} ── Glow & Lifestyle: Products Grid ── {%- endcomment -%}
        {%- comment -%} Select collection: custom per-menu override > variant default {%- endcomment -%}
        {%- liquid
          if custom_collection != blank
            assign _active_collection = collections[custom_collection]
          elsif menu_variant == 'lifestyle'
            assign _active_collection = collections[collection_lifestyle]
          else
            assign _active_collection = collections[collection_glow]
          endif
        -%}
        <div class="sgl-mega-products-header">
          <span class="sgl-mega-section-title" style="margin-bottom:0;">
            {%- if custom_products_title != blank -%}
              {{ custom_products_title }}
            {%- elsif menu_variant == 'lifestyle' -%}
              {{ products_title_lifestyle | default: 'Curated Picks' }}
            {%- else -%}
              {{ products_title_glow | default: 'Trending Now' }}
            {%- endif -%}
          </span>
          {%- if _active_collection != blank -%}
            <a href="{{ _active_collection.url }}" class="sgl-mega-products-link">
              View All {%- render 'sgl-icon', icon: 'arrow-right', size: 14 -%}
            </a>
          {%- endif -%}
        </div>
        <div class="sgl-mega-products-grid" data-columns="{{ products_per_row | default: 'auto' }}">
          {%- assign mega_collection = _active_collection -%}
          {%- if mega_collection -%}
            {%- assign _product_limit = custom_product_limit | default: nil -%}
            {%- if _product_limit == nil -%}
              {%- if menu_variant == 'lifestyle' -%}{%- assign _product_limit = product_limit_lifestyle | default: 4 -%}
              {%- else -%}{%- assign _product_limit = product_limit_glow | default: 6 -%}{%- endif -%}
            {%- endif -%}
            {%- for product in mega_collection.products limit: _product_limit -%}
              <a href="{{ product.url }}" class="sgl-mega-product-card">
                <div class="sgl-mega-product-img">
                  {%- if product.featured_image != blank -%}
                    {{ product.featured_image | image_url: width: 300 | image_tag: loading: 'lazy', class: 'sgl-mega-product-photo' }}
                  {%- else -%}
                    <div class="sgl-octagon" style="width:60%;height:60%;background:conic-gradient(from var(--angle),var(--mega-accent-1),var(--mega-accent-2),var(--mega-accent-3),var(--mega-accent-1));animation:sgl-rotate 8s linear infinite;"></div>
                  {%- endif -%}

                  {%- if product.tags contains 'bestseller' -%}
                    <span class="sgl-mega-product-badge sgl-mega-product-badge--bestseller">Bestseller</span>
                  {%- elsif product.tags contains 'new' -%}
                    <span class="sgl-mega-product-badge sgl-mega-product-badge--new">New</span>
                  {%- elsif product.compare_at_price > product.price -%}
                    {%- assign discount = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
                    <span class="sgl-mega-product-badge sgl-mega-product-badge--sale">-{{ discount }}%</span>
                  {%- endif -%}
                </div>
                <div class="sgl-mega-product-name">{{ product.title }}</div>
                <div class="sgl-mega-product-price">
                  <span class="sgl-mega-product-price-current">{{ product.price | money }}</span>
                  {%- if product.compare_at_price > product.price -%}
                    <span class="sgl-mega-product-price-original">{{ product.compare_at_price | money }}</span>
                  {%- endif -%}
                </div>
              </a>
            {%- endfor -%}
          {%- else -%}
            {%- assign _placeholder_limit = product_limit_glow | default: 6 -%}
            {%- if menu_variant == 'lifestyle' -%}{%- assign _placeholder_limit = product_limit_lifestyle | default: 4 -%}{%- endif -%}
            {%- for i in (1.._placeholder_limit) -%}
              <div class="sgl-mega-product-card sgl-mega-product-card--placeholder">
                <div class="sgl-mega-product-img">
                  <div class="sgl-octagon" style="width:60%;height:60%;background:conic-gradient(from var(--angle),var(--mega-accent-1),var(--mega-accent-2),var(--mega-accent-3),var(--mega-accent-1));animation:sgl-rotate 8s linear infinite;"></div>
                </div>
                <div class="sgl-mega-product-name">Product {{ i }}</div>
                <div class="sgl-mega-product-price">
                  <span class="sgl-mega-product-price-current">$0.00</span>
                </div>
              </div>
            {%- endfor -%}
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} ── Right Column: Featured Area ── {%- endcomment -%}
    <div class="sgl-mega-featured">
      {%- if menu_variant == 'support' -%}
        {%- comment -%} ── Support: Contact Us Card ── {%- endcomment -%}
        <div class="sgl-mega-featured-card">
          {%- if featured_label_support != blank -%}
            <span class="sgl-mega-featured-label">
              {%- render 'sgl-icon', icon: 'headphones', size: 14 -%}
              {{ featured_label_support }}
            </span>
          {%- endif -%}
          {%- if support_title != blank -%}
            <h3 class="sgl-mega-featured-title">{{ support_title }}</h3>
          {%- endif -%}
          {%- if support_description != blank -%}
            <p class="sgl-mega-featured-desc">{{ support_description }}</p>
          {%- endif -%}
          <div class="sgl-mega-contact-methods">
            {%- if support_email != blank -%}
              <a href="mailto:{{ support_email }}" class="sgl-mega-contact-item">
                {%- render 'sgl-icon', icon: 'mail', size: 18 -%}
                <span>{{ support_email }}</span>
              </a>
            {%- endif -%}
            {%- if support_phone != blank -%}
              <a href="tel:{{ support_phone | remove: ' ' | remove: '(' | remove: ')' | remove: '-' }}" class="sgl-mega-contact-item">
                {%- render 'sgl-icon', icon: 'smartphone', size: 18 -%}
                <span>{{ support_phone }}</span>
              </a>
            {%- endif -%}
            {%- if support_chat_label != blank -%}
              <a href="{{ support_chat_link | default: '/pages/contact' }}" class="sgl-mega-contact-item">
                {%- render 'sgl-icon', icon: 'message-circle', size: 18 -%}
                <span>{{ support_chat_label }}</span>
              </a>
            {%- endif -%}
          </div>
          {%- if support_btn_text != blank -%}
          <div class="sgl-mega-featured-cta">
            <a href="{{ support_btn_link | default: '/pages/contact' }}" class="sgl-mega-featured-btn sgl-mega-featured-btn--primary">
              {{ support_btn_text }} {%- render 'sgl-icon', icon: 'arrow-right', size: 16 -%}
            </a>
          </div>
          {%- endif -%}
        </div>

      {%- elsif menu_variant == 'lifestyle' -%}
        {%- comment -%} ── Lifestyle: Style Inspiration Card ── {%- endcomment -%}
        <div class="sgl-mega-featured-card">
          {%- if featured_label_lifestyle != blank -%}
            <span class="sgl-mega-featured-label">
              {%- render 'sgl-icon', icon: 'eye', size: 14 -%}
              {{ featured_label_lifestyle }}
            </span>
          {%- endif -%}
          {%- if lifestyle_title != blank -%}
            <h3 class="sgl-mega-featured-title">{{ lifestyle_title }}</h3>
          {%- endif -%}
          {%- if lifestyle_subtitle != blank -%}
            <p class="sgl-mega-featured-desc">{{ lifestyle_subtitle }}</p>
          {%- endif -%}
          <div class="sgl-mega-featured-visual">
            {%- if lifestyle_image -%}
              {{ lifestyle_image | image_url: width: 600 | image_tag: loading: 'lazy' }}
            {%- elsif lifestyle_video_url != blank -%}
              <video class="sgl-mega-featured-video" autoplay loop muted playsinline>
                <source src="{{ lifestyle_video_url }}" type="video/mp4">
              </video>
            {%- else -%}
              <div class="sgl-mega-featured-lifestyle-placeholder">
                {%- render 'sgl-icon', icon: 'sun', size: 40 -%}
              </div>
            {%- endif -%}
          </div>
          <div class="sgl-mega-featured-cta">
            {%- if lifestyle_btn_primary != blank -%}
              <a href="{{ lifestyle_link | default: '/pages/inspiration' }}" class="sgl-mega-featured-btn sgl-mega-featured-btn--primary">
                {{ lifestyle_btn_primary }} {%- render 'sgl-icon', icon: 'arrow-right', size: 16 -%}
              </a>
            {%- endif -%}
            {%- if lifestyle_btn_secondary != blank -%}
              <a href="{{ lifestyle_btn_secondary_link | default: '/collections' }}" class="sgl-mega-featured-btn sgl-mega-featured-btn--secondary">
                {{ lifestyle_btn_secondary }}
              </a>
            {%- endif -%}
          </div>
        </div>

      {%- else -%}
        {%- comment -%} ── Glow: Featured Collection Promo (default) ── {%- endcomment -%}
        <div class="sgl-mega-featured-card">
          {%- if featured_label_glow != blank -%}
            <span class="sgl-mega-featured-label">
              {%- render 'sgl-icon', icon: 'sparkles', size: 14 -%}
              {{ featured_label_glow }}
            </span>
          {%- endif -%}
          {%- if promo_title != blank -%}
            <h3 class="sgl-mega-featured-title">{{ promo_title }}</h3>
          {%- endif -%}
          {%- if promo_subtitle != blank -%}
            <p class="sgl-mega-featured-desc">{{ promo_subtitle }}</p>
          {%- endif -%}
          <div class="sgl-mega-featured-visual">
            {%- if promo_image -%}
              {{ promo_image | image_url: width: 600 | image_tag: loading: 'lazy' }}
            {%- elsif video_url != blank -%}
              <video class="sgl-mega-featured-video" autoplay loop muted playsinline>
                <source src="{{ video_url }}" type="video/mp4">
              </video>
            {%- else -%}
              <div class="sgl-mega-featured-lifestyle-placeholder">
                {%- render 'sgl-icon', icon: 'sparkles', size: 40 -%}
              </div>
            {%- endif -%}
          </div>
          <div class="sgl-mega-featured-cta">
            {%- if promo_btn_primary != blank -%}
              <a href="{{ promo_link | default: '/collections/all' }}" class="sgl-mega-featured-btn sgl-mega-featured-btn--primary">
                {{ promo_btn_primary }} {%- render 'sgl-icon', icon: 'arrow-right', size: 16 -%}
              </a>
            {%- endif -%}
            {%- if promo_btn_secondary != blank -%}
              <a href="{{ promo_btn_secondary_link | default: '/collections' }}" class="sgl-mega-featured-btn sgl-mega-featured-btn--secondary">
                {{ promo_btn_secondary }}
              </a>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} ── Bottom: Quick Links (pre-rendered from blocks) ── {%- endcomment -%}
    {%- assign _support_links = support_quick_links_html | strip -%}
    {%- assign _lifestyle_links = lifestyle_quick_links_html | strip -%}
    {%- assign _glow_links = glow_quick_links_html | strip -%}
    {%- if menu_variant == 'support' and _support_links != blank -%}
      <div class="sgl-mega-quick">{{ support_quick_links_html }}</div>
    {%- elsif menu_variant == 'lifestyle' and _lifestyle_links != blank -%}
      <div class="sgl-mega-quick">{{ lifestyle_quick_links_html }}</div>
    {%- elsif _glow_links != blank -%}
      <div class="sgl-mega-quick">{{ glow_quick_links_html }}</div>
    {%- endif -%}

  </div>
</div>

{% stylesheet %}
  /* ═══════════════════════════════════════════════════════
     VARIANT COLOR SYSTEM
     Colors are inherited from parent .sgl-header-section CSS vars
     ═══════════════════════════════════════════════════════ */

  /* ── Glow (default): Purple + Pink ── */
  .sgl-mega-menu--glow {
    --mega-accent-1: var(--sgl-glow-primary, #B0C3FA);
    --mega-accent-2: var(--sgl-glow-secondary, #EA7940);
    --mega-accent-3: var(--sgl-support-primary, #FFBF9F);
    --mega-accent-1-rgb: var(--sgl-glow-primary-rgb, 147, 51, 234);
    --mega-accent-2-rgb: var(--sgl-glow-secondary-rgb, 236, 72, 153);
    --mega-glow-1: rgba(var(--sgl-glow-primary-rgb, 147, 51, 234), 0.15);
    --mega-glow-2: rgba(var(--sgl-glow-secondary-rgb, 236, 72, 153), 0.1);
    --mega-cat-hover-bg: linear-gradient(135deg, rgba(var(--sgl-glow-primary-rgb, 147, 51, 234), 0.15), rgba(var(--sgl-glow-secondary-rgb, 236, 72, 153), 0.1));
    --mega-cat-icon-bg: linear-gradient(135deg, rgba(var(--sgl-glow-primary-rgb, 147, 51, 234), 0.2), rgba(var(--sgl-glow-secondary-rgb, 236, 72, 153), 0.15));
    --mega-cat-icon-hover: linear-gradient(135deg, var(--sgl-glow-primary, #B0C3FA), var(--sgl-glow-secondary, #EA7940));
    --mega-featured-bg: linear-gradient(135deg, rgba(var(--sgl-glow-primary-rgb, 147, 51, 234), 0.15), rgba(var(--sgl-glow-secondary-rgb, 236, 72, 153), 0.1));
    --mega-featured-label-color: var(--sgl-glow-secondary, #EA7940);
    --mega-featured-top-bar: linear-gradient(90deg, var(--sgl-glow-primary, #B0C3FA), var(--sgl-glow-secondary, #EA7940), var(--sgl-support-primary, #FFBF9F));
    --mega-card-hover-border: rgba(var(--sgl-glow-primary-rgb, 147, 51, 234), 0.3);
    --mega-link-color: var(--sgl-glow-primary, #B0C3FA);
  }

  /* ── Lifestyle: Gold + Amber ── */
  .sgl-mega-menu--lifestyle {
    --mega-accent-1: var(--sgl-lifestyle-primary, #F2FFA0);
    --mega-accent-2: var(--sgl-lifestyle-secondary, #d97706);
    --mega-accent-3: #fbbf24;
    --mega-accent-1-rgb: var(--sgl-lifestyle-primary-rgb, 245, 158, 11);
    --mega-accent-2-rgb: var(--sgl-lifestyle-secondary-rgb, 217, 119, 6);
    --mega-glow-1: rgba(var(--sgl-lifestyle-primary-rgb, 245, 158, 11), 0.12);
    --mega-glow-2: rgba(var(--sgl-lifestyle-secondary-rgb, 217, 119, 6), 0.08);
    --mega-cat-hover-bg: linear-gradient(135deg, rgba(var(--sgl-lifestyle-primary-rgb, 245, 158, 11), 0.12), rgba(var(--sgl-lifestyle-secondary-rgb, 217, 119, 6), 0.08));
    --mega-cat-icon-bg: linear-gradient(135deg, rgba(var(--sgl-lifestyle-primary-rgb, 245, 158, 11), 0.15), rgba(var(--sgl-lifestyle-secondary-rgb, 217, 119, 6), 0.1));
    --mega-cat-icon-hover: linear-gradient(135deg, var(--sgl-lifestyle-primary, #F2FFA0), var(--sgl-lifestyle-secondary, #d97706));
    --mega-featured-bg: linear-gradient(135deg, rgba(var(--sgl-lifestyle-primary-rgb, 245, 158, 11), 0.12), rgba(var(--sgl-lifestyle-secondary-rgb, 217, 119, 6), 0.08));
    --mega-featured-label-color: var(--sgl-lifestyle-primary, #F2FFA0);
    --mega-featured-top-bar: linear-gradient(90deg, var(--sgl-lifestyle-primary, #F2FFA0), var(--sgl-lifestyle-secondary, #d97706), #fbbf24);
    --mega-card-hover-border: rgba(var(--sgl-lifestyle-primary-rgb, 245, 158, 11), 0.3);
    --mega-link-color: var(--sgl-lifestyle-primary, #F2FFA0);
  }

  /* ── Support: Teal + Cyan ── */
  .sgl-mega-menu--support {
    --mega-accent-1: var(--sgl-support-primary, #FFBF9F);
    --mega-accent-2: var(--sgl-support-secondary, #0891b2);
    --mega-accent-3: #67e8f9;
    --mega-accent-1-rgb: var(--sgl-support-primary-rgb, 6, 182, 212);
    --mega-accent-2-rgb: var(--sgl-support-secondary-rgb, 8, 145, 178);
    --mega-glow-1: rgba(var(--sgl-support-primary-rgb, 6, 182, 212), 0.1);
    --mega-glow-2: rgba(var(--sgl-support-secondary-rgb, 8, 145, 178), 0.06);
    --mega-cat-hover-bg: linear-gradient(135deg, rgba(var(--sgl-support-primary-rgb, 6, 182, 212), 0.1), rgba(var(--sgl-support-secondary-rgb, 8, 145, 178), 0.06));
    --mega-cat-icon-bg: linear-gradient(135deg, rgba(var(--sgl-support-primary-rgb, 6, 182, 212), 0.15), rgba(var(--sgl-support-secondary-rgb, 8, 145, 178), 0.1));
    --mega-cat-icon-hover: linear-gradient(135deg, var(--sgl-support-primary, #FFBF9F), var(--sgl-support-secondary, #0891b2));
    --mega-featured-bg: linear-gradient(135deg, rgba(var(--sgl-support-primary-rgb, 6, 182, 212), 0.1), rgba(var(--sgl-support-secondary-rgb, 8, 145, 178), 0.06));
    --mega-featured-label-color: #ffffff;
    --mega-featured-top-bar: linear-gradient(90deg, var(--sgl-support-primary, #FFBF9F), var(--sgl-support-secondary, #0891b2), #67e8f9);
    --mega-card-hover-border: rgba(var(--sgl-support-primary-rgb, 6, 182, 212), 0.3);
    --mega-link-color: var(--sgl-support-primary, #FFBF9F);
  }

  /* Support variant: wider card column + taller menu to fit contact info */
  .sgl-mega-menu--support {
    max-height: clamp(600px, 85vh, 820px);
    overflow-y: auto;
    scrollbar-width: none;
  }
  .sgl-mega-menu--support::-webkit-scrollbar {
    display: none;
  }
  .sgl-mega-menu--support .sgl-mega-inner {
    grid-template-columns: minmax(0, 18%) minmax(0, 1fr) minmax(0, 38%);
    max-height: none;
    overflow: visible;
  }

  /* Support featured area: remove clipping so all content shows */
  .sgl-mega-menu--support .sgl-mega-featured {
    overflow: visible;
  }
  .sgl-mega-menu--support .sgl-mega-featured-card {
    overflow: visible;
  }

  /* Support featured card: white text and icons */
  .sgl-mega-menu--support .sgl-mega-featured-card .sgl-mega-featured-label {
    color: #ffffff;
  }
  .sgl-mega-menu--support .sgl-mega-featured-card .sgl-mega-featured-label svg {
    color: #ffffff;
  }
  .sgl-mega-menu--support .sgl-mega-contact-item svg {
    color: #ffffff;
  }
  .sgl-mega-menu--support .sgl-mega-contact-item {
    color: #ffffff;
  }

