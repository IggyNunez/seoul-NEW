    --mega-cat-hover-bg: rgba(255, 255, 255, 0.5);
    --mega-cat-icon-bg: rgba(255, 255, 255, 0.5);
    --mega-cat-icon-hover: linear-gradient(135deg, rgba(0, 0, 0, 0.75), rgba(0, 0, 0, 0.6));
    --mega-featured-bg: rgba(255, 255, 255, 0.35);
    --mega-featured-label-color: rgba(0, 0, 0, 0.6);
    --mega-featured-top-bar: linear-gradient(90deg, rgba(0, 0, 0, 0.15), rgba(0, 0, 0, 0.08), rgba(0, 0, 0, 0.04));
    --mega-card-hover-border: rgba(0, 0, 0, 0.12);
    --mega-link-color: rgba(0, 0, 0, 0.7);
  }

  /* Glassmorphic theme: stronger blur + no ambient glows */
  .sgl-mega-theme--glass.sgl-mega-menu {
    backdrop-filter: blur(60px) saturate(180%);
    -webkit-backdrop-filter: blur(60px) saturate(180%);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08), inset 0 0 0 0.5px rgba(255, 255, 255, 0.4);
  }
  .sgl-mega-theme--glass .sgl-mega-glow { display: none; }
  .sgl-mega-theme--glass .sgl-mega-cat-badge { color: #ffffff; }
  .sgl-mega-theme--glass .sgl-mega-cat-badge--hot { background: rgba(245, 158, 11, 0.85); }
  .sgl-mega-theme--glass .sgl-mega-cat-badge--new { background: rgba(34, 197, 94, 0.85); }
  .sgl-mega-theme--glass .sgl-mega-cat-badge--sale { background: rgba(239, 68, 68, 0.85); }

  /* ═══════════════════════════════════════════════════════
     MEGA MENU CONTAINER & POSITIONING
     ═══════════════════════════════════════════════════════ */

  .sgl-mega-menu {
    position: fixed;
    /* Use JS-calculated height (includes announcement bar), fallback to CSS header height */
    top: var(--header-group-height, var(--sgl-header-height, 80px));
    left: 50%;
    transform: translateX(-50%) translateY(-10px);
    width: calc(100vw - clamp(20px, 3vw, 40px));
    max-width: 1400px;
    /* Responsive max-height based on viewport */
    max-height: clamp(520px, 80vh, 720px);
    overflow: hidden;
    background: var(--theme-bg, linear-gradient(180deg, rgba(15, 15, 24, 0.98) 0%, rgba(10, 10, 15, 0.99) 100%));
    backdrop-filter: blur(40px);
    -webkit-backdrop-filter: blur(40px);
    border: 1px solid var(--theme-border, rgba(255, 255, 255, 0.08));
    border-top: none;
    border-radius: 0 0 clamp(16px, 1.8vw, 24px) clamp(16px, 1.8vw, 24px);
    color: var(--theme-text, #ffffff);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1),
                visibility 0.3s cubic-bezier(0.4, 0, 0.2, 1),
                transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    transition-delay: 0s;
    pointer-events: none;
    z-index: 999;
    box-sizing: border-box;
  }

  /* Show when parent is active (click-toggled) */
  .sgl-nav-item.is-open .sgl-mega-menu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
    pointer-events: auto;
    transition-delay: 0s;
  }

  /* Ambient glow — uses variant variables */
  .sgl-mega-menu::before {
    content: '';
    position: absolute;
    top: -100px;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 400px;
    background: radial-gradient(ellipse, var(--mega-glow-1, rgba(147, 51, 234, 0.15)) 0%, transparent 70%);
    pointer-events: none;
  }
  .sgl-mega-menu::after {
    content: '';
    position: absolute;
    bottom: 0;
    right: 0;
    width: 400px;
    height: 300px;
    background: radial-gradient(ellipse, var(--mega-glow-2, rgba(236, 72, 153, 0.1)) 0%, transparent 70%);
    pointer-events: none;
  }

  /* Inner grid - use percentages for truly flexible columns */
  .sgl-mega-inner {
    position: relative;
    padding: clamp(16px, 3vw, 40px);
    padding-bottom: clamp(12px, 2vw, 24px);
    display: grid;
    grid-template-columns: minmax(0, 22%) minmax(0, 1fr) minmax(0, 26%);
    grid-template-rows: minmax(0, 1fr) auto;
    align-items: stretch;
    gap: clamp(16px, 2.5vw, 32px);
    width: 100%;
    height: 100%;
    max-height: calc(clamp(520px, 80vh, 720px) - clamp(32px, 6vw, 80px));
    box-sizing: border-box;
    min-width: 0;
    min-height: 0;
    overflow: hidden;
  }

  /* When quick links are present, add back some bottom space */
  /* Quick links add their own bottom padding when present */

  /* ═══════════════════════════════════════════════════════
     SECTION TITLE
     ═══════════════════════════════════════════════════════ */

  .sgl-mega-section-title {
    font-size: clamp(8px, 0.8vw, 10px);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: clamp(1px, 0.15vw, 2px);
    color: var(--theme-text-muted, rgba(255, 255, 255, 0.4));
    margin-bottom: clamp(10px, 2vw, 20px);
    padding-left: clamp(8px, 1.2vw, 16px);
    flex-shrink: 0;
  }

  /* ═══════════════════════════════════════════════════════
     LEFT COLUMN: CATEGORIES
     ═══════════════════════════════════════════════════════ */

  .sgl-mega-categories {
    min-width: 0;
    min-height: 0;
    max-width: 100%;
    max-height: 100%;
    height: 100%;
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    overflow-y: auto;
    overflow-x: hidden;
    padding-right: 4px;
    box-sizing: border-box;
  }

  /* Custom scrollbar for categories - premium glassmorphism style */
  .sgl-mega-categories::-webkit-scrollbar {
    width: 6px;
  }
  .sgl-mega-categories::-webkit-scrollbar-track {
    background: var(--theme-scrollbar-track, rgba(255, 255, 255, 0.03));
    border-radius: 10px;
    margin: 8px 0;
  }
  .sgl-mega-categories::-webkit-scrollbar-thumb {
    background: linear-gradient(180deg, var(--mega-accent-1, #B0C3FA), var(--mega-accent-2, #EA7940));
    border-radius: 10px;
    border: 1px solid var(--theme-card-border, rgba(255, 255, 255, 0.1));
    box-shadow: 0 0 8px rgba(var(--mega-accent-1-rgb, 147, 51, 234), 0.3);
  }
  .sgl-mega-categories::-webkit-scrollbar-thumb:hover {
    background: linear-gradient(180deg, var(--mega-accent-2, #EA7940), var(--mega-accent-1, #B0C3FA));
    box-shadow: 0 0 12px rgba(var(--mega-accent-1-rgb, 147, 51, 234), 0.5);
  }
  /* Firefox scrollbar */
  .sgl-mega-categories {
    scrollbar-width: thin;
    scrollbar-color: var(--mega-accent-1, #B0C3FA) var(--theme-scrollbar-track, rgba(255, 255, 255, 0.03));
  }

  .sgl-mega-cat-list {
    display: flex;
    flex-direction: column;
    gap: clamp(2px, 0.3vw, 4px);
    min-width: 0;
  }

  .sgl-mega-cat-item {
    display: flex;
    align-items: center;
    gap: clamp(8px, 1vw, 14px);
    padding: clamp(8px, 1vw, 14px) clamp(10px, 1.2vw, 16px);
    border-radius: clamp(10px, 1vw, 14px);
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
    color: var(--theme-text, white);
    min-width: 0;
  }

  .sgl-mega-cat-item:hover {
    background: var(--mega-cat-hover-bg);
  }

  .sgl-mega-cat-icon {
    width: clamp(32px, 3.2vw, 44px);
    height: clamp(32px, 3.2vw, 44px);
    border-radius: clamp(8px, 0.9vw, 12px);
    background: var(--mega-cat-icon-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s;
    flex-shrink: 0;
    flex-shrink: 0;
  }

  .sgl-mega-cat-icon--has-image {
    overflow: hidden;
    padding: 0;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .sgl-mega-cat-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: inherit;
    transition: transform 0.3s, filter 0.3s;
  }

  .sgl-mega-cat-item:hover .sgl-mega-cat-img {
    transform: scale(1.1);
    filter: brightness(1.1);
  }

  .sgl-mega-cat-item:hover .sgl-mega-cat-icon {
    background: var(--mega-cat-icon-hover);
    box-shadow: 0 8px 24px rgba(var(--mega-accent-1-rgb, 147, 51, 234), 0.4);
  }

  .sgl-mega-cat-item:hover .sgl-mega-cat-icon--has-image {
    background: transparent;
    border-color: rgba(255, 255, 255, 0.25);
    box-shadow: 0 8px 24px rgba(var(--mega-accent-1-rgb, 147, 51, 234), 0.4);
  }

  .sgl-mega-cat-content { flex: 1; min-width: 0; overflow: hidden; }
  .sgl-mega-cat-name { font-size: clamp(11px, 1vw, 14px); font-weight: 500; margin-bottom: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: var(--theme-text, white); }
  .sgl-mega-cat-count { font-size: clamp(9px, 0.9vw, 12px); color: var(--theme-text-muted, rgba(255, 255, 255, 0.4)); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  .sgl-mega-cat-arrow {
    width: 20px;
    height: 20px;
    opacity: 0;
    transform: translateX(-8px);
    transition: all 0.2s;
    color: var(--mega-accent-1, #B0C3FA);
  }
  .sgl-mega-cat-item:hover .sgl-mega-cat-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .sgl-mega-cat-badge {
    font-size: 9px;
    font-weight: 600;
    padding: 4px 8px;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: #5E0A02;
  }
  .sgl-mega-cat-badge--new { background: var(--sgl-green, #1B4900); }
  .sgl-mega-cat-badge--sale { background: var(--sgl-red, #5E0A02); }
  .sgl-mega-cat-badge--hot { background: var(--sgl-gold, #F2FFA0); color: #000; }

  /* ═══════════════════════════════════════════════════════
     CENTER COLUMN: PRODUCTS (Glow & Lifestyle)
     ═══════════════════════════════════════════════════════ */

  .sgl-mega-products {
    border-left: 1px solid var(--theme-divider, rgba(255, 255, 255, 0.08));
    border-right: 1px solid var(--theme-divider, rgba(255, 255, 255, 0.08));
    padding: 0 clamp(12px, 1.8vw, 24px);
    min-width: 0;
    min-height: 0;
    max-width: 100%;
    max-height: 100%;
    height: 100%;
    flex: 1 1 auto;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .sgl-mega-products-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: clamp(12px, 1.8vw, 24px);
    min-width: 0;
    flex-shrink: 0;
  }

  .sgl-mega-products-link {
    font-size: clamp(10px, 0.9vw, 12px);
    color: var(--mega-link-color, #B0C3FA);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 4px;
    transition: gap 0.2s;
    white-space: nowrap;
  }
  .sgl-mega-products-link:hover { gap: 8px; }

  .sgl-mega-products-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(8px, 1.5vw, 16px);
    min-width: 0;
    min-height: 0;
    flex: 1 1 auto;
    width: 100%;
    overflow-y: auto;
    overflow-x: hidden;
    padding-right: 4px;
    padding-bottom: 8px;
  }

  /* Column control via data attribute */
  .sgl-mega-products-grid[data-columns="2"] {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  .sgl-mega-products-grid[data-columns="3"] {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
  /* Auto: 2 columns default, 3 on large screens handled in media query */

  /* Custom scrollbar for products - premium glassmorphism style */
  .sgl-mega-products-grid::-webkit-scrollbar {
    width: 6px;
  }
  .sgl-mega-products-grid::-webkit-scrollbar-track {
    background: var(--theme-scrollbar-track, rgba(255, 255, 255, 0.03));
    border-radius: 10px;
    margin: 8px 0;
  }
  .sgl-mega-products-grid::-webkit-scrollbar-thumb {
    background: linear-gradient(180deg, var(--mega-accent-1, #B0C3FA), var(--mega-accent-2, #EA7940));
    border-radius: 10px;
    border: 1px solid var(--theme-card-border, rgba(255, 255, 255, 0.1));
    box-shadow: 0 0 8px rgba(var(--mega-accent-1-rgb, 147, 51, 234), 0.3);
  }
  .sgl-mega-products-grid::-webkit-scrollbar-thumb:hover {
    background: linear-gradient(180deg, var(--mega-accent-2, #EA7940), var(--mega-accent-1, #B0C3FA));
    box-shadow: 0 0 12px rgba(var(--mega-accent-1-rgb, 147, 51, 234), 0.5);
  }
  /* Firefox scrollbar */
  .sgl-mega-products-grid {
    scrollbar-width: thin;
    scrollbar-color: var(--mega-accent-1, #B0C3FA) var(--theme-scrollbar-track, rgba(255, 255, 255, 0.03));
  }

  /* Lifestyle variant: 2-column product grid */
  .sgl-mega-menu--lifestyle .sgl-mega-products-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
  }
  .sgl-mega-menu--lifestyle .sgl-mega-products-grid[data-columns="3"] {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .sgl-mega-product-card {
    background: var(--theme-card-bg, rgba(255, 255, 255, 0.03));
    border: 1px solid var(--theme-card-border, rgba(255, 255, 255, 0.06));
    border-radius: clamp(10px, 1.2vw, 16px);
    padding: clamp(8px, 1.2vw, 16px);
    cursor: pointer;
    transition: all 0.3s;
    text-decoration: none;
    color: var(--theme-text, white);
    min-width: 0;
    box-sizing: border-box;
    display: block;
  }

  .sgl-mega-product-card:hover {
    background: var(--theme-card-hover-bg, rgba(255, 255, 255, 0.06));
    border-color: var(--mega-card-hover-border, rgba(147, 51, 234, 0.3));
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.3);
  }

  .sgl-mega-product-img {
    aspect-ratio: 1;
    border-radius: clamp(8px, 1vw, 12px);
    margin-bottom: clamp(6px, 1vw, 12px);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 0;
    width: 100%;
    background: rgba(255, 255, 255, 0.02);
  }

  .sgl-mega-product-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 12px;
  }

  .sgl-mega-product-badge {
    position: absolute;
    top: clamp(4px, 0.6vw, 8px);
    left: clamp(4px, 0.6vw, 8px);
    font-size: clamp(7px, 0.7vw, 9px);
    font-weight: 600;
    padding: clamp(2px, 0.4vw, 4px) clamp(6px, 0.8vw, 10px);
    border-radius: 20px;
    text-transform: uppercase;
    color: #5E0A02;
  }
  .sgl-mega-product-badge--bestseller { background: var(--mega-accent-1, #B0C3FA); }
  .sgl-mega-product-badge--new { background: var(--sgl-green, #1B4900); }
  .sgl-mega-product-badge--sale { background: var(--sgl-red, #5E0A02); }

  .sgl-mega-product-name {
    font-size: clamp(10px, 1vw, 13px);
    font-weight: 500;
    margin-bottom: clamp(3px, 0.5vw, 6px);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
  }

  .sgl-mega-product-price {
    display: flex;
    align-items: center;
    gap: clamp(4px, 0.5vw, 8px);
    min-width: 0;
    flex-wrap: wrap;
  }
  .sgl-mega-product-price-current { font-size: clamp(11px, 1vw, 14px); font-weight: 600; color: var(--theme-text, white); }
  .sgl-mega-product-price-original { font-size: clamp(9px, 0.8vw, 12px); color: var(--theme-text-muted, rgba(255, 255, 255, 0.4)); text-decoration: line-through; }

  /* ═══════════════════════════════════════════════════════
     CENTER COLUMN: FAQ CARDS (Support variant)
     ═══════════════════════════════════════════════════════ */

  .sgl-mega-faq-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .sgl-mega-faq-card {
    background: var(--theme-card-bg, rgba(255, 255, 255, 0.03));
    border: 1px solid var(--theme-card-border, rgba(255, 255, 255, 0.06));
    border-radius: 16px;
    padding: 20px;
    text-decoration: none;
    color: var(--theme-text, white);
    display: flex;
    flex-direction: column;
    gap: 8px;
    transition: all 0.3s;
  }

  .sgl-mega-faq-card:hover {
    background: var(--theme-card-hover-bg, rgba(255, 255, 255, 0.06));
    border-color: var(--mega-card-hover-border, rgba(6, 182, 212, 0.3));
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.3);
  }

  .sgl-mega-faq-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: var(--mega-cat-icon-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 4px;
    transition: all 0.3s;
  }

  .sgl-mega-faq-card:hover .sgl-mega-faq-icon {
    background: var(--mega-cat-icon-hover);
    box-shadow: 0 8px 24px rgba(var(--mega-accent-1-rgb, 6, 182, 212), 0.3);
  }

  .sgl-mega-faq-title {
    font-size: 14px;
    font-weight: 600;
  }

  .sgl-mega-faq-desc {
    font-size: 12px;
    color: var(--theme-text-muted, rgba(255, 255, 255, 0.4));
    line-height: 1.5;
  }

  .sgl-mega-faq-arrow {
    color: var(--mega-link-color, #FFBF9F);
    margin-top: auto;
    opacity: 0;
    transform: translateX(-4px);
    transition: all 0.2s;
  }
  .sgl-mega-faq-card:hover .sgl-mega-faq-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  /* ═══════════════════════════════════════════════════════
     RIGHT COLUMN: FEATURED CARD (all variants)
     ═══════════════════════════════════════════════════════ */

  /* Right column container */
  .sgl-mega-featured {
    min-width: 0;
    min-height: 0;
    max-width: 100%;
    width: 100%;
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    overflow-y: auto;
    overflow-x: hidden;
    box-sizing: border-box;
    scrollbar-width: none;
  }
  .sgl-mega-featured::-webkit-scrollbar {
    display: none;
  }

  .sgl-mega-featured-card {
    flex: 1 1 auto;
    min-height: 0;
    background: var(--mega-featured-bg);
    border: 1px solid var(--theme-card-border, rgba(255, 255, 255, 0.1));
    border-radius: clamp(14px, 1.5vw, 20px);
    padding: clamp(12px, 1.5vw, 20px);
    position: relative;
    display: flex;
    flex-direction: column;
    min-width: 0;
    max-width: 100%;
    width: 100%;
    box-sizing: border-box;
    overflow-y: auto;
    overflow-x: hidden;
    /* Fix backdrop-filter text ghosting */
    isolation: isolate;
    -webkit-transform: translateZ(0);
    transform: translateZ(0);
  }
  .sgl-mega-featured-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--mega-featured-top-bar);
  }

  .sgl-mega-featured-label {
    display: inline-flex;
    align-items: center;
    gap: clamp(4px, 0.5vw, 6px);
    font-size: clamp(8px, 0.8vw, 10px);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: clamp(1px, 0.12vw, 1.5px);
    color: var(--mega-featured-label-color, #EA7940);
    margin-bottom: clamp(6px, 1vw, 16px);
    max-width: 100%;
    overflow: hidden;
  }

  .sgl-mega-featured-title {
    font-size: clamp(14px, 1.4vw, 22px);
    font-weight: 600;
    margin-bottom: clamp(4px, 0.6vw, 8px);
    line-height: 1.3;
    color: var(--theme-text, white);
    word-wrap: break-word;
    overflow-wrap: break-word;
    max-width: 100%;
    /* Fix backdrop-filter text ghosting */
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    position: relative;
    z-index: 1;
  }

  .sgl-mega-featured-desc {
    font-size: clamp(10px, 0.9vw, 13px);
    color: var(--theme-text-muted, rgba(255, 255, 255, 0.5));
    line-height: 1.5;
    margin-bottom: clamp(8px, 1.2vw, 16px);
    word-wrap: break-word;
    overflow-wrap: break-word;
    /* Fix backdrop-filter text ghosting */
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    position: relative;
    z-index: 1;
  }

  .sgl-mega-featured-visual {
    flex: 1 1 auto;
    min-height: 100px;
    border-radius: clamp(10px, 1.2vw, 16px);
    background: linear-gradient(135deg, #1a1a2e, #F8EBDA);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    margin-bottom: clamp(10px, 1.5vw, 20px);
    overflow: hidden;
    min-width: 0;
    max-width: 100%;
    width: 100%;
    box-sizing: border-box;
  }
  .sgl-mega-featured-visual::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, rgba(var(--mega-accent-1-rgb, 147, 51, 234), 0.3), transparent 70%);
  }
  .sgl-mega-featured-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 16px;
    position: relative;
    z-index: 1;
  }

  .sgl-mega-featured-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 16px;
    position: relative;
    z-index: 1;
  }

  /* Lifestyle placeholder */
  .sgl-mega-featured-lifestyle-placeholder {
    width: 100%;
    height: 100%;
    min-height: 0;
    background: linear-gradient(135deg, rgba(245, 158, 11, 0.15), rgba(217, 119, 6, 0.1));
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.3);
    position: relative;
    z-index: 1;
  }

  /* ── Contact Methods (Support variant) ── */
  .sgl-mega-contact-methods {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 24px;
    flex: 1;
  }

  .sgl-mega-contact-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    background: var(--theme-card-bg, rgba(255, 255, 255, 0.04));
    border: 1px solid var(--theme-card-border, rgba(255, 255, 255, 0.08));
    border-radius: 12px;
    color: var(--theme-text, white);
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    font-family: inherit;
  }

  .sgl-mega-contact-item:hover {
    background: rgba(var(--mega-accent-1-rgb, 6, 182, 212), 0.1);
    border-color: rgba(var(--mega-accent-1-rgb, 6, 182, 212), 0.3);
  }

  .sgl-mega-contact-item svg {
    color: var(--mega-accent-1, #FFBF9F);
    flex-shrink: 0;
  }

  /* ── CTA Buttons ── */
  .sgl-mega-featured-cta {
    display: flex;
    gap: clamp(6px, 0.6vw, 8px);
    flex-wrap: wrap;
    min-width: 0;
    max-width: 100%;
    margin-top: auto;
    box-sizing: border-box;
  }

  .sgl-mega-featured-btn {
    flex: 1 1 45%;
    min-width: 0;
    max-width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(4px, 0.5vw, 6px);
    padding: clamp(8px, 0.9vw, 12px) clamp(10px, 1.2vw, 16px);
    border-radius: clamp(8px, 0.9vw, 12px);
    font-size: clamp(10px, 0.9vw, 13px);
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    box-sizing: border-box;
  }
  .sgl-mega-featured-btn--primary {
    background: var(--theme-btn-primary-bg, white);
    color: var(--theme-btn-primary-text, #F8EBDA);
  }
  .sgl-mega-featured-btn--primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(var(--mega-accent-1-rgb, 255, 255, 255), 0.2);
  }
  .sgl-mega-featured-btn--secondary {
    background: var(--theme-btn-secondary-bg, rgba(255, 255, 255, 0.1));
    color: var(--theme-btn-secondary-text, white);
    border: 1px solid var(--theme-btn-secondary-border, rgba(255, 255, 255, 0.2));
  }
  .sgl-mega-featured-btn--secondary:hover {
    background: var(--theme-card-hover-bg, rgba(255, 255, 255, 0.15));
  }

  /* ═══════════════════════════════════════════════════════
     BOTTOM: QUICK LINKS
     ═══════════════════════════════════════════════════════ */

  .sgl-mega-quick {
    grid-column: 1 / -1;
    display: flex;
    flex-wrap: wrap;
    gap: clamp(6px, 0.9vw, 12px);
    padding-top: clamp(10px, 1.5vw, 20px);
    padding-bottom: clamp(8px, 1.5vw, 20px);
    border-top: 1px solid var(--theme-divider, rgba(255, 255, 255, 0.08));
    margin-top: clamp(4px, 0.8vw, 12px);
    min-width: 0;
  }

  /* Hide quick links section if empty (whitespace-only content) */
  .sgl-mega-quick:empty {
    display: none;
  }

  .sgl-mega-quick-link {
    display: flex;
    align-items: center;
    gap: clamp(4px, 0.6vw, 8px);
    padding: clamp(6px, 0.8vw, 10px) clamp(10px, 1.4vw, 18px);
    background: var(--theme-card-bg, rgba(255, 255, 255, 0.03));
    border: 1px solid var(--theme-card-border, rgba(255, 255, 255, 0.08));
    border-radius: 100px;
    color: var(--theme-text-muted, rgba(255, 255, 255, 0.6));
    text-decoration: none;
    font-size: clamp(10px, 1vw, 13px);
    white-space: nowrap;
    transition: all 0.2s;
  }
  .sgl-mega-quick-link:hover {
    background: var(--theme-card-hover-bg, rgba(255, 255, 255, 0.08));
    color: var(--theme-text, white);
    border-color: var(--mega-card-hover-border, rgba(147, 51, 234, 0.3));
  }

  /* ═══════════════════════════════════════════════════════
     RESPONSIVE: SUPPORT VARIANT (smaller screens)
     Hide center column, go 2-column layout
     ═══════════════════════════════════════════════════════ */

  @media (max-width: 1200px) {
    /* Support variant: hide center column, 2-column layout */
    .sgl-mega-menu--support .sgl-mega-inner {
      grid-template-columns: 280px 1fr;
    }
    .sgl-mega-menu--support .sgl-mega-products {
      display: none;
    }

    /* Contact card adjustments */
    .sgl-mega-menu--support .sgl-mega-contact-item span {
      font-size: 13px;
    }
  }

  /* Note: Below 1100px, mobile drawer shows instead of mega menu */

  /* ═══════════════════════════════════════════════════════
     RESPONSIVE: MEDIUM DESKTOP (1200px - 1400px)
     Slightly compacted layout for mid-sized screens
     ═══════════════════════════════════════════════════════ */

  @media (min-width: 1200px) and (max-width: 1400px) {
    .sgl-mega-menu {
      width: calc(100vw - 40px);
      max-height: min(78vh, 650px);
    }

    .sgl-mega-inner {
      padding: 28px;
      grid-template-columns: minmax(0, 20%) minmax(0, 1fr) minmax(0, 24%);
      gap: 24px;
      max-height: calc(min(78vh, 650px) - 56px);
    }

    .sgl-mega-cat-item {
      padding: 10px 12px;
    }

    .sgl-mega-cat-icon {
      width: 36px;
      height: 36px;
    }

    .sgl-mega-cat-name {
      font-size: 13px;
    }

    /* Products: 2x3 grid */
    .sgl-mega-products-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }

    .sgl-mega-product-img {
      aspect-ratio: 1;
      height: auto;
    }

    .sgl-mega-product-name {
      font-size: 12px;
    }

    /* Featured card */
    .sgl-mega-featured-card {
      padding: 20px;
    }

    .sgl-mega-featured-title {
      font-size: 18px;
    }

    .sgl-mega-featured-desc {
      font-size: 12px;
      margin-bottom: 16px;
    }

    .sgl-mega-featured-visual {
      min-height: 90px;
    }

    .sgl-mega-featured-btn {
      padding: 10px 16px;
      font-size: 12px;
    }

    /* Quick links */
    .sgl-mega-quick {
      flex-wrap: wrap;
      gap: 8px;
    }

    .sgl-mega-quick-link {
      padding: 8px 14px;
      font-size: 12px;
    }
  }

  /* ═══════════════════════════════════════════════════════
     RESPONSIVE: COMPACT DESKTOP (1100px - 1200px)
     Below 1100px, mobile header takes over
     ═══════════════════════════════════════════════════════ */

  @media (min-width: 1100px) and (max-width: 1200px) {
    .sgl-mega-menu {
      width: calc(100vw - 20px);
      max-width: 100%;
      max-height: min(75vh, 580px);
    }

    .sgl-mega-inner {
      padding: 20px;
      grid-template-columns: minmax(0, 18%) minmax(0, 1fr) minmax(0, 22%);
      gap: 16px;
      max-height: calc(min(75vh, 580px) - 40px);
    }

    .sgl-mega-section-title {
      font-size: 9px;
      margin-bottom: 14px;
      padding-left: 10px;
    }

    .sgl-mega-cat-item {
      padding: 10px 12px;
      gap: 10px;
    }

    .sgl-mega-cat-icon {
      width: 34px;
      height: 34px;
    }

    .sgl-mega-cat-name {
      font-size: 12px;
    }

    .sgl-mega-cat-count {
      font-size: 10px;
    }

    .sgl-mega-cat-arrow {
      display: none;
    }

    /* Products: keep center column padding */
    .sgl-mega-products {
      padding: 0 20px;
    }

    /* Products grid: 2 columns */
    .sgl-mega-products-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .sgl-mega-product-card {
      padding: 10px;
    }

    .sgl-mega-product-img {
      aspect-ratio: 1;
      height: auto;
    }

    .sgl-mega-product-name {
      font-size: 11px;
    }

    .sgl-mega-product-price-current {
      font-size: 12px;
    }

    .sgl-mega-product-badge {
      font-size: 8px;
      padding: 3px 6px;
    }

    /* Featured card */
    .sgl-mega-featured-card {
      padding: 18px;
    }

    .sgl-mega-featured-label {
      font-size: 9px;
      margin-bottom: 12px;
    }

    .sgl-mega-featured-title {
      font-size: 17px;
      margin-bottom: 6px;
    }

    .sgl-mega-featured-desc {
      font-size: 11px;
      margin-bottom: 14px;
      line-height: 1.5;
    }

    .sgl-mega-featured-visual {
      flex: 1 1 auto;
      min-height: 80px;
      margin-bottom: 14px;
    }

    .sgl-mega-featured-cta {
      gap: 8px;
    }

    .sgl-mega-featured-btn {
      padding: 10px 14px;
      font-size: 11px;
    }

    /* Contact methods */
    .sgl-mega-contact-methods {
      gap: 8px;
      margin-bottom: 14px;
    }

    .sgl-mega-contact-item {
      padding: 10px 12px;
      font-size: 12px;
    }

    /* Quick links: wrap */
    .sgl-mega-quick {
      flex-wrap: wrap;
      gap: 8px;
      padding-top: 16px;
    }

    .sgl-mega-quick-link {
      padding: 7px 12px;
      font-size: 11px;
    }
  }

  /* ═══════════════════════════════════════════════════════
     RESPONSIVE: SMALL DESKTOP (900px - 1100px)
     Very compact layout for small desktop screens
     ═══════════════════════════════════════════════════════ */

  @media (min-width: 900px) and (max-width: 1100px) {
    .sgl-mega-menu {
      width: calc(100vw - 16px);
      max-width: 100%;
      max-height: min(72vh, 520px);
      border-radius: 0 0 12px 12px;
    }

    .sgl-mega-inner {
      padding: 16px;
      grid-template-columns: minmax(0, 22%) minmax(0, 1fr) minmax(0, 28%);
      gap: 12px;
      max-height: calc(min(72vh, 520px) - 32px);
    }

    .sgl-mega-section-title {
      font-size: 8px;
      margin-bottom: 10px;
      padding-left: 8px;
      letter-spacing: 1.5px;
    }

    .sgl-mega-cat-item {
      padding: 8px 10px;
      gap: 8px;
      border-radius: 8px;
    }

    .sgl-mega-cat-icon {
      width: 28px;
      height: 28px;
      border-radius: 6px;
    }

    .sgl-mega-cat-icon svg {
      width: 14px;
      height: 14px;
    }

    .sgl-mega-cat-name {
      font-size: 11px;
    }

    .sgl-mega-cat-count {
      font-size: 9px;
    }

    .sgl-mega-cat-arrow,
    .sgl-mega-cat-badge {
      display: none;
    }

    /* Products */
    .sgl-mega-products {
      padding: 0 12px;
    }

    .sgl-mega-products-header {
      margin-bottom: 10px;
    }

    .sgl-mega-products-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 8px;
    }

    .sgl-mega-product-card {
      padding: 8px;
      border-radius: 10px;
    }

    .sgl-mega-product-img {
      border-radius: 8px;
      margin-bottom: 6px;
    }

    .sgl-mega-product-name {
      font-size: 10px;
      margin-bottom: 3px;
    }

    .sgl-mega-product-price-current {
      font-size: 11px;
    }

    .sgl-mega-product-price-original {
      font-size: 9px;
    }

    .sgl-mega-product-badge {
      font-size: 7px;
      padding: 2px 5px;
      top: 3px;
      left: 3px;
    }

    /* Featured card */
    .sgl-mega-featured-card {
      padding: 14px;
      border-radius: 12px;
    }

    .sgl-mega-featured-label {
      font-size: 8px;
      margin-bottom: 8px;
      letter-spacing: 1px;
    }

    .sgl-mega-featured-title {
      font-size: 14px;
      margin-bottom: 4px;
    }

    .sgl-mega-featured-desc {
      font-size: 10px;
      margin-bottom: 10px;
      line-height: 1.4;
    }

    .sgl-mega-featured-visual {
      min-height: 70px;
      margin-bottom: 10px;
      border-radius: 8px;
    }

    .sgl-mega-featured-cta {
      gap: 6px;
    }

    .sgl-mega-featured-btn {
      padding: 8px 10px;
      font-size: 10px;
      border-radius: 6px;
    }

    /* Contact methods */
    .sgl-mega-contact-methods {
      gap: 6px;
      margin-bottom: 10px;
    }

    .sgl-mega-contact-item {
      padding: 8px 10px;
      font-size: 11px;
      border-radius: 8px;
      gap: 8px;
    }

    .sgl-mega-contact-item svg {
      width: 16px;
      height: 16px;
    }

    /* FAQ cards */
    .sgl-mega-faq-grid {
      gap: 8px;
    }

    .sgl-mega-faq-card {
      padding: 12px;
      border-radius: 10px;
      gap: 6px;
    }

    .sgl-mega-faq-icon {
      width: 28px;
      height: 28px;
      border-radius: 6px;
    }

    .sgl-mega-faq-icon svg {
      width: 14px;
      height: 14px;
    }

    .sgl-mega-faq-title {
      font-size: 11px;
    }

    .sgl-mega-faq-desc {
      font-size: 10px;
      line-height: 1.4;
    }

    /* Quick links */
    .sgl-mega-quick {
      gap: 6px;
      padding-top: 12px;
      padding-bottom: 4px;
      margin-top: 8px;
    }

    .sgl-mega-quick-link {
      padding: 6px 10px;
      font-size: 10px;
    }

    /* Ambient glow - reduce on smaller screens */
    .sgl-mega-menu::before {
      width: 300px;
      height: 200px;
      opacity: 0.7;
    }

    .sgl-mega-menu::after {
      width: 200px;
      height: 150px;
      opacity: 0.7;
    }
  }

  /* ═══════════════════════════════════════════════════════
     RESPONSIVE: TABLET LANDSCAPE (750px - 900px)
     Super compact, hide less essential elements
     ═══════════════════════════════════════════════════════ */

  @media (min-width: 750px) and (max-width: 900px) {
    .sgl-mega-menu {
      width: calc(100vw - 12px);
      max-width: 100%;
      max-height: min(68vh, 460px);
      border-radius: 0 0 10px 10px;
    }

    .sgl-mega-inner {
      padding: 12px;
      grid-template-columns: minmax(0, 25%) minmax(0, 1fr) minmax(0, 30%);
      gap: 10px;
      max-height: calc(min(68vh, 460px) - 24px);
    }

    .sgl-mega-section-title {
      font-size: 7px;
      margin-bottom: 8px;
      padding-left: 6px;
      letter-spacing: 1px;
    }

    .sgl-mega-cat-item {
      padding: 6px 8px;
      gap: 6px;
      border-radius: 6px;
    }

    .sgl-mega-cat-icon {
      width: 24px;
      height: 24px;
      border-radius: 5px;
    }

    .sgl-mega-cat-icon svg {
      width: 12px;
      height: 12px;
    }

    .sgl-mega-cat-name {
      font-size: 10px;
    }

    .sgl-mega-cat-count,
    .sgl-mega-cat-arrow,
    .sgl-mega-cat-badge {
      display: none;
    }

    /* Products */
    .sgl-mega-products {
      padding: 0 8px;
    }

    .sgl-mega-products-header {
      margin-bottom: 8px;
    }

    .sgl-mega-products-link {
      font-size: 9px;
    }

    .sgl-mega-products-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 6px;
    }

    .sgl-mega-product-card {
      padding: 6px;
      border-radius: 8px;
    }

    .sgl-mega-product-img {
      border-radius: 6px;
      margin-bottom: 4px;
    }

    .sgl-mega-product-name {
      font-size: 9px;
      margin-bottom: 2px;
    }

    .sgl-mega-product-price-current {
      font-size: 10px;
    }

    .sgl-mega-product-price-original {
      display: none;
    }

    .sgl-mega-product-badge {
      font-size: 6px;
      padding: 2px 4px;
      top: 2px;
      left: 2px;
    }

    /* Featured card */
    .sgl-mega-featured-card {
      padding: 10px;
      border-radius: 10px;
    }

    .sgl-mega-featured-label {
      font-size: 7px;
      margin-bottom: 6px;
    }

    .sgl-mega-featured-title {
      font-size: 12px;
      margin-bottom: 3px;
    }

    .sgl-mega-featured-desc {
      font-size: 9px;
      margin-bottom: 8px;
      line-height: 1.3;
      /* Limit to 2 lines */
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .sgl-mega-featured-visual {
      min-height: 60px;
      margin-bottom: 8px;
      border-radius: 6px;
    }

    .sgl-mega-featured-cta {
      gap: 4px;
      flex-direction: column;
    }

    .sgl-mega-featured-btn {
      padding: 6px 8px;
      font-size: 9px;
      border-radius: 5px;
    }

    /* Contact methods */
    .sgl-mega-contact-methods {
      gap: 4px;
      margin-bottom: 8px;
    }

    .sgl-mega-contact-item {
      padding: 6px 8px;
      font-size: 9px;
      border-radius: 6px;
      gap: 6px;
    }

    .sgl-mega-contact-item svg {
      width: 14px;
      height: 14px;
    }

    /* FAQ cards */
    .sgl-mega-faq-grid {
      gap: 6px;
    }

    .sgl-mega-faq-card {
      padding: 8px;
      border-radius: 8px;
      gap: 4px;
    }

    .sgl-mega-faq-icon {
      width: 22px;
      height: 22px;
      border-radius: 5px;
    }

    .sgl-mega-faq-icon svg {
      width: 12px;
      height: 12px;
    }

    .sgl-mega-faq-title {
      font-size: 10px;
    }

    .sgl-mega-faq-desc {
      font-size: 9px;
      line-height: 1.3;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .sgl-mega-faq-arrow {
      display: none;
    }

    /* Quick links - hide on very small screens */
    .sgl-mega-quick {
      display: none;
    }

    /* Ambient glow - minimal on smaller screens */
    .sgl-mega-menu::before,
    .sgl-mega-menu::after {
      opacity: 0.5;
    }
  }

  /* Note: Below 750px, the mobile drawer takes over - no need for
     more responsive styles. The mega menu is only shown on desktop. */

  /* ═══════════════════════════════════════════════════════
     RESPONSIVE: LARGE DESKTOP (1440px+)
     ═══════════════════════════════════════════════════════ */

  @media (min-width: 1440px) {
    .sgl-mega-inner {
      padding: 40px;
      grid-template-columns: minmax(0, 20%) minmax(0, 1fr) minmax(0, 26%);
      gap: 40px;
    }

    .sgl-mega-products-grid {
      gap: 20px;
    }

    .sgl-mega-product-img {
      aspect-ratio: 1;
      height: auto;
    }

    .sgl-mega-featured-visual {
      min-height: 140px;
    }
  }

  /* ═══════════════════════════════════════════════════════
     RESPONSIVE: EXTRA LARGE DESKTOP (1600px+)
     Only show 3 product columns on very wide screens (auto mode)
     ═══════════════════════════════════════════════════════ */

  @media (min-width: 1600px) {
    .sgl-mega-inner {
      grid-template-columns: minmax(0, 18%) minmax(0, 1fr) minmax(0, 24%);
    }

    /* Auto mode: switch to 3 columns on extra-large screens */
    .sgl-mega-products-grid[data-columns="auto"] {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    /* Explicit 2 or 3 columns override auto behavior */
    .sgl-mega-products-grid[data-columns="2"] {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .sgl-mega-products-grid[data-columns="3"] {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  /* ═══════════════════════════════════════════════════════
     RESPONSIVE: EXTRA LARGE DESKTOP (1920px+)
     Expanded layout for larger monitors
     ═══════════════════════════════════════════════════════ */

  @media (min-width: 1920px) {
    .sgl-mega-menu {
      max-width: 1600px;
      max-height: min(85vh, 800px);
    }

    .sgl-mega-inner {
      padding: 48px;
      gap: 48px;
      max-height: calc(min(85vh, 800px) - 96px);
    }

    .sgl-mega-section-title {
      font-size: 11px;
      margin-bottom: 24px;
    }

    .sgl-mega-cat-item {
      padding: 16px 18px;
    }

    .sgl-mega-cat-icon {
