{% doc %}
  Casa Cart Items

  Premium cart item cards with glassmorphism styling.
  Maintains all JS integration points (refs, event bindings, data attributes)
  for compatibility with cart-items-component.

  @param {boolean} [force_empty] - Force render empty cart state
{% enddoc %}

<script src="{{ 'component-cart-items.js' | asset_url }}" type="module" fetchpriority="low"></script>
<script src="{{ 'component-cart-quantity-selector.js' | asset_url }}" type="module" fetchpriority="low"></script>
<script src="{{ 'volume-pricing-info.js' | asset_url }}" type="module" fetchpriority="low"></script>

<div
  class="casa-cart-items__wrapper"
  {% if settings.product_title_case == 'uppercase' %}
    style="--product-title-case: uppercase;"
  {% endif %}
>
  {% if cart.empty? or force_empty %}
    {%- render 'casa-cart-empty' -%}
  {%- else -%}
    <span class="visually-hidden" ref="cartItemCount" aria-hidden="true">
      {{- cart.item_count -}}
    </span>
    <form action="{{ routes.cart_url }}" class="cart-form" id="cart-form" method="post">
      <div class="casa-cart-items" style="--cart-items-gap: 24px;">
        <table class="casa-cart-items__table" role="table">
          <caption class="visually-hidden" role="caption">
            {{ 'content.cart_total' | t }}
            <span>{{ cart.total_price | money_with_currency }}</span>
          </caption>
          <thead class="visually-hidden" role="rowgroup">
            <tr role="row">
              <th id="casaProductImage" scope="col" role="columnheader">{{ 'content.product_image' | t }}</th>
              <th id="casaProductInfo" scope="col" role="columnheader">{{ 'content.product_information' | t }}</th>
              <th id="casaQuantity" scope="col" role="columnheader">{{ 'content.quantity' | t }}</th>
              <th id="casaProductTotal" scope="col" role="columnheader">{{ 'content.product_total' | t }}</th>
            </tr>
          </thead>
          <tbody role="rowgroup">
            {% for item in cart.items %}
              {%- liquid
                assign border_opacity = settings.cart_thumbnail_border_opacity | divided_by: 100.0
                assign border_override = '--border-width: VAL1px; --border-style: VAL2; --border-color: rgb(var(--color-border-rgb) / VAL3); --border-radius: VAL4px;' | replace: 'VAL1', settings.cart_thumbnail_border_width | replace: 'VAL2', settings.cart_thumbnail_border | replace: 'VAL3', border_opacity | replace: 'VAL4', settings.cart_thumbnail_border_radius
                if settings.cart_thumbnail_border_radius > 0
                  assign border_override = border_override | append: ' overflow: hidden;'
                endif

                assign ratio = 1
                if settings.cart_thumbnail_border_ratio == 'portrait'
                  assign ratio = 0.8
                elsif settings.cart_thumbnail_border_ratio == 'adapt' and item.image
                  assign ratio = item.image.aspect_ratio
                endif
              -%}
              <tr
                role="row"
                class="casa-cart-items__card cart-items__table-row{% if item.parent_relationship.parent != null %} cart-items__nested-line{% endif %}"
                ref="cartItemRows[]"
                data-parent-key="{{ item.parent_relationship.parent.key }}"
                data-key="{{ item.key }}"
                data-product-id="{{ item.product.id }}"
                data-variant-id="{{ item.variant.id }}"
                data-line-item-key="{{ item.key }}"
                style="animation-delay: {{ forloop.index0 | times: 100 }}ms;"
              >
                {%- comment -%} Product Image {%- endcomment -%}
                <td class="casa-cart-items__media" role="cell" headers="casaProductImage">
                  {% if item.image -%}
                    <a href="{{ item.url }}" class="casa-cart-items__media-link" style="--ratio: 1;">
                      {{ item.image | image_url: width: 300 | image_tag: class: 'casa-cart-items__image', style: border_override }}
                    </a>
                  {%- endif %}
                </td>

                {%- comment -%} Product Details {%- endcomment -%}
                <td class="casa-cart-items__details" role="cell" headers="casaProductInfo">
                  <a href="{{ item.url }}" class="casa-cart-items__title">
                    {{- item.product.title -}}
                  </a>

                  {%- if item.product.vendor -%}
                    <p class="casa-cart-items__vendor">{{ item.product.vendor }}</p>
                  {%- endif -%}

                  {%- if item.item_components.size != 0 -%}
                    <ul class="casa-cart-items__bundle list-unstyled">
                      {%- for component in item.item_components -%}
                        <li>
                          {{ component.title }}
                          {%- if component.quantity > 1 %} <span>&times; {{ component.quantity }}</span>{% endif -%}
                        </li>
                      {%- endfor -%}
                    </ul>
                  {%- endif -%}

                  {%- comment -%} Variant options (Onyx, Large, etc.) {%- endcomment -%}
                  {%- if item.product.has_only_default_variant == false and item.item_components.size == 0 -%}
                    <dl class="casa-cart-items__variants">
                      {%- for option in item.options_with_values -%}
                        <div class="casa-cart-items__variant">
                          <dt class="visually-hidden">{{ option.name }}:</dt>
                          <dd>{{ option.value }}{%- unless forloop.last %},&nbsp;{% endunless -%}</dd>
                        </div>
                      {%- endfor -%}
                    </dl>
                  {%- endif -%}

                  {%- comment -%} Line item properties (Estimated delivery, etc.) {%- endcomment -%}
                  {%- if item.properties.size > 0 -%}
                    <div class="casa-cart-items__properties cart-items__meta">
                      {%- for property in item.properties -%}
                        {%- assign property_first_char = property.first | slice: 0 -%}
                        {%- if property.last != blank and property_first_char != '_' -%}
                          <div class="casa-cart-items__property cart-items__property">
                            <dt>{{ property.first }}:</dt>
                            <dd>
                              {%- if property.last contains '/uploads/' -%}
                                <a href="{{ property.last }}">{{ property.last | split: '/' | last }}</a>
                              {%- else -%}
                                {{ property.last }}
                              {%- endif -%}
                            </dd>
                          </div>
                        {%- endif -%}
                      {%- endfor -%}
                    </div>
                  {%- endif -%}

                  {%- if item.selling_plan_allocation -%}
                    <p class="casa-cart-items__selling-plan">{{ item.selling_plan_allocation.selling_plan.name }}</p>
                  {%- endif -%}

                  {%- comment -%} App injection hook for EDT and similar apps {%- endcomment -%}
                  <div class="casa-cart-items__app-block cart-items__app-block" data-cart-item-key="{{ item.key }}" data-product-id="{{ item.product.id }}" data-variant-id="{{ item.variant.id }}"></div>

                  {%- comment -%} Line-level discounts {%- endcomment -%}
                  {%- if item.line_level_discount_allocations.size > 0 -%}
                    <ul class="casa-cart-items__discounts list-unstyled" role="list">
                      {%- for discount in item.line_level_discount_allocations -%}
                        <li class="casa-cart-items__discount">
                          {%- render 'casa-icon', icon: 'tag', size: 12 -%}
                          {{ discount.discount_application.title | escape }}
                        </li>
                      {%- endfor -%}
                    </ul>
                  {%- endif -%}

                  {%- comment -%} Unit price {%- endcomment -%}
                  <div class="casa-cart-items__pricing">
                    {% if item.original_price != item.final_price %}
                      <span class="visually-hidden">{{ 'content.price_sale' | t }}</span>
                      <span class="casa-cart-items__price casa-cart-items__price--sale">{{ item.final_price | money }}</span>
                      <span class="visually-hidden">{{ 'content.price_regular' | t }}</span>
                      <s class="casa-cart-items__price--compare">
                        {% if item.variant.compare_at_price > item.original_price %}
                          {{ item.variant.compare_at_price | money }}
                        {% else %}
                          {{ item.original_price | money }}
                        {% endif %}
                      </s>
                    {% else %}
                      {% if item.variant.compare_at_price > item.original_price %}
                        <span class="visually-hidden">{{ 'content.price_sale' | t }}</span>
                      {% else %}
                        <span class="visually-hidden">{{ 'content.price' | t }}</span>
                      {% endif %}
                      <span class="casa-cart-items__price">{{ item.original_price | money }}</span>
                      {% if item.variant.compare_at_price > item.original_price %}
                        <span class="visually-hidden">{{ 'content.price_regular' | t }}</span>
                        <s class="casa-cart-items__price--compare">{{ item.variant.compare_at_price | money }}</s>
                      {% endif %}
                    {% endif %}
                  </div>

                  {%- comment -%} Low Stock Warning {%- endcomment -%}
                  {%- if settings.cart_show_low_stock -%}
                    {%- liquid
                      assign low_stock_threshold = settings.cart_low_stock_threshold | default: 5
                      assign variant_inventory = item.variant.inventory_quantity
                      assign show_warning = false
                      if item.variant.inventory_management == 'shopify' and item.variant.inventory_policy == 'deny'
                        if variant_inventory > 0 and variant_inventory <= low_stock_threshold
                          assign show_warning = true
                        endif
                      endif
                    -%}
                    {%- if show_warning -%}
                      <div class="casa-cart-items__low-stock">
                        {%- render 'casa-icon', icon: 'flame', size: 12 -%}
                        <span>Only {{ variant_inventory }} left!</span>
                      </div>
                    {%- endif -%}
                  {%- endif -%}

                  {%- comment -%} Savings display {%- endcomment -%}
                  {%- if settings.cart_show_compare_at_savings and item.variant.compare_at_price > item.original_price -%}
                    {%- assign savings = item.variant.compare_at_price | minus: item.final_price | times: item.quantity -%}
                    <div class="casa-cart-items__savings">
                      You save {{ savings | money }}
                    </div>
                  {%- endif -%}
                </td>

                {%- comment -%} Quantity & Remove {%- endcomment -%}
                <td class="casa-cart-items__quantity" role="cell" headers="casaQuantity">
                  {%- assign can_update_quantity = item.instructions.can_update_quantity | default: true, allow_false: true -%}
                  <div class="casa-cart-items__quantity-controls">
                    {% render 'volume-pricing-info',
                      variant: item.variant,
                      unique_id: item.index,
                      quantity: item.quantity
                    %}
                    {% render 'quantity-selector',
                      product: item.product,
                      variant: item.variant,
                      in_cart_quantity: item.quantity,
                      line_index: item.index,
                      class: 'casa-cart-qty',
                      can_update_quantity: can_update_quantity
                    %}
                    {%- comment -%} Save for later button {%- endcomment -%}
                    <button
                      class="casa-cart-items__save-later"
                      type="button"
                      aria-label="Save {{ item.title | escape }} for later"
                      data-product-handle="{{ item.product.handle }}"
                      data-variant-id="{{ item.variant.id }}"
                      onclick="casaSaveForLater(this)"
                    >
                      {%- render 'casa-icon', icon: 'heart', size: 16 -%}
                      <span class="casa-cart-items__save-later-text">Save</span>
                    </button>
                    <button
                      class="casa-cart-items__remove"
                      type="button"
                      aria-label="{{ 'accessibility.remove_item' | t: title: item.title | escape }}"
                      on:click="/onLineItemRemove/{{ item.index | plus: 1 }}"
                      {%- assign can_remove = item.instructions.can_remove | default: true, allow_false: true -%}
                      {% if can_remove == false %}hidden{% endif %}
                    >
                      {%- render 'casa-icon', icon: 'trash', size: 16 -%}
                      <span class="visually-hidden">{{ 'accessibility.remove' | t }}</span>
                    </button>
                  </div>
                </td>

                {%- comment -%} Error cell {%- endcomment -%}
                <td
                  class="casa-cart-items__error hidden"
                  role="cell"
                  ref="cartItemErrorContainer-{{ item.index | plus: 1 }}"
                  headers="casaQuantity"
                >
                  <div class="cart-item__error" role="alert">
                    <span class="svg-wrapper">
                      {{- 'icon-error.svg' | inline_asset_content -}}
                    </span>
                    <small
                      class="cart-item__error-text"
                      ref="cartItemError-{{ item.index | plus: 1 }}"
                    ></small>
                  </div>
                </td>

                {%- comment -%} Line Total {%- endcomment -%}
                <td class="casa-cart-items__line-total" role="cell" headers="casaProductTotal">
                  {%- liquid
                    if settings.currency_code_enabled_cart_items
                      assign price = item.final_line_price | money_with_currency
                      assign unit_price = item.unit_price | money_with_currency
                    else
                      assign price = item.final_line_price | money
                      assign unit_price = item.unit_price | money
                    endif
                  -%}
                  <text-component value="{{ price | strip_html }}">{{ price }}</text-component>
                  {%- if item.unit_price_measurement -%}
                    <div class="casa-cart-items__unit-price">
                      {% render 'unit-price', price: unit_price, measurement: item.unit_price_measurement %}
                    </div>
                  {%- endif -%}
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </form>
  {%- endif -%}
</div>

{% stylesheet %}
  .casa-cart-items__wrapper { width: 100%; }

  .casa-cart-items {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .casa-cart-items__table { width: 100%; border-spacing: 0; }
  .casa-cart-items__table * { margin: 0; }

  /* ── Item card — clean, minimal ── */
  .casa-cart-items__card {
    display: grid;
    grid-template-columns: 100px 1fr auto;
    grid-template-areas:
      'media details total'
      'media quantity total'
      'media error error';
    column-gap: 16px;
    row-gap: 4px;
    align-items: start;
    padding: 16px;
    background: var(--cart-bg-secondary, #f9fafb);
    border: 1px solid var(--cart-border, rgba(0,0,0,0.06));
    border-radius: 12px;
  }

  /* No decorative pseudo-elements */
  .casa-cart-items__card::before,
  .casa-cart-items__card::after { display: none; }

  .casa-cart-items__card.removing {
    overflow: hidden;
    animation: removeRow calc(var(--animation-speed, 0.25s) * 2) var(--animation-easing, ease) forwards;
    animation-delay: var(--animation-speed, 0.125s);
  }

  @keyframes removeRow {
    0% { height: var(--row-height); }
    100% { opacity: 0; height: 0; padding: 0; margin: 0; border-color: transparent; }
  }

  /* ── Image ── */
  .casa-cart-items__media { grid-area: media; padding: 0; }

  .casa-cart-items__media-link {
    display: block;
    aspect-ratio: 1;
    border-radius: 8px;
    overflow: hidden;
  }

  .casa-cart-items__media-link::before { display: none; }

  .casa-cart-items__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 8px;
  }

  /* ── Details ── */
  .casa-cart-items__details {
    grid-area: details;
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .casa-cart-items__title {
    font-size: var(--cart-title-size, 15px);
    font-weight: 500;
    color: var(--cart-text, #0a0a0a);
    text-decoration: none;
    text-transform: var(--product-title-case, none);
    line-height: 1.3;
  }
  .casa-cart-items__title:hover { color: var(--cart-accent-1, #9333ea); }

  .casa-cart-items__vendor {
    font-size: var(--cart-body-size, 13px);
    color: var(--cart-text-muted, #6b7280);
  }

  .casa-cart-items__variants { display: flex; flex-wrap: wrap; gap: 0; margin: 0; }
  .casa-cart-items__variant { display: inline; }
  .casa-cart-items__variant dt,
  .casa-cart-items__variant dd {
    display: inline;
    font-size: 13px;
    color: var(--cart-text-muted, #6b7280);
    margin: 0;
  }

  .casa-cart-items__properties { margin-top: 4px; }
  .casa-cart-items__property {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 2px 4px;
    margin-top: 4px;
    font-size: 12px;
    color: var(--cart-text-muted, #6b7280);
  }
  .casa-cart-items__property dt,
  .casa-cart-items__property dd { font-size: inherit; color: inherit; margin: 0; display: inline; }
  .casa-cart-items__property dt { font-weight: 500; flex-shrink: 0; }

  .casa-cart-items__selling-plan { font-size: 13px; color: #6b7280; }
  .casa-cart-items__bundle { padding: 0; margin: 4px 0 0 0; }
  .casa-cart-items__bundle li { font-size: 13px; color: #6b7280; }

  .casa-cart-items__discounts { padding: 0; margin: 4px 0 0 0; }
  .casa-cart-items__discount {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 13px;
    color: var(--cart-accent-1, #9333ea);
  }

  /* ── Pricing ── */
  .casa-cart-items__pricing {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 4px;
  }
  .casa-cart-items__price {
    font-size: 14px;
    color: var(--cart-price-color, var(--cart-text, #0a0a0a));
    font-weight: 500;
  }
  .casa-cart-items__price--sale { color: var(--cart-sale-price-color, #ec4899); }
  .casa-cart-items__price--compare {
    font-size: 13px;
    color: var(--cart-compare-price-color, #9ca3af);
    text-decoration: line-through;
  }

  .casa-cart-items__low-stock {
    display: flex; align-items: center; gap: 4px;
    font-size: 12px; color: #ef4444; margin-top: 4px;
  }

  .casa-cart-items__savings {
    font-size: 12px;
    color: var(--cart-savings-color, #22c55e);
    font-weight: 600;
    margin-top: 4px;
  }

  /* ── Quantity controls ── */
  .casa-cart-items__quantity {
    grid-area: quantity;
    padding: 0;
  }
  .casa-cart-items__quantity-controls {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 4px;
  }

  .casa-cart-items__save-later,
  .casa-cart-items__remove {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 6px;
    border: none;
    border-radius: 6px;
    background: transparent;
    cursor: pointer;
    color: var(--cart-text-muted, #9ca3af);
    transition: color 0.15s, background 0.15s;
    font-size: 12px;
  }
  .casa-cart-items__save-later:hover { color: var(--cart-accent-1, #9333ea); background: rgba(147,51,234,0.06); }
  .casa-cart-items__remove:hover { color: #ef4444; background: rgba(239,68,68,0.06); }
  .casa-cart-items__save-later-text { display: none; }

  /* ── Line total ── */
  .casa-cart-items__line-total {
    grid-area: total;
    text-align: right;
    font-size: 15px;
    font-weight: 600;
    color: var(--cart-text, #0a0a0a);
    padding: 0;
    white-space: nowrap;
  }
  .casa-cart-items__unit-price {
    font-size: 12px;
    color: var(--cart-text-muted, #6b7280);
    font-weight: 400;
    margin-top: 2px;
  }

  .casa-cart-items__error { padding: 0; }
  .cart-item__error {
    display: flex; align-items: center; gap: 6px;
    padding: 8px 12px; border-radius: 8px;
    background: rgba(239,68,68,0.06); color: #ef4444;
    font-size: 13px;
  }

  /* Nested line items */
  .cart-items__nested-line {
    border: none;
    background: transparent;
    padding: 8px 16px 8px 32px;
    border-radius: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 749px) {
    .casa-cart-items__card {
      grid-template-columns: 80px 1fr;
      grid-template-areas:
        'media details'
        'media quantity'
        'error error';
      column-gap: 12px;
      padding: 12px;
    }
    .casa-cart-items__line-total { display: none; }
    .casa-cart-items__title { font-size: 14px; }
  }
{% endstylesheet %}

{% javascript %}
  // Save for later functionality
  window.casaSaveForLater = function(btn) {
    const handle = btn.dataset.productHandle;
    const variantId = btn.dataset.variantId;

    // Get existing saved items
    let savedItems = JSON.parse(localStorage.getItem('casa_saved_items') || '[]');

    // Check if already saved
    const existingIndex = savedItems.findIndex(item => item.variantId === variantId);

    if (existingIndex > -1) {
      // Remove from saved
      savedItems.splice(existingIndex, 1);
      btn.classList.remove('saved');
      btn.querySelector('.casa-cart-items__save-later-text').textContent = 'Save';
    } else {
      // Add to saved
      savedItems.push({ handle, variantId, savedAt: Date.now() });
      btn.classList.add('saved');
      btn.querySelector('.casa-cart-items__save-later-text').textContent = 'Saved';

      // Add pulse animation
      btn.style.animation = 'casa-save-pulse 0.4s ease';
      setTimeout(() => btn.style.animation = '', 400);
    }

    localStorage.setItem('casa_saved_items', JSON.stringify(savedItems));
  };

  // Check saved state on load
  document.addEventListener('DOMContentLoaded', function() {
    const savedItems = JSON.parse(localStorage.getItem('casa_saved_items') || '[]');
    const savedVariantIds = savedItems.map(item => item.variantId);

    document.querySelectorAll('.casa-cart-items__save-later').forEach(btn => {
      if (savedVariantIds.includes(btn.dataset.variantId)) {
        btn.classList.add('saved');
        btn.querySelector('.casa-cart-items__save-later-text').textContent = 'Saved';
      }
    });
  });
{% endjavascript %}
