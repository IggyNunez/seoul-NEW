{%- comment -%}
  Breadcrumbs Snippet
  Simple breadcrumb navigation: Home > Collection > Product
{%- endcomment -%}

<nav class="casa-breadcrumbs" aria-label="Breadcrumb">
  <ol class="casa-breadcrumbs__list">
    <li class="casa-breadcrumbs__item">
      <a href="/" class="casa-breadcrumbs__link">Home</a>
    </li>
    {%- if product.collections.size > 0 -%}
      {%- assign collection = product.collections.first -%}
      <li class="casa-breadcrumbs__item">
        <span class="casa-breadcrumbs__separator" aria-hidden="true">/</span>
        <a href="{{ collection.url }}" class="casa-breadcrumbs__link">{{ collection.title }}</a>
      </li>
    {%- endif -%}
    <li class="casa-breadcrumbs__item casa-breadcrumbs__item--current" aria-current="page">
      <span class="casa-breadcrumbs__separator" aria-hidden="true">/</span>
      <span class="casa-breadcrumbs__current">{{ product.title }}</span>
    </li>
  </ol>
</nav>

<style>
.casa-breadcrumbs__list {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 4px;
  list-style: none;
  margin: 0;
  padding: 0;
  font-size: 13px;
}

.casa-breadcrumbs__item {
  display: flex;
  align-items: center;
  gap: 4px;
}

.casa-breadcrumbs__separator {
  color: rgba(0, 0, 0, 0.3);
}

.casa-breadcrumbs__link {
  color: rgba(0, 0, 0, 0.5);
  text-decoration: none;
  transition: color 0.2s ease;
}

.casa-breadcrumbs__link:hover {
  color: var(--cpm-accent-1, #9333ea);
}

.casa-breadcrumbs__current {
  color: rgba(0, 0, 0, 0.7);
}

@media (max-width: 480px) {
  .casa-breadcrumbs__list {
    font-size: 12px;
  }
}

@media (max-width: 375px) {
  .casa-breadcrumbs__list {
    font-size: 11px;
    gap: 3px;
  }

  .casa-breadcrumbs__item {
    gap: 3px;
  }
}
</style>
