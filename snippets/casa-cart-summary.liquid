{% doc %}
  Casa Cart Summary

  Premium order summary panel with glassmorphism styling.
  Maintains all JS integration points for morphing, discount, and checkout.

  @param {string} [section_id] - Section ID for discount component
{% enddoc %}

<div class="casa-cart-summary">
  {%- comment -%} ═══ Section Tag ═══ {%- endcomment -%}
  <span class="casa-cart-summary__tag">ORDER SUMMARY</span>

  {%- comment -%} ═══ Subtotal & Discounts ═══ {%- endcomment -%}
  <div class="casa-cart-summary__totals">
    <div class="cart__original-total-container">
      {%- if cart.cart_level_discount_applications.size > 0 -%}
        <div class="casa-cart-summary__row">
          <span class="casa-cart-summary__label">Subtotal</span>
          <span class="casa-cart-summary__value">{{ cart.original_total_price | money }}</span>
        </div>
        <div class="casa-cart-summary__discounts">
          <ul class="discounts list-unstyled" role="list" aria-label="{{ 'content.discounts' | t }}">
            {%- for discount in cart.cart_level_discount_applications -%}
              <li class="casa-cart-summary__row casa-cart-summary__row--discount">
                <span class="casa-cart-summary__label casa-cart-summary__label--discount">
                  {{- 'icon-discount.svg' | inline_asset_content -}}
                  {{ discount.title | escape }}
                </span>
                <span class="casa-cart-summary__value casa-cart-summary__value--discount">
                  -{{ discount.total_allocated_amount | money }}
                </span>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} ═══ Cart Note & Discount Code ═══ {%- endcomment -%}
  {% if settings.show_cart_note or settings.show_add_discount_code %}
    <div class="casa-cart-summary__actions">
      {% if settings.show_cart_note %}
        <script type="module" src="{{ 'cart-note.js' | asset_url }}"></script>
        <cart-note style="display: flex;">
          <accordion-custom
            class="cart-note casa-cart-summary__accordion"
            {% if settings.cart_note_open_by_default %}
              open-by-default-on-desktop
              open-by-default-on-mobile
            {% endif %}
          >
            <details
              class="details"
              {% if settings.cart_note_open_by_default %}open{% endif %}
            >
              <summary class="casa-cart-summary__accordion-trigger">
                <span class="casa-cart-summary__accordion-label">
                  {%- render 'casa-icon', icon: 'message-circle', size: 14 -%}
                  Add a note
                </span>
                <span class="casa-cart-summary__accordion-icon">
                  {%- render 'casa-icon', icon: 'plus', size: 14 -%}
                </span>
              </summary>
              <div class="details-content casa-cart-summary__accordion-content">
                <label for="cart-note" class="visually-hidden">{{ 'content.seller_note' | t }}</label>
                <textarea
                  form="cart-form"
                  on:input="/updateCartNote"
                  id="cart-note"
                  class="casa-cart-summary__textarea"
                  name="note"
                  placeholder="Add special instructions..."
                >{{ cart.note }}</textarea>
              </div>
            </details>
          </accordion-custom>
        </cart-note>
      {% endif %}

      {% if settings.show_cart_note and settings.show_add_discount_code %}
        <div class="casa-cart-summary__divider"></div>
      {% endif %}

      {% if settings.show_add_discount_code %}
        {%- liquid
          assign discount_codes = cart.cart_level_discount_applications | where: 'type', 'discount_code' | map: 'title'
          for item in cart.items
            for allocation in item.line_level_discount_allocations
              if allocation.discount_application.type == 'discount_code'
                assign discount_codes = item.line_level_discount_allocations | slice: forloop.index0 | map: 'discount_application' | map: 'title' | concat: discount_codes
              endif
            endfor
          endfor
          assign discount_codes = discount_codes | uniq
          if discount_codes.size == 0
            assign disclosure_expanded = false
          else
            assign disclosure_expanded = true
          endif
        -%}

        <accordion-custom class="cart-discount casa-cart-summary__accordion">
          <details class="details" {% if disclosure_expanded %}open{% endif %}>
            <summary class="casa-cart-summary__accordion-trigger">
              <span class="casa-cart-summary__accordion-label">
                {%- render 'casa-icon', icon: 'tag', size: 14 -%}
                Discount code
              </span>
              <span class="casa-cart-summary__accordion-icon">
                {%- render 'casa-icon', icon: 'plus', size: 14 -%}
              </span>
            </summary>
            <div class="details-content">
              <div id="cart-discount-disclosure">
                <cart-discount-component
                  {% if section_id != blank %}data-section-id="{{ section_id }}"{% endif %}
                >
                  <div class="casa-cart-summary__discount-form-wrap">
                    <form on:submit="/applyDiscount" onsubmit="return false;" class="casa-cart-summary__discount-form">
                      <label for="cart-discount" class="visually-hidden">{{ 'accessibility.discount' | t }}</label>
                      <input
                        id="cart-discount"
                        class="casa-cart-summary__discount-input"
                        type="text"
                        name="discount"
                        size="8"
                        placeholder="{{ 'content.discount_code' | t }}"
                        required
                      >
                      <button type="submit" class="casa-cart-summary__discount-btn">
                        {{ 'actions.apply' | t }}
                      </button>
                    </form>
                  </div>
                  <div class="cart-discount__error hidden" role="alert" ref="cartDiscountError">
                    <span class="svg-wrapper">{{ 'icon-error.svg' | inline_asset_content }}</span>
                    <small class="cart-discount__error-text hidden" ref="cartDiscountErrorDiscountCode">
                      {{ 'content.discount_code_error' | t: code: 'test' }}
                    </small>
                    <small class="cart-discount__error-text hidden" ref="cartDiscountErrorShipping">
                      {{ 'content.shipping_discount_error' | t }}
                    </small>
                  </div>
                  <ul class="casa-cart-summary__discount-codes">
                    {% for discount_code in discount_codes %}
                      <li class="casa-cart-summary__discount-pill" data-discount-code="{{ discount_code }}" aria-label="{{ 'accessibility.discount_applied' | t: code: discount_code }}">
                        <p class="casa-cart-summary__discount-pill-code">{{ discount_code }}</p>
                        <button
                          type="button"
                          on:click="/removeDiscount"
                          class="casa-cart-summary__discount-pill-remove svg-wrapper svg-wrapper--smaller button-unstyled"
                          aria-label="{{ 'actions.remove_discount' | t: code: discount_code }}"
                        >
                          {{ 'icon-filters-close.svg' | inline_asset_content }}
                        </button>
                      </li>
                    {% endfor %}
                  </ul>
                </cart-discount-component>
              </div>
            </div>
          </details>
        </accordion-custom>
      {% endif %}
    </div>
  {% endif %}

  {%- comment -%} ═══ Divider ═══ {%- endcomment -%}
  <div class="casa-cart-summary__divider"></div>

  {%- comment -%} ═══ Estimated Total ═══ {%- endcomment -%}
  {%- liquid
    if settings.currency_code_enabled_cart_total
      assign total_price = cart.total_price | money_with_currency
    else
      assign total_price = cart.total_price | money
    endif
  -%}

  <div class="casa-cart-summary__total-wrap{% if settings.show_installments %} casa-cart-summary__total-wrap--installments{% endif %}">
    <span class="casa-cart-summary__row casa-cart-summary__row--total" role="status">
      <span class="casa-cart-summary__label casa-cart-summary__label--total">Estimated Total</span>
      <text-component
        ref="cartTotal"
        value="{{ total_price | strip_html }}"
        class="casa-cart-summary__value casa-cart-summary__value--total"
        data-cart-subtotal
      >
        {{ total_price }}
      </text-component>
    </span>

    {%- comment -%} Total savings {%- endcomment -%}
    {%- if settings.cart_show_savings and cart.total_discount > 0 -%}
      <div class="casa-cart-summary__total-savings">
        You save {{ cart.total_discount | money }}!
      </div>
    {%- endif -%}

    {% if settings.show_installments %}
      <span class="casa-cart-summary__installments">
        {% form 'cart', cart %}
          {{ form | payment_terms }}
        {% endform %}
      </span>
    {% endif %}

    {%- unless settings.cart_hide_tax_shipping_note -%}
      <div class="casa-cart-summary__tax-note">
        {% render 'tax-info', has_discounts_enabled: settings.show_add_discount_code %}
      </div>
    {%- endunless -%}
  </div>

  {%- comment -%} ═══ Delivery Estimate ═══ {%- endcomment -%}
  {%- if settings.cart_show_delivery_estimate -%}
    {%- liquid
      assign processing_days = settings.cart_processing_days | default: 1
      assign shipping_days = settings.cart_shipping_days | default: 3
      assign min_days = processing_days | plus: shipping_days
      assign max_days = min_days | plus: 2

      assign now_seconds = 'now' | date: '%s' | plus: 0
      assign min_seconds = min_days | times: 86400 | plus: now_seconds
      assign max_seconds = max_days | times: 86400 | plus: now_seconds
      assign min_date = min_seconds | date: '%b %-d'
      assign max_date = max_seconds | date: '%b %-d'
    -%}
    <div class="casa-cart-summary__delivery">
      {%- render 'casa-icon', icon: 'package', size: 14 -%}
      <span>Est. delivery: {{ min_date }} – {{ max_date }}</span>
    </div>
  {%- endif -%}

  {%- comment -%} ═══ Checkout Button ═══ {%- endcomment -%}
  <div class="casa-cart-summary__ctas">
    <button
      type="submit"
      id="checkout"
      class="casa-cart-summary__checkout-btn"
      name="checkout"
      {% if cart == empty %}disabled{% endif %}
      form="cart-form"
    >
      <span class="casa-cart-summary__checkout-text">Checkout</span>
    </button>

    {% if additional_checkout_buttons and settings.show_accelerated_checkout_buttons %}
      <div class="additional-checkout-buttons casa-cart-summary__accelerated">
        {{ content_for_additional_checkout_buttons }}
      </div>
    {% endif %}
  </div>

  {%- comment -%} ═══ Trust Signals ═══ {%- endcomment -%}
  {%- render 'casa-cart-trust' -%}

  {%- comment -%} ═══ Payment Icons ═══ {%- endcomment -%}
  {%- if settings.cart_show_payment_icons -%}
    <div class="casa-cart-summary__payment-icons">
      {%- for type in shop.enabled_payment_types -%}
        {{ type | payment_type_svg_tag: class: 'casa-cart-summary__payment-icon' }}
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

{% stylesheet %}
  .casa-cart-summary {
    background: linear-gradient(145deg, var(--cart-bg-secondary, rgba(20, 20, 25, 0.95)), var(--cart-bg, rgba(30, 30, 35, 0.9)));
    backdrop-filter: blur(30px) saturate(180%);
    -webkit-backdrop-filter: blur(30px) saturate(180%);
    border: 1px solid transparent;
    border-radius: var(--casa-radius-xl);
    padding: var(--casa-space-8);
    position: sticky;
    top: calc(var(--header-height, 0px) + 24px);
    animation: casa-summary-enter 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both;
    overflow: hidden;
  }

  /* Premium gradient border */
  .casa-cart-summary::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: var(--casa-radius-xl);
    padding: 1px;
    background: linear-gradient(145deg, rgba(147, 51, 234, 0.4), rgba(236, 72, 153, 0.2), rgba(6, 182, 212, 0.2));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }

  /* Ambient glow */
  .casa-cart-summary::after {
    content: '';
    position: absolute;
    top: -50%;
    right: -50%;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle, rgba(147, 51, 234, 0.08) 0%, transparent 60%);
    pointer-events: none;
  }

  @keyframes casa-summary-enter {
    0% {
      opacity: 0;
      transform: translateX(20px);
    }
    100% {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @media (max-width: 999px) {
    .casa-cart-summary {
      position: static;
      padding: var(--casa-space-6);
      border-radius: var(--casa-radius-lg);
      animation-name: casa-fade-in-up;
    }
  }

  /* ── Tag ── */
  .casa-cart-summary__tag {
    display: block;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--cart-text-muted, var(--casa-text-secondary));
    margin-bottom: var(--casa-space-5);
    font-weight: 500;
  }

  /* ── Rows ── */
  .casa-cart-summary__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--casa-space-1) 0;
  }

  .casa-cart-summary__label {
    font-size: 14px;
    color: var(--cart-text-muted, var(--casa-text-secondary));
  }

  .casa-cart-summary__value {
    font-size: 14px;
    color: var(--cart-text, var(--casa-text-primary));
    font-weight: 600;
  }

  .casa-cart-summary__label--discount {
    display: flex;
    align-items: center;
    gap: var(--casa-space-2);
    color: var(--cart-accent-1, var(--casa-purple));
    font-size: 13px;
  }

  .casa-cart-summary__label--discount svg {
    width: 14px;
    height: 14px;
  }

  .casa-cart-summary__value--discount {
    color: var(--cart-accent-1, var(--casa-purple));
    font-size: 13px;
  }

  .casa-cart-summary__totals {
    margin-bottom: var(--casa-space-2);
  }

  .casa-cart-summary__discounts {
    margin-top: var(--casa-space-1);
  }

  .casa-cart-summary__discounts ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* ── Divider ── */
  .casa-cart-summary__divider {
    height: 1px;
    background: var(--casa-border-subtle);
    margin: var(--casa-space-4) 0;
  }

  /* ── Actions (Note & Discount) ── */
  .casa-cart-summary__actions {
    border-top: 1px solid var(--casa-border-subtle);
    border-bottom: 1px solid var(--casa-border-subtle);
    padding: var(--casa-space-1) 0;
    margin: var(--casa-space-2) 0;
  }

  .casa-cart-summary__accordion {
    width: 100%;
  }

  .casa-cart-summary__accordion-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--casa-space-3) 0;
    cursor: pointer;
    list-style: none;
  }

  .casa-cart-summary__accordion-trigger::-webkit-details-marker {
    display: none;
  }

  .casa-cart-summary__accordion-label {
    display: flex;
    align-items: center;
    gap: var(--casa-space-2);
    font-size: 13px;
    font-weight: 500;
    color: var(--casa-text-secondary);
    transition: color var(--casa-transition-fast);
  }

  .casa-cart-summary__accordion-trigger:hover .casa-cart-summary__accordion-label {
    color: var(--casa-text-primary);
  }

  .casa-cart-summary__accordion-icon {
    display: flex;
    align-items: center;
    color: var(--casa-text-muted);
    transition: transform var(--casa-transition-fast);
  }

  details[open] > .casa-cart-summary__accordion-trigger .casa-cart-summary__accordion-icon {
    transform: rotate(45deg);
  }

  .casa-cart-summary__accordion-content {
    padding-bottom: var(--casa-space-3);
  }

  .casa-cart-summary__textarea {
    width: 100%;
    min-height: 80px;
    background: var(--casa-bg-dark-tertiary);
    border: 1px solid var(--casa-border-subtle);
    border-radius: var(--casa-radius-md);
    color: var(--casa-text-primary);
    font-size: 14px;
    padding: var(--casa-space-3);
    resize: vertical;
    font-family: inherit;
    transition: border-color var(--casa-transition-fast);
  }

  .casa-cart-summary__textarea:focus {
    outline: none;
    border-color: var(--casa-border-medium);
  }

  .casa-cart-summary__textarea::placeholder {
    color: var(--casa-text-muted);
  }

  /* ── Discount form ── */
  .casa-cart-summary__discount-form-wrap {
    padding: var(--casa-space-2) 0 var(--casa-space-3) 0;
  }

  .casa-cart-summary__discount-form {
    display: flex;
    gap: var(--casa-space-2);
  }

  .casa-cart-summary__discount-input {
    flex: 1;
    min-width: 0;
    background: var(--casa-bg-dark-tertiary);
    border: 1px solid var(--casa-border-subtle);
    border-radius: var(--casa-radius-md);
    color: var(--casa-text-primary);
    font-size: 14px;
    padding: var(--casa-space-2) var(--casa-space-3);
    transition: border-color var(--casa-transition-fast);
  }

  .casa-cart-summary__discount-input:focus {
    outline: none;
    border-color: var(--casa-border-medium);
  }

  .casa-cart-summary__discount-input::placeholder {
    color: var(--casa-text-muted);
  }

  .casa-cart-summary__discount-btn {
    background: var(--casa-bg-dark-tertiary);
    border: 1px solid var(--casa-border-subtle);
    border-radius: var(--casa-radius-md);
    color: var(--casa-text-primary);
    font-size: 13px;
    font-weight: 600;
    padding: var(--casa-space-2) var(--casa-space-4);
    cursor: pointer;
    transition: background var(--casa-transition-fast), border-color var(--casa-transition-fast);
    white-space: nowrap;
  }

  .casa-cart-summary__discount-btn:hover {
    background: var(--casa-bg-dark-quaternary);
    border-color: var(--casa-border-medium);
  }

  .casa-cart-summary__discount-codes {
    display: none;
    flex-wrap: wrap;
    gap: var(--casa-space-2);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .casa-cart-summary__discount-codes:has(.casa-cart-summary__discount-pill) {
    display: flex;
  }

  .casa-cart-summary__discount-pill {
    display: flex;
    align-items: center;
    gap: var(--casa-space-2);
    padding: var(--casa-space-1) var(--casa-space-3);
    background: rgba(147, 51, 234, 0.15);
    border: 1px solid rgba(147, 51, 234, 0.3);
    border-radius: var(--casa-radius-full);
    color: var(--casa-purple);
    font-size: 12px;
    text-transform: uppercase;
    font-weight: 600;
  }

  .casa-cart-summary__discount-pill-code {
    margin: 0;
    max-width: 100px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .casa-cart-summary__discount-pill-remove {
    color: var(--casa-purple);
    opacity: 0.6;
    cursor: pointer;
    background: transparent;
    border: none;
    padding: 0;
    display: flex;
    align-items: center;
  }

  .casa-cart-summary__discount-pill-remove:hover {
    opacity: 1;
  }

  /* ── Discount errors (reuse existing styles) ── */
  .casa-cart-summary .cart-discount__error {
    display: flex;
    align-items: center;
    font-size: 13px;
    color: var(--casa-red);
    padding: var(--casa-space-1) 0;
  }

  .casa-cart-summary .cart-discount__error .svg-wrapper {
    flex-shrink: 0;
    width: 14px;
    height: 14px;
    margin-right: var(--casa-space-2);
  }

  /* ── Total ── */
  .casa-cart-summary__total-wrap {
    margin-bottom: var(--casa-space-4);
  }

  .casa-cart-summary__row--total {
    padding: 0;
  }

  .casa-cart-summary__label--total {
    font-size: 14px;
    color: var(--cart-text-muted, var(--casa-text-secondary));
    font-weight: 500;
  }

  .casa-cart-summary__value--total {
    font-size: 24px;
    color: var(--cart-text, var(--casa-text-primary));
    font-weight: 700;
  }

  @media (max-width: 749px) {
    .casa-cart-summary__value--total {
      font-size: 20px;
    }
  }

  .casa-cart-summary__total-savings {
    font-size: 13px;
    color: var(--casa-green);
    font-weight: 600;
    text-align: right;
    margin-top: var(--casa-space-1);
  }

  .casa-cart-summary__installments {
    font-size: 12px;
    color: var(--casa-text-muted);
  }

  .casa-cart-summary__tax-note {
    font-size: 11px;
    color: var(--casa-text-muted);
    margin-top: var(--casa-space-2);
  }

  .casa-cart-summary__tax-note small {
    font-size: 11px;
  }

  /* ── Delivery estimate ── */
  .casa-cart-summary__delivery {
    display: flex;
    align-items: center;
    gap: var(--casa-space-2);
    font-size: 13px;
    color: var(--casa-text-secondary);
    margin-bottom: var(--casa-space-5);
  }

  /* ── Checkout button ── */
  .casa-cart-summary__ctas {
    display: grid;
    gap: var(--casa-space-3);
    grid-template-columns: 1fr;
    width: 100%;
  }

  .casa-cart-summary__checkout-btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--cart-checkout-btn-bg, linear-gradient(135deg, var(--cart-accent-1, var(--casa-purple)), var(--cart-accent-2, var(--casa-pink))));
    color: var(--cart-checkout-btn-text, #fff);
    border: none;
    border-radius: var(--casa-radius-full);
    padding: var(--casa-space-4) var(--casa-space-8);
    font-weight: 700;
    font-size: 15px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: transform var(--casa-transition-smooth), box-shadow var(--casa-transition-smooth);
  }

  .casa-cart-summary__checkout-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.2), transparent 50%);
    pointer-events: none;
  }

  .casa-cart-summary__checkout-btn::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
    transition: left 0.5s ease;
  }

  .casa-cart-summary__checkout-btn:hover {
    transform: translateY(-3px) scale(1.02);
    box-shadow: 0 10px 30px rgba(147, 51, 234, 0.4), 0 0 50px rgba(236, 72, 153, 0.2);
  }

  .casa-cart-summary__checkout-btn:hover::after {
    left: 100%;
  }

  .casa-cart-summary__checkout-btn:active {
    transform: translateY(-1px) scale(0.98);
  }

  .casa-cart-summary__checkout-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }

  .casa-cart-summary__checkout-btn:disabled::after {
    display: none;
  }

  .casa-cart-summary__accelerated {
    width: 100%;
  }

  /* Accelerated checkout styling */
  .casa-cart-summary shopify-accelerated-checkout-cart {
    --shopify-accelerated-checkout-inline-alignment: center;
    --shopify-accelerated-checkout-button-border-radius: var(--casa-radius-full);
  }

  /* Hide all accelerated checkout buttons except Shop Pay */
  .casa-cart-summary__accelerated .dynamic-checkout__content > *:not([data-testid="ShopPay-button"]):not(:has([aria-label*="Shop Pay"])):not(:first-child) {
    display: none !important;
  }
  /* Fallback: hide by known brand container classes */
  .casa-cart-summary__accelerated [data-testid="GooglePay-button"],
  .casa-cart-summary__accelerated [data-testid="PayPal-button"],
  .casa-cart-summary__accelerated [data-testid="AmazonPay-button"] {
    display: none !important;
  }

  /* ── Payment icons ── */
  .casa-cart-summary__payment-icons {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--casa-space-2);
    flex-wrap: wrap;
    margin-top: var(--casa-space-5);
    padding-top: var(--casa-space-4);
    border-top: 1px solid var(--casa-border-subtle);
  }

  .casa-cart-summary__payment-icon {
    width: 36px;
    height: 24px;
    opacity: 0.4;
    transition: opacity var(--casa-transition-fast);
    filter: grayscale(1) brightness(1.5);
  }

  .casa-cart-summary__payment-icon:hover {
    opacity: 1;
    filter: none;
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .casa-cart-summary {
      animation: none;
    }
    .casa-cart-summary__checkout-btn {
      transition: none;
    }
  }
{% endstylesheet %}
