{%- comment -%}
  Seoul Glow Lab - Submenu Panel (Slide-from-right nested panel)
  Usage: {% render 'sgl-submenu-panel', link: link, panel_id: 'infinity-mirrors' %}
  Params:
    - link: parent nav link object (with .links children)
    - panel_id: unique string for the panel ID
{%- endcomment -%}

{%- comment -%} Try link.object first (auto-resolved by Shopify), then fallback to handle lookup {%- endcomment -%}
{%- liquid
  assign panel_collection = nil
  if link.type == 'collection_link'
    assign panel_collection = link.object
  endif
  if panel_collection == blank
    assign panel_collection = collections[link.handle]
  endif
-%}

{%- comment -%} ── Variant detection (same logic as mega menu) ── {%- endcomment -%}
{%- liquid
  assign submenu_variant = 'glow'
  assign _title_handle = link.title | downcase | handle

  case _title_handle
    when 'lighting', 'mirrors', 'shop', 'shop-all', 'infinity-mirrors', 'lamps', 'best-sellers'
      assign submenu_variant = 'glow'
    when 'home-decor', 'new-arrivals', 'collections', 'decor', 'furniture', 'inspiration'
      assign submenu_variant = 'lifestyle'
    when 'customer-care', 'customer-service', 'support', 'help', 'faq', 'contact', 'about'
      assign submenu_variant = 'support'
  endcase

  if panel_collection and panel_collection.metafields.sgl.menu_style != blank
    assign submenu_variant = panel_collection.metafields.sgl.menu_style
  endif
-%}

<div class="sgl-submenu-panel sgl-submenu-panel--{{ submenu_variant }}{% if drawer_glassmorphic %} sgl-submenu-panel--glass{% endif %}" id="sgl-submenu-{{ panel_id }}" role="dialog" aria-modal="true" aria-label="{{ link.title }} submenu">

  {%- comment -%} Header with back button {%- endcomment -%}
  <div class="sgl-submenu__header">
    <button class="sgl-submenu-back" data-sgl-submenu-close="{{ panel_id }}" aria-label="Back to main menu">
      {%- render 'sgl-icon', icon: 'chevron-left', size: 20 -%}
    </button>
    <div class="sgl-submenu__title-group">
      <span class="sgl-submenu__label">Browse</span>
      <h3 class="sgl-submenu__title">{{ link.title }}</h3>
    </div>
  </div>

  {%- comment -%} Scrollable content {%- endcomment -%}
  <div class="sgl-submenu__content">

    {%- comment -%} Featured banner with mirror visual {%- endcomment -%}
    <div class="sgl-submenu__featured-img">
      {%- if panel_collection.image != blank -%}
        {{ panel_collection.image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'sgl-submenu__featured-photo' }}
      {%- else -%}
        <div class="sgl-submenu__mirror">
          {%- render 'sgl-infinity-mirror', size: 'md', animate: true, shape: 'octagon' -%}
        </div>
      {%- endif -%}
      <span class="sgl-submenu__featured-badge">{{ link.title }}</span>
    </div>

    {%- comment -%} Product or subcategory list {%- endcomment -%}
    {%- assign _has_products = false -%}
    {%- if panel_collection and panel_collection.products.size > 0 -%}
      {%- assign _has_products = true -%}
    {%- endif -%}

    <div class="sgl-submenu__section-title">
      {%- if _has_products -%}
        Popular in {{ link.title }}
      {%- elsif link.links.size > 0 -%}
        Browse {{ link.title }}
      {%- else -%}
        {{ link.title }}
      {%- endif -%}
    </div>

    <div class="sgl-submenu__list">
      {%- if _has_products -%}
        {%- comment -%} Show products from this collection {%- endcomment -%}
        {%- assign _product_limit = submenu_product_limit | default: 6 -%}
        {%- for product in panel_collection.products limit: _product_limit -%}
          <a href="{{ product.url }}" class="sgl-submenu__item">
            <div class="sgl-submenu__item-img">
              {%- if product.featured_image != blank -%}
                {{ product.featured_image | image_url: width: 112 | image_tag: loading: 'lazy', class: 'sgl-submenu__item-photo' }}
              {%- else -%}
                <div class="sgl-submenu__item-shape sgl-octagon" style="width:32px;height:32px;background:conic-gradient(from var(--angle),var(--submenu-accent-1),var(--submenu-accent-2),var(--submenu-accent-1));animation:sgl-rotate 8s linear infinite;"></div>
              {%- endif -%}
            </div>
            <div class="sgl-submenu__item-content">
              <span class="sgl-submenu__item-name">{{ product.title }}</span>
              <div class="sgl-submenu__item-meta">
                <span class="sgl-submenu__item-price">{{ product.price | money }}</span>
                {%- if product.compare_at_price > product.price -%}
                  <span class="sgl-submenu__item-price-old">{{ product.compare_at_price | money }}</span>
                {%- endif -%}
                {%- if product.tags contains 'bestseller' -%}
                  <span class="sgl-submenu__item-badge sgl-submenu__item-badge--bestseller">Bestseller</span>
                {%- elsif product.tags contains 'new' -%}
                  <span class="sgl-submenu__item-badge sgl-submenu__item-badge--new">New</span>
                {%- endif -%}
              </div>
            </div>
            <div class="sgl-submenu__item-arrow">
              {%- render 'sgl-icon', icon: 'chevron-right', size: 16 -%}
            </div>
          </a>
        {%- endfor -%}
      {%- elsif link.links.size > 0 -%}
        {%- comment -%} Show child links as subcategories {%- endcomment -%}
        {%- for child_link in link.links -%}
          <a href="{{ child_link.url }}" class="sgl-submenu__item">
            <div class="sgl-submenu__item-img">
              <div class="sgl-submenu__item-icon">
                {%- render 'sgl-icon', icon: 'chevron-right', size: 20 -%}
              </div>
            </div>
            <div class="sgl-submenu__item-content">
              <span class="sgl-submenu__item-name">{{ child_link.title }}</span>
              {%- assign _child_collection = collections[child_link.handle] -%}
              {%- if _child_collection != blank -%}
                {%- assign _child_count = _child_collection.products_count | plus: 0 -%}
                {%- if _child_count > 0 -%}
                  <span class="sgl-submenu__item-count">{{ _child_count }} items</span>
                {%- endif -%}
              {%- endif -%}
            </div>
            <div class="sgl-submenu__item-arrow">
              {%- render 'sgl-icon', icon: 'chevron-right', size: 16 -%}
            </div>
          </a>
        {%- endfor -%}
      {%- else -%}
        {%- comment -%} No products and no child links - show empty state {%- endcomment -%}
        <div class="sgl-submenu__empty">
          <div class="sgl-submenu__empty-icon">
            {%- render 'sgl-icon', icon: 'sparkles', size: 24 -%}
          </div>
          <p class="sgl-submenu__empty-text">Coming soon!</p>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} View All CTA {%- endcomment -%}
    <a href="{{ link.url | default: '#' }}" class="sgl-submenu__view-all">
      View All {{ link.title }}
      {%- render 'sgl-icon', icon: 'arrow-right', size: 16 -%}
    </a>
  </div>
</div>

{% stylesheet %}
  /* ═══════════════════════════════════════════════════════
     SUBMENU VARIANT COLOR SYSTEM
     Colors inherited from parent .sgl-header-section CSS vars
     ═══════════════════════════════════════════════════════ */

  /* ── Glow (default): Purple + Pink ── */
  .sgl-submenu-panel--glow {
    --submenu-accent-1: var(--sgl-glow-primary, #B0C3FA);
    --submenu-accent-2: var(--sgl-glow-secondary, #EA7940);
    --submenu-accent-1-rgb: var(--sgl-glow-primary-rgb, 147, 51, 234);
    --submenu-accent-2-rgb: var(--sgl-glow-secondary-rgb, 236, 72, 153);
    --submenu-glow: rgba(var(--sgl-glow-primary-rgb, 147, 51, 234), 0.12);
    --submenu-banner-bg: linear-gradient(135deg, #1a1a2e, #2d1b4e);
    --submenu-banner-glow-1: rgba(var(--sgl-glow-primary-rgb, 147, 51, 234), 0.4);
    --submenu-banner-glow-2: rgba(var(--sgl-glow-secondary-rgb, 236, 72, 153), 0.3);
  }

  /* ── Lifestyle: Gold + Amber ── */
  .sgl-submenu-panel--lifestyle {
    --submenu-accent-1: var(--sgl-lifestyle-primary, #F2FFA0);
    --submenu-accent-2: var(--sgl-lifestyle-secondary, #d97706);
    --submenu-accent-1-rgb: var(--sgl-lifestyle-primary-rgb, 245, 158, 11);
    --submenu-accent-2-rgb: var(--sgl-lifestyle-secondary-rgb, 217, 119, 6);
    --submenu-glow: rgba(var(--sgl-lifestyle-primary-rgb, 245, 158, 11), 0.1);
    --submenu-banner-bg: linear-gradient(135deg, #1a1a18, #2d2a1b);
    --submenu-banner-glow-1: rgba(var(--sgl-lifestyle-primary-rgb, 245, 158, 11), 0.35);
    --submenu-banner-glow-2: rgba(var(--sgl-lifestyle-secondary-rgb, 217, 119, 6), 0.25);
  }

  /* ── Support: Teal + Cyan ── */
  .sgl-submenu-panel--support {
    --submenu-accent-1: var(--sgl-support-primary, #FFBF9F);
    --submenu-accent-2: var(--sgl-support-secondary, #0891b2);
    --submenu-accent-1-rgb: var(--sgl-support-primary-rgb, 6, 182, 212);
    --submenu-accent-2-rgb: var(--sgl-support-secondary-rgb, 8, 145, 178);
    --submenu-glow: rgba(var(--sgl-support-primary-rgb, 6, 182, 212), 0.1);
    --submenu-banner-bg: linear-gradient(135deg, #0f1a1a, #1b2d2d);
    --submenu-banner-glow-1: rgba(var(--sgl-support-primary-rgb, 6, 182, 212), 0.35);
    --submenu-banner-glow-2: rgba(var(--sgl-support-secondary-rgb, 8, 145, 178), 0.25);
  }

  /* ═══════════════════════════════════════════════════════
     SUBMENU PANEL STYLES
     ═══════════════════════════════════════════════════════ */

  /* ── Submenu Panel ── */
  .sgl-submenu-panel {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    max-width: 340px;
    height: 100%;
    background: linear-gradient(180deg, color-mix(in srgb, var(--sgl-drawer-bg, #F8EBDA) 100%, white 5%) 0%, var(--sgl-drawer-bg, #F8EBDA) 100%);
    z-index: 1300;
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1), visibility 0s 0.35s;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    color: white;
    visibility: hidden;
    pointer-events: none;
  }
  .sgl-submenu-panel.active {
    transform: translateX(0);
    visibility: visible;
    pointer-events: auto;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1), visibility 0s 0s;
  }

  /* Ambient glow - uses variant accent color */
  .sgl-submenu-panel::before {
    content: '';
    position: absolute;
    top: 100px;
    right: 0;
    width: 200px;
    height: 400px;
    background: radial-gradient(ellipse, var(--submenu-glow, rgba(147, 51, 234, 0.12)) 0%, transparent 70%);
    pointer-events: none;
  }

  /* ── Header ── */
  .sgl-submenu__header {
    padding: 16px 20px;
    display: flex;
    align-items: center;
    gap: 12px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    position: relative;
    z-index: 1;
  }
  .sgl-submenu-back {
    width: 40px;
    height: 40px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s;
    color: white;
    flex-shrink: 0;
  }
  .sgl-submenu-back:active { background: rgba(255, 255, 255, 0.1); }
  .sgl-submenu__title-group { flex: 1; }
  .sgl-submenu__label {
    font-size: 10px;
    color: rgba(255, 255, 255, 0.4);
    text-transform: uppercase;
    letter-spacing: 1px;
    display: block;
  }
  .sgl-submenu__title {
    font-size: 18px;
    font-weight: 600;
    margin: 0;
  }

  /* ── Content (scrollable) ── */
  .sgl-submenu__content {
    flex: 1;
    overflow-y: auto;
    padding: 16px 0;
    position: relative;
    z-index: 1;
  }

  /* ── Featured Banner ── */
  .sgl-submenu__featured-img {
    margin: 0 16px 20px;
    height: 140px;
    border-radius: 16px;
    background: var(--submenu-banner-bg, linear-gradient(135deg, #1a1a2e, #2d1b4e));
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .sgl-submenu__featured-img::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 30% 50%, var(--submenu-banner-glow-1, rgba(147, 51, 234, 0.4)), transparent 60%);
  }
  .sgl-submenu__featured-img::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 70% 50%, var(--submenu-banner-glow-2, rgba(236, 72, 153, 0.3)), transparent 60%);
  }
  .sgl-submenu__featured-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 16px;
    position: relative;
    z-index: 1;
  }
  .sgl-submenu__mirror {
    position: relative;
    z-index: 1;
  }
  .sgl-submenu__featured-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    font-size: 9px;
    font-weight: 600;
    padding: 6px 12px;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    z-index: 2;
    color: white;
  }

  /* ── Section Title ── */
  .sgl-submenu__section-title {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: rgba(255, 255, 255, 0.3);
    padding: 8px 20px;
  }

  /* ── Item List ── */
  .sgl-submenu__list { padding: 0 12px; }
  .sgl-submenu__item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 12px;
    border-radius: 12px;
    text-decoration: none;
    color: white;
    transition: all 0.2s;
  }
  .sgl-submenu__item:active {
    background: rgba(255, 255, 255, 0.05);
  }
  .sgl-submenu__item-img {
    width: 56px;
    height: 56px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.03);
  }
  .sgl-submenu__item-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 12px;
  }
  .sgl-submenu__item-content { flex: 1; }
  .sgl-submenu__item-name { font-size: 14px; font-weight: 500; display: block; margin-bottom: 2px; }
  .sgl-submenu__item-meta { display: flex; align-items: center; gap: 8px; }
  .sgl-submenu__item-price { font-size: 13px; font-weight: 600; color: white; }
  .sgl-submenu__item-price-old { font-size: 11px; color: rgba(255, 255, 255, 0.4); text-decoration: line-through; }
  .sgl-submenu__item-badge {
    font-size: 8px;
    font-weight: 600;
    padding: 3px 6px;
    border-radius: 10px;
    text-transform: uppercase;
    color: white;
  }
  .sgl-submenu__item-badge--bestseller { background: var(--submenu-accent-1, #B0C3FA); }
  .sgl-submenu__item-badge--new { background: var(--sgl-green, #1B4900); }
  .sgl-submenu__item-badge--sale { background: var(--sgl-red, #5E0A02); }
  .sgl-submenu__item-arrow {
    color: rgba(255, 255, 255, 0.3);
    flex-shrink: 0;
  }

  /* ── Child Link Items ── */
  .sgl-submenu__item-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: linear-gradient(135deg, rgba(var(--submenu-accent-1-rgb, 147, 51, 234), 0.15), rgba(var(--submenu-accent-2-rgb, 236, 72, 153), 0.1));
    border: 1px solid rgba(var(--submenu-accent-1-rgb, 147, 51, 234), 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--submenu-accent-1, #B0C3FA);
  }
  .sgl-submenu__item-count {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.4);
    display: block;
    margin-top: 2px;
  }

  /* ── Empty State ── */
  .sgl-submenu__empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
    text-align: center;
  }
  .sgl-submenu__empty-icon {
    width: 56px;
    height: 56px;
    border-radius: 16px;
    background: linear-gradient(135deg, rgba(var(--submenu-accent-1-rgb, 147, 51, 234), 0.15), rgba(var(--submenu-accent-2-rgb, 236, 72, 153), 0.1));
    border: 1px solid rgba(var(--submenu-accent-1-rgb, 147, 51, 234), 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--submenu-accent-1, #B0C3FA);
    margin-bottom: 16px;
  }
  .sgl-submenu__empty-text {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.5);
    margin: 0;
  }

  /* ── View All CTA ── */
  .sgl-submenu__view-all {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin: 16px;
    padding: 14px;
    background: linear-gradient(135deg, var(--submenu-accent-1, #B0C3FA), var(--submenu-accent-2, #EA7940));
    border-radius: 12px;
    color: white;
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    transition: all 0.3s;
    box-shadow: 0 4px 16px rgba(var(--submenu-accent-1-rgb, 147, 51, 234), 0.3);
  }
  .sgl-submenu__view-all:active {
    transform: scale(0.98);
  }

  /* ═══════════════════════════════════════════════════════
     RESPONSIVE: VERY SMALL MOBILE (375px and below)
     ═══════════════════════════════════════════════════════ */
  @media (max-width: 375px) {
    .sgl-submenu__header {
      padding: 16px;
    }

    .sgl-submenu__back {
      width: 36px;
      height: 36px;
      border-radius: 10px;
    }

    .sgl-submenu__title {
      font-size: 14px;
    }

    .sgl-submenu__close {
      width: 36px;
      height: 36px;
      border-radius: 10px;
    }

    .sgl-submenu__categories {
      padding: 12px;
      gap: 6px;
    }

    .sgl-submenu__cat-item {
      padding: 10px 12px;
      gap: 10px;
      border-radius: 10px;
    }

    .sgl-submenu__cat-icon {
      width: 34px;
      height: 34px;
      border-radius: 8px;
    }

    .sgl-submenu__cat-name {
      font-size: 13px;
    }

    .sgl-submenu__cat-count {
      font-size: 11px;
    }

    .sgl-submenu__products-title {
      padding: 10px 16px;
      font-size: 9px;
    }

    .sgl-submenu__products-grid {
      padding: 12px;
      gap: 10px;
    }

    .sgl-submenu__product-card {
      padding: 10px;
      border-radius: 10px;
    }

    .sgl-submenu__product-img {
      border-radius: 8px;
      margin-bottom: 8px;
    }

    .sgl-submenu__product-name {
      font-size: 12px;
    }

    .sgl-submenu__product-price {
      font-size: 12px;
    }

    .sgl-submenu__view-all {
      margin: 12px;
      padding: 12px;
      font-size: 13px;
      border-radius: 10px;
    }
  }

  /* ═══════════════════════════════════════════════════════
     RESPONSIVE: EXTRA SMALL MOBILE (320px and below)
     ═══════════════════════════════════════════════════════ */
  @media (max-width: 320px) {
    .sgl-submenu__header {
      padding: 12px;
    }

    .sgl-submenu__back,
    .sgl-submenu__close {
      width: 32px;
      height: 32px;
    }

    .sgl-submenu__title {
      font-size: 13px;
    }

    .sgl-submenu__categories {
      padding: 10px;
    }

    .sgl-submenu__cat-item {
      padding: 8px 10px;
    }

    .sgl-submenu__cat-icon {
      width: 30px;
      height: 30px;
    }

    .sgl-submenu__cat-name {
      font-size: 12px;
    }

    .sgl-submenu__products-grid {
      padding: 10px;
      gap: 8px;
    }

    .sgl-submenu__product-card {
      padding: 8px;
    }

    .sgl-submenu__product-name {
      font-size: 11px;
    }

    .sgl-submenu__view-all {
      margin: 10px;
      padding: 10px;
      font-size: 12px;
    }
  }

  /* ═══════════════════════════════════════════════════════
     GLASSMORPHIC SUBMENU PANEL
     Inherits --sgl-glass-* variables from :root
     Overrides every white-based color in the base panel.
     ═══════════════════════════════════════════════════════ */

  /* ── Panel background & base color ── */
  .sgl-submenu-panel--glass {
    background: rgba(var(--sgl-glass-tint-rgb), var(--sgl-glass-opacity));
    backdrop-filter: blur(var(--sgl-glass-blur)) saturate(180%);
    -webkit-backdrop-filter: blur(var(--sgl-glass-blur)) saturate(180%);
    color: var(--sgl-glass-text);
  }
  .sgl-submenu-panel--glass::before,
  .sgl-submenu-panel--glass::after { display: none; }

  /* ── Header ── */
  .sgl-submenu-panel--glass .sgl-submenu__header {
    border-bottom-color: rgba(var(--sgl-glass-border-rgb), 0.25);
  }
  .sgl-submenu-panel--glass .sgl-submenu-back {
    background: rgba(var(--sgl-glass-icon-bg-rgb), 0.35);
    border-color: rgba(var(--sgl-glass-border-rgb), 0.3);
    color: var(--sgl-glass-text);
  }
  .sgl-submenu-panel--glass .sgl-submenu-back:active {
    background: rgba(var(--sgl-glass-icon-bg-rgb), 0.55);
  }
  .sgl-submenu-panel--glass .sgl-submenu__title {
    color: var(--sgl-glass-text);
  }
  .sgl-submenu-panel--glass .sgl-submenu__label {
    color: var(--sgl-glass-text-muted);
  }

  /* ── Section title ("POPULAR IN LIGHTING") ── */
  .sgl-submenu-panel--glass .sgl-submenu__section-title {
    color: var(--sgl-glass-text-muted);
  }

  /* ── Item rows (product items & child links) ── */
  .sgl-submenu-panel--glass .sgl-submenu__item {
    color: var(--sgl-glass-text);
  }
  .sgl-submenu-panel--glass .sgl-submenu__item:active {
    background: rgba(var(--sgl-glass-icon-bg-rgb), 0.3);
  }
  .sgl-submenu-panel--glass .sgl-submenu__item-img {
    background: rgba(var(--sgl-glass-card-bg-rgb), 0.5);
  }
  .sgl-submenu-panel--glass .sgl-submenu__item-name {
    color: var(--sgl-glass-text);
  }
  .sgl-submenu-panel--glass .sgl-submenu__item-price {
    color: var(--sgl-glass-text);
  }
  .sgl-submenu-panel--glass .sgl-submenu__item-price-old {
    color: var(--sgl-glass-text-muted);
  }
  .sgl-submenu-panel--glass .sgl-submenu__item-count {
    color: var(--sgl-glass-text-muted);
  }
  .sgl-submenu-panel--glass .sgl-submenu__item-arrow {
    color: var(--sgl-glass-text-muted);
  }

  /* ── Child link icon circles ── */
  .sgl-submenu-panel--glass .sgl-submenu__item-icon {
    background: rgba(var(--sgl-glass-icon-bg-rgb), 0.4);
