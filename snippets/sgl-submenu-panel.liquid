  }
  .sgl-submenu-panel--glass .sgl-submenu__featured-img::before,
  .sgl-submenu-panel--glass .sgl-submenu__featured-img::after {
    display: none;
  }
  .sgl-submenu-panel--glass .sgl-submenu__featured-badge {
    background: rgba(var(--sgl-glass-text-rgb), 0.6);
