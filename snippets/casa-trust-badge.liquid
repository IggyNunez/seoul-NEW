{%- doc -%}
  Seoul Glow Lab Trust Badge

  @param icon {string} - Required. Icon name from casa-icon
  @param title {string} - Required. Badge title text
  @param subtitle {string} - Optional. Badge subtitle text
  @param variant {string} - Optional. Variant: 'inline' (default), 'stacked', 'footer'
{%- enddoc -%}

{%- liquid
  assign _icon = icon | default: 'shield'
  assign _title = title | default: ''
  assign _subtitle = subtitle | default: ''
  assign _variant = variant | default: 'inline'
-%}

<div class="casa-trust-badge casa-trust-badge--{{ _variant }}">
  <div class="casa-trust-badge__icon">
    {%- render 'casa-icon', icon: _icon, size: 24 -%}
  </div>
  <div class="casa-trust-badge__text">
    {%- if _title != blank -%}
      <strong class="casa-trust-badge__title">{{ _title }}</strong>
    {%- endif -%}
    {%- if _subtitle != blank -%}
      <span class="casa-trust-badge__subtitle">{{ _subtitle }}</span>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
.casa-trust-badge {
  display: flex;
  align-items: center;
  gap: 12px;
}

.casa-trust-badge__icon {
  flex-shrink: 0;
}

.casa-trust-badge__icon svg {
  stroke: var(--footer-trust-icon, #9333ea);
}

.casa-trust-badge__text {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.casa-trust-badge__title {
  font-size: 14px;
  font-weight: 600;
  color: var(--footer-trust-text, var(--footer-text, #ffffff));
}

.casa-trust-badge__subtitle {
  font-size: 12px;
  color: var(--footer-muted, rgba(255, 255, 255, 0.5));
}

/* Inline variant (trust bar) */
.casa-trust-badge--inline {
  color: rgba(255, 255, 255, 0.8);
  font-size: 14px;
}

.casa-trust-badge--inline .casa-trust-badge__text {
  flex-direction: row;
  gap: 0;
}

.casa-trust-badge--inline .casa-trust-badge__title {
  font-weight: 400;
}

.casa-trust-badge--inline .casa-trust-badge__subtitle {
  display: none;
}

/* Stacked variant */
.casa-trust-badge--stacked {
  flex-direction: column;
  text-align: center;
  gap: 8px;
}

.casa-trust-badge--stacked .casa-trust-badge__icon {
  width: 48px;
  height: 48px;
  border-radius: 12px;
  background: var(--footer-trust-icon-bg, linear-gradient(135deg, rgba(147, 51, 234, 0.2), rgba(236, 72, 153, 0.2)));
  display: flex;
  align-items: center;
  justify-content: center;
}

.casa-trust-badge--stacked .casa-trust-badge__text {
  align-items: center;
}

/* Footer variant */
.casa-trust-badge--footer {
  gap: 12px;
}

.casa-trust-badge--footer .casa-trust-badge__icon {
  width: 48px;
  height: 48px;
  border-radius: 12px;
  background: var(--footer-trust-icon-bg, linear-gradient(135deg, rgba(147, 51, 234, 0.2), rgba(236, 72, 153, 0.2)));
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.casa-trust-badge--footer .casa-trust-badge__title {
  display: block;
  font-size: 14px;
  color: #ffffff;
}

.casa-trust-badge--footer .casa-trust-badge__subtitle {
  display: block;
  font-size: 12px;
  color: rgba(255, 255, 255, 0.5);
}
{% endstylesheet %}
