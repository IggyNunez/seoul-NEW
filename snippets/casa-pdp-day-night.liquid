{%- comment -%}
  Casa PDP Day/Night Showcase
  Split section showing product in day mode (mirror) and night mode (portal/LED)
{%- endcomment -%}

<div class="casa-day-night">
  {%- comment -%} Day Side {%- endcomment -%}
  <div class="casa-day-night__panel casa-day-night__panel--day">
    <div class="casa-day-night__content">
      <div class="casa-day-night__image-wrapper casa-day-night__image-wrapper--day">
        {%- if block.settings.day_image != blank -%}
          <img
            src="{{ block.settings.day_image | image_url: width: 400 }}"
            alt="{{ block.settings.day_title | escape }}"
            class="casa-day-night__image"
            loading="lazy"
            width="200"
            height="200"
          >
        {%- else -%}
          <div class="casa-day-night__placeholder casa-day-night__placeholder--day"></div>
        {%- endif -%}
      </div>
      <h3 class="casa-day-night__title">{{ block.settings.day_title | default: 'Mirror by Day' }}</h3>
      <p class="casa-day-night__subtitle">{{ block.settings.day_subtitle | default: 'A perfect, functional reflection' }}</p>
    </div>
  </div>

  {%- comment -%} Night Side {%- endcomment -%}
  <div class="casa-day-night__panel casa-day-night__panel--night">
    <div class="casa-day-night__content">
      <div class="casa-day-night__image-wrapper casa-day-night__image-wrapper--night">
        {%- if block.settings.night_image != blank -%}
          <img
            src="{{ block.settings.night_image | image_url: width: 400 }}"
            alt="{{ block.settings.night_title | escape }}"
            class="casa-day-night__image"
            loading="lazy"
            width="200"
            height="200"
          >
        {%- else -%}
          <div class="casa-day-night__placeholder casa-day-night__placeholder--night"></div>
        {%- endif -%}
      </div>
      <h3 class="casa-day-night__title">{{ block.settings.night_title | default: 'Portal by Night' }}</h3>
      <p class="casa-day-night__subtitle">{{ block.settings.night_subtitle | default: 'An infinite, mesmerizing dimension' }}</p>
    </div>
  </div>
</div>

<style>
.casa-day-night {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 400px;
}

.casa-day-night__panel {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60px 40px;
}

.casa-day-night__panel--day {
  background: #f8f9fa;
}

.casa-day-night__panel--night {
  background: #0a0a0f;
}

.casa-day-night__content {
  text-align: center;
  max-width: 300px;
}

.casa-day-night__image-wrapper {
  width: 160px;
  height: 160px;
  margin: 0 auto 24px;
  border-radius: 50%;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.casa-day-night__image-wrapper--day {
  background: linear-gradient(145deg, #e6e6e6, #ffffff);
  box-shadow:
    8px 8px 16px rgba(0, 0, 0, 0.1),
    -8px -8px 16px rgba(255, 255, 255, 0.9);
}

.casa-day-night__image-wrapper--night {
  background: #0a0a0f;
  box-shadow:
    0 0 60px rgba(147, 51, 234, 0.4),
    0 0 100px rgba(147, 51, 234, 0.2),
    inset 0 0 30px rgba(147, 51, 234, 0.3);
}

.casa-day-night__placeholder {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.casa-day-night__placeholder--day {
  background: linear-gradient(145deg, #d1d1d1, #e8e8e8);
}

.casa-day-night__placeholder--night {
  background: #0a0a0f;
  box-shadow: inset 0 0 40px rgba(147, 51, 234, 0.5);
}

.casa-day-night__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.casa-day-night__title {
  font-size: 24px;
  font-weight: 600;
  margin: 0 0 8px 0;
  line-height: 1.2;
}

.casa-day-night__panel--day .casa-day-night__title {
  color: #0a0a0a;
}

.casa-day-night__panel--night .casa-day-night__title {
  color: #ffffff;
}

.casa-day-night__subtitle {
  font-size: 14px;
  margin: 0;
  line-height: 1.5;
}

.casa-day-night__panel--day .casa-day-night__subtitle {
  color: rgba(0, 0, 0, 0.6);
}

.casa-day-night__panel--night .casa-day-night__subtitle {
  color: rgba(255, 255, 255, 0.6);
}

@media (max-width: 768px) {
  .casa-day-night {
    grid-template-columns: 1fr;
  }

  .casa-day-night__panel {
    padding: 48px 24px;
    min-height: 280px;
  }

  .casa-day-night__image-wrapper {
    width: 120px;
    height: 120px;
    margin-bottom: 20px;
  }

  .casa-day-night__title {
    font-size: 20px;
  }

  .casa-day-night__subtitle {
    font-size: 13px;
  }
}

@media (max-width: 480px) {
  .casa-day-night__panel {
    padding: 40px 20px;
    min-height: 240px;
  }

  .casa-day-night__image-wrapper {
    width: 100px;
    height: 100px;
  }

  .casa-day-night__title {
    font-size: 18px;
  }
}
</style>
