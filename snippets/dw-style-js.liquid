<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.querySelector('[data-section-id="{{ section.id }}"]');
    if (!section) return;

    // Quantity controls
    const qtyInput = section.querySelector('[data-quantity]');
    const decreaseBtn = section.querySelector('[data-qty-decrease]');
    const increaseBtn = section.querySelector('[data-qty-increase]');

    if (decreaseBtn && increaseBtn && qtyInput) {
      decreaseBtn.addEventListener('click', () => {
        const current = parseInt(qtyInput.value) || 1;
        if (current > 1) qtyInput.value = current - 1;
      });

      increaseBtn.addEventListener('click', () => {
        const current = parseInt(qtyInput.value) || 1;
        const max = parseInt(qtyInput.max) || 99;
        if (current < max) qtyInput.value = current + 1;
      });
    }

    // Thumbnail Navigation
    const thumbTrack = section.querySelector('[data-thumbnails-track]');
    const thumbPrev = section.querySelector('[data-thumb-prev]');
    const thumbNext = section.querySelector('[data-thumb-next]');

    if (thumbTrack && thumbPrev && thumbNext) {
      const scrollAmount = 250; // pixels to scroll
      
      const updateThumbNavState = () => {
        const { scrollLeft, scrollWidth, clientWidth } = thumbTrack;
        thumbPrev.disabled = scrollLeft <= 0;
        thumbNext.disabled = scrollLeft >= scrollWidth - clientWidth - 5;
      };
      
      thumbPrev.addEventListener('click', () => {
        thumbTrack.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
      });
      
      thumbNext.addEventListener('click', () => {
        thumbTrack.scrollBy({ left: scrollAmount, behavior: 'smooth' });
      });
      
      thumbTrack.addEventListener('scroll', updateThumbNavState);
      
      // Initial state
      updateThumbNavState();
    }

    // Subscription toggle
    const subOptions = section.querySelectorAll('.dw-product__sub-option');
    const frequencySelector = section.querySelector('[data-frequency-selector]');

    subOptions.forEach(option => {
      option.addEventListener('click', function() {
        subOptions.forEach(o => o.classList.remove('dw-product__sub-option--active'));
        this.classList.add('dw-product__sub-option--active');

        if (frequencySelector) {
          if (this.dataset.purchaseType === 'subscription') {
            frequencySelector.style.display = 'flex';
          } else {
            frequencySelector.style.display = 'none';
          }
        }
      });
    });

    // Subscription Tiers Selection (IM8 style)
    const subscriptionTiers = section.querySelectorAll('[data-subscription-tier]');
    const sellingPlanInput = section.querySelector('input[name="selling_plan"]') || 
                              (() => {
                                const input = document.createElement('input');
                                input.type = 'hidden';
                                input.name = 'selling_plan';
                                const form = section.querySelector('form');
                                if (form) form.appendChild(input);
                                return input;
                              })();

    subscriptionTiers.forEach(tier => {
      tier.addEventListener('click', function() {
        // Remove selection from all tiers
        subscriptionTiers.forEach(t => t.classList.remove('dw-product__sub-tier--selected'));
        
        // Add selection to clicked tier
        this.classList.add('dw-product__sub-tier--selected');
        
        // Update selling plan input
        const sellingPlan = this.dataset.sellingPlan || '';
        if (sellingPlanInput) {
          sellingPlanInput.value = sellingPlan;
        }
        
        // Dispatch event for any listeners
        section.dispatchEvent(new CustomEvent('subscription-tier-changed', {
          detail: {
            tier: this.dataset.subscriptionTier,
            sellingPlan: sellingPlan
          },
          bubbles: true
        }));
      });
    });

    // Visual Variant Cards handling
    const variantCards = section.querySelectorAll('[data-variant-card]');
    const variantIdInput = section.querySelector('[data-variant-id]');
    const priceDisplay = section.querySelector('[data-current-price]');
    const compareDisplay = section.querySelector('[data-compare-price]');
    const saveBadge = section.querySelector('[data-save-badge]');
    const addToCartBtn = section.querySelector('[data-add-to-cart]');
    const addToCartText = section.querySelector('[data-atc-text]');
    const stickyPrice = section.querySelector('[data-sticky-price]');
    const stickyAddToCart = section.querySelector('[data-sticky-add-to-cart]');
    
    // Get product variants data
    const productData = {{ product.variants | json }};
    const productOptions = {{ product.options | json }};

    // Format money helper
    const formatMoney = (cents) => {
      return (cents / 100).toLocaleString('en-US', {
        style: 'currency',
        currency: {{ shop.currency | json }}
      });
    };

    function updateVariantUI(variant) {
      if (!variant) return;
      
      // Update hidden input
      if (variantIdInput) {
        variantIdInput.value = variant.id;
      }
      
      // Update URL
      const url = new URL(window.location.href);
      url.searchParams.set('variant', variant.id);
      history.replaceState({}, '', url.toString());
      
      // Update prices
      if (priceDisplay) {
        priceDisplay.textContent = formatMoney(variant.price);
      }
      if (stickyPrice) {
        stickyPrice.textContent = formatMoney(variant.price);
      }
      if (compareDisplay) {
        if (variant.compare_at_price && variant.compare_at_price > variant.price) {
          compareDisplay.textContent = formatMoney(variant.compare_at_price);
          compareDisplay.style.display = '';
          if (saveBadge) {
            const percent = Math.round((1 - variant.price / variant.compare_at_price) * 100);
            saveBadge.textContent = `SAVE ${percent}%`;
            saveBadge.style.display = '';
          }
        } else {
          compareDisplay.style.display = 'none';
          if (saveBadge) saveBadge.style.display = 'none';
        }
      }
      
      // Update availability
      if (addToCartBtn) {
        if (variant.available) {
          addToCartBtn.disabled = false;
          if (addToCartText) addToCartText.textContent = '{{ block.settings.button_text | default: "Add to Cart" }}';
        } else {
          addToCartBtn.disabled = true;
          if (addToCartText) addToCartText.textContent = 'Sold Out';
        }
      }
      if (stickyAddToCart) {
        stickyAddToCart.disabled = !variant.available;
      }
      
      // Update main product image to variant image
      if (variant.featured_image) {
        const mainImage = section.querySelector('.dw-product__main-image img');
        if (mainImage) {
          mainImage.src = variant.featured_image.src.replace(/(\.[^.]+)$/, '_800x$1');
          mainImage.alt = variant.featured_image.alt || variant.title;
        }
      }
    }

    // Variant card click handling (selection only, not add to cart)
    variantCards.forEach(card => {
      card.addEventListener('click', function(e) {
        e.preventDefault(); // Prevent any form submission
        if (this.disabled) return;
        
        // Update active state
        variantCards.forEach(c => c.classList.remove('dw-product__variant-card--active'));
        this.classList.add('dw-product__variant-card--active');
        
        // Find variant and update UI
        const variantId = parseInt(this.dataset.variantId);
        const variant = productData.find(v => v.id === variantId);
        if (variant) {
          updateVariantUI(variant);
        }
      });
    });

    // Variant option buttons handling (for standard buttons style)
    const optionBtns = section.querySelectorAll('.dw-product__option-btn');
    
    function getSelectedOptions() {
      const selected = {};
      section.querySelectorAll('.dw-product__option').forEach(optionGroup => {
        const activeBtn = optionGroup.querySelector('.dw-product__option-btn--active');
        if (activeBtn) {
          selected[activeBtn.dataset.optionName] = activeBtn.dataset.optionValue;
        }
      });
      return selected;
    }
    
    function findVariant(selectedOptions) {
      return productData.find(variant => {
        return productOptions.every((optionName, index) => {
          const optionKey = 'option' + (index + 1);
          return variant[optionKey] === selectedOptions[optionName];
        });
      });
    }
    
    optionBtns.forEach(btn => {
      btn.addEventListener('click', function(e) {
        e.preventDefault(); // Prevent any form submission
        
        // Update active state within option group
        const optionGroup = this.closest('.dw-product__option-values');
        if (optionGroup) {
          optionGroup.querySelectorAll('.dw-product__option-btn').forEach(b => {
            b.classList.remove('dw-product__option-btn--active');
          });
          this.classList.add('dw-product__option-btn--active');
        }
        
        // Find and update variant
        const selectedOptions = getSelectedOptions();
        const variant = findVariant(selectedOptions);
        if (variant) {
          updateVariantUI(variant);
        }
      });
    });

    // Thumbnail gallery
    const thumbnails = section.querySelectorAll('[data-thumbnail]');
    const mainImage = section.querySelector('[data-main-image]');
    const prevBtn = section.querySelector('[data-gallery-prev]');
    const nextBtn = section.querySelector('[data-gallery-next]');
    const currentIndexEl = section.querySelector('[data-current-index]');
    let currentIndex = 0;
    const totalImages = thumbnails.length;

    function updateGallery(index) {
      if (!thumbnails.length || !mainImage) return;
      
      // Clamp index
      if (index < 0) index = totalImages - 1;
      if (index >= totalImages) index = 0;
      currentIndex = index;
      
      const thumb = thumbnails[index];
      if (!thumb) return;
      
      // Update main image with fade
      const newSrc = thumb.dataset.imageUrl;
      const newSrcset = thumb.dataset.imageSrcset;
      const newAlt = thumb.dataset.imageAlt;
      
      if (newSrc) {
        mainImage.classList.add('is-changing');
        setTimeout(() => {
          mainImage.src = newSrc;
          if (newSrcset) mainImage.srcset = newSrcset;
          if (newAlt) mainImage.alt = newAlt;
          mainImage.classList.remove('is-changing');
        }, 150);
      }
      
      // Update active thumbnail
      thumbnails.forEach(t => t.classList.remove('dw-product__thumbnail--active'));
      thumb.classList.add('dw-product__thumbnail--active');
      
      // Update counter
      if (currentIndexEl) {
        currentIndexEl.textContent = currentIndex + 1;
      }
      
      // Scroll thumbnail into view WITHOUT scrolling the page
      const thumbsContainer = section.querySelector('.dw-product__thumbnails');
      if (thumbsContainer) {
        const thumbLeft = thumb.offsetLeft;
        const thumbWidth = thumb.offsetWidth;
        const containerScroll = thumbsContainer.scrollLeft;
        const containerWidth = thumbsContainer.offsetWidth;
        
        // Calculate if thumbnail is outside visible area
        const thumbRight = thumbLeft + thumbWidth;
        const visibleLeft = containerScroll;
        const visibleRight = containerScroll + containerWidth;
        
        // Only scroll the container, not the page
        if (thumbLeft < visibleLeft) {
          thumbsContainer.scrollTo({
            left: thumbLeft - 20,
            behavior: 'smooth'
          });
        } else if (thumbRight > visibleRight) {
          thumbsContainer.scrollTo({
            left: thumbRight - containerWidth + 20,
            behavior: 'smooth'
          });
        }
      }
    }

    // Thumbnail clicks
    thumbnails.forEach((thumb, index) => {
      thumb.addEventListener('click', function() {
        updateGallery(index);
      });
    });

    // Arrow navigation
    if (prevBtn) {
      prevBtn.addEventListener('click', () => updateGallery(currentIndex - 1));
    }
    if (nextBtn) {
      nextBtn.addEventListener('click', () => updateGallery(currentIndex + 1));
    }

    // Keyboard navigation when gallery is focused/hovered
    const galleryContainer = section.querySelector('[data-main-image-container]');
    if (galleryContainer) {
      galleryContainer.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft') {
          e.preventDefault();
          updateGallery(currentIndex - 1);
        } else if (e.key === 'ArrowRight') {
          e.preventDefault();
          updateGallery(currentIndex + 1);
        }
      });
      galleryContainer.setAttribute('tabindex', '0');
    }

    // Swipe support for mobile
    let touchStartX = 0;
    let touchEndX = 0;
    
    if (galleryContainer) {
      galleryContainer.addEventListener('touchstart', (e) => {
        touchStartX = e.changedTouches[0].screenX;
      }, { passive: true });
      
      galleryContainer.addEventListener('touchend', (e) => {
        touchEndX = e.changedTouches[0].screenX;
        const diff = touchStartX - touchEndX;
        if (Math.abs(diff) > 50) {
          if (diff > 0) {
            updateGallery(currentIndex + 1); // Swipe left = next
          } else {
            updateGallery(currentIndex - 1); // Swipe right = prev
          }
        }
      }, { passive: true });
    }

    // Add to Cart Functionality
    const productForm = section.querySelector('form[action*="/cart/add"]') || 
                        section.querySelector('form[data-type="add-to-cart-form"]') ||
                        section.querySelector('form');
    const atcBtn = section.querySelector('[data-add-to-cart]');
    const stickyAtcBtn = section.querySelector('[data-sticky-add-to-cart]');
    const variantInput = section.querySelector('input[name="id"]');
    const quantityInput = section.querySelector('[data-quantity]');
    
    // Debug: log what we found
    console.log('DW Product Form Debug:', {
      form: productForm ? 'found' : 'NOT FOUND',
      formAction: productForm?.action,
      atcBtn: atcBtn ? 'found' : 'NOT FOUND',
      variantInput: variantInput ? variantInput.value : 'NOT FOUND',
      quantityInput: quantityInput ? quantityInput.value : 'NOT FOUND'
    });

    function setButtonState(btn, state) {
      if (!btn) return;
      btn.classList.remove('is-loading', 'is-success', 'is-error');
      btn.removeAttribute('data-added');
      if (state === 'loading') {
        btn.classList.add('is-loading');
      } else if (state === 'success') {
        btn.classList.add('is-success');
        btn.setAttribute('data-added', 'true');
      } else if (state === 'error') {
        btn.classList.add('is-error');
      }
    }

    // Fly-to-cart animation
    function animateFlyToCart(sourceButton) {
      // Check if user prefers reduced motion
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      
      // Get the product image
      const productImage = section.querySelector('.dw-product__main-image img, .dw-product__media-main img');
      const imageUrl = productImage?.src || section.dataset.productImage;
      
      if (!imageUrl) {
        console.log('No product image found for fly animation');
        return;
      }
      
      // Find the cart icon in the header
      const cartIcon = document.querySelector('.header-actions__cart-icon, .cart-icon, [data-cart-icon], .header__icon--cart, a[href*="/cart"] svg, a[href*="/cart"] .icon');
      
      if (!cartIcon || !sourceButton) {
        console.log('Cart icon or source button not found');
        return;
      }
      
      // Get positions
      const sourceRect = sourceButton.getBoundingClientRect();
      const destRect = cartIcon.getBoundingClientRect();
      
      const startX = sourceRect.left + sourceRect.width / 2;
      const startY = sourceRect.top + sourceRect.height / 2;
      const endX = destRect.left + destRect.width / 2;
      const endY = destRect.top + destRect.height / 2;
      
      // Determine animation class (main vs sticky)
      const flyClass = sourceButton.dataset.flyClass === 'sticky' ? 'dw-fly-to-cart--sticky' : 'dw-fly-to-cart--main';
      delete sourceButton.dataset.flyClass; // Clean up
      
      // Create the flying element
      const flyEl = document.createElement('div');
      flyEl.className = `dw-fly-to-cart ${flyClass}`;
      flyEl.style.setProperty('background-image', `url(${imageUrl})`);
      flyEl.style.setProperty('--start-x', `${startX}px`);
      flyEl.style.setProperty('--start-y', `${startY}px`);
      flyEl.style.setProperty('--travel-x', `${endX - startX}px`);
      flyEl.style.setProperty('--travel-y', `${endY - startY}px`);
      flyEl.style.setProperty('--start-opacity', '0');
      flyEl.style.setProperty('--width', '50px');
      flyEl.style.setProperty('--height', '50px');
      
      document.body.appendChild(flyEl);
      
      // Add bounce effect to cart icon when animation ends
      const animDuration = flyClass.includes('sticky') ? 750 : 600;
      setTimeout(() => {
        cartIcon.classList.add('dw-cart-bounce');
        setTimeout(() => cartIcon.classList.remove('dw-cart-bounce'), 400);
      }, animDuration);
      
      // Remove the flying element after animation completes
      setTimeout(() => {
        flyEl.remove();
      }, animDuration + 200);
    }

    // Track which button triggered the add to cart
    let clickedButton = null;

    async function handleAddToCart(e) {
      if (e) e.preventDefault();
      
      // Track which button was clicked for fly animation
      clickedButton = e?.target?.closest('button') || atcBtn;
      
      console.log('Add to cart triggered');
      
      if (!variantInput || !variantInput.value) {
        console.error('No variant selected', variantInput);
        return;
      }

      const buttons = [atcBtn, stickyAtcBtn].filter(Boolean);
      
      // Check if button is disabled (sold out)
      if (atcBtn && atcBtn.disabled) {
        console.log('Button is disabled');
        return;
      }
      
      // Set loading state
      buttons.forEach(btn => setButtonState(btn, 'loading'));

      // Build FormData
      const formData = new FormData();
      formData.append('id', variantInput.value);
      formData.append('quantity', quantityInput ? quantityInput.value : '1');
      
      // Add sections parameter for cart drawer updates
      const cartSections = [];
      document.querySelectorAll('cart-items-component, cart-drawer-component').forEach(el => {
        if (el.dataset && el.dataset.sectionId) {
          cartSections.push(el.dataset.sectionId);
        }
      });
      if (cartSections.length) {
        formData.append('sections', cartSections.join(','));
      }

      // Get the correct cart add URL
      const cartAddUrl = (window.Shopify?.routes?.root || '/') + 'cart/add.js';
      console.log('Posting to:', cartAddUrl, 'with variant:', variantInput.value);

      try {
        const response = await fetch(cartAddUrl, {
          method: 'POST',
          body: formData,
          headers: {
            'X-Requested-With': 'XMLHttpRequest'
          }
        });

        const result = await response.json();
        console.log('Cart response:', result);

        // Check for error response
        if (result.status === 422 || result.status === 'bad_request' || result.status) {
          throw new Error(result.message || result.description || 'Could not add to cart');
        }

        // Success! Trigger fly-to-cart animation
        animateFlyToCart(clickedButton);
        
        buttons.forEach(btn => setButtonState(btn, 'success'));
        
        setTimeout(() => {
          buttons.forEach(btn => setButtonState(btn, null));
        }, 2500);

        // Fetch updated cart
        const cartResponse = await fetch('/cart.js');
        const cart = await cartResponse.json();
        
        // Update cart count
        document.querySelectorAll('.cart-count-bubble span, [data-cart-count]').forEach(el => {
          if (el) el.textContent = cart.item_count;
        });
        document.querySelectorAll('.cart-count-bubble').forEach(el => {
          if (el) el.style.display = cart.item_count > 0 ? '' : 'none';
        });

        // Dispatch cart:update event
        document.dispatchEvent(new CustomEvent('cart:update', { 
          bubbles: true,
          detail: {
            resource: cart,
            sourceId: section.dataset.sectionId || 'dw-product',
            data: {
              source: 'dw-product-section',
              productId: section.dataset.productId,
              variantId: variantInput.value,
              itemCount: parseInt(quantityInput?.value || '1'),
              sections: result.sections
            }
          }
        }));
        
        // Open cart drawer
        const cartDrawer = document.querySelector('cart-drawer-component');
        if (cartDrawer) {
          setTimeout(() => {
            if (typeof cartDrawer.showDialog === 'function') {
              cartDrawer.showDialog();
            } else if (typeof cartDrawer.show === 'function') {
              cartDrawer.show();
            }
          }, 150);
        }

      } catch (error) {
        console.error('Add to cart error:', error);
        buttons.forEach(btn => setButtonState(btn, 'error'));
        
        setTimeout(() => {
          buttons.forEach(btn => setButtonState(btn, null));
        }, 3000);
      }
    }

    // Form submission
    if (productForm) {
      console.log('Attaching submit handler to form');
      productForm.addEventListener('submit', handleAddToCart);
    }
    
    // Also add direct click handler on button as fallback
    if (atcBtn) {
      atcBtn.addEventListener('click', (e) => {
        // If form exists, let form handle it via submit event
        // Otherwise handle directly
        if (!productForm) {
          handleAddToCart(e);
        }
      });
    }

    // Sticky button click (outside form, needs to trigger same action)
    if (stickyAtcBtn) {
      stickyAtcBtn.addEventListener('click', (e) => {
        e.preventDefault();
        // Mark as sticky button click for different animation curve
        stickyAtcBtn.dataset.flyClass = 'sticky';
        handleAddToCart(e);
      });
    }

    // Sticky bar visibility
    const stickyBar = section.querySelector('.dw-product__sticky-bar');
    if (stickyBar && atcBtn) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            section.classList.remove('show-sticky');
          } else {
            section.classList.add('show-sticky');
          }
        });
      }, { threshold: 0 });

      observer.observe(atcBtn);
    }

    // Video Modal Functionality
    const videoTriggers = section.querySelectorAll('[data-video-trigger]');
    const videoModal = section.querySelector('[data-video-modal]');
    const videoPlayer = section.querySelector('[data-video-player]');
    const modalCloseButtons = section.querySelectorAll('[data-modal-close]');
    const videosTrack = section.querySelector('.dw-product__videos-track');

    // Arrow navigation
    if (videosTrack) {
      const prevBtn = section.querySelector('[data-video-prev]');
      const nextBtn = section.querySelector('[data-video-next]');
      
      if (prevBtn && nextBtn) {
        const scrollAmount = 150;
        
        const updateArrows = () => {
          const maxScroll = videosTrack.scrollWidth - videosTrack.clientWidth;
          prevBtn.style.opacity = videosTrack.scrollLeft <= 0 ? '0.3' : '1';
          prevBtn.style.pointerEvents = videosTrack.scrollLeft <= 0 ? 'none' : 'auto';
          nextBtn.style.opacity = videosTrack.scrollLeft >= maxScroll - 1 ? '0.3' : '1';
          nextBtn.style.pointerEvents = videosTrack.scrollLeft >= maxScroll - 1 ? 'none' : 'auto';
        };
        
        prevBtn.addEventListener('click', () => {
          videosTrack.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
        });
        
        nextBtn.addEventListener('click', () => {
          videosTrack.scrollBy({ left: scrollAmount, behavior: 'smooth' });
        });
        
        videosTrack.addEventListener('scroll', updateArrows);
        updateArrows();
      }
    }

    if (videoTriggers.length && videoModal && videoPlayer) {
      // Open modal
      videoTriggers.forEach(trigger => {
        trigger.addEventListener('click', function() {
          const videoUrl = this.dataset.videoUrl;
          
          if (videoUrl) {
            // Check if it's a YouTube/Vimeo URL or direct video
            if (videoUrl.includes('youtube.com') || videoUrl.includes('youtu.be')) {
              // Extract YouTube ID and create embed
              let videoId = '';
              if (videoUrl.includes('youtu.be/')) {
                videoId = videoUrl.split('youtu.be/')[1].split('?')[0];
              } else if (videoUrl.includes('v=')) {
                videoId = videoUrl.split('v=')[1].split('&')[0];
              }
              videoPlayer.style.display = 'none';
              const iframe = document.createElement('iframe');
              iframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0`;
              iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
              iframe.allowFullscreen = true;
              iframe.className = 'dw-product__video-iframe';
              iframe.style.cssText = 'width:100%;height:100%;border:none;position:absolute;inset:0;';
              const playerContainer = videoPlayer.parentElement;
              const existingIframe = playerContainer.querySelector('iframe');
              if (existingIframe) existingIframe.remove();
              playerContainer.appendChild(iframe);
            } else if (videoUrl.includes('vimeo.com')) {
              // Extract Vimeo ID
              const vimeoId = videoUrl.split('vimeo.com/')[1].split('?')[0];
              videoPlayer.style.display = 'none';
              const iframe = document.createElement('iframe');
              iframe.src = `https://player.vimeo.com/video/${vimeoId}?autoplay=1`;
              iframe.allow = 'autoplay; fullscreen; picture-in-picture';
              iframe.allowFullscreen = true;
              iframe.className = 'dw-product__video-iframe';
              iframe.style.cssText = 'width:100%;height:100%;border:none;position:absolute;inset:0;';
              const playerContainer = videoPlayer.parentElement;
              const existingIframe = playerContainer.querySelector('iframe');
              if (existingIframe) existingIframe.remove();
              playerContainer.appendChild(iframe);
            } else {
              // Direct video URL
              const existingIframe = videoPlayer.parentElement.querySelector('iframe');
              if (existingIframe) existingIframe.remove();
              videoPlayer.style.display = 'block';
              videoPlayer.querySelector('source').src = videoUrl;
              videoPlayer.load();
              videoPlayer.play();
            }
          }
          
          videoModal.setAttribute('aria-hidden', 'false');
          document.body.classList.add('dw-video-modal-open');
        });
      });

      // Close modal function
      function closeVideoModal() {
        videoModal.setAttribute('aria-hidden', 'true');
        document.body.classList.remove('dw-video-modal-open');
        
        // Pause/stop video
        videoPlayer.pause();
        videoPlayer.currentTime = 0;
        
        // Remove any iframes
        const iframe = videoPlayer.parentElement.querySelector('iframe');
        if (iframe) iframe.remove();
        videoPlayer.style.display = 'block';
      }

      // Close button clicks
      modalCloseButtons.forEach(btn => {
        btn.addEventListener('click', closeVideoModal);
      });

      // Close on escape key
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && videoModal.getAttribute('aria-hidden') === 'false') {
          closeVideoModal();
        }
      });
    }
  });
</script>