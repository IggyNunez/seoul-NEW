{%- doc -%}
  Seoul Glow Lab Collection Filter Group
  Renders a single filter group from Shopify's collection.filters API

  @param filter {filter} - Required. A filter object from collection.filters
  @param open {boolean} - Optional. Whether the group starts open (default: true)
{%- enddoc -%}

{%- liquid
  assign _open = open | default: true
  assign active_count = 0
  if filter.type == 'price_range'
    if filter.min_value.value != nil or filter.max_value.value != nil
      assign active_count = 1
    endif
  else
    assign active_count = filter.active_values.size
  endif
  assign is_swatch = false
  if filter.presentation == 'swatch'
    assign is_swatch = true
  endif
  assign is_color = false
  assign filter_label_lower = filter.label | downcase
  if filter_label_lower contains 'color' or filter_label_lower contains 'colour' or filter_label_lower contains 'light color'
    assign is_color = true
  endif
  assign is_shape = false
  if filter_label_lower contains 'shape'
    assign is_shape = true
  endif
  assign is_size = false
  if filter_label_lower contains 'size'
    assign is_size = true
  endif
-%}

<details class="casa-col-filter" {% if _open %}open{% endif %}>
  <summary class="casa-col-filter__header">
    <span class="casa-col-filter__label">{{ filter.label }}</span>
    {%- if active_count > 0 -%}
      <span class="casa-col-filter__count">{{ active_count }}</span>
    {%- endif -%}
    <svg class="casa-col-filter__chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </summary>

  <div class="casa-col-filter__body">
    {%- case filter.type -%}

      {%- when 'price_range' -%}
        {%- liquid
          assign min_price = filter.range_min | default: 0 | money_without_currency | plus: 0
          assign max_price = filter.range_max | default: 50000 | money_without_currency | plus: 0
          assign current_min = filter.min_value.value | default: filter.range_min | money_without_currency | plus: 0
          assign current_max = filter.max_value.value | default: filter.range_max | money_without_currency | plus: 0
        -%}
        <div class="casa-col-filter__price-range" data-min="{{ min_price }}" data-max="{{ max_price }}">
          <div class="casa-col-filter__price-slider">
            <div class="casa-col-filter__price-track">
              <div class="casa-col-filter__price-fill"></div>
              <input
                type="range"
                class="casa-col-filter__price-thumb casa-col-filter__price-thumb--min"
                min="{{ min_price }}"
                max="{{ max_price }}"
                value="{{ current_min }}"
                aria-label="Minimum price"
              >
              <input
                type="range"
                class="casa-col-filter__price-thumb casa-col-filter__price-thumb--max"
                min="{{ min_price }}"
                max="{{ max_price }}"
                value="{{ current_max }}"
                aria-label="Maximum price"
              >
            </div>
          </div>
          <div class="casa-col-filter__price-inputs">
            <div class="casa-col-filter__price-field">
              <span class="casa-col-filter__price-currency">{{ cart.currency.symbol }}</span>
              <input
                type="number"
                class="casa-col-filter__price-input"
                name="{{ filter.min_value.param_name }}"
                value="{{ current_min | ceil }}"
                min="{{ min_price }}"
                max="{{ max_price }}"
                placeholder="{{ min_price | ceil }}"
                aria-label="Minimum price"
              >
            </div>
            <span class="casa-col-filter__price-sep">—</span>
            <div class="casa-col-filter__price-field">
              <span class="casa-col-filter__price-currency">{{ cart.currency.symbol }}</span>
              <input
                type="number"
                class="casa-col-filter__price-input"
                name="{{ filter.max_value.param_name }}"
                value="{{ current_max | ceil }}"
                min="{{ min_price }}"
                max="{{ max_price }}"
                placeholder="{{ max_price | ceil }}"
                aria-label="Maximum price"
              >
            </div>
          </div>
        </div>

      {%- when 'boolean' -%}
        {%- for value in filter.values -%}
          <label class="casa-col-filter__toggle">
            <span class="casa-col-filter__toggle-text">{{ value.label }}</span>
            <div class="casa-col-filter__toggle-switch">
              <input
                type="checkbox"
                name="{{ value.param_name }}"
                value="{{ value.value }}"
                {% if value.active %}checked{% endif %}
                {% if value.count == 0 and value.active == false %}disabled{% endif %}
              >
              <span class="casa-col-filter__toggle-slider"></span>
            </div>
            {%- if value.count > 0 -%}
              <span class="casa-col-filter__option-count">({{ value.count }})</span>
            {%- endif -%}
          </label>
        {%- endfor -%}

      {%- when 'list' -%}
        {%- if is_swatch or is_color -%}
          {%- comment -%} Color swatch grid {%- endcomment -%}
          <div class="casa-col-filter__swatch-grid">
            {%- for value in filter.values -%}
              <label class="casa-col-filter__swatch{% if value.active %} casa-col-filter__swatch--active{% endif %}{% if value.count == 0 and value.active == false %} casa-col-filter__swatch--disabled{% endif %}" title="{{ value.label }}">
                <input
                  type="checkbox"
                  name="{{ value.param_name }}"
                  value="{{ value.value }}"
                  {% if value.active %}checked{% endif %}
                  {% if value.count == 0 and value.active == false %}disabled{% endif %}
                  class="visually-hidden"
                >
                {%- if value.swatch.color -%}
                  <span class="casa-col-filter__swatch-color" style="background: {{ value.swatch.color }};"></span>
                {%- elsif value.swatch.image -%}
                  <img src="{{ value.swatch.image | image_url: width: 80 }}" alt="{{ value.label }}" class="casa-col-filter__swatch-img" loading="lazy">
                {%- else -%}
                  {%- comment -%} Fallback: derive color from label name {%- endcomment -%}
                  <span class="casa-col-filter__swatch-color" style="background: {{ value.label | downcase | replace: ' ', '' }};"></span>
                {%- endif -%}
              </label>
            {%- endfor -%}
          </div>

        {%- elsif is_shape or is_size -%}
          {%- comment -%} Chip / pill buttons {%- endcomment -%}
          <div class="casa-col-filter__chips">
            {%- for value in filter.values -%}
              <label class="casa-col-filter__chip{% if value.active %} casa-col-filter__chip--active{% endif %}{% if value.count == 0 and value.active == false %} casa-col-filter__chip--disabled{% endif %}">
                <input
                  type="checkbox"
                  name="{{ value.param_name }}"
                  value="{{ value.value }}"
                  {% if value.active %}checked{% endif %}
                  {% if value.count == 0 and value.active == false %}disabled{% endif %}
                  class="visually-hidden"
                >
                {%- if is_shape -%}
                  <span class="casa-col-filter__chip-icon">
                    {%- assign shape_lower = value.label | downcase -%}
                    {%- case shape_lower -%}
                      {%- when 'circle' -%}
                        <svg width="16" height="16" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="2"/></svg>
                      {%- when 'square' or 'rectangle' -%}
                        <svg width="16" height="16" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2" fill="none" stroke="currentColor" stroke-width="2"/></svg>
                      {%- when 'hexagon' -%}
                        <svg width="16" height="16" viewBox="0 0 24 24"><path d="M12 2l8.66 5v10L12 22l-8.66-5V7z" fill="none" stroke="currentColor" stroke-width="2"/></svg>
                      {%- when 'octagon' -%}
                        <svg width="16" height="16" viewBox="0 0 24 24"><polygon points="7.86 2 16.14 2 22 7.86 22 16.14 16.14 22 7.86 22 2 16.14 2 7.86" fill="none" stroke="currentColor" stroke-width="2"/></svg>
                      {%- when 'triangle' -%}
                        <svg width="16" height="16" viewBox="0 0 24 24"><path d="M12 3L2 21h20z" fill="none" stroke="currentColor" stroke-width="2"/></svg>
                      {%- when 'diamond' -%}
                        <svg width="16" height="16" viewBox="0 0 24 24"><path d="M12 2l10 10-10 10L2 12z" fill="none" stroke="currentColor" stroke-width="2"/></svg>
                      {%- when 'star' -%}
                        <svg width="16" height="16" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01z" fill="none" stroke="currentColor" stroke-width="2"/></svg>
                      {%- when 'arch' -%}
                        <svg width="16" height="16" viewBox="0 0 24 24"><path d="M4 22V10a8 8 0 0 1 16 0v12" fill="none" stroke="currentColor" stroke-width="2"/></svg>
                      {%- else -%}
                        <svg width="16" height="16" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="2"/></svg>
                    {%- endcase -%}
                  </span>
                {%- endif -%}
                <span class="casa-col-filter__chip-text">{{ value.label }}</span>
              </label>
            {%- endfor -%}
          </div>

        {%- else -%}
          {%- comment -%} Default checkbox list {%- endcomment -%}
          <div class="casa-col-filter__list">
            {%- for value in filter.values -%}
              <label class="casa-col-filter__option{% if value.active %} casa-col-filter__option--active{% endif %}{% if value.count == 0 and value.active == false %} casa-col-filter__option--disabled{% endif %}">
                <input
                  type="checkbox"
                  name="{{ value.param_name }}"
                  value="{{ value.value }}"
                  {% if value.active %}checked{% endif %}
                  {% if value.count == 0 and value.active == false %}disabled{% endif %}
                >
                <span class="casa-col-filter__checkbox">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                </span>
                <span class="casa-col-filter__option-text">{{ value.label }}</span>
                <span class="casa-col-filter__option-count">({{ value.count }})</span>
              </label>
            {%- endfor -%}
          </div>
        {%- endif -%}

    {%- endcase -%}
  </div>
</details>
