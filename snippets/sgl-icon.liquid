{%- comment -%}
  Seoul Glow Lab - SVG Icon Snippet
  Usage: {% render 'sgl-icon', icon: 'search', size: 24, class: 'my-class' %}
  Params:
    - icon: string (required) - icon name
    - size: number (optional, default 24)
    - class: string (optional) - extra CSS class
{%- endcomment -%}

{%- liquid
  unless size
    assign size = 24
  endunless
-%}

