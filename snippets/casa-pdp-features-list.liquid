{%- comment -%}
  Casa PDP Features List
  Displays product features as horizontal pill badges with checkmark icons
  Matches Figma design: "16M Colors", "App Control", "Music Sync", "Voice Control"
{%- endcomment -%}

<div class="casa-features-list">
  <div class="casa-features-list__pills">
    {%- if block.settings.feature_1 != blank -%}
      <div class="casa-features-list__pill">
        <span class="casa-features-list__icon" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.5"/>
            <path d="M4.5 7L6.25 8.75L9.5 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <span class="casa-features-list__text">{{ block.settings.feature_1 }}</span>
      </div>
    {%- endif -%}
    {%- if block.settings.feature_2 != blank -%}
      <div class="casa-features-list__pill">
        <span class="casa-features-list__icon" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.5"/>
            <path d="M4.5 7L6.25 8.75L9.5 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <span class="casa-features-list__text">{{ block.settings.feature_2 }}</span>
      </div>
    {%- endif -%}
    {%- if block.settings.feature_3 != blank -%}
      <div class="casa-features-list__pill">
        <span class="casa-features-list__icon" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.5"/>
            <path d="M4.5 7L6.25 8.75L9.5 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <span class="casa-features-list__text">{{ block.settings.feature_3 }}</span>
      </div>
    {%- endif -%}
    {%- if block.settings.feature_4 != blank -%}
      <div class="casa-features-list__pill">
        <span class="casa-features-list__icon" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.5"/>
            <path d="M4.5 7L6.25 8.75L9.5 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <span class="casa-features-list__text">{{ block.settings.feature_4 }}</span>
      </div>
    {%- endif -%}
  </div>
</div>

<style>
.casa-features-list__pills {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.casa-features-list__pill {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 9px 16px;
  border: 1px solid #e5e5e5;
  border-radius: 100px;
  background: #fafafa;
  font-size: 14px;
  font-weight: 500;
  color: #0a0a0a;
  transition: border-color 0.2s ease, background 0.2s ease;
  max-width: 100%;
}

.casa-features-list__pill:hover {
  border-color: var(--cpm-accent-1, #9333ea);
  background: rgba(147, 51, 234, 0.04);
}

.casa-features-list__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--cpm-accent-1, #9333ea);
  flex-shrink: 0;
}

.casa-features-list__text {
  overflow: hidden;
  text-overflow: ellipsis;
}

@media (max-width: 480px) {
  .casa-features-list__pills {
    gap: 6px;
  }

  .casa-features-list__pill {
    padding: 7px 12px;
    font-size: 12px;
    gap: 5px;
  }

  .casa-features-list__icon svg {
    width: 12px;
    height: 12px;
  }
}

@media (max-width: 375px) {
  .casa-features-list__pill {
    padding: 6px 10px;
    font-size: 11px;
  }
}
</style>
