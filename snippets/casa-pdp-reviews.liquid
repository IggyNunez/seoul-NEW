{%- comment -%}
  Casa PDP Reviews (What Customers Say)
  Compact review preview with "See All" link

  Parameters:
  - block: The block object with settings
  - product: The product object
{%- endcomment -%}

{%- liquid
  assign title = block.settings.title | default: 'What Customers Say'
  assign show_write_review = block.settings.show_write_review
-%}

<div class="casa-pdp-reviews-inline" id="reviews">
  <div class="casa-pdp-reviews-inline__header">
    <h3 class="casa-pdp-reviews-inline__title">{{ title }}</h3>
    <a href="#reviews-section" class="casa-pdp-reviews-inline__see-all">See All</a>
  </div>

  <div class="casa-pdp-reviews-inline__card">
    <div class="casa-pdp-reviews-inline__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
    <p class="casa-pdp-reviews-inline__text">
      {%- if product.metafields.reviews.rating_count > 0 -%}
        {{ product.description | strip_html | truncate: 120 }}
      {%- else -%}
        "Completely transformed my gaming setup. The music sync is absolutely unreal. Best purchase I've made for my room!"
      {%- endif -%}
    </p>
    <div class="casa-pdp-reviews-inline__author">
      <div class="casa-pdp-reviews-inline__avatar">JK</div>
      <div class="casa-pdp-reviews-inline__author-info">
        <span class="casa-pdp-reviews-inline__name">Jake K.</span>
        <span class="casa-pdp-reviews-inline__verified">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
          Verified
        </span>
      </div>
    </div>
  </div>

  {%- comment -%} App blocks inject here {%- endcomment -%}
  <div class="casa-pdp-reviews-inline__app" id="write-review"></div>
</div>

<style>
.casa-pdp-reviews-inline {
  border-top: 1px solid #e5e5e5;
  padding-top: 20px;
}

.casa-pdp-reviews-inline__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
}

.casa-pdp-reviews-inline__title {
  font-size: 15px;
  font-weight: 600;
  color: #0a0a0a;
  margin: 0;
}

.casa-pdp-reviews-inline__see-all {
  font-size: 13px;
  font-weight: 500;
  color: #9333ea;
  text-decoration: none;
}

.casa-pdp-reviews-inline__see-all:hover {
  text-decoration: underline;
}

.casa-pdp-reviews-inline__card {
  background: #fafafa;
  border-radius: 12px;
  padding: 16px;
}

.casa-pdp-reviews-inline__stars {
  font-size: 14px;
  color: #fbbf24;
  letter-spacing: 1px;
  margin-bottom: 8px;
}

.casa-pdp-reviews-inline__text {
  font-size: 13px;
  color: #555;
  line-height: 1.5;
  margin: 0 0 12px 0;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.casa-pdp-reviews-inline__author {
  display: flex;
  align-items: center;
  gap: 10px;
}

.casa-pdp-reviews-inline__avatar {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: #22c55e;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 11px;
  font-weight: 700;
  flex-shrink: 0;
}

.casa-pdp-reviews-inline__author-info {
  display: flex;
  flex-direction: column;
}

.casa-pdp-reviews-inline__name {
  font-size: 13px;
  font-weight: 600;
  color: #0a0a0a;
}

.casa-pdp-reviews-inline__verified {
  display: flex;
  align-items: center;
  gap: 3px;
  font-size: 11px;
  color: #22c55e;
}

@media (max-width: 480px) {
  .casa-pdp-reviews-inline__title {
    font-size: 15px;
  }

  .casa-pdp-reviews-inline__card {
    padding: 14px;
  }

  .casa-pdp-reviews-inline__text {
    font-size: 12px;
  }
}
</style>
