{%- comment -%}
  Casa PDP Buy Buttons
  Renders add to cart button, quantity selector, and dynamic checkout

  Parameters:
  - product: The product object
  - block: The block object with settings
  - section: The section object
{%- endcomment -%}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign show_quantity = block.settings.show_quantity | default: true
  assign show_dynamic_checkout = block.settings.show_dynamic_checkout | default: true
-%}

<product-form-component
  class="casa-pdp-buy-buttons"
  data-product-id="{{ product.id }}"
  data-section-id="{{ section.id }}"
>
  {%- form 'product', product, id: 'casa-product-form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
    <input type="hidden" name="id" value="{{ current_variant.id }}" ref="variantId">
    <div class="visually-hidden" role="status" aria-live="polite" aria-atomic="true" ref="liveRegion"></div>

    <div class="casa-pdp-buy-buttons__row">
      {%- if show_quantity -%}
        <div class="casa-pdp-buy-buttons__quantity">
          <label class="visually-hidden" for="Quantity-{{ section.id }}">{{ 'products.product.quantity.label' | t }}</label>
          <div class="casa-pdp-buy-buttons__quantity-wrapper">
            <button
              type="button"
              class="casa-pdp-buy-buttons__qty-btn"
              aria-label="Decrease quantity"
              data-qty-decrease
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
            </button>
            <input
              type="number"
              id="Quantity-{{ section.id }}"
              name="quantity"
              class="casa-pdp-buy-buttons__qty-input"
              value="{{ current_variant.quantity_rule.min | default: 1 }}"
              min="{{ current_variant.quantity_rule.min | default: 1 }}"
              {% if current_variant.quantity_rule.max %}max="{{ current_variant.quantity_rule.max }}"{% endif %}
              step="{{ current_variant.quantity_rule.increment | default: 1 }}"
              ref="quantityInput"
            >
            <button
              type="button"
              class="casa-pdp-buy-buttons__qty-btn"
              aria-label="Increase quantity"
              data-qty-increase
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19"/>
                <line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
            </button>
          </div>
        </div>
      {%- endif -%}

      <button
        type="submit"
        name="add"
        class="casa-pdp-buy-buttons__add-to-cart"
        ref="addToCartButton"
        {% unless current_variant.available %}disabled{% endunless %}
      >
        <span class="casa-pdp-buy-buttons__btn-text">
          {%- if current_variant.available -%}
            {{ 'products.product.add_to_cart' | t }} — {{ current_variant.price | money }}
          {%- elsif current_variant == blank -%}
            {{ 'products.product.unavailable' | t }}
          {%- else -%}
            {{ 'products.product.sold_out' | t }}
          {%- endif -%}
        </span>
        <span class="casa-pdp-buy-buttons__btn-loading">
          <svg class="casa-pdp-buy-buttons__spinner" width="20" height="20" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" fill="none" stroke-dasharray="31.42" stroke-dashoffset="10"/>
          </svg>
        </span>
        <span class="casa-pdp-buy-buttons__btn-added">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          Added!
        </span>
      </button>
    </div>

    {%- comment -%} Hidden Shopify dynamic checkout for functionality {%- endcomment -%}
    {%- if show_dynamic_checkout -%}
      <div class="casa-pdp-buy-buttons__dynamic-hidden">
        {{ form | payment_button }}
      </div>
    {%- endif -%}
  {%- endform -%}

  {%- comment -%} Custom Payment Method Buttons - Visual 3-column layout {%- endcomment -%}
  {%- if show_dynamic_checkout -%}
    <div class="casa-pdp-buy-buttons__payment-methods">
      {%- comment -%} Shop Pay Button {%- endcomment -%}
      <button type="button" class="casa-pdp-buy-buttons__payment-btn casa-pdp-buy-buttons__payment-btn--shoppay" data-payment-method="shoppay" aria-label="Buy with Shop Pay">
