<script>
  (function() {
    const form = document.querySelector('.casa-pdp-buy-buttons');
    if (!form) return;

    const quantityInput = form.querySelector('[ref="quantityInput"]');
    const decreaseBtn = form.querySelector('[data-qty-decrease]');
    const increaseBtn = form.querySelector('[data-qty-increase]');
    const addToCartBtn = form.querySelector('[ref="addToCartButton"]');

    // Quantity buttons
    if (quantityInput) {
      const min = parseInt(quantityInput.min) || 1;
      const max = parseInt(quantityInput.max) || 999;
      const step = parseInt(quantityInput.step) || 1;

      decreaseBtn?.addEventListener('click', () => {
        const current = parseInt(quantityInput.value) || min;
        const newVal = Math.max(min, current - step);
        quantityInput.value = newVal;
        quantityInput.dispatchEvent(new Event('change', { bubbles: true }));
      });

      increaseBtn?.addEventListener('click', () => {
        const current = parseInt(quantityInput.value) || min;
        const newVal = Math.min(max, current + step);
        quantityInput.value = newVal;
        quantityInput.dispatchEvent(new Event('change', { bubbles: true }));
      });

      // Dispatch quantity change event
      quantityInput.addEventListener('change', () => {
        document.dispatchEvent(new CustomEvent('quantity:changed', {
          detail: { quantity: parseInt(quantityInput.value) }
        }));
      });
    }

    // Add to cart animation
    const formElement = form.querySelector('form');
    formElement?.addEventListener('submit', (e) => {
      // The form will submit normally, but we add visual feedback
      addToCartBtn.classList.add('loading');

      // Listen for success (simplified - in production use cart events)
      setTimeout(() => {
        addToCartBtn.classList.remove('loading');
        addToCartBtn.classList.add('added');

        setTimeout(() => {
          addToCartBtn.classList.remove('added');
        }, 2000);
      }, 1000);
    });

    // Payment method buttons - trigger checkout
    const paymentBtns = document.querySelectorAll('.casa-pdp-buy-buttons__payment-btn');
    paymentBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        // First add to cart, then go to checkout
        const formData = new FormData(formElement);
        fetch('/cart/add.js', {
          method: 'POST',
          body: formData
        })
        .then(response => response.json())
        .then(() => {
          // Redirect to checkout
          window.location.href = '/checkout';
        })
        .catch(err => {
          console.error('Error adding to cart:', err);
        });
      });
    });
  })();
</script>

