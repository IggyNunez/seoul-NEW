{% comment %}
  Seoul Glow Lab — GSAP loader for the native Horizon hero section.
  Loads GSAP 3.12.5 + ScrollTrigger from CDN, then our animation script.
  Only outputs on the homepage (template == 'index') to avoid loading on every page.
{% endcomment %}

{%- if template == 'index' -%}
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" defer></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" defer></script>
  <script src="{{ 'sgl-hero-gsap.js' | asset_url }}" defer></script>
{%- endif -%}
