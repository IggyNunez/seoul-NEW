{%- comment -%}
  Casa PDP Trust Row
  Displays a row of trust badges with icons

  Parameters:
  - block: The block object with badge settings
{%- endcomment -%}

{%- liquid
  assign badge_1_icon = block.settings.badge_1_icon | default: 'truck'
  assign badge_1_text = block.settings.badge_1_text | default: 'Free Shipping'
  assign badge_2_icon = block.settings.badge_2_icon | default: 'refresh'
  assign badge_2_text = block.settings.badge_2_text | default: '30-Day Returns'
  assign badge_3_icon = block.settings.badge_3_icon | default: 'shield-check'
  assign badge_3_text = block.settings.badge_3_text | default: '2-Year Warranty'
  assign badge_4_icon = block.settings.badge_4_icon | default: 'lock'
  assign badge_4_text = block.settings.badge_4_text | default: 'Secure Checkout'
-%}

<div class="casa-pdp-trust-row">
  {%- if badge_1_text != blank -%}
    <div class="casa-pdp-trust-row__badge">
      <span class="casa-pdp-trust-row__icon">
        {%- render 'casa-icon', icon: badge_1_icon, size: 20 -%}
      </span>
      <span class="casa-pdp-trust-row__text">{{ badge_1_text }}</span>
    </div>
  {%- endif -%}

  {%- if badge_2_text != blank -%}
    <div class="casa-pdp-trust-row__badge">
      <span class="casa-pdp-trust-row__icon">
        {%- render 'casa-icon', icon: badge_2_icon, size: 20 -%}
      </span>
      <span class="casa-pdp-trust-row__text">{{ badge_2_text }}</span>
    </div>
  {%- endif -%}

  {%- if badge_3_text != blank -%}
    <div class="casa-pdp-trust-row__badge">
      <span class="casa-pdp-trust-row__icon">
        {%- render 'casa-icon', icon: badge_3_icon, size: 20 -%}
      </span>
      <span class="casa-pdp-trust-row__text">{{ badge_3_text }}</span>
    </div>
  {%- endif -%}

  {%- if badge_4_text != blank -%}
    <div class="casa-pdp-trust-row__badge">
      <span class="casa-pdp-trust-row__icon">
        {%- render 'casa-icon', icon: badge_4_icon, size: 20 -%}
      </span>
      <span class="casa-pdp-trust-row__text">{{ badge_4_text }}</span>
    </div>
  {%- endif -%}
</div>

<style>
.casa-pdp-trust-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
  padding: 16px 0;
  border-top: 1px solid #e5e5e5;
  border-bottom: 1px solid #e5e5e5;
  min-width: 0;
  max-width: 100%;
  overflow: hidden;
}

.casa-pdp-trust-row__badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 6px;
  min-width: 0;
  overflow: hidden;
}

.casa-pdp-trust-row__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0a0a0a;
}

.casa-pdp-trust-row__icon svg {
  width: 20px;
  height: 20px;
}

.casa-pdp-trust-row__text {
  font-size: 10px;
  font-weight: 500;
  color: #757575;
  line-height: 1.35;
  max-width: 100%;
  word-wrap: break-word;
  overflow-wrap: break-word;
}

@media (max-width: 480px) {
  .casa-pdp-trust-row {
    grid-template-columns: repeat(4, 1fr);
    gap: 4px;
    padding: 12px 0;
  }

  .casa-pdp-trust-row__icon svg {
    width: 16px;
    height: 16px;
  }

  .casa-pdp-trust-row__text {
    font-size: 8px;
  }
}

@media (max-width: 375px) {
  .casa-pdp-trust-row__text {
    font-size: 7px;
  }

  .casa-pdp-trust-row__icon svg {
    width: 14px;
    height: 14px;
  }
}
</style>
