{%- comment -%}
  Casa PDP What's Included
  Clean accordion with item list

  Parameters:
  - block: The block object with settings
{%- endcomment -%}

{%- liquid
  assign title = block.settings.title | default: "What's Included"
  assign items = block.settings.items
-%}

<details class="casa-pdp-accordion">
  <summary class="casa-pdp-accordion__header">
    <span class="casa-pdp-accordion__title">{{ title }}</span>
    <span class="casa-pdp-accordion__chevron">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 12 15 18 9"/>
      </svg>
    </span>
  </summary>
  <div class="casa-pdp-accordion__body">
    <ul class="casa-pdp-included-list">
      {%- assign items_list = items | split: '
' -%}
      {%- for item in items_list -%}
        {%- if item != blank -%}
          <li class="casa-pdp-included-list__item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#9333ea" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            {{ item }}
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>
  </div>
</details>

<style>
.casa-pdp-included-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.casa-pdp-included-list__item {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 14px;
  color: #333;
}

.casa-pdp-included-list__item svg {
  flex-shrink: 0;
}

@media (max-width: 480px) {
  .casa-pdp-included-list__item {
    font-size: 13px;
    gap: 8px;
  }
}
</style>
