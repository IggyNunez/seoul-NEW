{%- comment -%}
  Casa Editorial Story — shared content snippet
  Renders: names row, divider, heading, body text, CTA button
  Used by casa-editorial-story.liquid across all layout modes.
{%- endcomment -%}

{%- comment -%} ── Names Row ── {%- endcomment -%}
{%- if names_arr.size > 0 and names_arr[0] != '' -%}
  <div class="casa-edit__names" aria-label="Featured characters">
    {%- for name in names_arr -%}
      {%- assign clean_name = name | strip -%}
      {%- if clean_name != '' -%}
        {%- if forloop.index > 1 -%}
          <span class="casa-edit__name-sep" aria-hidden="true">&middot;</span>
        {%- endif -%}
        <span class="casa-edit__name">{{ clean_name }}</span>
      {%- endif -%}
    {%- endfor -%}
  </div>
{%- endif -%}

{%- comment -%} ── Divider ── {%- endcomment -%}
{%- if divider -%}
  <hr class="casa-edit__divider" aria-hidden="true">
{%- endif -%}

{%- comment -%} ── Heading ── {%- endcomment -%}
{%- if heading != blank -%}
  <h2 class="casa-edit__heading casa-edit__heading--{{ heading_size }}">
    {{- heading | escape -}}
  </h2>
{%- endif -%}

{%- comment -%} ── Body Text ── {%- endcomment -%}
{%- if body_text != blank -%}
  <div class="casa-edit__body">
    {{ body_text }}
  </div>
{%- endif -%}

{%- comment -%} ── CTA Button ── {%- endcomment -%}
{%- if btn_text != blank and btn_url != blank -%}
  <div class="casa-edit__btn-wrap">
    <a href="{{ btn_url }}" class="casa-edit__btn casa-edit__btn--{{ btn_style }}">
      {{ btn_text | escape }}
      <svg class="casa-edit__btn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="5" y1="12" x2="19" y2="12"></line>
        <polyline points="12 5 19 12 12 19"></polyline>
      </svg>
    </a>
  </div>
{%- endif -%}
