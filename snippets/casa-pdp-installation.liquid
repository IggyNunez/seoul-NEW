{%- comment -%}
  Casa PDP Installation Guide
  Clean accordion with richtext content

  Parameters:
  - block: The block object with settings
{%- endcomment -%}

{%- liquid
  assign title = block.settings.title | default: 'Installation'
  assign open_by_default = block.settings.open_by_default
  assign content = block.settings.content
-%}

<details class="casa-pdp-accordion"{% if open_by_default %} open{% endif %}>
  <summary class="casa-pdp-accordion__header">
    <span class="casa-pdp-accordion__title">{{ title }}</span>
    <span class="casa-pdp-accordion__chevron">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 12 15 18 9"/>
      </svg>
    </span>
  </summary>
  <div class="casa-pdp-accordion__body">
    <div class="casa-pdp-accordion__rte rte">
      {{ content }}
    </div>
  </div>
</details>

<style>
.casa-pdp-accordion__rte p {
  font-size: 14px;
  line-height: 1.7;
  color: #555;
  margin: 0 0 12px 0;
}

.casa-pdp-accordion__rte p:last-child {
  margin-bottom: 0;
}

.casa-pdp-accordion__rte strong {
  color: #0a0a0a;
}

@media (max-width: 480px) {
  .casa-pdp-accordion__rte p {
    font-size: 13px;
  }
}
</style>
