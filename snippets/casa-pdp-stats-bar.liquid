{%- comment -%}
  Casa PDP Stats Bar
  Displays 3 configurable stat cards in a row (e.g. "98% LOVE IT", "50K HOUR LIFE", "2 Yr WARRANTY")
{%- endcomment -%}

<div class="casa-stats-bar">
  <div class="casa-stats-bar__grid">
    {%- if block.settings.stat_1_value != blank -%}
      <div class="casa-stats-bar__card">
        <span class="casa-stats-bar__value">{{ block.settings.stat_1_value }}</span>
        <span class="casa-stats-bar__label">{{ block.settings.stat_1_label }}</span>
      </div>
    {%- endif -%}

    {%- if block.settings.stat_2_value != blank -%}
      <div class="casa-stats-bar__card">
        <span class="casa-stats-bar__value casa-stats-bar__value--pink">{{ block.settings.stat_2_value }}</span>
        <span class="casa-stats-bar__label">{{ block.settings.stat_2_label }}</span>
      </div>
    {%- endif -%}

    {%- if block.settings.stat_3_value != blank -%}
      <div class="casa-stats-bar__card">
        <span class="casa-stats-bar__value casa-stats-bar__value--cyan">{{ block.settings.stat_3_value }}</span>
        <span class="casa-stats-bar__label">{{ block.settings.stat_3_label }}</span>
      </div>
    {%- endif -%}
  </div>
</div>

<style>
.casa-stats-bar {
  min-width: 0;
  max-width: 100%;
  overflow: hidden;
}

.casa-stats-bar__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  border: 1px solid #e5e5e5;
  border-radius: 12px;
  overflow: hidden;
  min-width: 0;
}

.casa-stats-bar__card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 18px 12px;
  background: transparent;
  text-align: center;
  min-width: 0;
  overflow: hidden;
}

.casa-stats-bar__card:not(:last-child) {
  border-right: 1px solid #e5e5e5;
}

.casa-stats-bar__value {
  font-size: 28px;
  font-weight: 700;
  line-height: 1.1;
  background: linear-gradient(135deg, var(--cpm-accent-1, #9333ea), var(--cpm-accent-2, #ec4899));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
}

.casa-stats-bar__value--pink {
  background: linear-gradient(135deg, var(--cpm-accent-2, #ec4899), #f97316);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.casa-stats-bar__value--cyan {
  background: linear-gradient(135deg, #06b6d4, #3b82f6);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.casa-stats-bar__label {
  font-size: 12px;
  font-weight: 400;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  color: #757575;
  margin-top: 4px;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

@media (max-width: 480px) {
  .casa-stats-bar__card {
    padding: 14px 6px;
  }

  .casa-stats-bar__value {
    font-size: 20px;
  }

  .casa-stats-bar__label {
    font-size: 9px;
  }
}

@media (max-width: 375px) {
  .casa-stats-bar__value {
    font-size: 16px;
  }

  .casa-stats-bar__label {
    font-size: 8px;
  }
}
</style>
