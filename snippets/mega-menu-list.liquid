{%- doc -%}
  Renders drawer-style mega menu using submenu items (children of hovered item)
{%- enddoc -%}

{%- liquid
  assign bg_color = drawer_bg_color | default: '#C6D76B'
  assign bg_color_2 = drawer_bg_color_2 | default: '#a8c054'
  assign gradient_dir = drawer_gradient_direction | default: 'to bottom'
  assign use_gradient = drawer_bg_gradient
  assign text_color = drawer_text_color | default: '#1a1a1a'
  assign border_color = drawer_border_color | default: '#1a1a1a'
  assign border_radius = drawer_border_radius | default: 16
  assign gap = drawer_gap | default: 16
  assign padding = drawer_padding | default: 20
  assign show_labels = true
  if drawer_show_labels == false
    assign show_labels = false
  endif
  
  comment
    ALWAYS use the children (submenu) of the hovered parent item
    parent_link.links = the submenu items under Shop, About, etc.
  endcomment
  assign mega_menu_links = parent_link.links
  
  if drawer_menu_secondary != blank
    assign secondary_menu = linklists[drawer_menu_secondary]
  endif
-%}

<div 
  class="dw-drawer{% unless show_labels %} dw-drawer--no-labels{% endunless %}"
  style="
    {% if use_gradient %}
      --dw-bg: linear-gradient({{ gradient_dir }}, {{ bg_color }}, {{ bg_color_2 }});
    {% else %}
      --dw-bg: {{ bg_color }};
    {% endif %}
    --dw-text: {{ text_color }};
    --dw-border: {{ border_color }};
    --dw-radius: {{ border_radius }}px;
    --dw-gap: {{ gap }}px;
    --dw-padding: {{ padding }}px;
  "
>
  <!-- Scrollable Menu Items -->
  <div class="dw-drawer__scroll">
    
    <!-- Mega Menu - Shows children of hovered item -->
    <div class="dw-drawer__mega">
      {% for link in mega_menu_links %}
       {% liquid
  assign item_image = nil
  
  if link.object != blank
    if link.object.featured_image != blank
      assign item_image = link.object.featured_image
    elsif link.object.image != blank
      assign item_image = link.object.image
    elsif link.object.images != blank and link.object.images.first != blank
      assign item_image = link.object.images.first
    elsif link.object.products != blank and link.object.products.first != blank
      assign item_image = link.object.products.first.featured_image
    endif
  endif
%} {% liquid
          assign item_image = nil
          if link.type == 'collection_link' and link.object.image != blank
            assign item_image = link.object.image
          elsif link.type == 'collection_link' and link.object.products.first.featured_image != blank
            assign item_image = link.object.products.first.featured_image
          elsif link.type == 'product_link' and link.object.featured_image != blank
            assign item_image = link.object.featured_image
          endif
        %}
        
        <a href="{{ link.url }}" class="dw-drawer__item" style="--i: {{ forloop.index }};">
          <div class="dw-drawer__item-img">
            {% if item_image != blank %}
              <img 
                src="{{ item_image | image_url: width: 800 }}" 
                alt="{{ link.title | escape }}"
                loading="lazy"
              >
            {% else %}
              <div class="dw-drawer__item-placeholder">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                  <rect x="3" y="3" width="18" height="18" rx="2"></rect>
                  <circle cx="8.5" cy="8.5" r="1.5"></circle>
                  <polyline points="21 15 16 10 5 21"></polyline>
                </svg>
              </div>
            {% endif %}
          </div>
          {% if show_labels %}
            <span class="dw-drawer__item-label">{{ link.title }}</span>
          {% endif %}
        </a>
      {% endfor %}
    </div>

    <!-- Secondary Menu (Text Links) -->
    {% if secondary_menu.links.size > 0 %}
      <div class="dw-drawer__secondary">
        {% for link in secondary_menu.links %}
          <a href="{{ link.url }}" class="dw-drawer__link" style="--i: {{ forloop.index | plus: mega_menu_links.size }};">
            {{ link.title }}
          </a>
        {% endfor %}
      </div>
    {% endif %}

  </div>

  <!-- Footer -->
  <div class="dw-drawer__footer">
    {% if parent_link.url != '#' and parent_link.url != blank %}
      <a href="{{ parent_link.url }}" class="dw-drawer__viewall">
        View all {{ parent_link.title }}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    {% endif %}
  </div>
</div>

<style>
  .dw-drawer {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: var(--dw-bg);
    color: var(--dw-text);
  }

  .dw-drawer__scroll {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding: var(--dw-padding);
    display: flex;
    flex-direction: column;
    gap: 32px;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
  }

  .dw-drawer__scroll::-webkit-scrollbar {
    width: 3px;
  }

  .dw-drawer__scroll::-webkit-scrollbar-track {
    background: transparent;
  }

  .dw-drawer__scroll::-webkit-scrollbar-thumb {
    background: var(--dw-text);
    opacity: 0.2;
    border-radius: 3px;
  }

  .dw-drawer__mega {
    display: flex;
    flex-direction: column;
    gap: var(--dw-gap);
  }

  .dw-drawer__item {
    display: block;
    text-decoration: none;
    color: var(--dw-text);
    opacity: 0;
    transform: translateY(20px);
    animation: dw-fade-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--i, 1) * 60ms);
    position: relative;
  }

  @keyframes dw-fade-up {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .dw-drawer__item-img {
    position: relative;
    width: 100%;
    border-radius: var(--dw-radius);
    overflow: hidden;
    background: rgba(0,0,0,0.05);
  }

  .dw-drawer__item-img::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: var(--dw-radius);
    border: 3px solid var(--dw-border);
    opacity: 0;
    transform: scale(0.95);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 2;
    pointer-events: none;
  }

  .dw-drawer__item:hover .dw-drawer__item-img::before {
    opacity: 1;
    transform: scale(1);
  }

  .dw-drawer__item-img img {
    display: block;
    width: 100%;
    height: auto;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .dw-drawer__item:hover .dw-drawer__item-img img {
    transform: scale(1.04);
  }

  .dw-drawer__item-placeholder {
    width: 100%;
    aspect-ratio: 4 / 3;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .dw-drawer__item-placeholder svg {
    width: 32px;
    height: 32px;
    opacity: 0.2;
    color: var(--dw-text);
  }

  .dw-drawer__item-label {
    display: block;
    padding: 12px 4px 0;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.01em;
    transition: opacity 0.2s ease;
  }

  .dw-drawer__item:hover .dw-drawer__item-label {
    opacity: 0.7;
  }

  .dw-drawer--no-labels .dw-drawer__mega {
    gap: calc(var(--dw-gap) * 0.75);
  }

  .dw-drawer__secondary {
    display: flex;
    flex-direction: column;
    padding-top: 16px;
    border-top: 1px solid rgba(0,0,0,0.1);
  }

  .dw-drawer__link {
    display: block;
    padding: 14px 4px;
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    color: var(--dw-text);
    border-bottom: 1px solid rgba(0,0,0,0.08);
    opacity: 0;
    transform: translateY(10px);
    animation: dw-fade-up 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--i, 1) * 40ms);
    transition: opacity 0.2s ease;
  }

  .dw-drawer__link:last-child {
    border-bottom: none;
  }

  .dw-drawer__link:hover {
    opacity: 0.6;
  }

  .dw-drawer__footer {
    padding: var(--dw-padding);
    padding-bottom: calc(var(--dw-padding) + 8px);
    flex-shrink: 0;
  }

  .dw-drawer__footer:empty {
    display: none;
  }

  .dw-drawer__viewall {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--dw-text);
    text-decoration: none;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: gap 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .dw-drawer__viewall:hover {
    gap: 16px;
  }

  .dw-drawer__viewall svg {
    width: 16px;
    height: 16px;
    transition: transform 0.3s ease;
  }

  .dw-drawer__viewall:hover svg {
    transform: translateX(2px);
  }
</style>
```

---

**Also remove or clear the "Drawer mega menu" setting** in the customizer - leave it blank so it doesn't override.

---

**Now your menu structure:**
```
Main Menu (in header bar)
├── Shop (link: #) ← Stays in header, # means no click
│   ├── Hydration ← Shows in drawer when hovering Shop
│   ├── Energy ← Shows in drawer
│   └── Recovery ← Shows in drawer
├── Collections (link: #) ← Stays in header
│   ├── Summer ← Shows in drawer when hovering Collections  
│   └── Winter ← Shows in drawer
├── About (link: /pages/about) ← Regular link, no dropdown