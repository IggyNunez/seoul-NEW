{%- comment -%}
  Seoul Glow Lab - Mobile Navigation Drawer (Fully Customizable)
  All text, URLs, video, quick links, and product limits controlled via Casa Header schema.
{%- endcomment -%}

{%- comment -%} ── Overlay ── {%- endcomment -%}
<div class="casa-drawer-overlay" id="casa-drawer-overlay" aria-hidden="true"></div>

{%- comment -%} ── Drawer Panel ── {%- endcomment -%}
<div class="casa-drawer{% if drawer_glassmorphic %} casa-drawer--glass{% endif %}" id="casa-drawer" role="dialog" aria-modal="true" aria-label="Navigation menu" style="--drawer-logo-height: {{ drawer_logo_height | default: 28 }}px;">

  {%- comment -%} Header {%- endcomment -%}
  <div class="casa-drawer__header">
    {%- comment -%} Use drawer_logo_image if set, else fall back to header logo_image {%- endcomment -%}
    {%- assign effective_logo = drawer_logo_image | default: logo_image -%}
    <div class="casa-drawer__logo">
      {%- if effective_logo != blank -%}
        {{ effective_logo | image_url: width: 160 | image_tag: class: 'casa-drawer__logo-img', alt: logo_text | default: shop.name, loading: 'lazy' }}
      {%- else -%}
        <span class="casa-drawer__logo-text">{{ logo_text | default: 'SEOUL GLOW LAB' }}</span>
      {%- endif -%}
    </div>
    <div class="casa-drawer__header-actions">
      <button class="casa-drawer__header-btn" aria-label="Search" onclick="document.querySelector('.casa-drawer').classList.remove('active'); document.querySelector('.casa-drawer-overlay').classList.remove('active'); document.body.style.overflow = ''; document.querySelector('#search-modal')?.showDialog?.();">
        {%- render 'casa-icon', icon: 'search', size: 20 -%}
      </button>
      <button class="casa-drawer__close" data-casa-drawer-close aria-label="Close menu">
        {%- render 'casa-icon', icon: 'close', size: 20 -%}
      </button>
    </div>
  </div>

  {%- comment -%} Scrollable Content {%- endcomment -%}
  <div class="casa-drawer__content">

    {%- comment -%} Featured Promo Card (CRO: entire card clickable when promo_link set) {%- endcomment -%}
    {%- if promo_link != blank -%}
      <a href="{{ promo_link }}" class="casa-drawer__featured casa-drawer__featured--clickable">
    {%- else -%}
      <div class="casa-drawer__featured">
    {%- endif -%}
      <div class="casa-drawer__featured-content">
        <div class="casa-drawer__featured-visual">
          {%- if promo_image -%}
            {{ promo_image | image_url: width: 200 | image_tag: loading: 'lazy', class: 'casa-drawer__featured-img' }}
          {%- elsif video_url != blank -%}
            <video class="casa-drawer__featured-video" autoplay loop muted playsinline>
              <source src="{{ video_url }}" type="video/mp4">
            </video>
          {%- else -%}
            <div class="casa-drawer__featured-placeholder">
              {%- render 'casa-icon', icon: 'sparkles', size: 24 -%}
            </div>
          {%- endif -%}
        </div>
        <div class="casa-drawer__featured-text">
          <span class="casa-drawer__featured-label">
            {%- render 'casa-icon', icon: 'sparkles', size: 12 -%}
            {{ promo_title | default: 'New Collection' }}
          </span>
          <p class="casa-drawer__featured-desc">{{ promo_subtitle | default: 'Infinity Mirror Series now available' }}</p>
          <span class="casa-drawer__featured-link" aria-hidden="true">
            {{ mobile_promo_btn_text | default: 'Shop Now' }} {%- render 'casa-icon', icon: 'arrow-right', size: 14 -%}
          </span>
        </div>
      </div>
    {%- if promo_link != blank -%}
      </a>
    {%- else -%}
      </div>
    {%- endif -%}

    {%- comment -%} Navigation Items {%- endcomment -%}
    <nav class="casa-drawer__nav" aria-label="Main navigation">
      {%- for link in linklists[menu].links -%}
        {%- assign link_collection = collections[link.handle] -%}
        {%- assign link_icon = link.handle -%}
        {%- assign link_badge = '' -%}
        {%- if link_collection.metafields.sgl.icon != blank -%}
          {%- assign link_icon = link_collection.metafields.sgl.icon -%}
        {%- endif -%}
        {%- if link_collection.metafields.sgl.badge != blank -%}
          {%- assign link_badge = link_collection.metafields.sgl.badge -%}
        {%- endif -%}

        <div class="casa-drawer__nav-item">
          {%- if link.links.size > 0 -%}
            {%- comment -%} Has children → opens submenu panel {%- endcomment -%}
            <button class="casa-drawer__nav-link" data-casa-submenu-open="{{ link.handle }}" aria-expanded="false" aria-controls="casa-submenu-{{ link.handle }}">
              <div class="casa-drawer__nav-icon">
                {%- render 'casa-icon', icon: link_icon, size: 22 -%}
              </div>
              <div class="casa-drawer__nav-content">
                <span class="casa-drawer__nav-title">{{ link.title }}</span>
                {%- if link_collection -%}
                  <span class="casa-drawer__nav-subtitle">{{ link_collection.products_count }} products</span>
                {%- endif -%}
              </div>
              {%- if link_badge != blank -%}
                <span class="casa-drawer__nav-badge casa-drawer__nav-badge--{{ link_badge | downcase }}">{{ link_badge }}</span>
              {%- endif -%}
              <div class="casa-drawer__nav-arrow">
                {%- render 'casa-icon', icon: 'chevron-right', size: 16 -%}
              </div>
            </button>
          {%- else -%}
            {%- comment -%} No children → direct link {%- endcomment -%}
            <a href="{{ link.url }}" class="casa-drawer__nav-link">
              <div class="casa-drawer__nav-icon">
                {%- render 'casa-icon', icon: link_icon, size: 22 -%}
              </div>
              <div class="casa-drawer__nav-content">
                <span class="casa-drawer__nav-title">{{ link.title }}</span>
                {%- if link_collection -%}
                  <span class="casa-drawer__nav-subtitle">{{ link_collection.products_count }} products</span>
                {%- endif -%}
              </div>
              {%- if link_badge != blank -%}
                <span class="casa-drawer__nav-badge casa-drawer__nav-badge--{{ link_badge | downcase }}">{{ link_badge }}</span>
              {%- endif -%}
            </a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </nav>

    {%- comment -%} Secondary Menu (extra pages: About, Contact, FAQ, etc.) {%- endcomment -%}
    {%- if drawer_secondary_menu != blank and linklists[drawer_secondary_menu].links.size > 0 -%}
      <div class="casa-drawer__divider"></div>
      <div class="casa-drawer__secondary-nav">
        {%- if drawer_secondary_title != blank -%}
          <div class="casa-drawer__secondary-title">{{ drawer_secondary_title }}</div>
        {%- endif -%}
        <div class="casa-drawer__secondary-links">
          {%- for link in linklists[drawer_secondary_menu].links -%}
            <a href="{{ link.url }}" class="casa-drawer__secondary-link">
              <span>{{ link.title }}</span>
              {%- render 'casa-icon', icon: 'chevron-right', size: 14 -%}
            </a>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    {%- comment -%} Divider {%- endcomment -%}
    <div class="casa-drawer__divider"></div>

    {%- comment -%} Quick Links (pre-rendered from blocks) {%- endcomment -%}
    {%- if mobile_quick_links_html != blank -%}
      <div class="casa-drawer__secondary">
        <div class="casa-drawer__secondary-title">{{ mobile_quick_links_title | default: 'Quick Links' }}</div>
        <div class="casa-drawer__secondary-links">
          {{ mobile_quick_links_html }}
        </div>
      </div>
    {%- endif -%}
  </div>

  {%- comment -%} Footer {%- endcomment -%}
  <div class="casa-drawer__footer">
    {%- comment -%} Country/Currency Selector {%- endcomment -%}
    {%- if localization.available_countries.size > 1 or localization.available_languages.size > 1 -%}
      <button class="casa-drawer__locale-btn" aria-label="Country and language">
        {%- render 'casa-icon', icon: 'globe', size: 18 -%}
        <span class="casa-drawer__locale-country">{{ localization.country.name }}</span>
        <span class="casa-drawer__locale-currency">({{ localization.country.currency.iso_code }} {{ localization.country.currency.symbol }})</span>
        {%- render 'casa-icon', icon: 'chevron-right', size: 14 -%}
      </button>
    {%- endif -%}

    <div class="casa-drawer__social">
      <a href="{{ settings.social_instagram_link }}" class="casa-drawer__social-link" aria-label="Instagram" target="_blank" rel="noopener">
        {%- render 'casa-icon', icon: 'instagram', size: 20 -%}
      </a>
      <a href="{{ settings.social_tiktok_link }}" class="casa-drawer__social-link" aria-label="TikTok" target="_blank" rel="noopener">
        {%- render 'casa-icon', icon: 'tiktok', size: 20 -%}
      </a>
      <a href="{{ settings.social_pinterest_link }}" class="casa-drawer__social-link" aria-label="Pinterest" target="_blank" rel="noopener">
        {%- render 'casa-icon', icon: 'pinterest', size: 20 -%}
      </a>
      <a href="{{ settings.social_youtube_link }}" class="casa-drawer__social-link" aria-label="YouTube" target="_blank" rel="noopener">
        {%- render 'casa-icon', icon: 'youtube', size: 20 -%}
      </a>
    </div>
    <p class="casa-drawer__copyright">&copy; {{ 'now' | date: '%Y' }} {{ logo_text | default: 'Seoul Glow Lab' }}. All rights reserved.</p>
  </div>
</div>

{%- comment -%} ── Render Submenu Panels ── {%- endcomment -%}
{%- for link in linklists[menu].links -%}
  {%- if link.links.size > 0 -%}
    {%- render 'casa-submenu-panel', link: link, panel_id: link.handle, submenu_product_limit: submenu_product_limit, drawer_glassmorphic: drawer_glassmorphic -%}
  {%- endif -%}
{%- endfor -%}

{% stylesheet %}
  /* ── Drawer Overlay ── */
  .casa-drawer-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 1100;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s;
  }
  .casa-drawer-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  /* ── Drawer Panel ── */
  .casa-drawer {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    max-width: 340px;
    height: 100%;
    background: linear-gradient(180deg, color-mix(in srgb, var(--casa-drawer-bg, #0a0a0f) 100%, white 5%) 0%, var(--casa-drawer-bg, #0a0a0f) 100%);
    z-index: 1200;
    transform: translateX(-100%);
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    color: white;
  }
  .casa-drawer.active {
    transform: translateX(0);
  }

  /* Ambient glow - uses drawer accent color */
  .casa-drawer::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 200px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(var(--casa-drawer-accent-rgb, 147, 51, 234), 0.15) 0%, transparent 70%);
    pointer-events: none;
  }
  .casa-drawer::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 200px;
    height: 300px;
    background: radial-gradient(ellipse, rgba(var(--casa-glow-secondary-rgb, 236, 72, 153), 0.1) 0%, transparent 70%);
    pointer-events: none;
  }

  /* ── Header ── */
  .casa-drawer__header {
    padding: 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    position: relative;
    z-index: 1;
  }
  .casa-drawer__logo {
    display: flex;
    align-items: center;
    height: var(--drawer-logo-height, 28px);
  }
  .casa-drawer__logo-img {
    height: var(--drawer-logo-height, 28px);
    width: auto;
    object-fit: contain;
  }
  .casa-drawer__logo-text {
    font-size: 14px;
    font-weight: 300;
    letter-spacing: 3px;
  }
  .casa-drawer__close {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.2s;
    color: white;
  }
  .casa-drawer__close:hover { background: rgba(255, 255, 255, 0.1); }

  .casa-drawer__header-actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .casa-drawer__header-btn {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.2s;
    color: white;
  }
  .casa-drawer__header-btn:hover { background: rgba(255, 255, 255, 0.1); }

  /* ── Content (scrollable) ── */
  .casa-drawer__content {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    position: relative;
    z-index: 1;
  }
  .casa-drawer__content::-webkit-scrollbar { width: 4px; }
  .casa-drawer__content::-webkit-scrollbar-track { background: transparent; }
  .casa-drawer__content::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); border-radius: 4px; }

  /* ── Featured Card ── */
  .casa-drawer__featured {
    margin: 16px;
    padding: 20px;
    background: linear-gradient(135deg, rgba(var(--casa-drawer-accent-rgb, 147, 51, 234), 0.2), rgba(var(--casa-glow-secondary-rgb, 236, 72, 153), 0.15));
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    position: relative;
    overflow: hidden;
  }
  .casa-drawer__featured::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--casa-drawer-accent, #9333ea), var(--casa-glow-secondary, #ec4899), var(--casa-support-primary, #06b6d4));
  }
  .casa-drawer__featured-content {
    display: flex;
    gap: 16px;
    align-items: center;
  }
  .casa-drawer__featured-visual {
    width: 70px;
    height: 70px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    overflow: hidden;
  }
  .casa-drawer__featured-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 12px;
  }
  .casa-drawer__featured--clickable {
    display: block;
    text-decoration: none;
    color: white;
    cursor: pointer;
    transition: transform 0.2s, border-color 0.2s;
  }
  .casa-drawer__featured--clickable:active {
    transform: scale(0.98);
    border-color: rgba(var(--casa-drawer-accent-rgb, 147, 51, 234), 0.4);
  }
  .casa-drawer__featured-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 12px;
  }
  .casa-drawer__featured-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(var(--casa-drawer-accent-rgb, 147, 51, 234), 0.3), rgba(var(--casa-glow-secondary-rgb, 236, 72, 153), 0.2));
    border-radius: 12px;
    color: rgba(255, 255, 255, 0.5);
  }
  .casa-drawer__featured-label {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--casa-glow-secondary, #ec4899);
    margin-bottom: 4px;
  }
  .casa-drawer__featured-desc {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.4;
    margin-bottom: 8px;
  }
  .casa-drawer__featured-link {
    font-size: 12px;
    font-weight: 600;
    color: var(--casa-drawer-accent, #9333ea);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    transition: gap 0.2s;
  }
  .casa-drawer__featured-link:hover { gap: 8px; }

  /* ── Navigation Items ── */
  .casa-drawer__nav { padding: 8px 0; }

  .casa-drawer__nav-link {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 20px;
    color: white;
    text-decoration: none;
    transition: all 0.2s;
    background: none;
    border: none;
    width: 100%;
    text-align: left;
    cursor: pointer;
    font-family: inherit;
    font-size: inherit;
  }
  .casa-drawer__nav-link:active {
    background: rgba(255, 255, 255, 0.05);
  }

  .casa-drawer__nav-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: linear-gradient(135deg, rgba(var(--casa-drawer-accent-rgb, 147, 51, 234), 0.15), rgba(var(--casa-glow-secondary-rgb, 236, 72, 153), 0.1));
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s;
    flex-shrink: 0;
  }
  .casa-drawer__nav-link:active .casa-drawer__nav-icon {
    background: linear-gradient(135deg, var(--casa-drawer-accent, #9333ea), var(--casa-glow-secondary, #ec4899));
    box-shadow: 0 4px 16px rgba(var(--casa-drawer-accent-rgb, 147, 51, 234), 0.4);
  }

  .casa-drawer__nav-content { flex: 1; }
  .casa-drawer__nav-title { font-size: 15px; font-weight: 500; display: block; margin-bottom: 2px; }
  .casa-drawer__nav-subtitle { font-size: 12px; color: rgba(255, 255, 255, 0.4); display: block; }

  .casa-drawer__nav-badge {
    font-size: 9px;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 20px;
    text-transform: uppercase;
    color: white;
  }
  .casa-drawer__nav-badge--hot { background: var(--casa-gold, #f59e0b); color: #000; }
  .casa-drawer__nav-badge--new { background: var(--casa-green, #22c55e); }
  .casa-drawer__nav-badge--sale { background: var(--casa-red, #ef4444); }

  .casa-drawer__nav-arrow {
    width: 28px;
    height: 28px;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    flex-shrink: 0;
    color: rgba(255, 255, 255, 0.5);
  }

  /* ── Divider ── */
  .casa-drawer__divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
    margin: 8px 20px;
  }

  /* ── Quick Links ── */
  .casa-drawer__secondary { padding: 8px 20px 16px; }
  .casa-drawer__secondary-title {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: rgba(255, 255, 255, 0.3);
    margin-bottom: 12px;
    padding-left: 4px;
  }
  .casa-drawer__secondary-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .casa-drawer__secondary-link {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 100px;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    font-size: 12px;
    transition: all 0.2s;
  }
  .casa-drawer__secondary-link:active {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(var(--casa-drawer-accent-rgb, 147, 51, 234), 0.3);
    color: white;
  }

  /* ── Secondary Nav (extra pages menu) ── */
  .casa-drawer__secondary-nav { padding: 8px 20px 16px; }
  .casa-drawer__secondary-nav .casa-drawer__secondary-link {
    justify-content: space-between;
    width: 100%;
    border-radius: 10px;
  }
  .casa-drawer__secondary-nav .casa-drawer__secondary-link svg {
    opacity: 0.3;
  }

  /* ── Footer ── */
  .casa-drawer__footer {
    padding: 16px 20px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    position: relative;
    z-index: 1;
  }

  /* Locale/Currency Button */
  .casa-drawer__locale-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    padding: 12px 16px;
    margin-bottom: 16px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    color: white;
    font-size: 13px;
    cursor: pointer;
    transition: all 0.2s;
  }
  .casa-drawer__locale-btn:active {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(var(--casa-drawer-accent-rgb, 147, 51, 234), 0.3);
  }
  .casa-drawer__locale-country {
    flex: 1;
    text-align: left;
    font-weight: 500;
  }
  .casa-drawer__locale-currency {
    color: rgba(255, 255, 255, 0.5);
    font-size: 12px;
  }

  .casa-drawer__social {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-bottom: 16px;
  }
  .casa-drawer__social-link {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    color: white;
  }
  .casa-drawer__social-link:active {
    background: var(--casa-drawer-accent, #9333ea);
    border-color: var(--casa-drawer-accent, #9333ea);
  }
  .casa-drawer__copyright {
    font-size: 11px;
    color: rgba(255, 255, 255, 0.3);
    text-align: center;
    margin: 0;
  }

  /* ═══════════════════════════════════════════════════════
     GLASSMORPHIC DRAWER — Apple-style frosted glass
     All colors driven by --casa-glass-* CSS custom properties
     set in casa-header.liquid from customizer settings.
     ═══════════════════════════════════════════════════════ */
  .casa-drawer--glass {
    background: rgba(var(--casa-glass-tint-rgb), var(--casa-glass-opacity));
    backdrop-filter: blur(var(--casa-glass-blur)) saturate(180%);
    -webkit-backdrop-filter: blur(var(--casa-glass-blur)) saturate(180%);
    color: var(--casa-glass-text);
  }
  .casa-drawer--glass::before,
  .casa-drawer--glass::after {
    display: none;
  }
  .casa-drawer--glass .casa-drawer__header {
    border-bottom-color: rgba(var(--casa-glass-border-rgb), 0.25);
  }
  .casa-drawer--glass .casa-drawer__logo,
  .casa-drawer--glass .casa-drawer__logo-text {
    color: var(--casa-glass-text);
  }
  .casa-drawer--glass .casa-drawer__close,
  .casa-drawer--glass .casa-drawer__header-btn {
    background: rgba(var(--casa-glass-icon-bg-rgb), 0.35);
    border-color: rgba(var(--casa-glass-border-rgb), 0.3);
    color: var(--casa-glass-text);
  }
  .casa-drawer--glass .casa-drawer__close:hover,
  .casa-drawer--glass .casa-drawer__header-btn:hover {
    background: rgba(var(--casa-glass-icon-bg-rgb), 0.55);
  }
  .casa-drawer--glass .casa-drawer__featured {
    background: rgba(var(--casa-glass-card-bg-rgb), 0.4);
    border-color: rgba(var(--casa-glass-border-rgb), 0.25);
  }
  .casa-drawer--glass .casa-drawer__featured::before {
    background: linear-gradient(90deg, rgba(var(--casa-glass-text-rgb), 0.12), rgba(var(--casa-glass-text-rgb), 0.06), rgba(var(--casa-glass-text-rgb), 0.03));
  }
  .casa-drawer--glass .casa-drawer__featured-label {
    color: var(--casa-glass-text-muted);
  }
  .casa-drawer--glass .casa-drawer__featured-desc {
    color: rgba(var(--casa-glass-text-muted-rgb), 0.75);
  }
  .casa-drawer--glass .casa-drawer__featured-link {
    color: var(--casa-glass-text);
  }
  .casa-drawer--glass .casa-drawer__featured-placeholder {
    background: rgba(var(--casa-glass-icon-bg-rgb), 0.3);
    color: rgba(var(--casa-glass-text-muted-rgb), 0.5);
  }
  .casa-drawer--glass .casa-drawer__nav-link {
    color: var(--casa-glass-text);
  }
  .casa-drawer--glass .casa-drawer__nav-link:active {
    background: rgba(var(--casa-glass-icon-bg-rgb), 0.3);
  }
  .casa-drawer--glass .casa-drawer__nav-icon {
    background: rgba(var(--casa-glass-icon-bg-rgb), 0.4);
  }
  .casa-drawer--glass .casa-drawer__nav-link:active .casa-drawer__nav-icon {
    background: var(--casa-glass-icon-active);
    box-shadow: none;
    color: var(--casa-glass-card-bg);
  }
  .casa-drawer--glass .casa-drawer__nav-subtitle {
    color: var(--casa-glass-text-muted);
  }
  .casa-drawer--glass .casa-drawer__nav-arrow {
    background: rgba(var(--casa-glass-icon-bg-rgb), 0.3);
    color: var(--casa-glass-text-muted);
  }
  .casa-drawer--glass .casa-drawer__divider {
    background: linear-gradient(90deg, transparent, rgba(var(--casa-glass-border-rgb), 0.35), transparent);
  }
  .casa-drawer--glass .casa-drawer__secondary-title {
    color: var(--casa-glass-text-muted);
  }
  .casa-drawer--glass .casa-drawer__secondary-link {
    background: rgba(var(--casa-glass-card-bg-rgb), 0.25);
    border-color: rgba(var(--casa-glass-border-rgb), 0.3);
    color: var(--casa-glass-text);
  }
  .casa-drawer--glass .casa-drawer__secondary-link:active {
    background: rgba(var(--casa-glass-icon-bg-rgb), 0.45);
    border-color: rgba(var(--casa-glass-border-rgb), 0.5);
    color: var(--casa-glass-text);
  }
  .casa-drawer--glass .casa-drawer__footer {
    border-top-color: rgba(var(--casa-glass-border-rgb), 0.25);
  }
  .casa-drawer--glass .casa-drawer__locale-btn {
    background: rgba(var(--casa-glass-card-bg-rgb), 0.25);
    border-color: rgba(var(--casa-glass-border-rgb), 0.3);
    color: var(--casa-glass-text);
  }
  .casa-drawer--glass .casa-drawer__locale-btn:active {
    background: rgba(var(--casa-glass-icon-bg-rgb), 0.45);
  }
  .casa-drawer--glass .casa-drawer__locale-currency {
    color: var(--casa-glass-text-muted);
  }
  .casa-drawer--glass .casa-drawer__social-link {
    background: rgba(var(--casa-glass-card-bg-rgb), 0.25);
    border-color: rgba(var(--casa-glass-border-rgb), 0.3);
    color: var(--casa-glass-text);
  }
  .casa-drawer--glass .casa-drawer__social-link:active {
    background: var(--casa-glass-icon-active);
    border-color: var(--casa-glass-icon-active);
    color: var(--casa-glass-card-bg);
  }
  .casa-drawer--glass .casa-drawer__copyright {
    color: var(--casa-glass-text-muted);
  }
  .casa-drawer--glass .casa-drawer__content::-webkit-scrollbar-thumb {
    background: rgba(var(--casa-glass-border-rgb), 0.3);
  }

  /* ═══════════════════════════════════════════════════════
     RESPONSIVE: VERY SMALL MOBILE (375px and below)
     Optimized for iPhone SE and similar small devices
     ═══════════════════════════════════════════════════════ */
  @media (max-width: 375px) {
    .casa-drawer {
      max-width: 100%;
    }

    .casa-drawer__header {
      padding: 16px;
    }

    .casa-drawer__logo { height: var(--drawer-logo-height, 24px); }
    .casa-drawer__logo-img { height: var(--drawer-logo-height, 24px); }
    .casa-drawer__logo-text {
      font-size: 12px;
      letter-spacing: 2px;
    }

    .casa-drawer__close,
    .casa-drawer__header-btn {
      width: 36px;
      height: 36px;
      border-radius: 10px;
    }

    .casa-drawer__header-actions {
      gap: 6px;
    }

    .casa-drawer__featured {
      margin: 12px;
      padding: 14px;
    }

    .casa-drawer__featured-visual {
      width: 56px;
      height: 56px;
      border-radius: 10px;
    }

    .casa-drawer__featured-content {
      gap: 12px;
    }

    .casa-drawer__featured-label {
      font-size: 9px;
    }

    .casa-drawer__featured-desc {
      font-size: 11px;
    }

    .casa-drawer__featured-link {
      font-size: 11px;
    }

    .casa-drawer__nav-link {
      padding: 12px 16px;
      gap: 12px;
    }

    .casa-drawer__nav-icon {
      width: 38px;
      height: 38px;
      border-radius: 10px;
    }

    .casa-drawer__nav-icon svg {
      width: 18px;
      height: 18px;
    }

    .casa-drawer__nav-title {
      font-size: 14px;
    }

    .casa-drawer__nav-subtitle {
      font-size: 11px;
    }

    .casa-drawer__nav-badge {
      font-size: 8px;
      padding: 3px 8px;
    }

    .casa-drawer__nav-arrow {
      width: 24px;
      height: 24px;
      border-radius: 6px;
    }

    .casa-drawer__divider {
      margin: 6px 16px;
    }

    .casa-drawer__secondary {
      padding: 6px 16px 12px;
    }

    .casa-drawer__secondary-title {
      font-size: 9px;
      margin-bottom: 10px;
    }

    .casa-drawer__secondary-links {
      gap: 6px;
    }

    .casa-drawer__secondary-link {
      padding: 8px 12px;
      font-size: 11px;
    }

    .casa-drawer__footer {
      padding: 12px 16px;
    }

    .casa-drawer__locale-btn {
      padding: 10px 14px;
      font-size: 12px;
      margin-bottom: 12px;
    }

    .casa-drawer__social {
      gap: 10px;
      margin-bottom: 12px;
    }

    .casa-drawer__social-link {
      width: 38px;
      height: 38px;
      border-radius: 10px;
    }

    .casa-drawer__social-link svg {
      width: 18px;
      height: 18px;
    }

    .casa-drawer__copyright {
      font-size: 10px;
    }
  }

  /* ═══════════════════════════════════════════════════════
     RESPONSIVE: EXTRA SMALL MOBILE (320px and below)
     For very narrow screens
     ═══════════════════════════════════════════════════════ */
  @media (max-width: 320px) {
    .casa-drawer__header {
      padding: 12px;
    }

    .casa-drawer__logo { height: var(--drawer-logo-height, 20px); }
    .casa-drawer__logo-img { height: var(--drawer-logo-height, 20px); }
    .casa-drawer__logo-text {
      font-size: 11px;
      letter-spacing: 1.5px;
    }

    .casa-drawer__close,
    .casa-drawer__header-btn {
      width: 32px;
      height: 32px;
    }

    .casa-drawer__featured {
      margin: 10px;
      padding: 12px;
    }

    .casa-drawer__featured-visual {
      width: 48px;
      height: 48px;
    }

    .casa-drawer__nav-link {
      padding: 10px 12px;
      gap: 10px;
    }

    .casa-drawer__nav-icon {
      width: 34px;
      height: 34px;
    }

    .casa-drawer__nav-title {
      font-size: 13px;
    }

    .casa-drawer__nav-badge {
      display: none;
    }

    .casa-drawer__secondary {
      padding: 4px 12px 10px;
    }

    .casa-drawer__secondary-link {
      padding: 6px 10px;
      font-size: 10px;
    }

    .casa-drawer__footer {
      padding: 10px 12px;
    }

    .casa-drawer__social-link {
      width: 34px;
      height: 34px;
    }
  }
{% endstylesheet %}
