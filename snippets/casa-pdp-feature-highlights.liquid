{%- comment -%}
  Casa PDP Feature Highlights
  2×2 grid with purple checkmarks

  Parameters:
  - block: The block object with settings
{%- endcomment -%}

{%- liquid
  assign highlight_1 = block.settings.highlight_1 | default: '16+ Million RGB Colors'
  assign highlight_2 = block.settings.highlight_2 | default: 'App & Voice Control'
  assign highlight_3 = block.settings.highlight_3 | default: 'Mirror by Day, Portal by Night'
  assign highlight_4 = block.settings.highlight_4 | default: '50,000 Hour LED Lifespan'
-%}

<div class="casa-pdp-highlights">
  {%- if highlight_1 != blank -%}
    <div class="casa-pdp-highlights__item">
      <span class="casa-pdp-highlights__icon">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </span>
      <span class="casa-pdp-highlights__text">{{ highlight_1 }}</span>
    </div>
  {%- endif -%}

  {%- if highlight_2 != blank -%}
    <div class="casa-pdp-highlights__item">
      <span class="casa-pdp-highlights__icon">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </span>
      <span class="casa-pdp-highlights__text">{{ highlight_2 }}</span>
    </div>
  {%- endif -%}

  {%- if highlight_3 != blank -%}
    <div class="casa-pdp-highlights__item">
      <span class="casa-pdp-highlights__icon">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </span>
      <span class="casa-pdp-highlights__text">{{ highlight_3 }}</span>
    </div>
  {%- endif -%}

  {%- if highlight_4 != blank -%}
    <div class="casa-pdp-highlights__item">
      <span class="casa-pdp-highlights__icon">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </span>
      <span class="casa-pdp-highlights__text">{{ highlight_4 }}</span>
    </div>
  {%- endif -%}
</div>

<style>
.casa-pdp-highlights {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px 16px;
}

.casa-pdp-highlights__item {
  display: flex;
  align-items: center;
  gap: 10px;
}

.casa-pdp-highlights__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 20px;
  height: 20px;
  border-radius: 10px;
  background: linear-gradient(135deg, #9333ea, #ec4899);
  color: #fff;
}

.casa-pdp-highlights__icon svg {
  width: 12px;
  height: 12px;
  stroke: #fff;
}

.casa-pdp-highlights__text {
  font-size: 14px;
  color: #757575;
  line-height: 1.5;
}

@media (max-width: 480px) {
  .casa-pdp-highlights {
    gap: 10px 12px;
  }

  .casa-pdp-highlights__text {
    font-size: 13px;
  }
}
</style>
