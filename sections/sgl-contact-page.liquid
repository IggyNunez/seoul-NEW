{%- comment -%}
  Seoul Glow Lab — Contact Page Section
  Hero + info cards + form + store location + FAQ — all in one branded section
{%- endcomment -%}

{%- liquid
  assign s = section.settings
-%}

<div class="sgl-contact" style="
  --sgl-c-bg: {{ s.bg_color | default: '#F8EBDA' }};
  --sgl-c-text: {{ s.text_color | default: '#5E0A02' }};
  --sgl-c-accent: {{ s.accent_color | default: '#B0C3FA' }};
  --sgl-c-card-bg: {{ s.card_bg_color | default: '#ffffff' }};
  --sgl-c-btn-bg: {{ s.btn_bg_color | default: '#5E0A02' }};
  --sgl-c-btn-text: {{ s.btn_text_color | default: '#F8EBDA' }};
" {{ section.shopify_attributes }}>

  {%- comment -%} ══ 1. Hero Banner ══ {%- endcomment -%}
  <div class="sgl-contact__hero">
    {%- if s.hero_image != blank -%}
      <div class="sgl-contact__hero-media">
        {{ s.hero_image | image_url: width: 1920 | image_tag: class: 'sgl-contact__hero-img', loading: 'eager' }}
        <div class="sgl-contact__hero-overlay"></div>
      </div>
    {%- endif -%}
    <div class="sgl-contact__hero-content">
      {%- if s.hero_subtitle != blank -%}
        <div class="sgl-contact__tag">{{ s.hero_subtitle }}</div>
      {%- endif -%}
      <h1 class="sgl-contact__hero-title">{{ s.hero_title | default: 'Get in Touch' }}</h1>
      {%- if s.hero_description != blank -%}
        <p class="sgl-contact__hero-desc">{{ s.hero_description }}</p>
      {%- endif -%}
    </div>
  </div>

  <div class="sgl-contact__body">

    {%- comment -%} ══ 2. Info Cards ══ {%- endcomment -%}
    {%- assign has_cards = false -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'info_card' -%}{%- assign has_cards = true -%}{%- break -%}{%- endif -%}
    {%- endfor -%}

    {%- if has_cards -%}
      <div class="sgl-contact__cards">
        {%- for block in section.blocks -%}
          {%- if block.type == 'info_card' -%}
            <div class="sgl-contact__card" style="--i: {{ forloop.index }}" {{ block.shopify_attributes }}>
              {%- if block.settings.icon_image != blank -%}
                <div class="sgl-contact__card-icon">
                  {{ block.settings.icon_image | image_url: width: 80 | image_tag: loading: 'lazy' }}
                </div>
              {%- endif -%}
              <h3 class="sgl-contact__card-title">{{ block.settings.title }}</h3>
              {%- if block.settings.description != blank -%}
                <div class="sgl-contact__card-desc">{{ block.settings.description }}</div>
              {%- endif -%}
              {%- if block.settings.email != blank -%}
                <a href="mailto:{{ block.settings.email }}" class="sgl-contact__card-link">{{ block.settings.email }}</a>
              {%- endif -%}
              {%- if block.settings.detail != blank -%}
                <div class="sgl-contact__card-detail">{{ block.settings.detail }}</div>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} ══ 3. Contact Form ══ {%- endcomment -%}
    <div class="sgl-contact__form-section" id="contact-form">
      <div class="sgl-contact__form-header">
        <h2 class="sgl-contact__section-title">{{ s.form_title | default: 'Send Us a Message' }}</h2>
        {%- if s.form_description != blank -%}
          <p class="sgl-contact__section-desc">{{ s.form_description }}</p>
        {%- endif -%}
      </div>

      {%- form 'contact', class: 'sgl-contact__form' -%}
        {%- if form.posted_successfully? -%}
          <div class="sgl-contact__form-success">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <p>Thank you! We'll get back to you soon.</p>
          </div>
        {%- endif -%}

        {%- if form.errors -%}
          <div class="sgl-contact__form-error">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="sgl-contact__form-row">
          <div class="sgl-contact__field">
            <label for="contact-first-name">First name</label>
            <input type="text" id="contact-first-name" name="contact[first_name]" placeholder="Your first name" autocomplete="given-name">
          </div>
          <div class="sgl-contact__field">
            <label for="contact-last-name">Last name</label>
            <input type="text" id="contact-last-name" name="contact[last_name]" placeholder="Your last name" autocomplete="family-name">
          </div>
        </div>

        <div class="sgl-contact__field">
          <label for="contact-email">Email *</label>
          <input type="email" id="contact-email" name="contact[email]" placeholder="your@email.com" required autocomplete="email">
        </div>

        <div class="sgl-contact__field">
          <label for="contact-subject">Subject</label>
          <select id="contact-subject" name="contact[subject]">
            <option value="">Select a topic</option>
            <option value="Customer Support">Customer Support</option>
            <option value="Skincare Consultation">Skincare Consultation</option>
            <option value="Press & Partnerships">Press & Partnerships</option>
            <option value="Other">Other</option>
          </select>
        </div>

        <div class="sgl-contact__field">
          <label for="contact-message">Message</label>
          <textarea id="contact-message" name="contact[body]" rows="5" placeholder="Tell us how we can help you..."></textarea>
        </div>

        <button type="submit" class="sgl-contact__submit">{{ s.form_button | default: 'Send Message' }}</button>
      {%- endform -%}
    </div>

    {%- comment -%} ══ 4. Store Location ══ {%- endcomment -%}
    {%- if s.store_title != blank or s.map_embed != blank -%}
      <div class="sgl-contact__store">
        <div class="sgl-contact__store-info">
          <h2 class="sgl-contact__section-title">{{ s.store_title | default: 'Visit Our Store' }}</h2>

          {%- for block in section.blocks -%}
            {%- if block.type == 'store_detail' -%}
              <div class="sgl-contact__store-detail" {{ block.shopify_attributes }}>
                {%- if block.settings.icon_image != blank -%}
                  <div class="sgl-contact__store-icon">
                    {{ block.settings.icon_image | image_url: width: 48 | image_tag: loading: 'lazy' }}
                  </div>
                {%- endif -%}
                <div>
                  {%- if block.settings.label != blank -%}
                    <strong class="sgl-contact__store-label">{{ block.settings.label }}</strong>
                  {%- endif -%}
                  {%- if block.settings.text != blank -%}
                    <div class="sgl-contact__store-text">{{ block.settings.text }}</div>
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}

          {%- if s.store_description != blank -%}
            <p class="sgl-contact__store-desc">{{ s.store_description }}</p>
          {%- endif -%}

          {%- if s.directions_link != blank -%}
            <a href="{{ s.directions_link }}" target="_blank" rel="noopener" class="sgl-contact__btn">
              {{ s.directions_text | default: 'Get Directions' }}
            </a>
          {%- endif -%}
        </div>

        {%- if s.map_embed != blank -%}
          <div class="sgl-contact__map">
            <iframe src="{{ s.map_embed }}" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} ══ 5. FAQ ══ {%- endcomment -%}
    {%- assign has_faq = false -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'faq' -%}{%- assign has_faq = true -%}{%- break -%}{%- endif -%}
    {%- endfor -%}

    {%- if has_faq -%}
      <div class="sgl-contact__faq">
        <h2 class="sgl-contact__section-title" style="text-align:center;">{{ s.faq_title | default: 'Frequently Asked Questions' }}</h2>
        {%- if s.faq_subtitle != blank -%}
          <p class="sgl-contact__section-desc" style="text-align:center;">{{ s.faq_subtitle }}</p>
        {%- endif -%}

        <div class="sgl-contact__faq-list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'faq' -%}
              <details class="sgl-contact__faq-item" {{ block.shopify_attributes }}>
                <summary class="sgl-contact__faq-q">
                  <span>{{ block.settings.question }}</span>
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
                </summary>
                <div class="sgl-contact__faq-a">{{ block.settings.answer }}</div>
              </details>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

  </div>
</div>

<style>
  .sgl-contact {
    background: var(--sgl-c-bg);
    color: var(--sgl-c-text);
  }

  .sgl-contact__body {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(16px, 4vw, 60px);
  }

  /* ══ Hero ══ */
  .sgl-contact__hero {
    position: relative;
    min-height: 340px;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 60px 24px 48px;
    overflow: hidden;
    background: var(--sgl-c-accent);
  }

  .sgl-contact__hero-media {
    position: absolute;
    inset: 0;
  }

  .sgl-contact__hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .sgl-contact__hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.5) 0%, rgba(0,0,0,0.1) 60%, transparent 100%);
  }

  .sgl-contact__hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 600px;
  }

  .sgl-contact__tag {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    opacity: 0.7;
    margin-bottom: 10px;
    color: #fff;
  }

  .sgl-contact__hero-title {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 300;
    line-height: 1.1;
    margin: 0 0 12px;
    color: #fff;
  }

  .sgl-contact__hero-desc {
    font-size: 0.95rem;
    line-height: 1.6;
    color: rgba(255,255,255,0.85);
    margin: 0;
  }

  /* ══ Info Cards ══ */
  .sgl-contact__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin: -40px 0 48px;
    position: relative;
    z-index: 3;
  }

  .sgl-contact__card {
    background: var(--sgl-c-card-bg);
    border-radius: 14px;
    padding: 28px 24px;
    text-align: center;
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    opacity: 0;
    animation: sgl-c-reveal 0.5s ease forwards;
    animation-delay: calc(var(--i) * 80ms);
  }

  .sgl-contact__card-icon {
    width: 40px;
    height: 40px;
    margin: 0 auto 14px;
  }
  .sgl-contact__card-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .sgl-contact__card-title {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 8px;
  }

  .sgl-contact__card-desc {
    font-size: 0.82rem;
    line-height: 1.55;
    opacity: 0.65;
    margin-bottom: 10px;
  }

  .sgl-contact__card-link {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--sgl-c-text);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
  }

  .sgl-contact__card-detail {
    font-size: 0.75rem;
    opacity: 0.5;
    margin-top: 4px;
  }

  /* ══ Section Titles ══ */
  .sgl-contact__section-title {
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 300;
    margin: 0 0 8px;
  }

  .sgl-contact__section-desc {
    font-size: 0.88rem;
    line-height: 1.6;
    opacity: 0.6;
    margin: 0 0 28px;
    max-width: 500px;
  }

  /* ══ Form ══ */
  .sgl-contact__form-section {
    max-width: 680px;
    margin: 0 auto 64px;
    padding: 40px;
    background: var(--sgl-c-card-bg);
    border-radius: 20px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.04);
  }

  .sgl-contact__form-header {
    text-align: center;
    margin-bottom: 28px;
  }
  .sgl-contact__form-header .sgl-contact__section-desc {
    margin-left: auto;
    margin-right: auto;
  }

  .sgl-contact__form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }

  .sgl-contact__field {
    margin-bottom: 14px;
  }

  .sgl-contact__field label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    margin-bottom: 6px;
    opacity: 0.7;
  }

  .sgl-contact__field input,
  .sgl-contact__field select,
  .sgl-contact__field textarea {
    width: 100%;
    padding: 12px 14px;
    font-size: 0.88rem;
    font-family: inherit;
    border: 1px solid rgba(0,0,0,0.1);
    border-radius: 10px;
    background: var(--sgl-c-bg);
    color: var(--sgl-c-text);
    transition: border-color 0.2s ease;
    box-sizing: border-box;
  }

  .sgl-contact__field input:focus,
  .sgl-contact__field select:focus,
  .sgl-contact__field textarea:focus {
    outline: none;
    border-color: var(--sgl-c-accent);
  }

  .sgl-contact__field textarea {
    resize: vertical;
    min-height: 120px;
  }

  .sgl-contact__submit {
    display: block;
    width: 100%;
    padding: 14px;
    font-size: 0.82rem;
    font-weight: 600;
    font-family: inherit;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border: none;
    border-radius: 10px;
    background: var(--sgl-c-btn-bg);
    color: var(--sgl-c-btn-text);
    cursor: pointer;
    transition: opacity 0.2s, transform 0.2s;
    margin-top: 6px;
  }
  .sgl-contact__submit:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .sgl-contact__form-success {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 18px;
    background: #f0fdf4;
    border-radius: 10px;
    margin-bottom: 20px;
    color: #166534;
    font-size: 0.88rem;
  }
  .sgl-contact__form-success p { margin: 0; }

  .sgl-contact__form-error {
    padding: 14px 18px;
    background: #fef2f2;
    border-radius: 10px;
    margin-bottom: 20px;
    color: #991b1b;
    font-size: 0.85rem;
  }

  /* ══ Store ══ */
  .sgl-contact__store {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    margin-bottom: 64px;
    align-items: start;
  }

  .sgl-contact__store-detail {
    display: flex;
    gap: 14px;
    margin-bottom: 16px;
  }

  .sgl-contact__store-icon {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .sgl-contact__store-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .sgl-contact__store-label {
    display: block;
    font-size: 0.88rem;
    font-weight: 600;
    margin-bottom: 2px;
  }

  .sgl-contact__store-text {
    font-size: 0.82rem;
    line-height: 1.5;
    opacity: 0.6;
  }

  .sgl-contact__store-desc {
    font-size: 0.85rem;
    line-height: 1.6;
    opacity: 0.6;
    margin: 16px 0 24px;
  }

  .sgl-contact__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 28px;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 10px;
    background: var(--sgl-c-btn-bg);
    color: var(--sgl-c-btn-text);
    transition: opacity 0.2s, transform 0.2s;
  }
  .sgl-contact__btn:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .sgl-contact__map {
    border-radius: 16px;
    overflow: hidden;
    min-height: 360px;
    background: #eee;
  }
  .sgl-contact__map iframe {
    display: block;
  }

  /* ══ FAQ ══ */
  .sgl-contact__faq {
    max-width: 720px;
    margin: 0 auto 64px;
  }

  .sgl-contact__faq .sgl-contact__section-desc {
    margin-left: auto;
    margin-right: auto;
  }

  .sgl-contact__faq-list {
    margin-top: 24px;
  }

  .sgl-contact__faq-item {
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }

  .sgl-contact__faq-q {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 0;
    font-size: 0.95rem;
    font-weight: 500;
    cursor: pointer;
    list-style: none;
  }
  .sgl-contact__faq-q::-webkit-details-marker { display: none; }

  .sgl-contact__faq-q svg {
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .sgl-contact__faq-item[open] .sgl-contact__faq-q svg {
    transform: rotate(180deg);
  }

  .sgl-contact__faq-a {
    padding: 0 0 18px;
    font-size: 0.85rem;
    line-height: 1.65;
    opacity: 0.65;
  }

  @keyframes sgl-c-reveal {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ══ Mobile ══ */
  @media (max-width: 749px) {
    .sgl-contact__hero {
      min-height: 260px;
      padding: 40px 20px 36px;
    }

    .sgl-contact__hero-title {
      font-size: 1.8rem;
    }

    .sgl-contact__cards {
      grid-template-columns: 1fr;
      margin-top: -30px;
      margin-left: 16px;
      margin-right: 16px;
      gap: 12px;
    }

    .sgl-contact__card {
      padding: 20px 18px;
    }

    .sgl-contact__form-section {
      margin: 0 0 40px;
      padding: 24px 20px;
      border-radius: 16px;
    }

    .sgl-contact__form-row {
      grid-template-columns: 1fr;
    }

    .sgl-contact__store {
      grid-template-columns: 1fr;
      margin-bottom: 40px;
    }

    .sgl-contact__map {
      min-height: 280px;
    }

    .sgl-contact__faq {
      margin-bottom: 40px;
      padding: 0 4px;
    }
  }
</style>

{% schema %}
{
  "name": "SGL Contact Page",
  "tag": "section",
  "class": "sgl-contact-section",
  "settings": [
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero background image"
    },
    {
      "type": "text",
      "id": "hero_subtitle",
      "label": "Subtitle",
      "default": "Seoul Glow Lab"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Title",
      "default": "Get in Touch"
    },
    {
      "type": "textarea",
      "id": "hero_description",
      "label": "Description",
      "default": "Have questions about your skincare routine? Need product recommendations? We're here to help you glow with confidence."
    },
    {
      "type": "header",
      "content": "Contact Form"
    },
    {
      "type": "text",
      "id": "form_title",
      "label": "Form title",
      "default": "Send Us a Message"
    },
    {
      "type": "textarea",
      "id": "form_description",
      "label": "Form description",
      "default": "We'd love to hear from you. Send us a message and we'll respond as soon as possible."
    },
    {
      "type": "text",
      "id": "form_button",
      "label": "Submit button text",
      "default": "Send Message"
    },
    {
      "type": "header",
      "content": "Store Location"
    },
    {
      "type": "text",
      "id": "store_title",
      "label": "Store section title",
      "default": "Visit Our Store"
    },
    {
      "type": "textarea",
      "id": "store_description",
      "label": "Store description",
      "default": "Experience our curated K-beauty collection in person. Get personalized skincare consultations and discover exclusive in-store products."
    },
    {
      "type": "text",
      "id": "map_embed",
      "label": "Google Maps embed URL",
      "info": "Paste the src URL from a Google Maps embed iframe"
    },
    {
      "type": "text",
      "id": "directions_text",
      "label": "Directions button text",
      "default": "Get Directions"
    },
    {
      "type": "url",
      "id": "directions_link",
      "label": "Directions link"
    },
    {
      "type": "header",
      "content": "FAQ"
    },
    {
      "type": "text",
      "id": "faq_title",
      "label": "FAQ title",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "text",
      "id": "faq_subtitle",
      "label": "FAQ subtitle",
      "default": "Quick answers to common questions"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#F8EBDA"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#5E0A02"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#B0C3FA"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_bg_color",
      "label": "Button background",
      "default": "#5E0A02"
    },
