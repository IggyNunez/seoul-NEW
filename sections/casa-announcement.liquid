{%- if section.settings.enable -%}
  {%- liquid
    assign announcement_count = 0
    for block in section.blocks
      if block.type == 'announcement'
        assign announcement_count = announcement_count | plus: 1
      endif
    endfor

    if announcement_count == 0
      assign announcement_count = 1
      assign use_fallback = true
    else
      assign use_fallback = false
    endif

    assign slide_duration = section.settings.slide_duration | default: 5
    assign bg_style = section.settings.background_style | default: 'animated'
  -%}

  {%- capture announcement_styles -%}
    --announcement-padding: {{ section.settings.padding }}px;
    --announcement-text: {{ section.settings.text_color | default: '#ffffff' }};
    {%- if bg_style == 'solid' -%}
      --announcement-bg: {{ section.settings.solid_color }};
    {%- else -%}
      --announcement-color-1: {{ section.settings.gradient_color_1 }};
      --announcement-color-2: {{ section.settings.gradient_color_2 }};
      --announcement-color-3: {{ section.settings.gradient_color_3 }};
    {%- endif -%}
  {%- endcapture -%}

  <div class="casa-announcement{% if announcement_count > 1 %} casa-announcement--slider{% endif %}{% if bg_style == 'solid' %} casa-announcement--solid{% endif %}"
       data-announcement-slider
       data-slide-duration="{{ slide_duration }}"
       data-pause-on-hover="{{ section.settings.pause_on_hover }}"
       style="{{ announcement_styles | strip_newlines }}"
       {{ section.shopify_attributes }}>

    <div class="casa-announcement__track" style="--announcement-count: {{ announcement_count }};">
      {%- if use_fallback -%}
        {%- comment -%} Fallback to legacy single announcement {%- endcomment -%}
        <div class="casa-announcement__slide{% if announcement_count == 1 %} is-active{% endif %}">
          {%- if section.settings.announcement_link != blank -%}
            <a href="{{ section.settings.announcement_link }}" class="casa-announcement__link">
          {%- endif -%}
          <span class="casa-announcement__text">
            {{ section.settings.announcement_text }}
            {%- if section.settings.promo_code != blank -%}
              <code class="casa-announcement__code">{{ section.settings.promo_code }}</code>
            {%- endif -%}
          </span>
          {%- if section.settings.announcement_link != blank -%}
            </a>
          {%- endif -%}
        </div>
      {%- else -%}
        {%- comment -%} Render announcement blocks {%- endcomment -%}
        {%- assign slide_index = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'announcement' -%}
            <div class="casa-announcement__slide{% if slide_index == 0 %} is-active{% endif %}" {{ block.shopify_attributes }}>
              {%- if block.settings.link != blank -%}
                <a href="{{ block.settings.link }}" class="casa-announcement__link">
              {%- endif -%}
              <span class="casa-announcement__text">
                {%- if block.settings.icon != 'none' -%}
                  <span class="casa-announcement__icon">{%- render 'casa-icon', icon: block.settings.icon, size: 16 -%}</span>
                {%- endif -%}
                {{ block.settings.text }}
                {%- if block.settings.promo_code != blank -%}
                  <code class="casa-announcement__code">{{ block.settings.promo_code }}</code>
                {%- endif -%}
              </span>
              {%- if block.settings.link != blank -%}
                </a>
              {%- endif -%}
            </div>
            {%- assign slide_index = slide_index | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if announcement_count > 1 and section.settings.show_navigation -%}
      <div class="casa-announcement__nav">
        {%- for i in (1..announcement_count) -%}
          <button class="casa-announcement__dot{% if forloop.first %} is-active{% endif %}"
                  data-slide-index="{{ forloop.index0 }}"
                  aria-label="Go to announcement {{ forloop.index }}">
          </button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  <script>
    (function() {
      const slider = document.querySelector('[data-announcement-slider]');
      if (!slider) return;

      const slides = slider.querySelectorAll('.casa-announcement__slide');
      const dots = slider.querySelectorAll('.casa-announcement__dot');
      if (slides.length <= 1) return;

      const duration = parseInt(slider.dataset.slideDuration) * 1000 || 5000;
      const pauseOnHover = slider.dataset.pauseOnHover === 'true';
      let currentIndex = 0;
      let interval;
      let isPaused = false;

      function showSlide(index) {
        slides.forEach((slide, i) => {
          slide.classList.toggle('is-active', i === index);
        });
        dots.forEach((dot, i) => {
          dot.classList.toggle('is-active', i === index);
        });
        currentIndex = index;
      }

      function nextSlide() {
        const next = (currentIndex + 1) % slides.length;
        showSlide(next);
      }

      function startAutoPlay() {
        if (interval) clearInterval(interval);
        interval = setInterval(() => {
          if (!isPaused) nextSlide();
        }, duration);
      }

      // Dot navigation
      dots.forEach((dot, i) => {
        dot.addEventListener('click', () => {
          showSlide(i);
          startAutoPlay(); // Reset timer on manual navigation
        });
      });

      // Pause on hover
      if (pauseOnHover) {
        slider.addEventListener('mouseenter', () => { isPaused = true; });
        slider.addEventListener('mouseleave', () => { isPaused = false; });
      }

      // Start
      startAutoPlay();
    })();
  </script>
{%- endif -%}

{% stylesheet %}
  .casa-announcement {
    background: linear-gradient(
      90deg,
      var(--announcement-color-1, #9333ea),
      var(--announcement-color-2, #ec4899),
      var(--announcement-color-3, #06b6d4),
      var(--announcement-color-2, #ec4899),
      var(--announcement-color-1, #9333ea)
    );
    background-size: 300% 100%;
    animation: casa-shimmer 4s linear infinite;
    padding: var(--announcement-padding, 14px) 40px;
    text-align: center;
    font-size: 14px;
    font-weight: 500;
    color: var(--announcement-text, white);
    line-height: 1.4;
    position: relative;
    overflow: hidden;
  }

  /* Solid color mode - no animation */
  .casa-announcement--solid {
    background: var(--announcement-bg, #9333ea);
    background-size: auto;
    animation: none;
  }

  .casa-announcement__track {
    position: relative;
    min-height: 1.4em;
  }

  .casa-announcement__slide {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.4s ease, transform 0.4s ease;
    pointer-events: none;
  }

  .casa-announcement__slide.is-active {
    position: relative;
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  /* Single announcement - no transitions needed */
  .casa-announcement:not(.casa-announcement--slider) .casa-announcement__slide {
    position: relative;
    opacity: 1;
    transform: none;
    pointer-events: auto;
  }

  .casa-announcement__link {
    color: var(--announcement-text, white);
    text-decoration: none;
    display: block;
  }

  .casa-announcement__text {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    justify-content: center;
  }

  .casa-announcement__icon {
    display: inline-flex;
    align-items: center;
    opacity: 0.9;
  }

  .casa-announcement__code {
    background: color-mix(in srgb, var(--announcement-text, white) 20%, transparent);
    padding: 4px 12px;
    border-radius: 4px;
    font-weight: 700;
    font-family: inherit;
    margin: 0 4px;
  }

  /* Navigation dots */
  .casa-announcement__nav {
    display: flex;
    justify-content: center;
    gap: 6px;
    margin-top: 10px;
  }

  .casa-announcement__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--announcement-text, white) 30%, transparent);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: all 0.2s;
  }

  .casa-announcement__dot:hover {
    background: color-mix(in srgb, var(--announcement-text, white) 50%, transparent);
  }

  .casa-announcement__dot.is-active {
    background: var(--announcement-text, white);
    transform: scale(1.3);
  }

  @media (max-width: 749px) {
    .casa-announcement {
      padding: calc(var(--announcement-padding, 14px) * 0.7) 16px;
      font-size: 12px;
    }

    .casa-announcement__code {
      padding: 2px 8px;
    }

    .casa-announcement__nav {
      margin-top: 8px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Casa Announcement Bar",
  "tag": "section",
  "class": "casa-announcement-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable",
      "label": "Enable announcement bar",
      "default": true
    },
    {
      "type": "header",
      "content": "Background Style"
    },
    {
      "type": "select",
      "id": "background_style",
      "label": "Background style",
      "options": [
        { "value": "animated", "label": "Animated gradient" },
        { "value": "solid", "label": "Solid color" }
      ],
      "default": "animated"
    },
    {
      "type": "color",
      "id": "solid_color",
      "label": "Solid background color",
      "default": "#9333ea",
      "info": "Used when 'Solid color' is selected"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "gradient_color_1",
      "label": "Gradient color 1",
      "default": "#9333ea",
      "info": "Purple (left side)"
    },
    {
      "type": "color",
      "id": "gradient_color_2",
      "label": "Gradient color 2",
      "default": "#ec4899",
      "info": "Pink (middle)"
    },
    {
      "type": "color",
      "id": "gradient_color_3",
      "label": "Gradient color 3",
      "default": "#06b6d4",
      "info": "Cyan (center accent)"
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Bar height (padding)",
      "min": 6,
      "max": 24,
      "step": 2,
      "default": 14,
      "unit": "px",
      "info": "Vertical padding controls the bar height"
    },
    {
      "type": "header",
      "content": "Slider Settings"
    },
    {
      "type": "range",
      "id": "slide_duration",
      "label": "Slide duration",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 5,
      "unit": "sec",
      "info": "How long each announcement displays"
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on hover",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_navigation",
      "label": "Show navigation dots",
      "default": false,
      "info": "Only visible when multiple announcements are added"
    },
    {
      "type": "header",
      "content": "Fallback (when no blocks)"
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement text",
      "default": "✨ Free Worldwide Shipping on All Orders • Use code for 20% off your first order"
    },
    {
      "type": "text",
      "id": "promo_code",
      "label": "Promo code (shown as badge)",
      "default": "LUMO20"
    },
    {
      "type": "url",
      "id": "announcement_link",
      "label": "Link (optional)"
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Announcement text",
          "default": "Free shipping on orders over $50"
        },
        {
          "type": "text",
          "id": "promo_code",
          "label": "Promo code (optional)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "none", "label": "No icon" },
            { "value": "sparkles", "label": "Sparkles ✨" },
            { "value": "truck", "label": "Truck 🚚" },
            { "value": "tag", "label": "Tag / Sale 🏷️" },
            { "value": "gift", "label": "Gift 🎁" },
            { "value": "star", "label": "Star ⭐" },
            { "value": "zap", "label": "Zap ⚡" },
            { "value": "heart", "label": "Heart ❤️" },
            { "value": "shield-check", "label": "Shield ✓" },
            { "value": "refresh", "label": "Returns ↻" }
          ],
          "default": "none"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Casa Announcement Bar",
      "blocks": [
        {
          "type": "announcement",
          "settings": {
            "text": "Free Worldwide Shipping on All Orders",
            "promo_code": "LUMO20",
            "icon": "sparkles"
          }
        },
        {
          "type": "announcement",
          "settings": {
            "text": "30-Day Easy Returns • Hassle Free",
            "icon": "refresh"
          }
        },
        {
          "type": "announcement",
          "settings": {
            "text": "New Collection Drop • Shop Now",
            "icon": "zap"
          }
        }
      ]
    }
  ]
}
{% endschema %}
