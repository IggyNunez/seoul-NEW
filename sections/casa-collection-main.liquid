        },
        {
          "type": "select",
          "id": "content_position",
          "label": "Content position",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" },
            { "value": "bottom-left", "label": "Bottom Left" },
            { "value": "bottom-center", "label": "Bottom Center" }
          ],
          "default": "bottom-left"
        },
        {
          "type": "header",
          "content": "Colors"
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Background color",
          "info": "Fallback when no image set",
          "default": "#0f0f18"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text color",
          "default": "#ffffff"
        },
        {
          "type": "color",
          "id": "tag_bg",
          "label": "Badge background",
          "default": "#9333ea"
        },
        {
          "type": "color",
          "id": "btn_bg",
          "label": "Button background",
          "default": "#9333ea"
        },
        {
          "type": "color",
          "id": "btn_text",
          "label": "Button text color",
          "default": "#ffffff"
        }
      ]
    }
  ]
}
{% endschema %}

{% stylesheet %}
/* ═══════════════════════════════════════════════════════════════════════
   CASA COLLECTION MAIN — Core Layout
   ═══════════════════════════════════════════════════════════════════════ */

.casa-col-main {
  background: var(--ccm-bg);
  padding: var(--ccm-pt) 0 var(--ccm-pb);
}

/* ── TOOLBAR ─────────────────────────────────────────────────────────── */

.casa-col-main__toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: 16px var(--ccm-toolbar-pad);
  border-bottom: var(--ccm-border-w) solid var(--ccm-divider);
  position: sticky;
  top: 0;
  z-index: 20;
  background: color-mix(in srgb, var(--ccm-bg) 95%, transparent);
  backdrop-filter: blur(var(--ccm-blur));
}

.casa-col-main__toolbar-left {
  display: flex;
  align-items: center;
  gap: 16px;
  flex: 1;
  min-width: 0;
}

.casa-col-main__toolbar-right {
  display: flex;
  align-items: center;
  gap: 16px;
  flex-shrink: 0;
}

/* Filter toggle (mobile only) */
.casa-col-main__filter-toggle {
  display: none;
  align-items: center;
  gap: 8px;
  padding: var(--ccm-chip-py) 16px;
  background: color-mix(in srgb, var(--ccm-toolbar-bg) 50%, transparent);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: var(--ccm-border-w) solid color-mix(in srgb, var(--ccm-toolbar-border) 50%, transparent);
  border-radius: var(--ccm-radius-sm);
  color: var(--ccm-text);
  font-size: var(--ccm-font-sm);
  font-weight: var(--ccm-fw-normal);
  cursor: pointer;
  transition: background var(--ccm-trans-fast), border-color var(--ccm-trans-fast);
  white-space: nowrap;
}

.casa-col-main__filter-toggle:hover {
  background: color-mix(in srgb, var(--ccm-bg-secondary) 60%, transparent);
  border-color: var(--ccm-accent-1);
}

.casa-col-main__active-filters-wrap {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

/* Product count */
.casa-col-main__count {
  font-size: var(--ccm-font-sm);
  color: var(--ccm-text-muted);
  white-space: nowrap;
}

/* Sort dropdown */
.casa-col-main__sort {
  position: relative;
  display: flex;
  align-items: center;
}

.casa-col-main__sort-select {
  appearance: none;
  -webkit-appearance: none;
  background: color-mix(in srgb, var(--ccm-toolbar-bg) 50%, transparent);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: var(--ccm-border-w) solid color-mix(in srgb, var(--ccm-toolbar-border) 50%, transparent);
  border-radius: var(--ccm-radius-sm);
  color: var(--ccm-text);
  font-size: var(--ccm-font-sm);
  padding: var(--ccm-chip-py) 36px var(--ccm-chip-py) var(--ccm-chip-px);
  cursor: pointer;
  transition: border-color var(--ccm-trans-fast);
}

.casa-col-main__sort-select:hover,
.casa-col-main__sort-select:focus {
  border-color: var(--ccm-accent-1);
  outline: none;
}

.casa-col-main__sort-select option {
  background: var(--ccm-bg-secondary);
  color: var(--ccm-text);
}

.casa-col-main__sort-icon {
  position: absolute;
  right: 12px;
  pointer-events: none;
  color: var(--ccm-text-muted);
}

/* View toggle */
.casa-col-main__view-toggle {
  display: flex;
  gap: 4px;
  background: color-mix(in srgb, var(--ccm-toolbar-bg) 50%, transparent);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: var(--ccm-border-w) solid color-mix(in srgb, var(--ccm-toolbar-border) 50%, transparent);
  border-radius: var(--ccm-radius-sm);
  padding: 4px;
}

.casa-col-main__view-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: var(--ccm-view-btn);
  height: var(--ccm-view-btn);
  border: none;
  border-radius: calc(var(--ccm-radius-sm) - 2px);
  background: transparent;
  color: var(--ccm-text-muted);
  cursor: pointer;
  transition: all var(--ccm-trans-fast);
}

.casa-col-main__view-btn:hover {
  color: var(--ccm-text-muted);
}

.casa-col-main__view-btn--active {
  background: color-mix(in srgb, var(--ccm-highlight-bg) 60%, transparent);
  color: var(--ccm-text);
}

/* ── MAIN LAYOUT ─────────────────────────────────────────────────────── */

.casa-col-main__layout {
  display: flex;
  gap: 0;
  padding: 0 var(--ccm-toolbar-pad);
}

/* ── SIDEBAR ─────────────────────────────────────────────────────────── */

.casa-col-main__sidebar {
  flex-shrink: 0;
  width: var(--ccm-sidebar-w);
  padding: var(--ccm-filter-gap);
  max-height: calc(100vh - var(--header-group-height, 80px) - 20px);
  overflow-y: auto;
  position: sticky;
  top: calc(var(--header-group-height, 80px) + 10px);
  align-self: flex-start;
  scrollbar-width: thin;
  scrollbar-color: var(--ccm-highlight-bg) transparent;
  /* Glassmorphism */
  background: color-mix(in srgb, var(--ccm-bg-secondary) 55%, transparent);
  backdrop-filter: blur(var(--ccm-blur));
  -webkit-backdrop-filter: blur(var(--ccm-blur));
  border: var(--ccm-border-w) solid color-mix(in srgb, var(--ccm-divider) 40%, transparent);
  border-radius: var(--ccm-radius-sm);
  box-shadow:
    0 4px 24px rgba(0, 0, 0, 0.12),
    inset 0 1px 0 color-mix(in srgb, var(--ccm-text) 5%, transparent);
  margin-right: var(--ccm-filter-gap);
}

.casa-col-main__sidebar::-webkit-scrollbar {
  width: 4px;
}

.casa-col-main__sidebar::-webkit-scrollbar-thumb {
  background: var(--ccm-highlight-bg);
  border-radius: 4px;
}

.casa-col-main__apply-btn {
  display: none;
}

/* ── PRODUCT GRID ────────────────────────────────────────────────────── */

.casa-col-main__grid-wrapper {
  flex: 1;
  min-width: 0;
  padding: var(--ccm-filter-gap) 0 0 32px;
}

.casa-col-main__grid {
  display: grid;
  grid-template-columns: repeat(var(--ccm-columns), 1fr);
  grid-auto-rows: auto;
  grid-auto-flow: dense;
  gap: var(--ccm-grid-gap);
  list-style: none;
  margin: 0;
  padding: 0;
}

.casa-col-main__grid-item {
  min-width: 0;
  display: flex;
}

/* Banners — grid-column set inline, content fills */
.casa-col-main__grid-item--promo > a,
.casa-col-main__grid-item--promo > div,
.casa-col-main__grid-item--full-width > a,
.casa-col-main__grid-item--full-width > div,
.casa-col-main__grid-item--media-banner > div {
  width: 100%;
  height: 100%;
}

.casa-col-main__grid-item--full-width {
  grid-column: 1 / -1;
}

/* Empty state */
.casa-col-main__empty {
  text-align: center;
  padding: 80px var(--ccm-drawer-pad);
  color: var(--ccm-text-muted);
  font-size: var(--ccm-font-md);
}

.casa-col-main__empty-link {
  display: inline-block;
  margin-top: 16px;
  color: var(--ccm-accent-1);
  text-decoration: none;
  font-weight: var(--ccm-fw-normal);
}

.casa-col-main__empty-link:hover {
  text-decoration: underline;
}

/* ── PAGINATION ──────────────────────────────────────────────────────── */

.casa-col-main__pagination {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--ccm-page-gap);
  padding: 48px 0 24px;
}

.casa-col-main__page-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: var(--ccm-page-btn);
  height: var(--ccm-page-btn);
  border-radius: var(--ccm-radius-sm);
  background: var(--ccm-input-bg);
  color: var(--ccm-text-muted);
  text-decoration: none;
  transition: all var(--ccm-trans-fast);
}

.casa-col-main__page-btn:hover {
  background: var(--ccm-highlight-bg);
  color: var(--ccm-text);
}

.casa-col-main__page-num {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: var(--ccm-page-btn);
  height: var(--ccm-page-btn);
  padding: 0 var(--ccm-page-gap);
  border-radius: var(--ccm-radius-sm);
  font-size: var(--ccm-font-sm);
  font-weight: var(--ccm-fw-normal);
  color: var(--ccm-text-muted);
  text-decoration: none;
  transition: all var(--ccm-trans-fast);
}

.casa-col-main__page-num:hover {
  background: var(--ccm-input-bg);
  color: var(--ccm-text);
}

.casa-col-main__page-num--current {
  background: linear-gradient(135deg, var(--ccm-accent-1), var(--ccm-accent-2));
  color: var(--ccm-text);
}

.casa-col-main__page-dots {
  color: var(--ccm-text-muted);
  font-size: var(--ccm-font-sm);
  padding: 0 4px;
}

/* ── MOBILE FILTER DRAWER ────────────────────────────────────────────── */

.casa-col-main__drawer {
  position: fixed;
  top: 0;
  left: 0;
  width: 85vw;
  max-width: var(--ccm-drawer-w);
  height: 100vh;
  height: 100dvh;
  z-index: 1000;
  transform: translateX(-100%);
  transition: transform var(--ccm-trans-normal) cubic-bezier(0.4, 0, 0.2, 1);
  display: flex;
  flex-direction: column;
  border-radius: 0 var(--ccm-drawer-radius) var(--ccm-drawer-radius) 0;
  /* Glassmorphism */
  background: color-mix(in srgb, var(--ccm-bg-secondary) 70%, transparent);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-right: var(--ccm-border-w) solid color-mix(in srgb, var(--ccm-divider) 40%, transparent);
  box-shadow:
    4px 0 30px rgba(0, 0, 0, 0.2),
    inset 1px 0 0 color-mix(in srgb, var(--ccm-text) 5%, transparent);
}

.casa-col-main__drawer.is-open {
  transform: translateX(0);
}

.casa-col-main__drawer-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--ccm-drawer-pad) calc(var(--ccm-drawer-pad) + 4px);
  min-height: var(--ccm-drawer-header);
  border-bottom: var(--ccm-border-w) solid color-mix(in srgb, var(--ccm-divider) 40%, transparent);
}

.casa-col-main__drawer-title {
  font-size: calc(var(--ccm-font-sm) + 4px);
  font-weight: var(--ccm-fw-bold);
  color: var(--ccm-text);
  margin: 0;
}

.casa-col-main__drawer-close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: var(--ccm-page-btn);
  height: var(--ccm-page-btn);
  background: transparent;
  border: none;
  color: var(--ccm-text-muted);
  cursor: pointer;
  transition: color var(--ccm-trans-fast);
}

.casa-col-main__drawer-close:hover {
  color: var(--ccm-text);
}

.casa-col-main__drawer-body {
  flex: 1;
  overflow-y: auto;
  padding: calc(var(--ccm-drawer-pad) + 4px);
  -webkit-overflow-scrolling: touch;
}

.casa-col-main__drawer-footer {
  padding: var(--ccm-drawer-pad) calc(var(--ccm-drawer-pad) + 4px);
  min-height: var(--ccm-drawer-footer);
  border-top: var(--ccm-border-w) solid color-mix(in srgb, var(--ccm-divider) 40%, transparent);
}

.casa-col-main__drawer-apply {
  width: 100%;
  padding: var(--ccm-chip-px);
  background: linear-gradient(135deg, var(--ccm-accent-1), var(--ccm-accent-2));
  color: var(--ccm-text);
  font-size: var(--ccm-font-md);
  font-weight: var(--ccm-fw-bold);
  border: none;
  border-radius: calc(var(--ccm-radius-sm) + 4px);
  cursor: pointer;
  transition: transform var(--ccm-trans-fast), box-shadow var(--ccm-trans-fast);
}

.casa-col-main__drawer-apply:hover {
  transform: translateY(-1px);
  box-shadow: 0 var(--ccm-shadow-offset) var(--ccm-shadow-blur) color-mix(in srgb, var(--ccm-accent-1) var(--ccm-shadow-intensity), transparent);
}

.casa-col-main__drawer-overlay {
  position: fixed;
  inset: 0;
  background: color-mix(in srgb, var(--ccm-overlay) calc(var(--ccm-overlay-opacity) * 1%), transparent);
  backdrop-filter: blur(4px);
  z-index: 999;
  opacity: 0;
  visibility: hidden;
  transition: opacity var(--ccm-trans-normal), visibility var(--ccm-trans-normal);
}

.casa-col-main__drawer-overlay.is-visible {
  opacity: 1;
  visibility: visible;
}

/* ── FILTER STYLES ───────────────────────────────────────────────────── */

.casa-col-filter {
  margin-bottom: var(--ccm-filter-gap);
  border-bottom: var(--ccm-border-w) solid color-mix(in srgb, var(--ccm-divider) 40%, transparent);
  padding-bottom: var(--ccm-filter-gap);
}

.casa-col-filter__header {
  display: flex;
  align-items: center;
  gap: 8px;
  cursor: pointer;
  list-style: none;
  padding: 4px 0;
  user-select: none;
}

.casa-col-filter__header::-webkit-details-marker {
  display: none;
}

.casa-col-filter__label {
  font-size: var(--ccm-font-sm);
  font-weight: var(--ccm-fw-bold);
  color: var(--ccm-text);
  flex: 1;
  text-transform: uppercase;
  letter-spacing: var(--ccm-ls-caps);
  line-height: 1.2;
}

.casa-col-filter__count {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: var(--ccm-checkbox-size);
  height: var(--ccm-checkbox-size);
  padding: 0 6px;
  border-radius: calc(var(--ccm-checkbox-size) / 2);
  background: var(--ccm-accent-1);
  color: var(--ccm-text);
  font-size: var(--ccm-font-xs);
  font-weight: 700;
}

.casa-col-filter__chevron {
  color: var(--ccm-text-muted);
  transition: transform var(--ccm-trans-fast);
  flex-shrink: 0;
}

.casa-col-filter[open] > .casa-col-filter__header .casa-col-filter__chevron {
  transform: rotate(180deg);
}

.casa-col-filter__body {
  padding-top: 10px;
}

/* Price range */
.casa-col-filter__price-slider {
  padding: 0 4px;
  margin-bottom: 16px;
}

.casa-col-filter__price-track {
  position: relative;
  height: 4px;
  background: var(--ccm-highlight-bg);
  border-radius: 4px;
}

.casa-col-filter__price-fill {
  position: absolute;
  height: 100%;
  background: linear-gradient(90deg, var(--ccm-accent-1), var(--ccm-accent-2));
  border-radius: 4px;
}

.casa-col-filter__price-thumb {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  -webkit-appearance: none;
  appearance: none;
  width: 100%;
  height: 4px;
  background: transparent;
  pointer-events: none;
}

.casa-col-filter__price-thumb::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: var(--ccm-icon-sm);
  height: var(--ccm-icon-sm);
  border-radius: 50%;
  background: var(--ccm-text);
  border: 3px solid var(--ccm-accent-1);
  cursor: pointer;
  pointer-events: all;
  box-shadow: 0 2px 8px color-mix(in srgb, var(--ccm-overlay) 30%, transparent);
}

.casa-col-filter__price-thumb::-moz-range-thumb {
  width: var(--ccm-icon-sm);
  height: var(--ccm-icon-sm);
  border-radius: 50%;
  background: var(--ccm-text);
  border: 3px solid var(--ccm-accent-1);
  cursor: pointer;
  pointer-events: all;
  box-shadow: 0 2px 8px color-mix(in srgb, var(--ccm-overlay) 30%, transparent);
}

.casa-col-filter__price-inputs {
  display: flex;
  align-items: center;
  gap: 12px;
}

.casa-col-filter__price-field {
  flex: 1;
  display: flex;
  align-items: center;
  background: var(--ccm-input-bg);
  border: var(--ccm-border-w) solid var(--ccm-input-border);
  border-radius: var(--ccm-radius-sm);
  padding: 0 12px;
  transition: border-color var(--ccm-trans-fast);
}

.casa-col-filter__price-field:focus-within {
  border-color: color-mix(in srgb, var(--ccm-accent-1) 50%, transparent);
}

.casa-col-filter__price-currency {
  color: var(--ccm-text-muted);
  font-size: var(--ccm-font-sm);
  margin-right: 4px;
}

.casa-col-filter__price-input {
  background: transparent;
  border: none;
  color: var(--ccm-text);
  font-size: var(--ccm-font-sm);
  padding: 10px 0;
  width: 100%;
  outline: none;
}

.casa-col-filter__price-input::-webkit-inner-spin-button,
.casa-col-filter__price-input::-webkit-outer-spin-button {
  -webkit-appearance: none;
  margin: 0;
}

.casa-col-filter__price-input[type="number"] {
  -moz-appearance: textfield;
}

.casa-col-filter__price-sep {
  color: var(--ccm-text-muted);
  flex-shrink: 0;
}

/* Swatch grid */
.casa-col-filter__swatch-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--ccm-chip-gap);
}

.casa-col-filter__swatch {
  position: relative;
  cursor: pointer;
}

.casa-col-filter__swatch-color {
  display: block;
  width: var(--ccm-swatch-size);
  height: var(--ccm-swatch-size);
  border-radius: 50%;
  border: var(--ccm-border-w) solid transparent;
  box-shadow: inset 0 2px 4px color-mix(in srgb, var(--ccm-text) 15%, transparent), 0 0 0 1px var(--ccm-input-border);
  transition: all var(--ccm-trans-fast);
}

.casa-col-filter__swatch-img {
  display: block;
  width: var(--ccm-swatch-size);
  height: var(--ccm-swatch-size);
  border-radius: 50%;
  object-fit: cover;
  border: var(--ccm-border-w) solid transparent;
  transition: all var(--ccm-trans-fast);
}

.casa-col-filter__swatch:hover .casa-col-filter__swatch-color,
.casa-col-filter__swatch:hover .casa-col-filter__swatch-img {
  border-color: color-mix(in srgb, var(--ccm-text) 50%, transparent);
  transform: scale(var(--ccm-hover-scale));
}

.casa-col-filter__swatch--active .casa-col-filter__swatch-color,
.casa-col-filter__swatch--active .casa-col-filter__swatch-img {
  border-color: var(--ccm-accent-1);
  box-shadow: 0 0 0 3px color-mix(in srgb, var(--ccm-accent-1) 30%, transparent);
}

.casa-col-filter__swatch--disabled {
  opacity: var(--ccm-disabled-opacity);
  pointer-events: none;
}

/* Chip buttons */
.casa-col-filter__chips {
  display: flex;
  flex-wrap: wrap;
  gap: var(--ccm-chip-gap);
}

.casa-col-filter__chip {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: var(--ccm-chip-py) var(--ccm-chip-px);
  border-radius: var(--ccm-radius-sm);
  background: var(--ccm-input-bg);
  border: var(--ccm-border-w) solid var(--ccm-input-border);
  color: var(--ccm-text-muted);
  font-size: calc(var(--ccm-font-sm) - 1px);
  cursor: pointer;
  transition: all var(--ccm-trans-fast);
  line-height: 1.2;
}

.casa-col-filter__chip:hover {
  background: var(--ccm-highlight-bg);
  border-color: color-mix(in srgb, var(--ccm-text) 20%, transparent);
  color: var(--ccm-text);
}

.casa-col-filter__chip--active {
  background: color-mix(in srgb, var(--ccm-accent-1) 20%, transparent);
  border-color: color-mix(in srgb, var(--ccm-accent-1) 40%, transparent);
  color: var(--ccm-text);
}

.casa-col-filter__chip--disabled {
  opacity: var(--ccm-disabled-opacity);
  pointer-events: none;
}

.casa-col-filter__chip-icon svg {
  display: block;
}

.casa-col-filter__chip-text {
  white-space: nowrap;
}

/* Checkbox list */
.casa-col-filter__list {
  display: flex;
  flex-direction: column;
  gap: var(--ccm-option-gap);
}

.casa-col-filter__option {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: var(--ccm-chip-py) 0;
  cursor: pointer;
  transition: color var(--ccm-trans-fast);
  color: var(--ccm-text-muted);
  font-size: var(--ccm-font-sm);
  line-height: 1.2;
}

.casa-col-filter__option:hover {
  color: var(--ccm-text);
}

.casa-col-filter__option--active {
  color: var(--ccm-text);
}

.casa-col-filter__option--disabled {
  opacity: var(--ccm-disabled-opacity);
  pointer-events: none;
}

.casa-col-filter__option input[type="checkbox"] {
  display: none;
}

.casa-col-filter__checkbox {
  display: flex;
  align-items: center;
  justify-content: center;
  width: var(--ccm-checkbox-size);
  height: var(--ccm-checkbox-size);
  border-radius: calc(var(--ccm-radius-sm) - 3px);
  border: var(--ccm-border-w) solid var(--ccm-input-border);
  background: transparent;
  flex-shrink: 0;
  transition: all var(--ccm-trans-fast);
}

.casa-col-filter__checkbox svg {
  opacity: 0;
  transform: scale(0.5);
  transition: all var(--ccm-trans-fast);
  color: var(--ccm-text);
}

.casa-col-filter__option input:checked ~ .casa-col-filter__checkbox {
  background: var(--ccm-accent-1);
  border-color: var(--ccm-accent-1);
}

.casa-col-filter__option input:checked ~ .casa-col-filter__checkbox svg {
  opacity: 1;
  transform: scale(1);
}

.casa-col-filter__option-text {
  flex: 1;
}

.casa-col-filter__option-count {
  font-size: var(--ccm-font-xs);
  color: var(--ccm-text-muted);
}

/* Toggle switch */
.casa-col-filter__toggle {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: var(--ccm-chip-py) 0;
  cursor: pointer;
}

.casa-col-filter__toggle-text {
  flex: 1;
  font-size: var(--ccm-font-sm);
  color: var(--ccm-text-muted);
}

.casa-col-filter__toggle-switch {
  position: relative;
  width: var(--ccm-toggle-w);
  height: var(--ccm-toggle-h);
  flex-shrink: 0;
}

.casa-col-filter__toggle-switch input {
  display: none;
}

.casa-col-filter__toggle-slider {
  position: absolute;
  inset: 0;
  background: var(--ccm-highlight-bg);
  border-radius: var(--ccm-radius-pill);
  transition: background var(--ccm-trans-normal);
  cursor: pointer;
}

.casa-col-filter__toggle-slider::after {
  content: '';
  position: absolute;
  top: 2px;
  left: 2px;
  width: calc(var(--ccm-toggle-h) - 4px);
  height: calc(var(--ccm-toggle-h) - 4px);
  border-radius: 50%;
  background: var(--ccm-text);
  transition: transform var(--ccm-trans-normal);
}

.casa-col-filter__toggle-switch input:checked + .casa-col-filter__toggle-slider {
  background: var(--ccm-accent-1);
}

.casa-col-filter__toggle-switch input:checked + .casa-col-filter__toggle-slider::after {
  transform: translateX(calc(var(--ccm-toggle-w) - var(--ccm-toggle-h)));
}

/* ── ACTIVE FILTER PILLS ─────────────────────────────────────────────── */

.casa-col-active {
  display: flex;
  align-items: center;
  gap: var(--ccm-chip-gap);
  flex-wrap: wrap;
}

.casa-col-active__pill {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 6px 12px;
  background: color-mix(in srgb, var(--ccm-toolbar-bg) 50%, transparent);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: var(--ccm-border-w) solid color-mix(in srgb, var(--ccm-toolbar-border) 50%, transparent);
  border-radius: var(--ccm-radius-pill);
  color: var(--ccm-text);
  font-size: calc(var(--ccm-font-sm) - 1px);
  text-decoration: none;
  transition: all var(--ccm-trans-fast);
  white-space: nowrap;
}

.casa-col-active__pill:hover {
  background: color-mix(in srgb, var(--ccm-bg-secondary) 60%, transparent);
  border-color: var(--ccm-remove-accent);
  color: var(--ccm-remove-accent);
}

.casa-col-active__pill svg {
  flex-shrink: 0;
  opacity: 0.6;
}

.casa-col-active__pill:hover svg {
  opacity: 1;
}

.casa-col-active__clear {
  font-size: calc(var(--ccm-font-sm) - 1px);
  color: var(--ccm-text-muted);
  text-decoration: none;
  padding: 6px var(--ccm-chip-gap);
  transition: color var(--ccm-trans-fast);
}

.casa-col-active__clear:hover {
  color: var(--ccm-text);
}

/* ── COLLECTION BANNER (Unified) ────────────────────────────────────── */

.casa-col-banner {
  position: relative;
  height: var(--cb-height, 280px);
  border-radius: var(--cb-radius, 12px);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--cb-bg, #0f0f18);
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
}

.casa-col-banner__media {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.casa-col-banner__media--mobile {
  display: none;
}

@media (max-width: 767px) {
  .casa-col-banner__media--desktop {
    display: none;
  }
  .casa-col-banner__media--mobile {
    display: block;
  }
}

.casa-col-banner__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(0,0,0, calc(var(--cb-overlay) * 0.5)) 0%, rgba(0,0,0, var(--cb-overlay)) 100%);
  z-index: 1;
  pointer-events: none;
}

.casa-col-banner__link {
  position: absolute;
  inset: 0;
  z-index: 3;
}

.casa-col-banner__content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: 32px;
  max-width: 560px;
  color: var(--cb-text, #ffffff);
}

.casa-col-banner__content--center {
  align-items: center;
  text-align: center;
  margin: 0 auto;
}

.casa-col-banner__content--left {
  align-items: flex-start;
  margin-right: auto;
}

.casa-col-banner__content--right {
  align-items: flex-end;
  text-align: right;
  margin-left: auto;
}

.casa-col-banner__content--bottom-left {
  align-items: flex-start;
  align-self: flex-end;
  margin-right: auto;
}

.casa-col-banner__content--bottom-center {
  align-items: center;
  text-align: center;
  align-self: flex-end;
  margin: 0 auto;
}

.casa-col-banner__tag {
  display: inline-flex;
  padding: 4px 12px;
  border-radius: 6px;
  background: var(--cb-tag-bg, #9333ea);
  color: #ffffff;
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.6px;
}

.casa-col-banner__title {
  margin: 0;
  color: var(--cb-text, #ffffff);
  font-size: clamp(20px, 2.5vw, 36px);
  font-weight: 600;
  line-height: 1.15;
  letter-spacing: -0.3px;
  text-shadow: 0 2px 12px rgba(0, 0, 0, 0.3);
}

.casa-col-banner__subtitle {
  margin: 0;
  color: var(--cb-text, rgba(255, 255, 255, 0.8));
  opacity: 0.85;
  font-size: 14px;
  line-height: 1.5;
  text-shadow: 0 1px 4px rgba(0, 0, 0, 0.3);
}

.casa-col-banner__cta {
  display: inline-flex;
  align-items: center;
  padding: 10px 24px;
  margin-top: 4px;
  border-radius: 8px;
  background: var(--cb-btn-bg, #9333ea);
  color: var(--cb-btn-text, #ffffff);
  font-size: 13px;
  font-weight: 600;
  text-decoration: none;
  transition: all 0.3s ease;
}

.casa-col-banner__cta:hover {
  filter: brightness(1.15);
  transform: translateY(-1px);
}

/* Banner grid item */
.casa-col-main__grid-item--promo > a,
.casa-col-main__grid-item--promo > div {
  width: 100%;
  height: 100%;
}

@media (max-width: 480px) {
  .casa-col-banner__content {
    padding: 20px;
  }
  .casa-col-banner__title {
    font-size: 20px;
  }
  .casa-col-banner__cta {
    width: 100%;
    justify-content: center;
  }
}

/* ── RESPONSIVE ──────────────────────────────────────────────────────── */

@media (max-width: 1200px) {
  .casa-col-main__toolbar {
    padding: 16px 24px;
  }
  .casa-col-main__layout {
    padding: 0 24px;
  }
  .casa-col-main__sidebar {
    width: 240px;
  }
  .casa-col-main__grid {
    --ccm-columns: 3;
    gap: 20px;
  }
}

@media (max-width: 900px) {
  .casa-col-main__filter-toggle {
    display: flex;
  }
  .casa-col-main__sidebar {
    display: none;
  }
  .casa-col-main__toolbar {
    padding: 12px 16px;
  }
  .casa-col-main__layout {
    padding: 0 16px;
  }
  .casa-col-main__grid-wrapper {
    padding: 16px 0 0 0;
  }
  .casa-col-main__grid {
    grid-template-columns: repeat(var(--ccm-columns-mobile), 1fr);
    gap: 16px;
  }
  .casa-col-main__grid-item--promo {
    grid-column: 1 / -1 !important;
  }
  .casa-col-main__view-toggle {
    display: none;
  }
  .casa-col-main__count {
    display: none;
  }
}

@media (max-width: 480px) {
  .casa-col-main__toolbar {
    padding: 10px 12px;
  }
  .casa-col-main__layout {
    padding: 0 12px;
  }
  .casa-col-main__grid {
    gap: 12px;
  }
  .casa-col-main__active-filters-wrap {
    display: none;
  }
  .casa-col-main__sort-select {
    font-size: 13px;
    padding: 6px 30px 6px 10px;
  }
}

@media (prefers-reduced-motion: reduce) {
  .casa-col-main__drawer,
  .casa-col-main__drawer-overlay,
  .casa-col-main__grid-item,
  .casa-col-banner,
  .casa-col-banner__cta,
  .casa-col-filter__chevron,
  .casa-col-filter__toggle-slider,
  .casa-col-filter__toggle-slider::after {
    transition: none;
  }
}
{% endstylesheet %}

<script>
document.addEventListener('DOMContentLoaded', function() {
  const section = document.getElementById('casa-collection-main');
  if (!section) return;

  const sectionId = section.dataset.sectionId;

  // ═══════════════════════════════════════════════════════════════════════
  // AJAX FILTERING
  // ═══════════════════════════════════════════════════════════════════════

  const filterForm = section.querySelector('[data-filter-form]');
  const gridWrapper = section.querySelector('[data-grid-wrapper]');
  const activeFiltersContainer = section.querySelector('[data-active-filters-container]');
  const productCountEl = section.querySelector('[data-product-count]');
  let fetchController = null;

  function getFilterURL() {
    if (!filterForm) return window.location.pathname;
    const formData = new FormData(filterForm);
    const params = new URLSearchParams();

    for (const [key, value] of formData.entries()) {
      if (value !== '' && value !== null) {
        params.append(key, value);
      }
    }

    // Remove empty price filters
    if (params.get('filter.v.price.gte') === '') params.delete('filter.v.price.gte');
    if (params.get('filter.v.price.lte') === '') params.delete('filter.v.price.lte');

    // Add sort
    const sortSelect = section.querySelector('[data-sort-select]');
    if (sortSelect && sortSelect.value) {
      params.set('sort_by', sortSelect.value);
    }

    const url = window.location.pathname;
    const paramString = params.toString();
    return paramString ? url + '?' + paramString : url;
  }

  function updateSection(url) {
    if (fetchController) fetchController.abort();
    fetchController = new AbortController();

    gridWrapper.classList.add('is-loading');

    const fetchURL = url + (url.includes('?') ? '&' : '?') + 'section_id=' + sectionId;

    fetch(fetchURL, { signal: fetchController.signal })
      .then(res => res.text())
      .then(html => {
        const parser = new DOMParser();
        const doc = parser.parseFromString(html, 'text/html');
        const newSection = doc.getElementById('casa-collection-main');

        if (newSection) {
          // Update grid
          const newGrid = newSection.querySelector('[data-grid-wrapper]');
          if (newGrid && gridWrapper) {
            gridWrapper.innerHTML = newGrid.innerHTML;
          }

          // Update active filters
          const newActive = newSection.querySelector('[data-active-filters-container]');
          if (newActive && activeFiltersContainer) {
            activeFiltersContainer.innerHTML = newActive.innerHTML;
          }

          // Update product count
          const newCount = newSection.querySelector('[data-product-count]');
          if (newCount && productCountEl) {
            productCountEl.textContent = newCount.textContent;
          }

          // Re-bind pagination links
          bindPaginationLinks();
          // Re-bind active filter removal
          bindActiveFilterLinks();
        }

        gridWrapper.classList.remove('is-loading');
        history.pushState(null, '', url);
      })
      .catch(err => {
        if (err.name !== 'AbortError') {
          gridWrapper.classList.remove('is-loading');
          console.error('Filter update failed:', err);
        }
      });
  }

  // Debounce helper
  let filterTimeout;
  function debouncedUpdate() {
    clearTimeout(filterTimeout);
    filterTimeout = setTimeout(() => {
      updateSection(getFilterURL());
    }, 300);
  }

  // Listen for filter changes
  if (filterForm) {
    filterForm.addEventListener('change', function(e) {
      if (e.target.matches('input, select')) {
        debouncedUpdate();
      }
    });

    filterForm.addEventListener('input', function(e) {
      if (e.target.matches('.casa-col-filter__price-input')) {
        debouncedUpdate();
      }
    });

    filterForm.addEventListener('submit', function(e) {
      e.preventDefault();
      updateSection(getFilterURL());
    });
  }

  // Sort change
  const sortSelect = section.querySelector('[data-sort-select]');
  if (sortSelect) {
    sortSelect.addEventListener('change', function() {
      updateSection(getFilterURL());
    });
  }

  // ═══════════════════════════════════════════════════════════════════════
  // ACTIVE FILTER REMOVAL (AJAX)
  // ═══════════════════════════════════════════════════════════════════════

  function bindActiveFilterLinks() {
    section.querySelectorAll('[data-filter-remove], [data-filter-clear]').forEach(link => {
      link.addEventListener('click', function(e) {
        e.preventDefault();
        updateSection(this.href);
      });
    });
  }
  bindActiveFilterLinks();

  // ═══════════════════════════════════════════════════════════════════════
  // PAGINATION (AJAX)
  // ═══════════════════════════════════════════════════════════════════════

  function bindPaginationLinks() {
    section.querySelectorAll('[data-page-link]').forEach(link => {
      link.addEventListener('click', function(e) {
        e.preventDefault();
        updateSection(this.href);
        // Scroll to top of section
        section.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });
  }
  bindPaginationLinks();

  // ═══════════════════════════════════════════════════════════════════════
  // BACK/FORWARD NAVIGATION
  // ═══════════════════════════════════════════════════════════════════════

  window.addEventListener('popstate', function() {
    updateSection(window.location.href);
  });

  // ═══════════════════════════════════════════════════════════════════════
  // VIEW TOGGLE
  // ═══════════════════════════════════════════════════════════════════════

  section.querySelectorAll('[data-view]').forEach(btn => {
    btn.addEventListener('click', function() {
      section.querySelectorAll('[data-view]').forEach(b => b.classList.remove('casa-col-main__view-btn--active'));
      this.classList.add('casa-col-main__view-btn--active');

      const view = this.dataset.view;
      const grid = section.querySelector('[data-product-grid]');
      if (!grid) return;

      if (view === 'large') {
        grid.style.setProperty('--ccm-columns', '2');
      } else if (view === 'list') {
        grid.style.setProperty('--ccm-columns', '1');
      } else {
        grid.style.removeProperty('--ccm-columns');
      }
    });
  });

  // ═══════════════════════════════════════════════════════════════════════
  // MOBILE FILTER DRAWER
  // ═══════════════════════════════════════════════════════════════════════

  const drawer = section.querySelector('[data-drawer]');
  const drawerOverlay = section.querySelector('[data-drawer-overlay]');
  const drawerBody = section.querySelector('[data-drawer-body]');
  const openBtn = section.querySelector('[data-drawer-open]');
  const closeBtn = section.querySelector('[data-drawer-close]');
  const applyBtn = section.querySelector('[data-drawer-apply]');

  function openDrawer() {
    if (!drawer || !drawerBody || !filterForm) return;

    // Clone filter form into drawer
    const clone = filterForm.cloneNode(true);
    clone.removeAttribute('id');
    clone.setAttribute('data-drawer-filter-form', '');
    drawerBody.innerHTML = '';
    drawerBody.appendChild(clone);

    drawer.classList.add('is-open');
    drawer.setAttribute('aria-hidden', 'false');
    drawerOverlay.classList.add('is-visible');
    document.body.style.overflow = 'hidden';

    // Sync changes from drawer back to main form
    clone.addEventListener('change', function(e) {
      const name = e.target.name;
      const value = e.target.value;
      const checked = e.target.checked;
      const mainInput = filterForm.querySelector('[name="' + name + '"][value="' + value + '"]');
      if (mainInput) {
        mainInput.checked = checked;
      }
    });
  }

  function closeDrawer() {
    if (!drawer) return;
    drawer.classList.remove('is-open');
    drawer.setAttribute('aria-hidden', 'true');
    drawerOverlay.classList.remove('is-visible');
    document.body.style.overflow = '';
  }

  if (openBtn) openBtn.addEventListener('click', openDrawer);
  if (closeBtn) closeBtn.addEventListener('click', closeDrawer);
  if (drawerOverlay) drawerOverlay.addEventListener('click', closeDrawer);
  if (applyBtn) {
    applyBtn.addEventListener('click', function() {
      closeDrawer();
      updateSection(getFilterURL());
    });
  }

  // Close drawer on Escape
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && drawer && drawer.classList.contains('is-open')) {
      closeDrawer();
    }
  });

  // ═══════════════════════════════════════════════════════════════════════
  // PRICE SLIDER SYNC
  // ═══════════════════════════════════════════════════════════════════════

  section.querySelectorAll('.casa-col-filter__price-range').forEach(priceRange => {
    const minThumb = priceRange.querySelector('.casa-col-filter__price-thumb--min');
    const maxThumb = priceRange.querySelector('.casa-col-filter__price-thumb--max');
    const fill = priceRange.querySelector('.casa-col-filter__price-fill');
    const minInput = priceRange.querySelector('.casa-col-filter__price-input[name*="gte"]');
    const maxInput = priceRange.querySelector('.casa-col-filter__price-input[name*="lte"]');

    if (!minThumb || !maxThumb || !fill) return;

    function updateFill() {
      const min = parseFloat(minThumb.value);
      const max = parseFloat(maxThumb.value);
      const rangeMin = parseFloat(minThumb.min);
      const rangeMax = parseFloat(minThumb.max);
      const range = rangeMax - rangeMin;

      const leftPct = ((min - rangeMin) / range) * 100;
      const rightPct = ((max - rangeMin) / range) * 100;

      fill.style.left = leftPct + '%';
      fill.style.width = (rightPct - leftPct) + '%';
    }

    minThumb.addEventListener('input', function() {
      if (parseFloat(this.value) > parseFloat(maxThumb.value)) {
        this.value = maxThumb.value;
      }
      if (minInput) minInput.value = Math.ceil(this.value);
      updateFill();
    });

    maxThumb.addEventListener('input', function() {
      if (parseFloat(this.value) < parseFloat(minThumb.value)) {
        this.value = minThumb.value;
      }
      if (maxInput) maxInput.value = Math.ceil(this.value);
      updateFill();
    });

    if (minInput) {
      minInput.addEventListener('input', function() {
        minThumb.value = this.value;
        updateFill();
      });
    }

    if (maxInput) {
      maxInput.addEventListener('input', function() {
        maxThumb.value = this.value;
        updateFill();
      });
    }

    // Initial fill
    updateFill();
  });

  // ═══════════════════════════════════════════════════════════════════════
  // ENTRANCE ANIMATIONS
  // ═══════════════════════════════════════════════════════════════════════

  if ('IntersectionObserver' in window) {
    const observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.style.opacity = '1';
          entry.target.style.transform = 'translateY(0)';
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

    section.querySelectorAll('.casa-col-main__grid-item').forEach(function(item, index) {
      item.style.opacity = '0';
      item.style.transform = 'translateY(20px)';
      item.style.transition = 'opacity 0.4s ease ' + (index % 4) * 0.08 + 's, transform 0.4s ease ' + (index % 4) * 0.08 + 's';
      observer.observe(item);
    });
  }
});
</script>
