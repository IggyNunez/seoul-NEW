{%- liquid
  assign products_per_page = section.settings.products_per_page | default: 24
  assign columns_desktop = section.settings.columns_desktop | default: 4
  assign columns_mobile = section.settings.columns_mobile | default: 2
  assign show_sidebar = section.settings.show_sidebar_filters | default: true
  assign show_sort = section.settings.show_sort | default: true
  assign show_view_toggle = section.settings.show_view_toggle | default: true
  assign show_product_count = section.settings.show_product_count | default: true
  assign sort_by = collection.sort_by | default: collection.default_sort_by
  assign padding_top = section.settings.padding_top | default: 0
  assign padding_bottom = section.settings.padding_bottom | default: 60

  # Color settings
  assign bg_color = section.settings.bg_color | default: '#0a0a0f'
  assign bg_secondary = section.settings.bg_secondary | default: '#0f0f18'
  assign text_primary = section.settings.text_primary | default: '#ffffff'
  assign text_secondary = section.settings.text_secondary | default: '#a0a0a0'
  assign accent_primary = section.settings.accent_primary | default: '#9333ea'
  assign accent_secondary = section.settings.accent_secondary | default: '#ec4899'
  assign toolbar_bg = section.settings.toolbar_bg | default: '#1a1a24'
  assign toolbar_border = section.settings.toolbar_border | default: '#2a2a3a'
  assign remove_accent = section.settings.remove_accent | default: '#ef4444'
  assign divider_color = section.settings.divider_color | default: '#1a1a2e'
  assign overlay_color = section.settings.overlay_color | default: '#000000'
  assign input_bg = section.settings.input_bg | default: '#12121a'
  assign input_border = section.settings.input_border | default: '#2a2a3e'
  assign card_bg = section.settings.card_bg | default: '#0f0f18'
  assign highlight_bg = section.settings.highlight_bg | default: '#1f1f2e'

  # Border radius settings
  assign radius_small = section.settings.radius_small | default: 8
  assign radius_pill = section.settings.radius_pill | default: 20

  # Spacing settings
  assign grid_gap = section.settings.grid_gap | default: 12
  assign sidebar_width = section.settings.sidebar_width | default: 280
  assign toolbar_padding = section.settings.toolbar_padding | default: 60
  assign filter_gap = section.settings.filter_gap | default: 16

  # Effect settings
  assign backdrop_blur = section.settings.backdrop_blur | default: 12
  assign overlay_opacity = section.settings.overlay_opacity | default: 60
  assign hover_lift = section.settings.hover_lift | default: 4
  assign border_width = section.settings.border_width | default: 1

  # Typography settings
  assign font_size_xs = section.settings.font_size_xs | default: 11
  assign font_size_sm = section.settings.font_size_sm | default: 12
  assign font_size_md = section.settings.font_size_md | default: 15
  assign font_size_lg = section.settings.font_size_lg | default: 24
  assign font_size_xl = section.settings.font_size_xl | default: 36
  assign font_weight_normal = section.settings.font_weight_normal | default: 500
  assign font_weight_bold = section.settings.font_weight_bold | default: 600
  assign letter_spacing_caps = section.settings.letter_spacing_caps | default: 1

  # Element size settings
  assign swatch_size = section.settings.swatch_size | default: 28
  assign checkbox_size = section.settings.checkbox_size | default: 16
  assign toggle_width = section.settings.toggle_width | default: 40
  assign toggle_height = section.settings.toggle_height | default: 22
  assign icon_size_sm = section.settings.icon_size_sm | default: 18
  assign icon_size_lg = section.settings.icon_size_lg | default: 24
  assign view_btn_size = section.settings.view_btn_size | default: 36

  # Shadow settings
  assign shadow_intensity = section.settings.shadow_intensity | default: 20
  assign shadow_blur = section.settings.shadow_blur | default: 20
  assign shadow_offset = section.settings.shadow_offset | default: 20

  # Transition settings
  assign transition_fast = section.settings.transition_fast | default: 200
  assign transition_normal = section.settings.transition_normal | default: 300

  # Drawer settings
  assign drawer_width = section.settings.drawer_width | default: 360
  assign drawer_header_height = section.settings.drawer_header_height | default: 60
  assign drawer_padding = section.settings.drawer_padding | default: 20
  assign drawer_footer_height = section.settings.drawer_footer_height | default: 80
  assign drawer_radius = section.settings.drawer_radius | default: 16

  # Pagination settings
  assign page_btn_size = section.settings.page_btn_size | default: 44
  assign page_btn_gap = section.settings.page_btn_gap | default: 8

  # Promo banner settings
  assign promo_padding = section.settings.promo_padding | default: 32
  assign promo_full_padding = section.settings.promo_full_padding | default: 48
  assign promo_visual_size = section.settings.promo_visual_size | default: 180
  assign promo_gap = section.settings.promo_gap | default: 60

  # Filter element settings
  assign chip_padding_x = section.settings.chip_padding_x | default: 10
  assign chip_padding_y = section.settings.chip_padding_y | default: 5
  assign chip_gap = section.settings.chip_gap | default: 8
  assign option_gap = section.settings.option_gap | default: 2

  # State settings
  assign disabled_opacity = section.settings.disabled_opacity | default: 30
  assign hover_scale = section.settings.hover_scale | default: 110

  # CRO feature flags
  assign show_quick_add = section.settings.show_quick_add | default: false
  assign show_variant_swatches = section.settings.show_variant_swatches | default: false
  assign show_wishlist = section.settings.show_wishlist | default: false
  assign show_rating = section.settings.show_rating | default: false
  assign show_quick_view = section.settings.show_quick_view | default: false
  assign show_stock_urgency = section.settings.show_stock_urgency | default: false
  assign show_installment = section.settings.show_installment | default: false
  assign show_savings_highlight = section.settings.show_savings_highlight | default: false
  assign show_social_proof = section.settings.show_social_proof | default: false

  # Collect promo banner positions for insertion logic
  assign promo_blocks = '' | split: ','
  for block in section.blocks
    if block.type == 'promo_banner' or block.type == 'full_width_banner' or block.type == 'media_banner'
      assign promo_blocks = promo_blocks | push: block
    endif
  endfor
-%}

<section
  class="casa-col-main"
  id="casa-collection-main"
  data-section-id="{{ section.id }}"
  style="
    --ccm-columns: {{ columns_desktop }};
    --ccm-columns-mobile: {{ columns_mobile }};
    --ccm-pt: {{ padding_top }}px;
    --ccm-pb: {{ padding_bottom }}px;
    --ccm-bg: {{ bg_color }};
    --ccm-bg-secondary: {{ bg_secondary }};
    --ccm-text: {{ text_primary }};
    --ccm-text-muted: {{ text_secondary }};
    --ccm-accent-1: {{ accent_primary }};
    --ccm-accent-2: {{ accent_secondary }};
    --ccm-toolbar-bg: {{ toolbar_bg }};
    --ccm-toolbar-border: {{ toolbar_border }};
    --ccm-remove-accent: {{ remove_accent }};
    --ccm-divider: {{ divider_color }};
    --ccm-overlay: {{ overlay_color }};
    --ccm-input-bg: {{ input_bg }};
    --ccm-input-border: {{ input_border }};
    --ccm-card-bg: {{ card_bg }};
    --ccm-highlight-bg: {{ highlight_bg }};
    --ccm-radius-sm: {{ radius_small }}px;
    --ccm-radius-pill: {{ radius_pill }}px;
    --ccm-grid-gap: {{ grid_gap }}px;
    --card-title-size: {{ section.settings.card_title_size | default: 13 }}px;
    --card-info-gap: {{ section.settings.card_info_gap | default: 4 }}px;
    --ccm-sidebar-w: {{ sidebar_width }}px;
    --ccm-toolbar-pad: {{ toolbar_padding }}px;
    --ccm-filter-gap: {{ filter_gap }}px;
    --ccm-blur: {{ backdrop_blur }}px;
    --ccm-overlay-opacity: {{ overlay_opacity }};
    --ccm-hover-lift: {{ hover_lift }}px;
    --ccm-border-w: {{ border_width }}px;
    --ccm-font-xs: {{ font_size_xs }}px;
    --ccm-font-sm: {{ font_size_sm }}px;
    --ccm-font-md: {{ font_size_md }}px;
    --ccm-font-lg: {{ font_size_lg }}px;
    --ccm-font-xl: {{ font_size_xl }}px;
    --ccm-fw-normal: {{ font_weight_normal }};
    --ccm-fw-bold: {{ font_weight_bold }};
    --ccm-ls-caps: {{ letter_spacing_caps }}px;
    --ccm-swatch-size: {{ swatch_size }}px;
    --ccm-checkbox-size: {{ checkbox_size }}px;
    --ccm-toggle-w: {{ toggle_width }}px;
    --ccm-toggle-h: {{ toggle_height }}px;
    --ccm-icon-sm: {{ icon_size_sm }}px;
    --ccm-icon-lg: {{ icon_size_lg }}px;
    --ccm-view-btn: {{ view_btn_size }}px;
    --ccm-shadow-intensity: {{ shadow_intensity }}%;
    --ccm-shadow-blur: {{ shadow_blur }}px;
    --ccm-shadow-offset: {{ shadow_offset }}px;
    --ccm-trans-fast: {{ transition_fast }}ms;
    --ccm-trans-normal: {{ transition_normal }}ms;
    --ccm-drawer-w: {{ drawer_width }}px;
    --ccm-drawer-header: {{ drawer_header_height }}px;
    --ccm-drawer-pad: {{ drawer_padding }}px;
    --ccm-drawer-footer: {{ drawer_footer_height }}px;
    --ccm-drawer-radius: {{ drawer_radius }}px;
    --ccm-page-btn: {{ page_btn_size }}px;
    --ccm-page-gap: {{ page_btn_gap }}px;
    --ccm-promo-pad: {{ promo_padding }}px;
    --ccm-promo-full-pad: {{ promo_full_padding }}px;
    --ccm-promo-visual: {{ promo_visual_size }}px;
    --ccm-promo-gap: {{ promo_gap }}px;
    --ccm-chip-px: {{ chip_padding_x }}px;
    --ccm-chip-py: {{ chip_padding_y }}px;
    --ccm-chip-gap: {{ chip_gap }}px;
    --ccm-option-gap: {{ option_gap }}px;
    --ccm-disabled-opacity: {{ disabled_opacity | divided_by: 100.0 }};
    --ccm-hover-scale: {{ hover_scale | divided_by: 100.0 }};
    {%- if section.settings.card_atc_bg_1 != blank and section.settings.card_atc_bg_2 != blank -%}--card-atc-bg: linear-gradient(135deg, {{ section.settings.card_atc_bg_1 }}, {{ section.settings.card_atc_bg_2 }});{%- endif -%}
    {%- if section.settings.card_atc_text != blank -%}--card-atc-text: {{ section.settings.card_atc_text }};{%- endif -%}
    {%- if section.settings.card_options_bg_1 != blank and section.settings.card_options_bg_2 != blank -%}--card-options-bg: linear-gradient(135deg, {{ section.settings.card_options_bg_1 }}, {{ section.settings.card_options_bg_2 }});{%- endif -%}
    {%- if section.settings.card_options_text != blank -%}--card-options-text: {{ section.settings.card_options_text }};{%- endif -%}
  "
>
  {%- comment -%} ══════════════════════════════════════════════════
     TOOLBAR
  ══════════════════════════════════════════════════ {%- endcomment -%}
  <div class="casa-col-main__toolbar">
    <div class="casa-col-main__toolbar-left">
      <button type="button" class="casa-col-main__filter-toggle" data-drawer-open aria-label="Open filters">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" y1="21" x2="4" y2="14"></line>
          <line x1="4" y1="10" x2="4" y2="3"></line>
          <line x1="12" y1="21" x2="12" y2="12"></line>
          <line x1="12" y1="8" x2="12" y2="3"></line>
          <line x1="20" y1="21" x2="20" y2="16"></line>
          <line x1="20" y1="12" x2="20" y2="3"></line>
          <line x1="1" y1="14" x2="7" y2="14"></line>
          <line x1="9" y1="8" x2="15" y2="8"></line>
          <line x1="17" y1="16" x2="23" y2="16"></line>
        </svg>
        <span>Filters</span>
      </button>
      <div class="casa-col-main__active-filters-wrap" data-active-filters-container>
        {%- render 'casa-collection-active-filters', filters: collection.filters, collection_url: collection.url -%}
      </div>
    </div>

    <div class="casa-col-main__toolbar-right">
      {%- if show_product_count -%}
        <span class="casa-col-main__count" data-product-count>
          {{ collection.products_count }} products
        </span>
      {%- endif -%}

      {%- if show_sort -%}
        <div class="casa-col-main__sort">
          <label for="casa-sort-select" class="visually-hidden">Sort by</label>
          <select id="casa-sort-select" class="casa-col-main__sort-select" data-sort-select>
            {%- for option in collection.sort_options -%}
              <option value="{{ option.value }}" {% if option.value == sort_by %}selected{% endif %}>
                {{ option.name }}
              </option>
            {%- endfor -%}
          </select>
          <svg class="casa-col-main__sort-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </div>
      {%- endif -%}

      {%- if show_view_toggle -%}
        <div class="casa-col-main__view-toggle">
          <button type="button" class="casa-col-main__view-btn casa-col-main__view-btn--active" data-view="grid" aria-label="Grid view">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="7" height="7"></rect>
              <rect x="14" y="3" width="7" height="7"></rect>
              <rect x="3" y="14" width="7" height="7"></rect>
              <rect x="14" y="14" width="7" height="7"></rect>
            </svg>
          </button>
          <button type="button" class="casa-col-main__view-btn" data-view="large" aria-label="Large grid view">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="8"></rect>
              <rect x="3" y="13" width="18" height="8"></rect>
            </svg>
          </button>
          <button type="button" class="casa-col-main__view-btn" data-view="list" aria-label="List view">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="8" y1="6" x2="21" y2="6"></line>
              <line x1="8" y1="12" x2="21" y2="12"></line>
              <line x1="8" y1="18" x2="21" y2="18"></line>
              <line x1="3" y1="6" x2="3.01" y2="6"></line>
              <line x1="3" y1="12" x2="3.01" y2="12"></line>
              <line x1="3" y1="18" x2="3.01" y2="18"></line>
            </svg>
          </button>
        </div>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} ══════════════════════════════════════════════════
     MAIN LAYOUT: Sidebar + Grid
  ══════════════════════════════════════════════════ {%- endcomment -%}
  <div class="casa-col-main__layout">

    {%- comment -%} SIDEBAR FILTERS (desktop) {%- endcomment -%}
    {%- if show_sidebar -%}
      <aside class="casa-col-main__sidebar" data-sidebar>
        <form id="casa-filter-form" data-filter-form>
          {%- for filter in collection.filters -%}
            {%- render 'casa-collection-filter', filter: filter, open: true -%}
          {%- endfor -%}

          {%- comment -%} Show Results button (visible on mobile drawer) {%- endcomment -%}
          <button type="submit" class="casa-col-main__apply-btn">
            Show {{ collection.products_count }} Results
          </button>
        </form>
      </aside>
    {%- endif -%}

    {%- comment -%} PRODUCT GRID {%- endcomment -%}
    <div class="casa-col-main__grid-wrapper" data-grid-wrapper>
      {%- paginate collection.products by products_per_page -%}
        {%- if collection.products.size > 0 -%}
          <ul class="casa-col-main__grid" data-product-grid>
            {%- assign grid_index = 0 -%}
            {%- for product in collection.products -%}
              {%- assign grid_index = grid_index | plus: 1 -%}

              {%- comment -%} Check if a banner should be inserted before this product {%- endcomment -%}
              {%- for block in section.blocks -%}
                {%- if block.type == 'promo_banner' -%}
                  {%- assign _block_pos = block.settings.grid_position | plus: 0 -%}
                  {%- if _block_pos == grid_index -%}
                    {%- liquid
                      assign _bw = block.settings.banner_width | default: 'full'
                      if _bw == 'full'
                        assign _col = '1 / -1'
                      else
                        assign _col = '1 / span ' | append: _bw
                      endif
                    -%}
                    <li class="casa-col-main__grid-item casa-col-main__grid-item--promo" style="grid-column: {{ _col }};" {{ block.shopify_attributes }}>
                      {%- render 'casa-collection-promo-banner', block: block -%}
                    </li>
                  {%- endif -%}
                {%- endif -%}
              {%- endfor -%}

              <li class="casa-col-main__grid-item">
                {%- render 'casa-product-card',
                  product: product,
                  variant: 'collection',
                  info_align: section.settings.card_info_align,
                  index: forloop.index0,
                  show_quick_add: show_quick_add,
                  show_variant_swatches: show_variant_swatches,
                  show_wishlist: show_wishlist,
                  show_rating: show_rating,
                  show_quick_view: show_quick_view,
                  show_stock_urgency: show_stock_urgency,
                  show_installment: show_installment,
                  show_savings_highlight: show_savings_highlight,
                  show_social_proof: show_social_proof,
                  title_color: section.settings.card_title_color,
                  price_color: section.settings.card_price_color,
                  compare_color: section.settings.card_compare_color,
                  show_sale_badge: section.settings.show_sale_badge,
                  badge_bg: section.settings.card_badge_bg,
                  badge_text: section.settings.card_badge_text,
                  savings_bg: section.settings.card_savings_bg,
                  savings_text: section.settings.card_savings_text,
                  installment_color: section.settings.card_installment_color,
                  stars_color: section.settings.card_stars_color,
                  reviews_color: section.settings.card_reviews_color
                -%}
              </li>
            {%- endfor -%}

            {%- comment -%} Render banners positioned beyond product count {%- endcomment -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'promo_banner' -%}
                {%- assign _block_pos = block.settings.grid_position | default: 999 | plus: 0 -%}
                {%- if _block_pos >= grid_index -%}
                  {%- liquid
                    assign _bw = block.settings.banner_width | default: 'full'
                    if _bw == 'full'
                      assign _col = '1 / -1'
                    else
                      assign _col = '1 / span ' | append: _bw
                    endif
                  -%}
                  <li class="casa-col-main__grid-item casa-col-main__grid-item--promo" style="grid-column: {{ _col }};" {{ block.shopify_attributes }}>
                    {%- render 'casa-collection-promo-banner', block: block -%}
                  </li>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          </ul>

          {%- comment -%} Pagination {%- endcomment -%}
          {%- if paginate.pages > 1 -%}
            <nav class="casa-col-main__pagination" aria-label="Pagination" data-pagination>
              {%- if paginate.previous -%}
                <a href="{{ paginate.previous.url }}" class="casa-col-main__page-btn" data-page-link aria-label="Previous page">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
                </a>
              {%- endif -%}

              {%- for part in paginate.parts -%}
                {%- if part.is_link -%}
                  <a href="{{ part.url }}" class="casa-col-main__page-num" data-page-link>{{ part.title }}</a>
                {%- elsif part.title == paginate.current_page -%}
                  <span class="casa-col-main__page-num casa-col-main__page-num--current" aria-current="page">{{ part.title }}</span>
                {%- else -%}
                  <span class="casa-col-main__page-dots">{{ part.title }}</span>
                {%- endif -%}
              {%- endfor -%}

              {%- if paginate.next -%}
                <a href="{{ paginate.next.url }}" class="casa-col-main__page-btn" data-page-link aria-label="Next page">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
                </a>
              {%- endif -%}
            </nav>
          {%- endif -%}
        {%- else -%}
          <div class="casa-col-main__empty">
            <p>No products match your filters.</p>
            <a href="{{ collection.url }}" class="casa-col-main__empty-link">Clear all filters</a>
          </div>
        {%- endif -%}
      {%- endpaginate -%}
    </div>
  </div>

  {%- comment -%} ══════════════════════════════════════════════════
     MOBILE FILTER DRAWER
  ══════════════════════════════════════════════════ {%- endcomment -%}
  <div class="casa-col-main__drawer" data-drawer aria-hidden="true">
    <div class="casa-col-main__drawer-header">
      <h3 class="casa-col-main__drawer-title">Filter & Sort</h3>
      <button type="button" class="casa-col-main__drawer-close" data-drawer-close aria-label="Close filters">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <div class="casa-col-main__drawer-body" data-drawer-body>
      {%- comment -%} Filter form gets cloned here via JS {%- endcomment -%}
    </div>
    <div class="casa-col-main__drawer-footer">
      <button type="button" class="casa-col-main__drawer-apply" data-drawer-apply>
        Show {{ collection.products_count }} Results
      </button>
    </div>
  </div>
  <div class="casa-col-main__drawer-overlay" data-drawer-overlay></div>
</section>

{% schema %}
{
  "name": "Casa Collection Main",
  "tag": "section",
  "class": "casa-collection-main-section",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 12,
      "max": 48,
      "step": 4,
      "default": 24
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Desktop columns",
      "options": [
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Mobile columns",
      "options": [
        { "value": "1", "label": "1 column" },
        { "value": "2", "label": "2 columns" }
      ],
      "default": "2"
    },
    {
      "type": "checkbox",
      "id": "show_sidebar_filters",
      "label": "Show sidebar filters",
      "default": true
    },
    {
      "type": "header",
      "content": "Toolbar"
    },
    {
      "type": "checkbox",
      "id": "show_sort",
      "label": "Show sort dropdown",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_view_toggle",
      "label": "Show view toggle",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_product_count",
      "label": "Show product count",
      "default": true
    },
    {
      "type": "header",
      "content": "CRO Features"
