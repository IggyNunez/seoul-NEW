{% comment %}
  Seoul Glow Lab — Bento Image Grid Section
  Asymmetric editorial image grid with text overlays
  Inspired by modern beauty brand layouts (Kylie-style)
  Fully editable via Shopify theme customizer
{% endcomment %}

{%- liquid
  assign color_scheme = section.settings.color_scheme | default: 'scheme-1'
  assign grid_gap = section.settings.grid_gap | default: 8
  assign section_padding_top = section.settings.padding_top | default: 0
  assign section_padding_bottom = section.settings.padding_bottom | default: 0
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign layout = section.settings.layout | default: 'asymmetric'
-%}

<section
  id="sgl-bento-{{ section.id }}"
  class="sgl-bento color-{{ color_scheme }}"
  data-section-id="{{ section.id }}"
  data-section-type="sgl-bento-grid"
  style="
    --bento-gap: {{ grid_gap }}px;
    --bento-padding-top: {{ section_padding_top }}px;
    --bento-padding-bottom: {{ section_padding_bottom }}px;
  "
>
  {%- comment -%} Optional section header {%- endcomment -%}
  {%- if heading != blank or subheading != blank -%}
    <div class="sgl-bento__header page-width">
      {%- if heading != blank -%}
        <h2 class="sgl-bento__heading">{{ heading }}</h2>
      {%- endif -%}
      {%- if subheading != blank -%}
        <p class="sgl-bento__subheading">{{ subheading }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- comment -%} Grid container {%- endcomment -%}
  <div class="sgl-bento__grid sgl-bento__grid--{{ layout }}" data-anim="bento-grid">
    {%- for block in section.blocks -%}
      {%- liquid
        assign block_color = block.settings.color_scheme | default: color_scheme
        assign text_position = block.settings.text_position | default: 'bottom-left'
        assign text_color = block.settings.text_color | default: 'light'
        assign overlay_opacity = block.settings.overlay_opacity | default: 30
        assign has_link = false
        if block.settings.link != blank
          assign has_link = true
        endif
      -%}

      {%- if has_link -%}
        <a
          href="{{ block.settings.link }}"
          class="sgl-bento__item sgl-bento__item--{{ forloop.index }} sgl-bento__text--{{ text_color }}"
          data-anim="bento-item"
          style="--overlay-opacity: {{ overlay_opacity | divided_by: 100.0 }};"
          {{ block.shopify_attributes }}
        >
      {%- else -%}
        <div
          class="sgl-bento__item sgl-bento__item--{{ forloop.index }} sgl-bento__text--{{ text_color }}"
          data-anim="bento-item"
          style="--overlay-opacity: {{ overlay_opacity | divided_by: 100.0 }};"
          {{ block.shopify_attributes }}
        >
      {%- endif -%}

        {%- comment -%} Image {%- endcomment -%}
        <div class="sgl-bento__image-wrap">
          {%- if block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: width: 1200 }}"
              srcset="
                {{ block.settings.image | image_url: width: 400 }} 400w,
                {{ block.settings.image | image_url: width: 600 }} 600w,
                {{ block.settings.image | image_url: width: 800 }} 800w,
                {{ block.settings.image | image_url: width: 1200 }} 1200w
              "
              sizes="(max-width: 749px) 100vw, 50vw"
              alt="{{ block.settings.image.alt | default: block.settings.heading | default: 'Seoul Glow Lab' }}"
              class="sgl-bento__image"
              loading="lazy"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
            >
          {%- else -%}
            <div class="sgl-bento__placeholder">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="sgl-bento__placeholder-icon">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <path d="m21 15-5-5L5 21"/>
              </svg>
            </div>
          {%- endif -%}

          {%- comment -%} Overlay {%- endcomment -%}
          <div class="sgl-bento__overlay"></div>
        </div>

        {%- comment -%} Text content {%- endcomment -%}
        {%- if block.settings.heading != blank or block.settings.caption != blank or block.settings.button_label != blank -%}
          <div class="sgl-bento__content sgl-bento__content--{{ text_position }}">
            {%- if block.settings.caption != blank -%}
              <span class="sgl-bento__caption">{{ block.settings.caption }}</span>
            {%- endif -%}

            {%- if block.settings.heading != blank -%}
              <h3 class="sgl-bento__item-heading">{{ block.settings.heading | newline_to_br }}</h3>
            {%- endif -%}

            {%- if block.settings.button_label != blank -%}
              <span class="sgl-bento__btn">{{ block.settings.button_label }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}

      {%- if has_link -%}
        </a>
      {%- else -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

<style>
  /* =============================================
     SGL BENTO GRID — BASE
  ============================================= */
  .sgl-bento {
    padding-top: var(--bento-padding-top, 0);
    padding-bottom: var(--bento-padding-bottom, 0);
    overflow: hidden;
  }

  /* Section header */
  .sgl-bento__header {
    text-align: center;
    padding-bottom: clamp(24px, 4vw, 48px);
  }

  .sgl-bento__heading {
    margin: 0;
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: clamp(1.8rem, 4vw, 3rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--color-foreground-heading);
  }

  .sgl-bento__subheading {
    margin: 12px 0 0;
    font-family: var(--font-body--family);
    font-size: clamp(0.85rem, 1.4vw, 1rem);
    line-height: 1.6;
    color: var(--color-foreground);
    opacity: 0.7;
    max-width: 520px;
    margin-left: auto;
    margin-right: auto;
  }

  /* =============================================
     GRID LAYOUTS
  ============================================= */
  .sgl-bento__grid {
    display: grid;
    gap: var(--bento-gap, 8px);
    width: 100%;
  }

  /* Asymmetric: 2 cols, first item spans full height left, 2 stacked right */
  .sgl-bento__grid--asymmetric {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
  }

  .sgl-bento__grid--asymmetric .sgl-bento__item--1 {
    grid-row: 1 / 3;
  }

  /* Triptych: 3 equal columns */
  .sgl-bento__grid--triptych {
    grid-template-columns: 1fr 1fr 1fr;
  }

  /* Featured: 1 large top, 2 half-width bottom */
  .sgl-bento__grid--featured {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
  }

  .sgl-bento__grid--featured .sgl-bento__item--1 {
    grid-column: 1 / 3;
  }

  /* Mosaic: 2×2 with first item 60% width */
  .sgl-bento__grid--mosaic {
    grid-template-columns: 3fr 2fr;
    grid-template-rows: 1fr 1fr;
  }

  .sgl-bento__grid--mosaic .sgl-bento__item--1 {
    grid-row: 1 / 3;
  }

  /* =============================================
     GRID ITEMS
  ============================================= */
  .sgl-bento__item {
    position: relative;
    display: block;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    min-height: 300px;
    cursor: default;
  }

  a.sgl-bento__item {
    cursor: pointer;
  }

  a.sgl-bento__item:hover .sgl-bento__image {
    transform: scale(1.04);
  }

  a.sgl-bento__item:hover .sgl-bento__btn {
    background: var(--color-foreground-heading);
    color: var(--color-background);
    border-color: var(--color-foreground-heading);
  }

  /* Image */
  .sgl-bento__image-wrap {
    position: absolute;
    inset: 0;
  }

  .sgl-bento__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .sgl-bento__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, var(--overlay-opacity, 0.3));
    pointer-events: none;
    transition: background 0.4s ease;
  }

  a.sgl-bento__item:hover .sgl-bento__overlay {
    background: rgba(0, 0, 0, calc(var(--overlay-opacity, 0.3) + 0.08));
  }

  /* Placeholder */
  .sgl-bento__placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-background);
    border: 1px solid var(--color-foreground);
    opacity: 0.1;
  }

  .sgl-bento__placeholder-icon {
    width: 48px;
    height: 48px;
    color: var(--color-foreground);
    opacity: 0.4;
  }

  /* =============================================
     TEXT CONTENT
  ============================================= */
  .sgl-bento__content {
    position: absolute;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: clamp(20px, 3vw, 40px);
    max-width: 90%;
  }

  /* Text colors */
  .sgl-bento__text--light .sgl-bento__item-heading,
  .sgl-bento__text--light .sgl-bento__caption {
    color: #F8EBDA;
  }

  .sgl-bento__text--dark .sgl-bento__item-heading,
  .sgl-bento__text--dark .sgl-bento__caption {
    color: #1a1a1a;
  }

  /* Text positions */
  .sgl-bento__content--bottom-left {
    bottom: 0;
    left: 0;
  }

  .sgl-bento__content--bottom-right {
    bottom: 0;
    right: 0;
    text-align: right;
    align-items: flex-end;
  }

  .sgl-bento__content--top-left {
    top: 0;
    left: 0;
  }

  .sgl-bento__content--top-right {
    top: 0;
    right: 0;
    text-align: right;
    align-items: flex-end;
  }

  .sgl-bento__content--center {
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    align-items: center;
    max-width: 80%;
  }

  /* Caption */
  .sgl-bento__caption {
    font-family: var(--font-body--family);
    font-size: clamp(0.6rem, 1vw, 0.75rem);
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    opacity: 0.8;
  }

  /* Heading */
  .sgl-bento__item-heading {
    margin: 0;
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: clamp(1.6rem, 3.5vw, 3.2rem);
    line-height: 0.95;
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }

  /* CTA button */
  .sgl-bento__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 4px;
    padding: 10px 24px;
    font-family: var(--font-body--family);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    border: 1.5px solid currentColor;
    border-radius: 0;
    background: transparent;
    color: inherit;
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .sgl-bento__text--light .sgl-bento__btn {
    color: #F8EBDA;
    border-color: rgba(248, 235, 218, 0.5);
  }

  .sgl-bento__text--dark .sgl-bento__btn {
    color: #1a1a1a;
    border-color: rgba(26, 26, 26, 0.4);
  }

  /* =============================================
     SCROLL ANIMATIONS
  ============================================= */
  .sgl-bento__item {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .sgl-bento__item.sgl-bento--visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Stagger per item index */
  .sgl-bento__item--1 { transition-delay: 0s; }
  .sgl-bento__item--2 { transition-delay: 0.1s; }
  .sgl-bento__item--3 { transition-delay: 0.2s; }
  .sgl-bento__item--4 { transition-delay: 0.3s; }
  .sgl-bento__item--5 { transition-delay: 0.35s; }
  .sgl-bento__item--6 { transition-delay: 0.4s; }

  /* =============================================
     MOBILE RESPONSIVE
  ============================================= */
  @media (max-width: 749px) {
    .sgl-bento__grid--asymmetric,
    .sgl-bento__grid--triptych,
    .sgl-bento__grid--featured,
    .sgl-bento__grid--mosaic {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
    }

    .sgl-bento__grid--asymmetric .sgl-bento__item--1,
    .sgl-bento__grid--featured .sgl-bento__item--1,
    .sgl-bento__grid--mosaic .sgl-bento__item--1 {
      grid-row: auto;
      grid-column: auto;
    }

    .sgl-bento__item {
      min-height: 380px;
    }

    .sgl-bento__item-heading {
      font-size: clamp(1.8rem, 7vw, 2.6rem);
    }
  }

  /* =============================================
     TABLET
  ============================================= */
  @media (min-width: 750px) and (max-width: 989px) {
    .sgl-bento__grid--triptych {
      grid-template-columns: 1fr 1fr;
    }

    .sgl-bento__item {
      min-height: 350px;
    }
  }

  /* =============================================
     DESKTOP — tall items for Kylie-style impact
  ============================================= */
  @media (min-width: 990px) {
    .sgl-bento__grid--asymmetric {
      min-height: 700px;
    }

    .sgl-bento__grid--triptych {
      min-height: 550px;
    }

    .sgl-bento__grid--featured .sgl-bento__item--1 {
      min-height: 500px;
    }
  }

  /* =============================================
     REDUCED MOTION
  ============================================= */
  @media (prefers-reduced-motion: reduce) {
    .sgl-bento__item {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }

    .sgl-bento__image {
      transition: none !important;
    }
  }
</style>

<script>
  (function() {
    'use strict';

    var section = document.getElementById('sgl-bento-{{ section.id }}');
    if (!section) return;

    var items = section.querySelectorAll('[data-anim="bento-item"]');
    if (!items.length) return;

    /* Reduced motion check */
    if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      items.forEach(function(item) { item.classList.add('sgl-bento--visible'); });
      return;
    }

    /* IntersectionObserver for scroll reveal */
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('sgl-bento--visible');
          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.15,
      rootMargin: '0px 0px -60px 0px'
    });

    items.forEach(function(item) { observer.observe(item); });
  })();
</script>

{% schema %}
{
  "name": "SGL Bento Grid",
  "tag": "section",
  "class": "sgl-bento-section",
  "settings": [
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": ""
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": ""
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Grid layout",
      "options": [
        {
          "value": "asymmetric",
          "label": "Asymmetric (1 tall + 2 stacked)"
        },
        {
          "value": "triptych",
          "label": "Triptych (3 equal columns)"
        },
        {
          "value": "featured",
          "label": "Featured (1 wide + 2 below)"
        },
        {
          "value": "mosaic",
          "label": "Mosaic (60/40 split)"
        }
      ],
      "default": "asymmetric"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Grid gap (px)",
      "min": 0,
      "max": 24,
      "step": 2,
      "default": 8,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "image_tile",
      "name": "Image tile",
      "limit": 6,
      "settings": [
        {
          "type": "header",
          "content": "Image"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "header",
          "content": "Text overlay"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption",
          "default": ""
        },
        {
          "type": "textarea",
          "id": "heading",
          "label": "Heading",
          "default": "Smooth As\nButter"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "header",
          "content": "Text styling"
        },
        {
          "type": "select",
          "id": "text_position",
          "label": "Text position",
          "options": [
            {
              "value": "bottom-left",
              "label": "Bottom left"
            },
            {
              "value": "bottom-right",
              "label": "Bottom right"
            },
            {
              "value": "top-left",
              "label": "Top left"
            },
            {
              "value": "top-right",
              "label": "Top right"
            },
            {
              "value": "center",
              "label": "Center"
            }
          ],
          "default": "bottom-left"
        },
        {
          "type": "select",
          "id": "text_color",
          "label": "Text color",
          "options": [
            {
              "value": "light",
              "label": "Light (for dark images)"
            },
            {
              "value": "dark",
              "label": "Dark (for light images)"
            }
          ],
          "default": "light"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "label": "Overlay darkness",
          "min": 0,
          "max": 80,
          "step": 5,
          "default": 30,
          "unit": "%"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SGL Bento Grid",
      "settings": {
        "layout": "asymmetric",
        "grid_gap": 8,
        "padding_top": 0,
        "padding_bottom": 0
      },
      "blocks": [
        {
          "type": "image_tile",
          "settings": {
            "heading": "Smooth As\nButter",
            "caption": "New Arrivals",
            "button_label": "Shop Now",
            "text_position": "bottom-left",
            "text_color": "light",
            "overlay_opacity": 30
          }
        },
        {
          "type": "image_tile",
          "settings": {
            "heading": "Glass Skin\nRoutine",
            "caption": "Best Sellers",
            "button_label": "Explore",
            "text_position": "bottom-left",
            "text_color": "light",
            "overlay_opacity": 30
          }
        },
        {
          "type": "image_tile",
          "settings": {
            "heading": "The Glow\nEdit",
            "caption": "Curated Sets",
            "button_label": "Shop Sets",
            "text_position": "bottom-left",
            "text_color": "light",
            "overlay_opacity": 30
          }
        }
      ]
    }
  ]
}
{% endschema %}
