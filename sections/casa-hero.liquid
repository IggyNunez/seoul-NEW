{%- comment -%}
  Seoul Glow Lab Hero Section - Premium Edition
  Full-bleed hero with video/image support, multiple animation presets,
  customizable colors, badges, promos, and conversion-focused design
{%- endcomment -%}

{%- liquid
  assign hero_height = section.settings.hero_height | default: '90vh'
  assign layout = section.settings.layout | default: 'split'
  assign animation_style = section.settings.animation_style | default: 'particles'
  assign color_theme = section.settings.color_theme | default: 'purple-glow'

  # Padding settings
  assign padding_top = section.settings.padding_top | default: 0
  assign padding_bottom = section.settings.padding_bottom | default: 0
  assign mobile_padding_top = section.settings.mobile_padding_top | default: 100
  assign mobile_padding_bottom = section.settings.mobile_padding_bottom | default: 80

  # Mobile settings
  assign mobile_height = section.settings.mobile_height | default: 'auto'
  assign mobile_order = section.settings.mobile_order | default: 'text-first'
  assign mobile_hide_visual = section.settings.mobile_hide_visual
  assign mobile_visual_size = section.settings.mobile_visual_size | default: 280

  # Color theme presets
  case color_theme
    when 'purple-glow'
      assign color_1 = section.settings.custom_color_1 | default: '#9333ea'
      assign color_2 = section.settings.custom_color_2 | default: '#ec4899'
      assign color_3 = section.settings.custom_color_3 | default: '#06b6d4'
    when 'sunset-gold'
      assign color_1 = '#f59e0b'
      assign color_2 = '#ef4444'
      assign color_3 = '#fbbf24'
    when 'ocean-teal'
      assign color_1 = '#06b6d4'
      assign color_2 = '#0891b2'
      assign color_3 = '#22d3ee'
    when 'midnight-rose'
      assign color_1 = '#ec4899'
      assign color_2 = '#be185d'
      assign color_3 = '#f472b6'
    when 'emerald-glow'
      assign color_1 = '#10b981'
      assign color_2 = '#059669'
      assign color_3 = '#34d399'
    when 'custom'
      assign color_1 = section.settings.custom_color_1 | default: '#9333ea'
      assign color_2 = section.settings.custom_color_2 | default: '#ec4899'
      assign color_3 = section.settings.custom_color_3 | default: '#06b6d4'
  endcase

  assign overlay_opacity = section.settings.overlay_opacity | default: 70
  assign text_alignment = section.settings.text_alignment | default: 'left'

  # Typography color overrides
  assign title_color = section.settings.title_color
  assign accent_word_color_1 = section.settings.accent_word_color_1
  assign accent_word_color_2 = section.settings.accent_word_color_2
  assign subtitle_color = section.settings.subtitle_color
  assign badge_bg_color = section.settings.badge_bg_color
  assign badge_text_color = section.settings.badge_text_color
  assign stats_color = section.settings.stats_color
  assign promo_bg_color = section.settings.promo_bg_color
  assign promo_text_color = section.settings.promo_text_color
  assign hero_bg_color = section.settings.hero_bg_color
-%}

<section
  class="casa-hero casa-hero--{{ layout }} casa-hero--{{ animation_style }} casa-hero--mobile-{{ mobile_order }}{% if mobile_hide_visual %} casa-hero--mobile-no-visual{% endif %}"
  id="casa-hero-{{ section.id }}"
  style="
    --hero-height: {{ hero_height }};
    --hero-color-1: {{ color_1 }};
    --hero-color-2: {{ color_2 }};
    --hero-color-3: {{ color_3 }};
    --hero-overlay-opacity: {{ overlay_opacity | divided_by: 100.0 }};
    --hero-text-align: {{ text_alignment }};
    --hero-flex-align: {% if text_alignment == "center" %}center{% elsif text_alignment == "right" %}flex-end{% else %}flex-start{% endif %};
    --hero-padding-top: {{ padding_top }}px;
    --hero-padding-bottom: {{ padding_bottom }}px;
    --hero-mobile-height: {{ mobile_height }};
    --hero-mobile-padding-top: {{ mobile_padding_top }}px;
    --hero-mobile-padding-bottom: {{ mobile_padding_bottom }}px;
    --hero-mobile-visual-size: {{ mobile_visual_size }}px;
    {%- if title_color != blank %}--hero-title-color: {{ title_color }};{% endif -%}
    {%- if accent_word_color_1 != blank %}--hero-accent-word-1: {{ accent_word_color_1 }};{% endif -%}
    {%- if accent_word_color_2 != blank %}--hero-accent-word-2: {{ accent_word_color_2 }};{% endif -%}
    {%- if subtitle_color != blank %}--hero-subtitle-color: {{ subtitle_color }};{% endif -%}
    {%- if badge_bg_color != blank %}--hero-badge-bg: {{ badge_bg_color }};{% endif -%}
    {%- if badge_text_color != blank %}--hero-badge-text: {{ badge_text_color }};{% endif -%}
    {%- if stats_color != blank %}--hero-stats-color: {{ stats_color }};{% endif -%}
    {%- if promo_bg_color != blank %}--hero-promo-bg: {{ promo_bg_color }};{% endif -%}
    {%- if promo_text_color != blank %}--hero-promo-text: {{ promo_text_color }};{% endif -%}
    {%- if hero_bg_color != blank %}--hero-bg-color: {{ hero_bg_color }};{% endif -%}
    --hero-glow-intensity: {{ section.settings.glow_intensity | default: 50 | divided_by: 100.0 }};
    --hero-glow-size: {{ section.settings.glow_size | default: 30 }}px;
  "
>
  {%- comment -%} ═══ Background Media ═══ {%- endcomment -%}
  <div class="casa-hero__bg">
    {%- if section.settings.background_video != blank -%}
      <video
        class="casa-hero__video"
        autoplay
        muted
        loop
        playsinline
        poster="{{ section.settings.background_image | image_url: width: 1920 }}"
      >
        <source src="{{ section.settings.background_video }}" type="video/mp4">
      </video>
    {%- elsif section.settings.background_image != blank -%}
      <img
        class="casa-hero__bg-image"
        src="{{ section.settings.background_image | image_url: width: 1920 }}"
        srcset="
          {{ section.settings.background_image | image_url: width: 1200 }} 1200w,
          {{ section.settings.background_image | image_url: width: 1920 }} 1920w,
          {{ section.settings.background_image | image_url: width: 2560 }} 2560w
        "
        sizes="100vw"
        alt="{{ section.settings.background_image.alt | default: 'Hero background' | escape }}"
        loading="eager"
        fetchpriority="high"
      >
    {%- endif -%}
    <div class="casa-hero__overlay"></div>
  </div>

  {%- comment -%} ═══ Animation Layer ═══ {%- endcomment -%}
  {%- if animation_style != 'none' -%}
    <div class="casa-hero__animations" aria-hidden="true">
      {%- case animation_style -%}
        {%- when 'particles' -%}
          {%- for i in (1..15) -%}
            <div class="casa-hero__particle"></div>
          {%- endfor -%}
        {%- when 'aurora' -%}
          <div class="casa-hero__aurora">
            <div class="casa-hero__aurora-layer"></div>
            <div class="casa-hero__aurora-layer"></div>
            <div class="casa-hero__aurora-layer"></div>
          </div>
        {%- when 'orbs' -%}
          <div class="casa-hero__orb casa-hero__orb--1"></div>
          <div class="casa-hero__orb casa-hero__orb--2"></div>
          <div class="casa-hero__orb casa-hero__orb--3"></div>
        {%- when 'gradient-flow' -%}
          <div class="casa-hero__gradient-flow"></div>
        {%- when 'starfield' -%}
          {%- for i in (1..50) -%}
            <div class="casa-hero__star"></div>
          {%- endfor -%}
        {%- when 'waves' -%}
          <div class="casa-hero__waves">
            <div class="casa-hero__wave"></div>
            <div class="casa-hero__wave"></div>
            <div class="casa-hero__wave"></div>
          </div>
      {%- endcase -%}
    </div>
  {%- endif -%}

  {%- comment -%} ═══ Promo Banner ═══ {%- endcomment -%}
  {%- if section.settings.show_promo_banner and section.settings.promo_text != blank -%}
    <div class="casa-hero__promo">
      <div class="casa-hero__promo-inner">
        {%- if section.settings.promo_icon != 'none' -%}
          {%- render 'casa-icon', icon: section.settings.promo_icon, size: 16 -%}
        {%- endif -%}
        <span>{{ section.settings.promo_text }}</span>
        {%- if section.settings.promo_code != blank -%}
          <code class="casa-hero__promo-code">{{ section.settings.promo_code }}</code>
        {%- endif -%}
        {%- if section.settings.promo_countdown != blank -%}
          <span class="casa-hero__countdown" data-countdown="{{ section.settings.promo_countdown }}"></span>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} ═══ Main Content ═══ {%- endcomment -%}
  <div class="casa-hero__container">
    <div class="casa-hero__content">
      {%- comment -%} Text Column {%- endcomment -%}
      <div class="casa-hero__text">
        {%- comment -%} Badges Row {%- endcomment -%}
        <div class="casa-hero__badges">
          {%- if section.settings.badge_new -%}
            <span class="casa-hero__badge casa-hero__badge--new" style="{% if badge_bg_color != blank %}background: {{ badge_bg_color }};{% endif %}{% if badge_text_color != blank %}color: {{ badge_text_color }};{% endif %}">
              {%- render 'casa-icon', icon: 'sparkles', size: 12 -%}
              New
            </span>
          {%- endif -%}
          {%- if section.settings.badge_sale and section.settings.badge_sale_text != blank -%}
            <span class="casa-hero__badge casa-hero__badge--sale" style="{% if badge_bg_color != blank %}background: {{ badge_bg_color }};{% endif %}{% if badge_text_color != blank %}color: {{ badge_text_color }};{% endif %}">
              {%- render 'casa-icon', icon: 'tag', size: 12 -%}
              {{ section.settings.badge_sale_text }}
            </span>
          {%- endif -%}
          {%- if section.settings.badge_limited -%}
            <span class="casa-hero__badge casa-hero__badge--limited" style="{% if badge_bg_color != blank %}background: {{ badge_bg_color }};{% endif %}{% if badge_text_color != blank %}color: {{ badge_text_color }};{% endif %}">
              {%- render 'casa-icon', icon: 'zap', size: 12 -%}
              Limited Edition
            </span>
          {%- endif -%}
          {%- if section.settings.tag_text != blank -%}
            <span class="casa-hero__badge casa-hero__badge--tag" style="{% if badge_bg_color != blank %}background: {{ badge_bg_color }};{% endif %}{% if badge_text_color != blank %}color: {{ badge_text_color }};{% endif %}">
              {%- if section.settings.tag_icon != 'none' -%}
                {%- render 'casa-icon', icon: section.settings.tag_icon, size: 14 -%}
              {%- endif -%}
              {{ section.settings.tag_text }}
            </span>
          {%- endif -%}
        </div>

        {%- comment -%} Title {%- endcomment -%}
        {%- if section.settings.title_line_1 != blank or section.settings.title_gradient != blank or section.settings.title_line_2 != blank -%}
          <h1 class="casa-hero__title">
            {%- if section.settings.title_line_1 != blank -%}
              <span class="casa-hero__title-line">{{ section.settings.title_line_1 }}</span>
            {%- endif -%}
            {%- if section.settings.title_gradient != blank -%}
              <span class="casa-hero__title-gradient">{{ section.settings.title_gradient }}</span>
            {%- endif -%}
            {%- if section.settings.title_line_2 != blank -%}
              <span class="casa-hero__title-line">{{ section.settings.title_line_2 }}</span>
            {%- endif -%}
          </h1>
        {%- endif -%}

        {%- comment -%} Subtitle {%- endcomment -%}
        {%- if section.settings.subtitle != blank -%}
          <p class="casa-hero__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}

        {%- comment -%} Features List {%- endcomment -%}
        {%- if section.settings.show_features -%}
          <ul class="casa-hero__features">
            {%- if section.settings.feature_1 != blank -%}
              <li>
                {%- render 'casa-icon', icon: 'check', size: 16 -%}
                {{ section.settings.feature_1 }}
              </li>
            {%- endif -%}
            {%- if section.settings.feature_2 != blank -%}
              <li>
                {%- render 'casa-icon', icon: 'check', size: 16 -%}
                {{ section.settings.feature_2 }}
              </li>
            {%- endif -%}
            {%- if section.settings.feature_3 != blank -%}
              <li>
                {%- render 'casa-icon', icon: 'check', size: 16 -%}
                {{ section.settings.feature_3 }}
              </li>
            {%- endif -%}
          </ul>
        {%- endif -%}

        {%- comment -%} Price Display {%- endcomment -%}
        {%- if section.settings.show_price and section.settings.price != blank -%}
          <div class="casa-hero__price-wrapper">
            {%- if section.settings.compare_price != blank -%}
              <span class="casa-hero__compare-price">{{ section.settings.compare_price }}</span>
            {%- endif -%}
            <span class="casa-hero__price">{{ section.settings.price }}</span>
            {%- if section.settings.price_suffix != blank -%}
              <span class="casa-hero__price-suffix">{{ section.settings.price_suffix }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- comment -%} Buttons {%- endcomment -%}
        <div class="casa-hero__buttons">
          {%- if section.settings.button_primary_text != blank -%}
            <a
              href="{{ section.settings.button_primary_link }}"
              class="casa-hero__btn casa-hero__btn--primary casa-hero__btn--{{ section.settings.button_primary_size | default: 'medium' }}"
              style="{% if section.settings.button_primary_bg != blank %}background: {{ section.settings.button_primary_bg }};{% endif %}{% if section.settings.button_primary_text_color != blank %}color: {{ section.settings.button_primary_text_color }};{% endif %}border-radius: {{ section.settings.button_primary_radius | default: 12 }}px;"
              {%- if section.settings.button_primary_style == 'pulse' %} data-pulse{%- endif -%}
            >
              {%- if section.settings.button_primary_icon != 'none' -%}
                {%- render 'casa-icon', icon: section.settings.button_primary_icon, size: 18 -%}
              {%- endif -%}
              {{ section.settings.button_primary_text }}
            </a>
          {%- endif -%}
          {%- if section.settings.button_secondary_text != blank -%}
            <a href="{{ section.settings.button_secondary_link }}" class="casa-hero__btn casa-hero__btn--secondary casa-hero__btn--{{ section.settings.button_secondary_size | default: "medium" }}" style="{% if section.settings.button_secondary_bg != blank %}background: {{ section.settings.button_secondary_bg }};{% endif %}{% if section.settings.button_secondary_text_color != blank %}color: {{ section.settings.button_secondary_text_color }};{% endif %}border-radius: {{ section.settings.button_secondary_radius | default: 12 }}px;">
              {%- if section.settings.button_secondary_icon != 'none' -%}
                {%- render 'casa-icon', icon: section.settings.button_secondary_icon, size: 18 -%}
              {%- endif -%}
              {{ section.settings.button_secondary_text }}
            </a>
          {%- endif -%}
          {%- if section.settings.button_tertiary_text != blank -%}
            <a href="{{ section.settings.button_tertiary_link }}" class="casa-hero__btn casa-hero__btn--tertiary">
              {{ section.settings.button_tertiary_text }}
              {%- render 'casa-icon', icon: 'chevron-right', size: 16 -%}
            </a>
          {%- endif -%}
        </div>

        {%- comment -%} Social Proof {%- endcomment -%}
        {%- if section.settings.show_social_proof -%}
          <div class="casa-hero__social-proof">
            {%- if section.settings.show_rating -%}
              <div class="casa-hero__rating">
                <div class="casa-hero__stars">
                  {%- for i in (1..5) -%}
                    {%- render 'casa-icon', icon: 'star', size: 16 -%}
                  {%- endfor -%}
                </div>
                <span class="casa-hero__rating-text">
                  {{ section.settings.rating_score | default: '4.9' }}
                  {%- if section.settings.rating_count != blank -%}
                    <span class="casa-hero__rating-count">({{ section.settings.rating_count }} reviews)</span>
                  {%- endif -%}
                </span>
              </div>
            {%- endif -%}
            {%- if section.settings.social_proof_text != blank -%}
              <p class="casa-hero__proof-text">{{ section.settings.social_proof_text }}</p>
            {%- endif -%}
            {%- if section.settings.show_avatars -%}
              <div class="casa-hero__avatars">
                <div class="casa-hero__avatar-stack">
                  {%- for i in (1..5) -%}
                    <div class="casa-hero__avatar">{{ i }}</div>
                  {%- endfor -%}
                </div>
                <span>+{{ section.settings.customer_count | default: '50K' }} happy customers</span>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- comment -%} Trust Badges {%- endcomment -%}
        {%- if section.settings.show_trust_row -%}
          <div class="casa-hero__trust-row">
            {%- if section.settings.trust_1_text != blank -%}
              <div class="casa-hero__trust-item">
                {%- render 'casa-icon', icon: section.settings.trust_1_icon | default: 'truck', size: 18 -%}
                <span>{{ section.settings.trust_1_text }}</span>
              </div>
            {%- endif -%}
            {%- if section.settings.trust_2_text != blank -%}
              <div class="casa-hero__trust-item">
                {%- render 'casa-icon', icon: section.settings.trust_2_icon | default: 'shield-check', size: 18 -%}
                <span>{{ section.settings.trust_2_text }}</span>
              </div>
            {%- endif -%}
            {%- if section.settings.trust_3_text != blank -%}
              <div class="casa-hero__trust-item">
                {%- render 'casa-icon', icon: section.settings.trust_3_icon | default: 'refresh', size: 18 -%}
                <span>{{ section.settings.trust_3_text }}</span>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Visual Column {%- endcomment -%}
      {%- if layout == 'split' or layout == 'split-reverse' -%}
        <div class="casa-hero__visual">
          <div class="casa-hero__visual-wrapper">
            {%- comment -%} Animated Glow Frame {%- endcomment -%}
            {%- if section.settings.show_glow_frame -%}
              <div class="casa-hero__glow-frame">
                <div class="casa-hero__glow-ring"></div>
                <div class="casa-hero__glow-ring"></div>
              </div>
            {%- endif -%}

            {%- comment -%} Product/Feature Image or Video {%- endcomment -%}
            {%- if section.settings.visual_video != blank -%}
              <div class="casa-hero__visual-media casa-hero__visual-media--video">
                <video autoplay muted loop playsinline>
                  <source src="{{ section.settings.visual_video }}" type="video/mp4">
                </video>
              </div>
            {%- elsif section.settings.visual_image != blank -%}
              <div class="casa-hero__visual-media">
                <img
                  src="{{ section.settings.visual_image | image_url: width: 800 }}"
                  srcset="
                    {{ section.settings.visual_image | image_url: width: 400 }} 400w,
                    {{ section.settings.visual_image | image_url: width: 600 }} 600w,
                    {{ section.settings.visual_image | image_url: width: 800 }} 800w
                  "
                  sizes="(max-width: 900px) 300px, 500px"
                  alt="{{ section.settings.visual_image.alt | default: section.settings.title_gradient | escape }}"
                  loading="eager"
                  class="casa-hero__product-image"
                >
              </div>
            {%- else -%}
              {%- comment -%} Animated Infinity Mirror Fallback {%- endcomment -%}
              <div class="casa-hero__mirror {{ section.settings.mirror_shape | default: 'octagon' }}">
                <div class="casa-hero__mirror-frame {{ section.settings.mirror_shape | default: 'octagon' }}">
                  <div class="casa-hero__mirror-glow {{ section.settings.mirror_shape | default: 'octagon' }}">
                    <div class="casa-hero__mirror-inner {{ section.settings.mirror_shape | default: 'octagon' }}">
                      <div class="casa-hero__mirror-depth {{ section.settings.mirror_shape | default: 'octagon' }}">
                        <div class="casa-hero__mirror-center {{ section.settings.mirror_shape | default: 'octagon' }}"></div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            {%- endif -%}

            {%- comment -%} Floating Badges on Visual {%- endcomment -%}
            {%- if section.settings.visual_badge_1 != blank -%}
              <div class="casa-hero__float-badge casa-hero__float-badge--1">
                {%- render 'casa-icon', icon: section.settings.visual_badge_1_icon | default: 'zap', size: 16 -%}
                {{ section.settings.visual_badge_1 }}
              </div>
            {%- endif -%}
            {%- if section.settings.visual_badge_2 != blank -%}
              <div class="casa-hero__float-badge casa-hero__float-badge--2">
                {%- render 'casa-icon', icon: section.settings.visual_badge_2_icon | default: 'palette', size: 16 -%}
                {{ section.settings.visual_badge_2 }}
              </div>
            {%- endif -%}
            {%- if section.settings.visual_badge_3 != blank -%}
              <div class="casa-hero__float-badge casa-hero__float-badge--3">
                {%- render 'casa-icon', icon: section.settings.visual_badge_3_icon | default: 'smartphone', size: 16 -%}
                {{ section.settings.visual_badge_3 }}
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} Scroll Indicator {%- endcomment -%}
  {%- if section.settings.show_scroll_indicator -%}
    <div class="casa-hero__scroll-indicator">
      <div class="casa-hero__scroll-mouse">
        <div class="casa-hero__scroll-wheel"></div>
      </div>
      <span>Scroll to explore</span>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Casa Hero",
  "tag": "section",
  "class": "casa-hero-section",
  "settings": [
    {
      "type": "header",
      "content": "Layout & Size"
    },
    {
      "type": "select",
      "id": "hero_height",
      "label": "Hero height",
      "options": [
        { "value": "100vh", "label": "Full viewport" },
        { "value": "90vh", "label": "90% viewport" },
        { "value": "80vh", "label": "80% viewport" },
        { "value": "70vh", "label": "70% viewport" },
        { "value": "600px", "label": "Fixed: 600px" },
        { "value": "700px", "label": "Fixed: 700px" },
        { "value": "800px", "label": "Fixed: 800px" }
      ],
      "default": "90vh"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "split", "label": "Split (Text left, Visual right)" },
        { "value": "split-reverse", "label": "Split reverse (Visual left, Text right)" },
        { "value": "centered", "label": "Centered (Text only)" },
        { "value": "full-visual", "label": "Full visual with overlay text" }
      ],
      "default": "split"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Mobile Layout"
    },
    {
      "type": "select",
      "id": "mobile_height",
      "label": "Mobile height",
      "options": [
        { "value": "auto", "label": "Auto (fit content)" },
        { "value": "100vh", "label": "Full screen" },
