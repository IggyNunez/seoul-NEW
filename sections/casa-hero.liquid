{% stylesheet %}
/* ══════════════════════════════════════════════════════════════════════════
   CASA HERO - PREMIUM EDITION
   Full-featured hero section with animations, themes, and conversion elements
   ══════════════════════════════════════════════════════════════════════════ */

/* ── CSS Custom Properties ── */
.casa-hero {
  --hero-height: 90vh;
  --hero-color-1: #9333ea;
  --hero-color-2: #ec4899;
  --hero-color-3: #06b6d4;
  --hero-overlay-opacity: 0.7;
  --hero-text-align: left;
}

/* ── Base Container ── */
.casa-hero {
  position: relative;
  height: var(--hero-height);
  min-height: 600px;
  max-height: 1200px;
  overflow: hidden;
  max-width: 100vw;
  display: flex;
  align-items: center;
  background: var(--hero-bg-color, #0a0a0f);
  padding-top: var(--hero-padding-top, 0);
  padding-bottom: var(--hero-padding-bottom, 0);
}

/* ── Background Layer ── */
.casa-hero__bg {
  position: absolute;
  inset: 0;
  z-index: 0;
}

.casa-hero__bg-image,
.casa-hero__video {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.casa-hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    135deg,
    rgba(10, 10, 15, var(--hero-overlay-opacity)) 0%,
    rgba(26, 26, 46, calc(var(--hero-overlay-opacity) * 0.9)) 50%,
    rgba(22, 33, 62, calc(var(--hero-overlay-opacity) * 0.8)) 100%
  );
}

/* ══════════════════════════════════════════════════════════════════════════
   ANIMATION STYLES
   ══════════════════════════════════════════════════════════════════════════ */

.casa-hero__animations {
  position: absolute;
  inset: 0;
  z-index: 1;
  pointer-events: none;
  overflow: hidden;
}

/* ── Particles ── */
.casa-hero__particle {
  position: absolute;
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: var(--hero-color-1);
  opacity: 0.6;
  bottom: -10px;
  animation: hero-particle 10s linear infinite;
}

.casa-hero__particle:nth-child(1) { left: 5%; animation-delay: 0s; }
.casa-hero__particle:nth-child(2) { left: 12%; animation-delay: 0.8s; background: var(--hero-color-2); }
.casa-hero__particle:nth-child(3) { left: 20%; animation-delay: 1.6s; background: var(--hero-color-3); }
.casa-hero__particle:nth-child(4) { left: 28%; animation-delay: 2.4s; }
.casa-hero__particle:nth-child(5) { left: 36%; animation-delay: 3.2s; background: var(--hero-color-2); }
.casa-hero__particle:nth-child(6) { left: 44%; animation-delay: 4s; background: var(--hero-color-3); }
.casa-hero__particle:nth-child(7) { left: 52%; animation-delay: 4.8s; }
.casa-hero__particle:nth-child(8) { left: 60%; animation-delay: 5.6s; background: var(--hero-color-2); }
.casa-hero__particle:nth-child(9) { left: 68%; animation-delay: 6.4s; background: var(--hero-color-3); }
.casa-hero__particle:nth-child(10) { left: 76%; animation-delay: 7.2s; }
.casa-hero__particle:nth-child(11) { left: 84%; animation-delay: 8s; background: var(--hero-color-2); }
.casa-hero__particle:nth-child(12) { left: 92%; animation-delay: 8.8s; background: var(--hero-color-3); }
.casa-hero__particle:nth-child(13) { left: 8%; animation-delay: 1.2s; width: 6px; height: 6px; }
.casa-hero__particle:nth-child(14) { left: 48%; animation-delay: 3.8s; width: 6px; height: 6px; background: var(--hero-color-2); }
.casa-hero__particle:nth-child(15) { left: 88%; animation-delay: 6.2s; width: 6px; height: 6px; background: var(--hero-color-3); }

@keyframes hero-particle {
  0% { transform: translateY(0) translateX(0) scale(1); opacity: 0; }
  5% { opacity: 0.8; }
  50% { opacity: 0.6; }
  95% { opacity: 0.4; }
  100% { transform: translateY(-100vh) translateX(30px) scale(0.5); opacity: 0; }
}

/* ── Aurora ── */
.casa-hero__aurora {
  position: absolute;
  inset: 0;
  overflow: hidden;
}

.casa-hero__aurora-layer {
  position: absolute;
  width: 200%;
  height: 200%;
  top: -50%;
  left: -50%;
  background: conic-gradient(
    from 0deg at 50% 50%,
    transparent 0deg,
    var(--hero-color-1) 60deg,
    transparent 120deg,
    var(--hero-color-2) 180deg,
    transparent 240deg,
    var(--hero-color-3) 300deg,
    transparent 360deg
  );
  opacity: 0.15;
  animation: aurora-rotate 20s linear infinite;
  filter: blur(80px);
}

.casa-hero__aurora-layer:nth-child(2) {
  animation-delay: -6s;
  animation-duration: 25s;
  opacity: 0.1;
}

.casa-hero__aurora-layer:nth-child(3) {
  animation-delay: -12s;
  animation-duration: 30s;
  opacity: 0.12;
}

@keyframes aurora-rotate {
  to { transform: rotate(360deg); }
}

/* ── Orbs ── */
.casa-hero__orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(60px);
  animation: orb-float 8s ease-in-out infinite;
}

.casa-hero__orb--1 {
  width: 400px;
  height: 400px;
  background: var(--hero-color-1);
  opacity: 0.3;
  top: 10%;
  left: 10%;
}

.casa-hero__orb--2 {
  width: 300px;
  height: 300px;
  background: var(--hero-color-2);
  opacity: 0.25;
  top: 40%;
  right: 15%;
  animation-delay: -2s;
}

.casa-hero__orb--3 {
  width: 350px;
  height: 350px;
  background: var(--hero-color-3);
  opacity: 0.2;
  bottom: 10%;
  left: 30%;
  animation-delay: -4s;
}

@keyframes orb-float {
  0%, 100% { transform: translate(0, 0) scale(1); }
  25% { transform: translate(30px, -20px) scale(1.05); }
  50% { transform: translate(-20px, 30px) scale(0.95); }
  75% { transform: translate(20px, 20px) scale(1.02); }
}

/* ── Gradient Flow ── */
.casa-hero__gradient-flow {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    45deg,
    var(--hero-color-1),
    var(--hero-color-2),
    var(--hero-color-3),
    var(--hero-color-1)
  );
  background-size: 400% 400%;
  opacity: 0.15;
  animation: gradient-flow 15s ease infinite;
}

@keyframes gradient-flow {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

/* ── Starfield ── */
.casa-hero__star {
  position: absolute;
  width: 2px;
  height: 2px;
  background: #fff;
  border-radius: 50%;
  animation: star-twinkle 3s ease-in-out infinite;
}

.casa-hero__star:nth-child(odd) { animation-delay: -1.5s; }
.casa-hero__star:nth-child(3n) { width: 3px; height: 3px; }
.casa-hero__star:nth-child(5n) { animation-duration: 4s; }
.casa-hero__star:nth-child(7n) { animation-duration: 2.5s; }

/* Position stars randomly using nth-child */
.casa-hero__star:nth-child(1) { top: 10%; left: 5%; }
.casa-hero__star:nth-child(2) { top: 5%; left: 15%; }
.casa-hero__star:nth-child(3) { top: 15%; left: 25%; }
.casa-hero__star:nth-child(4) { top: 8%; left: 35%; }
.casa-hero__star:nth-child(5) { top: 20%; left: 45%; }
.casa-hero__star:nth-child(6) { top: 3%; left: 55%; }
.casa-hero__star:nth-child(7) { top: 12%; left: 65%; }
.casa-hero__star:nth-child(8) { top: 18%; left: 75%; }
.casa-hero__star:nth-child(9) { top: 7%; left: 85%; }
.casa-hero__star:nth-child(10) { top: 22%; left: 95%; }
.casa-hero__star:nth-child(11) { top: 30%; left: 8%; }
.casa-hero__star:nth-child(12) { top: 35%; left: 18%; }
.casa-hero__star:nth-child(13) { top: 28%; left: 28%; }
.casa-hero__star:nth-child(14) { top: 40%; left: 38%; }
.casa-hero__star:nth-child(15) { top: 32%; left: 48%; }
.casa-hero__star:nth-child(16) { top: 38%; left: 58%; }
.casa-hero__star:nth-child(17) { top: 25%; left: 68%; }
.casa-hero__star:nth-child(18) { top: 42%; left: 78%; }
.casa-hero__star:nth-child(19) { top: 33%; left: 88%; }
.casa-hero__star:nth-child(20) { top: 45%; left: 92%; }
.casa-hero__star:nth-child(21) { top: 50%; left: 3%; }
.casa-hero__star:nth-child(22) { top: 55%; left: 12%; }
.casa-hero__star:nth-child(23) { top: 48%; left: 22%; }
.casa-hero__star:nth-child(24) { top: 60%; left: 32%; }
.casa-hero__star:nth-child(25) { top: 52%; left: 42%; }
.casa-hero__star:nth-child(26) { top: 58%; left: 52%; }
.casa-hero__star:nth-child(27) { top: 65%; left: 62%; }
.casa-hero__star:nth-child(28) { top: 53%; left: 72%; }
.casa-hero__star:nth-child(29) { top: 62%; left: 82%; }
.casa-hero__star:nth-child(30) { top: 68%; left: 90%; }
.casa-hero__star:nth-child(31) { top: 70%; left: 6%; }
.casa-hero__star:nth-child(32) { top: 75%; left: 16%; }
.casa-hero__star:nth-child(33) { top: 72%; left: 26%; }
.casa-hero__star:nth-child(34) { top: 78%; left: 36%; }
.casa-hero__star:nth-child(35) { top: 82%; left: 46%; }
.casa-hero__star:nth-child(36) { top: 76%; left: 56%; }
.casa-hero__star:nth-child(37) { top: 80%; left: 66%; }
.casa-hero__star:nth-child(38) { top: 85%; left: 76%; }
.casa-hero__star:nth-child(39) { top: 88%; left: 86%; }
.casa-hero__star:nth-child(40) { top: 90%; left: 94%; }
.casa-hero__star:nth-child(n+41) { top: 92%; left: calc((40 - var(--n, 41)) * 2%); }

@keyframes star-twinkle {
  0%, 100% { opacity: 0.3; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.2); }
}

/* ── Waves ── */
.casa-hero__waves {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 200px;
  overflow: hidden;
}

.casa-hero__wave {
  position: absolute;
  bottom: 0;
  left: -50%;
  width: 200%;
  height: 100%;
  background: linear-gradient(to top, var(--hero-color-1), transparent);
  opacity: 0.1;
  border-radius: 100% 100% 0 0;
  animation: wave-motion 8s ease-in-out infinite;
}

.casa-hero__wave:nth-child(2) {
  animation-delay: -2s;
  opacity: 0.08;
  background: linear-gradient(to top, var(--hero-color-2), transparent);
}

.casa-hero__wave:nth-child(3) {
  animation-delay: -4s;
  opacity: 0.06;
  background: linear-gradient(to top, var(--hero-color-3), transparent);
}

@keyframes wave-motion {
  0%, 100% { transform: translateX(0) translateY(0); }
  50% { transform: translateX(2%) translateY(-10px); }
}

/* ══════════════════════════════════════════════════════════════════════════
   PROMO BANNER
   ══════════════════════════════════════════════════════════════════════════ */

.casa-hero__promo {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 10;
  background: linear-gradient(
    90deg,
    var(--hero-color-1),
    var(--hero-color-2),
    var(--hero-color-3),
    var(--hero-color-2),
    var(--hero-color-1)
  );
  background-size: 300% 100%;
  animation: promo-shimmer 4s linear infinite;
  padding: 10px 20px;
}

.casa-hero__promo-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  color: var(--hero-promo-text, #fff);
  font-size: 14px;
  font-weight: 500;
}

.casa-hero__promo-inner svg {
  width: 16px;
  height: 16px;
  stroke: #fff;
}

.casa-hero__promo-code {
  background: rgba(255, 255, 255, 0.2);
  padding: 4px 12px;
  border-radius: 4px;
  font-weight: 700;
  font-family: inherit;
}

@keyframes promo-shimmer {
  0% { background-position: 0% 50%; }
  100% { background-position: 200% 50%; }
}

/* ══════════════════════════════════════════════════════════════════════════
   CONTENT CONTAINER
   ══════════════════════════════════════════════════════════════════════════ */

.casa-hero__container {
  position: relative;
  z-index: 5;
  width: 100%;
  max-width: min(1600px, 100vw);
  margin: 0 auto;
  padding: 0 80px;
  box-sizing: border-box;
  overflow: hidden;
}

.casa-hero__content {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}

/* ── Layout Variants ── */
.casa-hero--split-reverse .casa-hero__content {
  direction: rtl;
}

.casa-hero--split-reverse .casa-hero__content > * {
  direction: ltr;
}

.casa-hero--centered .casa-hero__content {
  grid-template-columns: 1fr;
  max-width: 900px;
  margin: 0 auto;
  text-align: center;
}

.casa-hero--centered .casa-hero__text {
  align-items: center;
}

.casa-hero--full-visual .casa-hero__content {
  grid-template-columns: 1fr;
  max-width: 800px;
}

/* ══════════════════════════════════════════════════════════════════════════
   TEXT CONTENT
   ══════════════════════════════════════════════════════════════════════════ */

.casa-hero__text {
  display: flex;
  flex-direction: column;
  align-items: var(--hero-flex-align, flex-start);
  text-align: var(--hero-text-align);
  animation: hero-fadeInUp 1s ease-out;
}

@keyframes hero-fadeInUp {
  from { transform: translateY(40px); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

/* ── Badges ── */
.casa-hero__badges {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-bottom: 20px;
}

.casa-hero__badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 6px 14px;
  border-radius: 100px;
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

/* Badge color overrides from settings */
.casa-hero__badge[style] {
  /* Inline styles from settings take priority */
}

.casa-hero__badge svg {
  width: 12px;
  height: 12px;
}

.casa-hero__badge--new {
  background: linear-gradient(135deg, var(--hero-color-1), var(--hero-color-2));
  color: #fff;
}

.casa-hero__badge--sale {
  background: linear-gradient(135deg, #ef4444, #f97316);
  color: #fff;
}

.casa-hero__badge--limited {
  background: linear-gradient(135deg, #f59e0b, #eab308);
  color: #000;
}

.casa-hero__badge--tag {
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.2);
  color: var(--hero-color-1);
}

.casa-hero__badge--tag svg {
  fill: currentColor;
  stroke: none;
}

/* ── Title ── */
.casa-hero__title {
  font-size: clamp(36px, 6vw, 80px);
  font-weight: 300;
  color: var(--hero-title-color, #fff);
  line-height: 1.05;
  margin: 0 0 24px 0;
  letter-spacing: -3px;
}

.casa-hero__title-line {
  display: block;
}

.casa-hero__title-gradient {
  display: block;
  background: linear-gradient(
    90deg,
    var(--hero-accent-word-1, var(--hero-color-1)),
    var(--hero-accent-word-2, var(--hero-color-2)),
    var(--hero-accent-word-2, var(--hero-color-3))
  );
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: 400;
}

/* ── Subtitle ── */
.casa-hero__subtitle {
  font-size: clamp(16px, 1.5vw, 22px);
  color: var(--hero-subtitle-color, rgba(255, 255, 255, 0.65));
  line-height: 1.7;
  margin: 0 0 32px 0;
  max-width: 550px;
}

/* ── Features List ── */
.casa-hero__features {
  list-style: none;
  padding: 0;
  margin: 0 0 32px 0;
  display: flex;
  flex-wrap: wrap;
  gap: 16px 32px;
}

.casa-hero__features li {
  display: flex;
  align-items: center;
  gap: 8px;
  color: var(--hero-stats-color, rgba(255, 255, 255, 0.8));
  font-size: 14px;
}

.casa-hero__features svg {
  color: var(--hero-color-1);
  stroke: currentColor;
}

/* ── Price ── */
.casa-hero__price-wrapper {
  display: flex;
  align-items: baseline;
  gap: 12px;
  margin-bottom: 32px;
}

.casa-hero__compare-price {
  font-size: 24px;
  color: rgba(255, 255, 255, 0.4);
  text-decoration: line-through;
}

.casa-hero__price {
  font-size: 48px;
  font-weight: 600;
  color: #fff;
}

.casa-hero__price-suffix {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.5);
}

/* ── Buttons ── */
.casa-hero__buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  margin-bottom: 32px;
}

.casa-hero__btn {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 18px 36px;
  border-radius: 12px;
  font-size: 16px;
  font-weight: 600;
  text-decoration: none;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  cursor: pointer;
  border: none;
}

.casa-hero__btn svg {
  width: 18px;
  height: 18px;
}

.casa-hero__btn--primary {
  background: linear-gradient(135deg, var(--hero-color-1), var(--hero-color-2));
  color: #fff;
  box-shadow: 0 4px 20px rgba(147, 51, 234, 0.3);
}

.casa-hero__btn--primary:hover {
  transform: translateY(-3px);
  box-shadow: 0 12px 40px rgba(147, 51, 234, 0.5);
}

.casa-hero__btn--primary[data-pulse] {
  animation: btn-pulse 2s ease-in-out infinite;
}

@keyframes btn-pulse {
  0%, 100% { box-shadow: 0 4px 20px rgba(147, 51, 234, 0.3); }
  50% { box-shadow: 0 8px 40px rgba(147, 51, 234, 0.6); }
}

.casa-hero__btn--secondary {
  background: rgba(255, 255, 255, 0.08);
  color: #fff;
  border: 1px solid rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10px);
}

.casa-hero__btn--secondary:hover {
  background: rgba(255, 255, 255, 0.15);
  border-color: rgba(255, 255, 255, 0.25);
}

.casa-hero__btn--tertiary {
  background: transparent;
  color: var(--hero-color-1);
  padding: 12px 0;
}

.casa-hero__btn--tertiary:hover {
  gap: 14px;
}

/* Button sizes */
.casa-hero__btn--small { padding: 10px 20px; font-size: 13px; }
.casa-hero__btn--medium { padding: 16px 32px; font-size: 15px; }
.casa-hero__btn--large { padding: 20px 40px; font-size: 17px; }

/* ── Social Proof ── */
.casa-hero__social-proof {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-bottom: 24px;
}

.casa-hero__rating {
  display: flex;
  align-items: center;
  gap: 12px;
}

.casa-hero__stars {
  display: flex;
  gap: 2px;
}

.casa-hero__stars svg {
  width: 16px;
  height: 16px;
  fill: #fbbf24;
  stroke: none;
}

.casa-hero__rating-text {
  color: rgba(255, 255, 255, 0.9);
  font-size: 14px;
  font-weight: 500;
}

.casa-hero__rating-count {
  color: rgba(255, 255, 255, 0.5);
}

.casa-hero__proof-text {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.6);
  margin: 0;
}

.casa-hero__avatars {
  display: flex;
  align-items: center;
  gap: 12px;
}

.casa-hero__avatar-stack {
  display: flex;
}

.casa-hero__avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--hero-color-1), var(--hero-color-2));
  border: 2px solid #0a0a0f;
  margin-left: -10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 10px;
  font-weight: 600;
  color: #fff;
}

.casa-hero__avatar:first-child {
  margin-left: 0;
}

.casa-hero__avatars > span {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.6);
}

/* ── Trust Row ── */
.casa-hero__trust-row {
  display: flex;
  flex-wrap: wrap;
  gap: 24px;
  padding-top: 24px;
  border-top: 1px solid rgba(255, 255, 255, 0.1);
}

.casa-hero__trust-item {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  color: rgba(255, 255, 255, 0.7);
}

.casa-hero__trust-item svg {
  width: 18px;
  height: 18px;
  stroke: var(--hero-color-1);
}

/* ══════════════════════════════════════════════════════════════════════════
   VISUAL COLUMN
   ══════════════════════════════════════════════════════════════════════════ */

.casa-hero__visual {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: hero-scaleIn 1s ease-out 0.3s both;
}

@keyframes hero-scaleIn {
  from { transform: scale(0.9); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

.casa-hero__visual-wrapper {
  position: relative;
  width: 100%;
  max-width: 550px;
  aspect-ratio: 1;
  animation: hero-float 6s ease-in-out infinite;
}

/* ── Glow Frame ── */
.casa-hero__glow-frame {
  position: absolute;
  inset: -30px;
  pointer-events: none;
}

.casa-hero__glow-frame {
  inset: calc(var(--hero-glow-size, 30px) * -1);
}
.casa-hero__glow-ring {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: conic-gradient(
    from var(--hero-angle, 0deg),
    var(--hero-color-1),
    var(--hero-color-2),
    var(--hero-color-3),
    var(--hero-color-1)
  );
  filter: blur(calc(20px + var(--hero-glow-size, 30px)));
  opacity: var(--hero-glow-intensity, 0.5);
  animation: glow-rotate 8s linear infinite;
}

.casa-hero__glow-ring:nth-child(2) {
  filter: blur(80px);
  opacity: 0.3;
  animation-direction: reverse;
  animation-duration: 12s;
}

@property --hero-angle {
  syntax: '<angle>';
  initial-value: 0deg;
  inherits: false;
}

@keyframes glow-rotate {
  to { --hero-angle: 360deg; }
}

/* ── Visual Media ── */
.casa-hero__visual-media {
  position: relative;
  width: 100%;
  height: 100%;
  border-radius: 24px;
  overflow: hidden;
  z-index: 2;
}

.casa-hero__visual-media img,
.casa-hero__visual-media video {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* Product image inherits float animation from wrapper */
.casa-hero__product-image {
  /* Animation moved to .casa-hero__visual-wrapper to prevent clipping */
}

@keyframes hero-float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-15px); }
}

/* ── Infinity Mirror (fallback) ── */
.casa-hero__mirror {
  position: relative;
  width: 100%;
  height: 100%;
  animation: hero-float 8s ease-in-out infinite;
  z-index: 2;
}

.octagon { clip-path: polygon(30% 0%, 70% 0%, 100% 30%, 100% 70%, 70% 100%, 30% 100%, 0% 70%, 0% 30%); }
.hexagon { clip-path: polygon(25% 0%, 75% 0%, 100% 50%, 75% 100%, 25% 100%, 0% 50%); }
.circle { clip-path: circle(50%); }

.casa-hero__mirror-frame {
  width: 100%;
  height: 100%;
  background: linear-gradient(145deg, #1a1a1a 0%, #2a2a2a 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 50px 100px -20px rgba(0, 0, 0, 0.5);
}

.casa-hero__mirror-glow {
  width: 94%;
  height: 94%;
  background: conic-gradient(
    from var(--hero-angle, 0deg),
    var(--hero-color-1),
    var(--hero-color-2),
    var(--hero-color-3),
    var(--hero-color-1)
  );
  animation: glow-rotate 4s linear infinite;
  display: flex;
  align-items: center;
  justify-content: center;
}

.casa-hero__mirror-inner {
  width: 92%;
  height: 92%;
  background: rgba(0, 0, 0, 0.85);
  display: flex;
  align-items: center;
  justify-content: center;
}

.casa-hero__mirror-depth {
  width: 85%;
  height: 85%;
  background: conic-gradient(
    from var(--hero-angle, 0deg),
    rgba(147, 51, 234, 0.5),
    rgba(236, 72, 153, 0.5),
    rgba(6, 182, 212, 0.5),
    rgba(147, 51, 234, 0.5)
  );
  animation: glow-rotate 6s linear infinite reverse;
  display: flex;
  align-items: center;
  justify-content: center;
}

.casa-hero__mirror-center {
  width: 80%;
  height: 80%;
  background: rgba(0, 0, 0, 0.9);
}

/* ── Floating Badges ── */
.casa-hero__float-badge {
  position: absolute;
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 16px;
  background: rgba(10, 10, 15, 0.8);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 12px;
  font-size: 12px;
  font-weight: 600;
  color: #fff;
  z-index: 10;
  animation: badge-float 4s ease-in-out infinite;
}

.casa-hero__float-badge svg {
  width: 16px;
  height: 16px;
  stroke: var(--hero-color-1);
}

.casa-hero__float-badge--1 {
  top: 10%;
  right: -10%;
}

.casa-hero__float-badge--2 {
  bottom: 25%;
  left: -15%;
  animation-delay: -1s;
}

.casa-hero__float-badge--3 {
  bottom: 5%;
  right: 5%;
  animation-delay: -2s;
}

@keyframes badge-float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8px); }
}

/* ══════════════════════════════════════════════════════════════════════════
   SCROLL INDICATOR
   ══════════════════════════════════════════════════════════════════════════ */

.casa-hero__scroll-indicator {
  position: absolute;
  bottom: 40px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  z-index: 10;
  animation: scroll-fade 2s ease-in-out infinite;
}

.casa-hero__scroll-mouse {
  width: 24px;
  height: 40px;
  border: 2px solid rgba(255, 255, 255, 0.3);
  border-radius: 12px;
  display: flex;
  justify-content: center;
  padding-top: 8px;
}

.casa-hero__scroll-wheel {
  width: 4px;
  height: 8px;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 2px;
  animation: scroll-wheel 1.5s ease-in-out infinite;
}

.casa-hero__scroll-indicator span {
  font-size: 11px;
  color: rgba(255, 255, 255, 0.4);
  text-transform: uppercase;
  letter-spacing: 1px;
}

@keyframes scroll-fade {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 1; }
}

@keyframes scroll-wheel {
  0% { transform: translateY(0); opacity: 1; }
  100% { transform: translateY(12px); opacity: 0; }
}

/* ══════════════════════════════════════════════════════════════════════════
   REDUCED MOTION
   ══════════════════════════════════════════════════════════════════════════ */

@media (prefers-reduced-motion: reduce) {
  .casa-hero__particle,
  .casa-hero__aurora-layer,
  .casa-hero__orb,
  .casa-hero__gradient-flow,
  .casa-hero__star,
  .casa-hero__wave,
  .casa-hero__promo,
  .casa-hero__glow-ring,
  .casa-hero__product-image,
  .casa-hero__mirror,
  .casa-hero__mirror-glow,
  .casa-hero__mirror-depth,
  .casa-hero__float-badge,
  .casa-hero__scroll-indicator,
  .casa-hero__scroll-wheel,
  .casa-hero__text,
  .casa-hero__visual,
  .casa-hero__btn--primary[data-pulse] {
    animation: none !important;
  }
}

/* ══════════════════════════════════════════════════════════════════════════
   RESPONSIVE
   ══════════════════════════════════════════════════════════════════════════ */

@media (max-width: 1200px) {
  .casa-hero__container {
    padding: 0 40px;
  }

  .casa-hero__content {
    gap: 60px;
  }

  .casa-hero__visual-wrapper {
    max-width: 450px;
  }

  .casa-hero__float-badge--1 { right: -5%; }
  .casa-hero__float-badge--2 { left: -5%; }
}

@media (max-width: 900px) {
  .casa-hero {
    height: auto !important;
    min-height: auto !important;
    max-height: none !important;
    overflow-x: hidden;
    padding-top: var(--hero-mobile-padding-top, 80px);
    padding-bottom: var(--hero-mobile-padding-bottom, 60px);
  }

  .casa-hero__promo {
    /* Keep absolute positioning — overlaps the padding-top area */
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    padding: 8px 16px;
    box-sizing: border-box;
  }

  .casa-hero__promo-inner {
    font-size: 11px;
    flex-wrap: wrap;
    gap: 6px;
  }

  .casa-hero__container {
    padding: 0 20px;
    box-sizing: border-box;
  }

  .casa-hero__content {
    display: flex !important;
    flex-direction: column !important;
    gap: 32px;
    text-align: center;
  }

  .casa-hero__text {
    width: 100% !important;
    max-width: 100% !important;
    align-items: center !important;
    text-align: center !important;
    order: 1;
  }

  .casa-hero__visual {
    width: 100% !important;
    display: flex;
    justify-content: center;
    order: 2;
    overflow: hidden;
  }

  .casa-hero__visual-wrapper {
    max-width: var(--hero-mobile-visual-size, 250px);
    margin: 0 auto;
  }

  .casa-hero--mobile-visual-first .casa-hero__text { order: 2 !important; }
  .casa-hero--mobile-visual-first .casa-hero__visual { order: 1 !important; }
  .casa-hero--mobile-no-visual .casa-hero__visual { display: none !important; }

  .casa-hero__badges { justify-content: center; flex-wrap: wrap; }
  .casa-hero__subtitle { max-width: 100%; }
  .casa-hero__features { justify-content: center; flex-wrap: wrap; }
  .casa-hero__buttons { justify-content: center; flex-wrap: wrap; width: 100%; }
  .casa-hero__social-proof { align-items: center; }
  .casa-hero__trust-row { justify-content: center; flex-wrap: wrap; }

  .casa-hero__float-badge { display: none !important; }
  .casa-hero__waves { display: none; }
}
}

@media (max-width: 600px) {
  .casa-hero {
    padding-top: var(--hero-mobile-padding-top, 60px);
    padding-bottom: var(--hero-mobile-padding-bottom, 48px);
  }

  .casa-hero__container { padding: 0 16px; }
  .casa-hero__content { gap: 24px !important; }

  .casa-hero__title {
    font-size: clamp(24px, 7vw, 36px) !important;
    letter-spacing: -1px;
    word-break: break-word;
  }

  .casa-hero__subtitle { font-size: 14px !important; }

  .casa-hero__btn,
  .casa-hero__btn--small,
  .casa-hero__btn--medium,
  .casa-hero__btn--large {
    width: 100%;
    justify-content: center;
    padding: 14px 20px;
    font-size: 14px;
  }

  .casa-hero__features {
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .casa-hero__visual-wrapper {
    max-width: var(--hero-mobile-visual-size, 200px);
  }
}
{% endstylesheet %}
