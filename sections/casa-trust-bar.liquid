{%- comment -%}
  Seoul Glow Lab Trust Bar — Fully customizable
{%- endcomment -%}

{%- liquid
  assign bg_color = section.settings.bg_color | default: '#0a0a0f'
  assign text_color = section.settings.text_color | default: '#cccccc'
  assign icon_color = section.settings.icon_color | default: '#9333ea'
  assign border_color = section.settings.border_color | default: '#1a1a2e'
  assign font_size = section.settings.font_size | default: 14
  assign font_weight = section.settings.font_weight | default: '400'
  assign icon_size = section.settings.icon_size | default: 24
  assign padding_y = section.settings.padding_y | default: 24
  assign gap = section.settings.gap | default: 80
  assign layout = section.settings.layout | default: 'horizontal'
  assign show_border_top = section.settings.show_border_top
  assign show_border_bottom = section.settings.show_border_bottom
  assign icon_bg = section.settings.icon_bg
  assign icon_radius = section.settings.icon_radius | default: 10
  assign show_icon_bg = section.settings.show_icon_bg
-%}

<div
  class="casa-trust-bar casa-trust-bar--{{ layout }}"
  style="
    --ctb-bg: {{ bg_color }};
    --ctb-text: {{ text_color }};
    --ctb-icon: {{ icon_color }};
    --ctb-border: {{ border_color }};
    --ctb-font-size: {{ font_size }}px;
    --ctb-font-weight: {{ font_weight }};
    --ctb-icon-size: {{ icon_size }}px;
    --ctb-padding: {{ padding_y }}px;
    --ctb-gap: {{ gap }}px;
    --ctb-icon-radius: {{ icon_radius }}px;
    {%- if icon_bg != blank %}--ctb-icon-bg: {{ icon_bg }};{% endif -%}
  "
>
  {%- if show_border_top -%}<div class="casa-trust-bar__border-top"></div>{%- endif -%}
  <div class="casa-trust-bar__inner">
    {%- for block in section.blocks -%}
      <div class="casa-trust-bar__item" {{ block.shopify_attributes }}>
        <div class="casa-trust-bar__icon{% if show_icon_bg %} casa-trust-bar__icon--bg{% endif %}">
          {%- render 'casa-icon', icon: block.settings.icon, size: icon_size -%}
        </div>
        <div class="casa-trust-bar__text">
          <span class="casa-trust-bar__title">{{ block.settings.text | default: block.settings.title }}</span>
          {%- if block.settings.subtitle != blank -%}
            <span class="casa-trust-bar__subtitle">{{ block.settings.subtitle }}</span>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>
  {%- if show_border_bottom -%}<div class="casa-trust-bar__border-bottom"></div>{%- endif -%}
</div>

{% schema %}
{
  "name": "Casa Trust Bar",
  "tag": "section",
  "class": "casa-trust-bar-section",
  "settings": [
    { "type": "header", "content": "Layout" },
    {
      "type": "select", "id": "layout", "label": "Layout",
      "options": [
        { "value": "horizontal", "label": "Horizontal row" },
        { "value": "grid-2", "label": "Grid (2 columns)" },
        { "value": "grid-4", "label": "Grid (4 columns)" }
      ],
      "default": "horizontal"
    },
    { "type": "range", "id": "gap", "label": "Item spacing", "min": 16, "max": 120, "step": 4, "default": 80, "unit": "px" },
    { "type": "range", "id": "padding_y", "label": "Vertical padding", "min": 8, "max": 60, "step": 4, "default": 24, "unit": "px" },
    { "type": "header", "content": "Typography" },
    { "type": "range", "id": "font_size", "label": "Font size", "min": 10, "max": 20, "step": 1, "default": 14, "unit": "px" },
    {
      "type": "select", "id": "font_weight", "label": "Font weight",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "400"
    },
    { "type": "header", "content": "Icons" },
    { "type": "range", "id": "icon_size", "label": "Icon size", "min": 16, "max": 40, "step": 2, "default": 24, "unit": "px" },
    { "type": "checkbox", "id": "show_icon_bg", "label": "Show icon background", "default": false },
    { "type": "color", "id": "icon_bg", "label": "Icon background color", "info": "Only visible when icon background is enabled" },
    { "type": "range", "id": "icon_radius", "label": "Icon bg radius", "min": 0, "max": 50, "step": 2, "default": 10, "unit": "px" },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#0a0a0f" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#cccccc" },
    { "type": "color", "id": "icon_color", "label": "Icon color", "default": "#9333ea" },
    { "type": "color", "id": "border_color", "label": "Border color", "default": "#1a1a2e" },
    { "type": "header", "content": "Borders" },
    { "type": "checkbox", "id": "show_border_top", "label": "Show top border", "default": false },
    { "type": "checkbox", "id": "show_border_bottom", "label": "Show bottom border", "default": true }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "settings": [
        {
          "type": "select", "id": "icon", "label": "Icon",
          "options": [
            { "value": "truck", "label": "Shipping" },
            { "value": "shield-check", "label": "Warranty" },
            { "value": "refresh", "label": "Returns" },
            { "value": "lock", "label": "Secure" },
            { "value": "star", "label": "Star" },
            { "value": "heart", "label": "Heart" },
            { "value": "check", "label": "Check" },
            { "value": "clock", "label": "Clock" },
            { "value": "zap", "label": "Lightning" },
            { "value": "gift", "label": "Gift" },
            { "value": "headphones", "label": "Support" },
            { "value": "globe", "label": "Globe" }
          ],
          "default": "truck"
        },
        { "type": "text", "id": "title", "label": "Title", "default": "Free Worldwide Shipping" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "info": "Optional smaller text below title" },
        { "type": "text", "id": "text", "label": "Text (legacy)", "info": "Fallback if title is empty" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Casa Trust Bar",
      "blocks": [
        { "type": "trust_item", "settings": { "icon": "lock", "title": "Secure Payments", "subtitle": "256-bit SSL encryption" } },
        { "type": "trust_item", "settings": { "icon": "truck", "title": "Free Express Shipping", "subtitle": "Worldwide delivery" } },
        { "type": "trust_item", "settings": { "icon": "refresh", "title": "30-Day Returns", "subtitle": "No questions asked" } },
        { "type": "trust_item", "settings": { "icon": "shield-check", "title": "2-Year Warranty", "subtitle": "Full coverage guarantee" } }
      ]
    }
  ]
}
{% endschema %}

<style>
.casa-trust-bar {
  background: var(--ctb-bg, #0a0a0f);
  padding: var(--ctb-padding, 24px) 0;
}
.casa-trust-bar__border-top,
.casa-trust-bar__border-bottom {
  height: 1px;
  background: var(--ctb-border, rgba(255,255,255,0.1));
}
.casa-trust-bar__border-top { margin-bottom: var(--ctb-padding, 24px); }
.casa-trust-bar__border-bottom { margin-top: var(--ctb-padding, 24px); }
.casa-trust-bar__inner {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 40px;
  display: flex;
  justify-content: center;
  gap: var(--ctb-gap, 80px);
  flex-wrap: wrap;
}
.casa-trust-bar--grid-2 .casa-trust-bar__inner {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--ctb-gap, 40px);
  justify-items: center;
}
.casa-trust-bar--grid-4 .casa-trust-bar__inner {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--ctb-gap, 40px);
  justify-items: center;
}
.casa-trust-bar__item {
  display: flex;
  align-items: center;
  gap: 12px;
}
.casa-trust-bar__icon {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.casa-trust-bar__icon svg {
  stroke: var(--ctb-icon, #9333ea);
  width: var(--ctb-icon-size, 24px);
  height: var(--ctb-icon-size, 24px);
}
.casa-trust-bar__icon--bg {
  width: calc(var(--ctb-icon-size, 24px) + 16px);
  height: calc(var(--ctb-icon-size, 24px) + 16px);
  background: var(--ctb-icon-bg, rgba(147, 51, 234, 0.1));
  border-radius: var(--ctb-icon-radius, 10px);
}
.casa-trust-bar__text {
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.casa-trust-bar__title {
  color: var(--ctb-text, rgba(255,255,255,0.8));
  font-size: var(--ctb-font-size, 14px);
  font-weight: var(--ctb-font-weight, 400);
  line-height: 1.3;
}
.casa-trust-bar__subtitle {
  color: var(--ctb-text, rgba(255,255,255,0.8));
  opacity: 0.6;
  font-size: calc(var(--ctb-font-size, 14px) - 2px);
  font-weight: 400;
  line-height: 1.3;
}
@media (max-width: 900px) {
  .casa-trust-bar__inner { gap: calc(var(--ctb-gap, 80px) * 0.5); }
  .casa-trust-bar--grid-4 .casa-trust-bar__inner { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 600px) {
  .casa-trust-bar__inner {
    display: grid !important;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px 16px;
    padding: 0 16px;
  }
  .casa-trust-bar__title { font-size: calc(var(--ctb-font-size, 14px) - 2px); }
  .casa-trust-bar__subtitle { font-size: calc(var(--ctb-font-size, 14px) - 4px); }
  .casa-trust-bar__icon svg { width: calc(var(--ctb-icon-size, 24px) - 4px); height: calc(var(--ctb-icon-size, 24px) - 4px); }
  .casa-trust-bar__icon--bg { width: calc(var(--ctb-icon-size, 24px) + 8px); height: calc(var(--ctb-icon-size, 24px) + 8px); }
}
@media (max-width: 380px) {
  .casa-trust-bar { padding: var(--ctb-padding, 16px) 0; }
  .casa-trust-bar__inner { gap: 10px 12px; padding: 0 12px; }
  .casa-trust-bar__item { gap: 8px; }
  .casa-trust-bar__title { font-size: 11px; }
  .casa-trust-bar__subtitle { display: none; }
  .casa-trust-bar__icon svg { width: 18px; height: 18px; }
  .casa-trust-bar__icon--bg { width: 30px; height: 30px; }
}
</style>
