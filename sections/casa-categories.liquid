{% stylesheet %}
/* ===== CASA CATEGORIES ===== */

.casa-cat {
  position: relative;
  padding: var(--cc-pad-top) 5% var(--cc-pad-bottom);
  overflow: hidden;
}

/* Backgrounds */
.casa-cat--bg-light { background: #fff; }
.casa-cat--bg-light-gray { background: #f5f5f5; }
.casa-cat--bg-dark { background: #0a0a0a; }
.casa-cat--bg-gradient-light { background: linear-gradient(180deg, var(--cc-bg-grad-1) 0%, var(--cc-bg-grad-2) 100%); }
.casa-cat--bg-gradient-dark { background: linear-gradient(180deg, var(--cc-bg-grad-1) 0%, var(--cc-bg-grad-2) 100%); }
.casa-cat--bg-custom { background: var(--cc-bg-color); }
.casa-cat--bg-image { background: #0a0a0a; }

.casa-cat__bg {
  position: absolute;
  inset: 0;
  z-index: 0;
}

.casa-cat__bg-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.casa-cat__bg-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, var(--cc-bg-overlay));
}

/* Container */
.casa-cat__container {
  position: relative;
  z-index: 1;
  max-width: var(--casa-cat-max-w, 100%);
  margin: 0 auto;
}

/* ===== HEADER ===== */

.casa-cat__header {
  margin-bottom: 48px;
}

.casa-cat__header--center { text-align: center; }
.casa-cat__header--left { text-align: left; }

.casa-cat__tag {
  display: inline-block;
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: var(--cc-tag-color);
  margin-bottom: 12px;
}

.casa-cat__title {
  font-size: clamp(28px, 4vw, 48px);
  font-weight: 300;
  letter-spacing: -0.5px;
  line-height: 1.1;
  color: var(--cc-text-primary);
  margin: 0 0 12px 0;
}

.casa-cat__subtitle {
  font-size: clamp(14px, 1.5vw, 17px);
  color: var(--cc-text-secondary);
  max-width: 560px;
  margin: 0;
  line-height: 1.5;
}

.casa-cat__header--center .casa-cat__subtitle { margin: 0 auto; }

/* ===== GRID ===== */

.casa-cat__grid {
  display: grid;
  grid-template-columns: repeat(var(--cc-columns), 1fr);
  gap: var(--cc-gap);
}

/* Masonry */
.casa-cat--masonry .casa-cat__grid {
  display: block;
  column-count: var(--cc-columns);
  column-gap: var(--cc-gap);
}

.casa-cat--masonry .casa-cat__item {
  break-inside: avoid;
  margin-bottom: var(--cc-gap);
}

.casa-cat--masonry .casa-cat__card:nth-child(odd) { aspect-ratio: 3/4; }
.casa-cat--masonry .casa-cat__card:nth-child(even) { aspect-ratio: 4/5; }

/* Featured layout */
.casa-cat--featured .casa-cat__grid {
  grid-template-columns: repeat(4, 1fr);
}

.casa-cat--featured .casa-cat__item--featured {
  grid-column: span 2;
  grid-row: span 2;
}

/* Carousel */
.casa-cat--carousel .casa-cat__grid {
  display: flex;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  padding-bottom: 4px;
}

.casa-cat--carousel .casa-cat__grid::-webkit-scrollbar { display: none; }

.casa-cat--carousel .casa-cat__item {
  flex: 0 0 calc(25% - var(--cc-gap) * 0.75);
  scroll-snap-align: start;
}

/* ===== ITEM (card wrapper) ===== */

.casa-cat__item {
  display: flex;
  flex-direction: column;
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.5s ease, transform 0.5s ease;
  transition-delay: var(--card-delay, 0ms);
}

.casa-cat__item--visible {
  opacity: 1;
  transform: translateY(0);
}

/* fade-in variant */
.casa-cat[data-animation="fade-in"] .casa-cat__item {
  transform: none;
}

/* scale-up variant */
.casa-cat[data-animation="scale-up"] .casa-cat__item {
  transform: scale(0.95);
}

.casa-cat[data-animation="scale-up"] .casa-cat__item--visible {
  transform: scale(1);
}

/* No animation */
.casa-cat[data-animation="none"] .casa-cat__item {
  opacity: 1;
  transform: none;
  transition: none;
}

/* ===== CARD ===== */

.casa-cat__card {
  position: relative;
  aspect-ratio: var(--cc-aspect);
  border-radius: var(--cc-radius);
  overflow: hidden;
  display: flex;
  flex: 1;
  text-decoration: none;
  color: #fff;
  cursor: pointer;
  transition: transform 0.35s ease, box-shadow 0.35s ease;
}

/* Hover effects */
.casa-cat__card--hover-lift:hover {
  transform: translateY(-6px);
  box-shadow: 0 16px 40px rgba(0, 0, 0, 0.15);
}

.casa-cat__card--hover-zoom:hover .casa-cat__media {
  transform: scale(1.08);
}

.casa-cat__card--hover-glow:hover {
  box-shadow: 0 0 30px rgba(var(--card-overlay-rgb), 0.35);
}

/* ===== MEDIA (image/video) ===== */

.casa-cat__media {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
}

/* ===== OVERLAY ===== */

/* Gradient style: full overlay using per-card color + opacity */
.casa-cat--style-gradient .casa-cat__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top,
    rgba(var(--card-overlay-rgb), var(--card-overlay-opacity)) 0%,
    rgba(var(--card-overlay-rgb), calc(var(--card-overlay-opacity) * 0.3)) 100%
  );
  z-index: 1;
}

/* Minimal style: bottom fade only */
.casa-cat--style-minimal .casa-cat__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top,
    rgba(var(--card-overlay-rgb), var(--card-overlay-opacity)) 0%,
    transparent 50%
  );
  z-index: 1;
}

/* Glass style: light top overlay, glass panel at bottom */
.casa-cat--style-glass .casa-cat__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top,
    rgba(var(--card-overlay-rgb), calc(var(--card-overlay-opacity) * 0.6)) 0%,
    transparent 40%
  );
  z-index: 1;
}

.casa-cat__glass-panel {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 45%;
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(12px) saturate(150%);
  -webkit-backdrop-filter: blur(12px) saturate(150%);
  border-top: 1px solid rgba(255, 255, 255, 0.15);
  z-index: 2;
  pointer-events: none;
}

/* ===== CARD CONTENT ===== */

.casa-cat__content {
  position: relative;
  z-index: 5;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  width: 100%;
  height: 100%;
  padding: 20px;
  color: #fff;
}

.casa-cat__name {
  font-size: clamp(16px, 1.4vw, 20px);
  font-weight: 600;
  margin: 0 0 4px 0;
  line-height: 1.2;
}

.casa-cat__sub {
  font-size: 13px;
  opacity: 0.8;
  margin: 0 0 4px 0;
}

.casa-cat__count {
  font-size: 12px;
  opacity: 0.6;
}

.casa-cat__arrow {
  position: absolute;
  bottom: 20px;
  right: 20px;
  opacity: 0;
  transform: translateX(-8px);
  transition: opacity 0.3s ease, transform 0.3s ease;
}

.casa-cat__card:hover .casa-cat__arrow {
  opacity: 1;
  transform: translateX(0);
}

/* ===== EXTERNAL TEXT ===== */

.casa-cat__ext-text {
  color: var(--cc-text-primary);
  padding: 10px 4px;
}

.casa-cat__ext-title {
  font-size: 16px;
  font-weight: 600;
  margin: 0 0 2px 0;
  transition: color 0.3s ease;
}

.casa-cat__item:hover .casa-cat__ext-title {
  color: var(--cc-accent);
}

.casa-cat__ext-sub {
  font-size: 13px;
  color: var(--cc-text-secondary);
  margin: 0 0 2px 0;
}

.casa-cat__ext-count {
  font-size: 12px;
  color: var(--cc-text-secondary);
}

/* ===== BADGE ===== */

.casa-cat__badge {
  position: absolute;
  top: 12px;
  right: 12px;
  z-index: 10;
  padding: 5px 10px;
  border-radius: 16px;
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: #fff;
}

.casa-cat__badge--new { background: #7c3aed; }
.casa-cat__badge--sale { background: #ef4444; }
.casa-cat__badge--trending { background: #f59e0b; color: #0a0a0a; }
.casa-cat__badge--custom { background: var(--cc-accent); }

/* ===== DOTS (carousel indicators) ===== */

.casa-cat__dots {
  display: none;
  justify-content: center;
  gap: 6px;
  margin-top: 20px;
}

.casa-cat__dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--cc-text-secondary);
  opacity: 0.3;
  transition: all 0.3s ease;
}

.casa-cat__dot--active {
  opacity: 1;
  background: var(--cc-accent);
  width: 20px;
  border-radius: 3px;
}

/* ===== VIEW ALL ===== */

.casa-cat__footer {
  display: flex;
  justify-content: center;
  margin-top: 40px;
}

.casa-cat__view-all {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 14px 28px;
  background: var(--cc-btn-bg);
  color: var(--cc-btn-text);
  text-decoration: none;
  font-size: 13px;
  font-weight: 600;
  border-radius: 24px;
  transition: transform 0.3s ease, opacity 0.3s ease;
}

.casa-cat__view-all:hover {
  transform: translateY(-2px);
  opacity: 0.9;
}

/* ===== RESPONSIVE ===== */

@media (max-width: 1200px) {
  .casa-cat__grid { --cc-columns: 3; }
  .casa-cat--featured .casa-cat__grid { grid-template-columns: repeat(3, 1fr); }
  .casa-cat--carousel .casa-cat__item { flex: 0 0 calc(33.333% - var(--cc-gap) * 0.67); }
}

@media (max-width: 900px) {
  .casa-cat__grid { --cc-columns: 2; }
  .casa-cat--featured .casa-cat__grid { grid-template-columns: repeat(2, 1fr); }
  .casa-cat--featured .casa-cat__item--featured { grid-column: span 2; grid-row: span 1; }
  .casa-cat--carousel .casa-cat__item { flex: 0 0 calc(50% - var(--cc-gap) * 0.5); }
  .casa-cat--masonry .casa-cat__grid { column-count: 2; }
}

@media (max-width: 600px) {
  .casa-cat { padding: 48px 16px 48px; }
  .casa-cat__header { margin-bottom: 28px; }

  /* Mobile carousel when enabled */
  .casa-cat:not(.casa-cat--carousel) .casa-cat__grid {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    gap: 12px;
  }

  .casa-cat:not(.casa-cat--carousel) .casa-cat__grid::-webkit-scrollbar { display: none; }

  .casa-cat:not(.casa-cat--carousel) .casa-cat__item {
    flex: 0 0 200px;
    scroll-snap-align: start;
  }

  .casa-cat:not(.casa-cat--carousel) .casa-cat__item--featured {
    flex: 0 0 260px;
  }

  .casa-cat--carousel .casa-cat__item {
    flex: 0 0 200px;
  }

  .casa-cat__card { aspect-ratio: 1/1; }

  .casa-cat--masonry .casa-cat__grid {
    display: flex;
    column-count: unset;
  }

  .casa-cat--masonry .casa-cat__item { margin-bottom: 0; }
  .casa-cat--masonry .casa-cat__card { aspect-ratio: 1/1; }

  .casa-cat__dots { display: flex; }
}

/* Reduced motion */
@media (prefers-reduced-motion: reduce) {
  .casa-cat__item {
    opacity: 1;
    transform: none;
    transition: none;
  }

  .casa-cat__card,
  .casa-cat__media,
  .casa-cat__arrow,
  .casa-cat__ext-title {
    transition: none;
  }
}
{% endstylesheet %}
