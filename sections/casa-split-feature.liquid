{%- comment -%}
  Seoul Glow Lab — Split Feature Section
  Two full-bleed cards side-by-side: image/video fills entire card,
  glassmorphic title overlay revealed on hover.
  Day/Night concept for mirror by day / portal by night.
{%- endcomment -%}

{%- liquid
  assign s = section.settings
  assign min_h = s.min_height | default: 600

  assign day_title    = s.day_title | default: ''
  assign day_sub      = s.day_subtitle | default: ''
  assign night_title  = s.night_title | default: ''
  assign night_sub    = s.night_subtitle | default: ''

  assign desktop_ratio = s.desktop_ratio | default: ''
  assign mobile_ratio  = s.mobile_ratio | default: ''
  assign show_overlay  = s.show_overlay
  assign mobile_cols   = s.mobile_columns | default: ''

  assign day_has_video = false
  assign day_has_ext   = false
  if s.day_video != blank
    assign day_has_video = true
  endif
  if s.day_video_url != blank
    assign day_has_ext = true
  endif

  assign night_has_video = false
  assign night_has_ext   = false
  if s.night_video != blank
    assign night_has_video = true
  endif
  if s.night_video_url != blank
    assign night_has_ext = true
  endif
-%}

<section
  class="cdl-split{% if mobile_cols == '2' %} cdl-split--two-col-mobile{% endif %}{% unless show_overlay %} cdl-split--no-overlay{% endunless %}"
  id="cdl-split-{{ section.id }}"
  style="
    --cdl-split-h: {{ min_h }}px;
    --cdl-split-desktop-ratio: {{ desktop_ratio }};
    --cdl-split-mobile-ratio: {{ mobile_ratio }};
    --cdl-split-padding: {{ s.section_padding | default: 0 }}px;
    --cdl-split-gap: {{ s.card_gap | default: 0 }}px;
    --cdl-split-radius: {{ s.card_radius | default: 0 }}px;
    --cdl-split-bg: {{ s.section_bg | default: '#0a0a0f' }};
    --cdl-split-overlay: {{ s.overlay_opacity | default: 30 | divided_by: 100.0 }};
    --cdl-split-title-color: {{ s.title_color | default: '#ffffff' }};
    --cdl-split-sub-color: {{ s.subtitle_color | default: '#ffffff' }};
    --cdl-split-title-size: {{ s.title_size | default: 28 }}px;
    --cdl-split-title-weight: {{ s.title_weight | default: '300' }};
    --cdl-split-glass-blur: {{ s.glass_blur | default: 12 }}px;
    --cdl-split-glass-radius: {{ s.glass_radius | default: 12 }}px;
    {%- if s.glass_bg != blank %}--cdl-split-glass-bg: {{ s.glass_bg }};{% endif -%}
  "
>
  {%- comment -%} ── DAY SIDE ── {%- endcomment -%}
  <div class="cdl-split__card cdl-split__card--day">
    {%- comment -%} Video background {%- endcomment -%}
    {%- if day_has_video -%}
      <video class="cdl-split__media" autoplay loop muted playsinline
        {%- if s.day_image != blank %} poster="{{ s.day_image | image_url: width: 1400 }}"{% endif %}>
        {%- for source in s.day_video.sources -%}
          <source src="{{ source.url }}" type="{{ source.mime_type }}">
        {%- endfor -%}
      </video>
    {%- elsif day_has_ext -%}
      <video class="cdl-split__media" src="{{ s.day_video_url }}" autoplay loop muted playsinline
        {%- if s.day_image != blank %} poster="{{ s.day_image | image_url: width: 1400 }}"{% endif %}></video>
    {%- endif -%}

    {%- comment -%} Image background {%- endcomment -%}
    {%- if s.day_image != blank -%}
      <img
        src="{{ s.day_image | image_url: width: 1400 }}"
        srcset="
          {{ s.day_image | image_url: width: 600 }} 600w,
          {{ s.day_image | image_url: width: 900 }} 900w,
          {{ s.day_image | image_url: width: 1400 }} 1400w
        "
        sizes="(max-width: 900px) 100vw, 50vw"
        alt="{{ day_title | escape }}"
        class="cdl-split__media cdl-split__media--img{% if day_has_video or day_has_ext %} cdl-split__media--poster{% endif %}"
        loading="lazy"
      >
    {%- endif -%}

    {%- comment -%} Fallback gradient when no image/video {%- endcomment -%}
    {%- if s.day_image == blank and day_has_video == false and day_has_ext == false -%}
      <div class="cdl-split__fallback cdl-split__fallback--day"></div>
    {%- endif -%}

    <div class="cdl-split__overlay"></div>

    <div class="cdl-split__content">
      <div class="cdl-split__glass">
        <h3 class="cdl-split__title">{{ day_title }}</h3>
        <p class="cdl-split__sub">{{ day_sub }}</p>
      </div>
    </div>

    {%- if s.day_link != blank -%}
      <a href="{{ s.day_link }}" class="cdl-split__link" aria-label="{{ day_title | escape }}"></a>
    {%- endif -%}
  </div>

  {%- comment -%} ── NIGHT SIDE ── {%- endcomment -%}
  <div class="cdl-split__card cdl-split__card--night">
    {%- if night_has_video -%}
      <video class="cdl-split__media" autoplay loop muted playsinline
        {%- if s.night_image != blank %} poster="{{ s.night_image | image_url: width: 1400 }}"{% endif %}>
        {%- for source in s.night_video.sources -%}
          <source src="{{ source.url }}" type="{{ source.mime_type }}">
        {%- endfor -%}
      </video>
    {%- elsif night_has_ext -%}
      <video class="cdl-split__media" src="{{ s.night_video_url }}" autoplay loop muted playsinline
        {%- if s.night_image != blank %} poster="{{ s.night_image | image_url: width: 1400 }}"{% endif %}></video>
    {%- endif -%}

    {%- if s.night_image != blank -%}
      <img
        src="{{ s.night_image | image_url: width: 1400 }}"
        srcset="
          {{ s.night_image | image_url: width: 600 }} 600w,
          {{ s.night_image | image_url: width: 900 }} 900w,
          {{ s.night_image | image_url: width: 1400 }} 1400w
        "
        sizes="(max-width: 900px) 100vw, 50vw"
        alt="{{ night_title | escape }}"
        class="cdl-split__media cdl-split__media--img{% if night_has_video or night_has_ext %} cdl-split__media--poster{% endif %}"
        loading="lazy"
      >
    {%- endif -%}

    {%- if s.night_image == blank and night_has_video == false and night_has_ext == false -%}
      <div class="cdl-split__fallback cdl-split__fallback--night"></div>
    {%- endif -%}

    <div class="cdl-split__overlay"></div>

    <div class="cdl-split__content">
      <div class="cdl-split__glass">
        <h3 class="cdl-split__title">{{ night_title }}</h3>
        <p class="cdl-split__sub">{{ night_sub }}</p>
      </div>
    </div>

    {%- if s.night_link != blank -%}
      <a href="{{ s.night_link }}" class="cdl-split__link" aria-label="{{ night_title | escape }}"></a>
    {%- endif -%}
  </div>
</section>

<script>
(function() {
  var root = document.getElementById('cdl-split-{{ section.id }}');
  if (!root) return;

  /* Fade poster once video plays */
  root.querySelectorAll('.cdl-split__card').forEach(function(card) {
    var video = card.querySelector('video.cdl-split__media');
    var poster = card.querySelector('.cdl-split__media--poster');
    if (!video || !poster) return;
    video.addEventListener('playing', function() {
      poster.style.opacity = '0';
    }, { once: true });
  });

  /* Pause off-screen videos */
  if ('IntersectionObserver' in window) {
    var obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) e.target.play().catch(function(){});
        else e.target.pause();
      });
    }, { rootMargin: '100px' });
    root.querySelectorAll('video.cdl-split__media').forEach(function(v) { obs.observe(v); });
  }
})();
</script>

