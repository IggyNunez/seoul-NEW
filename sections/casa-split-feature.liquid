{% stylesheet %}
/* ══════════════════════════════════════════════════════════════════════════
   CDL SPLIT FEATURE — Full-bleed day/night cards with glassmorphic overlay
   ══════════════════════════════════════════════════════════════════════════ */

.cdl-split-section,
.cdl-split {
  background: var(--cdl-split-bg, transparent);
}
.cdl-split-section {
  padding: 0 !important;
  margin: 0;
}

.cdl-split {
  display: flex;
  gap: var(--cdl-split-gap, 0px);
  padding: var(--cdl-split-padding, 0px);
  min-height: var(--cdl-split-h, 600px);
}

/* ── Card base ── */
.cdl-split__card {
  flex: 1;
  position: relative;
  overflow: hidden;
  cursor: pointer;
  border-radius: var(--cdl-split-radius, 0px);
}

/* ── Desktop aspect ratio (when not "auto") ── */
.cdl-split__card {
  aspect-ratio: var(--cdl-split-desktop-ratio);
}
/* When auto, min-height drives sizing instead of aspect-ratio */
.cdl-split[style*="--cdl-split-desktop-ratio: auto"] .cdl-split__card {
  aspect-ratio: unset;
}

/* ── Media — fills entire card ── */
.cdl-split__media {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 0;
  transition: transform 0.6s ease;
}

.cdl-split__card:hover .cdl-split__media {
  transform: scale(1.05);
}

/* Poster image fades out when video plays (JS sets opacity:0) */
.cdl-split__media--poster {
  z-index: 1;
  transition: opacity 0.6s ease, transform 0.6s ease;
}

/* ── Fallback gradients when no image/video ── */
.cdl-split__fallback {
  position: absolute;
  inset: 0;
  z-index: 0;
}

.cdl-split__fallback--day {
  background: linear-gradient(135deg, #f5f5f5 0%, #e0e0e0 50%, #d4d4d8 100%);
}

.cdl-split__fallback--night {
  background: linear-gradient(135deg, #0a0a14 0%, #1a1a2e 50%, #2d1b4e 100%);
}

/* ── Dark overlay — subtle gradient from bottom for text legibility ── */
.cdl-split__overlay {
  position: absolute;
  inset: 0;
  z-index: 2;
  background: linear-gradient(
    to top,
    rgba(0, 0, 0, var(--cdl-split-overlay, 0.3)) 0%,
    rgba(0, 0, 0, calc(var(--cdl-split-overlay, 0.3) * 0.4)) 40%,
    rgba(0, 0, 0, calc(var(--cdl-split-overlay, 0.3) * 0.1)) 100%
  );
  transition: background 0.4s ease;
  pointer-events: none;
}

.cdl-split__card:hover .cdl-split__overlay {
  background: linear-gradient(
    to top,
    rgba(0, 0, 0, 0.7) 0%,
    rgba(0, 0, 0, 0.25) 50%,
    rgba(0, 0, 0, 0.1) 100%
  );
}

/* ── No-overlay modifier ── */
.cdl-split--no-overlay .cdl-split__overlay {
  display: none;
}

/* ── Content — positioned bottom-left ── */
.cdl-split__content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 3;
  padding: 40px;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

/* ── Glassmorphic pill ── */
.cdl-split__glass {
  background: var(--cdl-split-glass-bg, rgba(255, 255, 255, 0.12));
  backdrop-filter: blur(var(--cdl-split-glass-blur, 12px));
  -webkit-backdrop-filter: blur(var(--cdl-split-glass-blur, 12px));
  border: 1px solid rgba(255, 255, 255, 0.15);
  border-radius: var(--cdl-split-glass-radius, 12px);
  padding: 20px 28px;
  transition: background 0.35s ease, transform 0.35s ease;
}

.cdl-split__card:hover .cdl-split__glass {
  background: rgba(255, 255, 255, 0.18);
  transform: translateY(-4px);
}

/* ── Title ── */
.cdl-split__title {
  font-size: var(--cdl-split-title-size, 28px);
  font-weight: var(--cdl-split-title-weight, 300);
  color: var(--cdl-split-title-color, #ffffff);
  margin: 0 0 6px 0;
  line-height: 1.25;
  letter-spacing: -0.3px;
}

/* ── Subtitle — hidden by default, slides in on hover ── */
.cdl-split__sub {
  font-size: 14px;
  color: var(--cdl-split-sub-color, rgba(255, 255, 255, 0.7));
  margin: 0;
  line-height: 1.5;
  max-height: 0;
  opacity: 0;
  overflow: hidden;
  transition: max-height 0.4s ease, opacity 0.35s ease;
}

.cdl-split__card:hover .cdl-split__sub {
  max-height: 80px;
  opacity: 1;
}

/* ── Full-card clickable link ── */
.cdl-split__link {
  position: absolute;
  inset: 0;
  z-index: 5;
}

/* ══════════════════════════════════════════════════════════════════════════
   RESPONSIVE
   ══════════════════════════════════════════════════════════════════════════ */

@media (max-width: 900px) {
  .cdl-split {
    flex-direction: column;
    min-height: auto;
  }

  /* Two-column mobile: keep side-by-side */
  .cdl-split--two-col-mobile {
    flex-direction: row;
  }

  .cdl-split__card {
    min-height: 280px;
    aspect-ratio: var(--cdl-split-mobile-ratio, 16/9);
  }

  /* Two-col mobile: each card takes half width */
  .cdl-split--two-col-mobile .cdl-split__card {
    flex: 1;
    min-height: 240px;
  }

  .cdl-split__content {
    padding: 28px;
  }

  .cdl-split__glass {
    padding: 16px 22px;
    border-radius: 12px;
  }

  .cdl-split__title {
    font-size: 24px;
  }

  /* Two-col mobile: smaller text */
  .cdl-split--two-col-mobile .cdl-split__title {
    font-size: 20px;
  }

  /* Show subtitle always on mobile (no hover) */
  .cdl-split__sub {
    max-height: 80px;
    opacity: 1;
    margin-top: 4px;
  }
}

@media (max-width: 600px) {
  .cdl-split__card {
    min-height: 220px;
  }

  .cdl-split--two-col-mobile .cdl-split__card {
    min-height: 200px;
  }

  .cdl-split__content {
    padding: 20px;
  }

  /* Two-col mobile: tighter padding */
  .cdl-split--two-col-mobile .cdl-split__content {
    padding: 14px;
  }

  .cdl-split__glass {
    padding: 14px 18px;
    border-radius: 10px;
  }

  .cdl-split--two-col-mobile .cdl-split__glass {
    padding: 10px 14px;
    border-radius: 8px;
  }

  .cdl-split__title {
    font-size: 20px;
  }

  .cdl-split--two-col-mobile .cdl-split__title {
    font-size: 16px;
  }

  .cdl-split__sub {
    font-size: 13px;
  }

  .cdl-split--two-col-mobile .cdl-split__sub {
    font-size: 11px;
  }
}

@media (prefers-reduced-motion: reduce) {
  .cdl-split__media,
  .cdl-split__glass,
  .cdl-split__overlay,
  .cdl-split__sub {
    transition: none !important;
  }
}
{% endstylesheet %}
