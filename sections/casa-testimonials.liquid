{%- comment -%}
  Seoul Glow Lab — Premium Testimonials Section
  3 layout modes: carousel, masonry, marquee
  Glassmorphic cards, accent word support, stats row
{%- endcomment -%}

{%- liquid
  assign s = section.settings
  assign layout = s.layout_style | default: 'carousel'
  assign sid = section.id

  # Header
  assign tag_text = s.tag_text | default: ''
  assign title = s.title | default: ''
  assign subtitle = s.subtitle | default: ''
  assign accent_word = s.accent_word
  assign accent_style = s.accent_style | default: 'gradient'
  assign accent_color = s.accent_color | default: '#9333ea'
  assign accent_color_2 = s.accent_color_2 | default: '#ec4899'

  # Stats
  assign show_stats = s.show_stats
  assign avg_rating = s.avg_rating | default: '4.9'
  assign total_reviews = s.total_reviews | default: '2,847'
  assign recommend_pct = s.recommend_pct | default: '98'

  # Carousel
  assign auto_play = s.auto_play
  assign auto_play_speed = s.auto_play_speed | default: 5
  assign cards_visible = s.cards_visible | default: 3

  # Marquee
  assign scroll_speed = s.scroll_speed | default: 'medium'
  assign pause_on_hover = s.pause_on_hover

  # Colors
  assign bg_color = s.bg_color | default: '#0a0a0f'
  assign text_color = s.text_color | default: '#ffffff'
  assign card_bg = s.card_bg | default: 'rgba(255,255,255,0.05)'
  assign card_border = s.card_border | default: 'rgba(255,255,255,0.1)'
  assign star_color = s.star_color | default: '#fbbf24'
  assign author_color = s.author_color | default: 'rgba(255,255,255,0.5)'
  assign quote_color = s.quote_color | default: 'rgba(255,255,255,0.75)'

  # Spacing
  assign padding_top = s.padding_top | default: 100
  assign padding_bottom = s.padding_bottom | default: 100
  assign card_gap = s.card_gap | default: 20

  # Marquee speed mapping
  assign marquee_duration = '40s'
  if scroll_speed == 'slow'
    assign marquee_duration = '60s'
  elsif scroll_speed == 'fast'
    assign marquee_duration = '25s'
  endif

  # Build accent title
  assign display_title = title
  if accent_word != blank and title != blank
    assign accent_html = '<span class="casa-test__accent casa-test__accent--' | append: accent_style | append: '">' | append: accent_word | append: '</span>'
    assign display_title = title | replace: accent_word, accent_html
  endif

  # Check if header has content
  assign header_visible = false
  if tag_text != blank or title != blank or subtitle != blank or show_stats
    assign header_visible = true
  endif
-%}

<section
  class="casa-test casa-test--{{ layout }}"
  id="casa-test-{{ sid }}"
  data-layout="{{ layout }}"
  data-auto-play="{{ auto_play }}"
  data-auto-play-speed="{{ auto_play_speed }}"
  data-cards-visible="{{ cards_visible }}"
  style="
    --ct-bg: {{ bg_color }};
    --ct-text: {{ text_color }};
    --ct-card-bg: {{ card_bg }};
    --ct-card-border: {{ card_border }};
    --ct-star: {{ star_color }};
    --ct-accent-1: {{ accent_color }};
    --ct-accent-2: {{ accent_color_2 }};
    --ct-author: {{ author_color }};
    --ct-quote: {{ quote_color }};
    --ct-pad-top: {{ padding_top }}px;
    --ct-pad-bottom: {{ padding_bottom }}px;
    --ct-gap: {{ card_gap }}px;
    --ct-cards: {{ cards_visible }};
    --ct-marquee-dur: {{ marquee_duration }};
    --ct-max-w: {% case section.settings.section_width %}{% when 'full' %}100%{% when 'wide' %}1600px{% when 'narrow' %}1200px{% else %}1400px{% endcase %};
  "
>
  <div class="casa-test__inner">

    {%- comment -%} ═══ HEADER ═══ {%- endcomment -%}
    {%- if header_visible -%}
    <div class="casa-test__header">
      {%- if tag_text != blank -%}
        <span class="casa-test__tag">{{ tag_text }}</span>
      {%- endif -%}
      {%- if title != blank -%}
        <h2 class="casa-test__title">{{ display_title }}</h2>
      {%- endif -%}
      {%- if subtitle != blank -%}
        <p class="casa-test__subtitle">{{ subtitle }}</p>
      {%- endif -%}

      {%- if show_stats -%}
      <div class="casa-test__stats">
        <div class="casa-test__stat">
          <span class="casa-test__stat-value">{{ avg_rating }}</span>
          <div class="casa-test__stat-stars">
            {%- for i in (1..5) -%}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--ct-star)"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14l-5-4.87 6.91-1.01z"/></svg>
            {%- endfor -%}
          </div>
          <span class="casa-test__stat-label">Average Rating</span>
        </div>
        <div class="casa-test__stat-divider"></div>
        <div class="casa-test__stat">
          <span class="casa-test__stat-value">{{ total_reviews }}</span>
          <span class="casa-test__stat-label">Total Reviews</span>
        </div>
        <div class="casa-test__stat-divider"></div>
        <div class="casa-test__stat">
          <span class="casa-test__stat-value">{{ recommend_pct }}%</span>
          <span class="casa-test__stat-label">Recommend</span>
        </div>
      </div>
      {%- endif -%}
    </div>
    {%- endif -%}

    {%- comment -%} ═══ CAROUSEL LAYOUT ═══ {%- endcomment -%}
    {%- if layout == 'carousel' -%}
    <div class="casa-test__carousel-wrap">
      <div class="casa-test__carousel" id="casa-test-carousel-{{ sid }}">
        {%- for block in section.blocks -%}
          {%- if block.type == 'review' -%}
            {%- render 'casa-test-card', block: block, star_color: star_color -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
      <button class="casa-test__arrow casa-test__arrow--prev" aria-label="Previous review" data-dir="prev">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button class="casa-test__arrow casa-test__arrow--next" aria-label="Next review" data-dir="next">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
    {%- endif -%}

    {%- comment -%} ═══ MASONRY LAYOUT ═══ {%- endcomment -%}
    {%- if layout == 'masonry' -%}
    <div class="casa-test__masonry" id="casa-test-masonry-{{ sid }}">
      {%- for block in section.blocks -%}
        {%- if block.type == 'review' -%}
          <div class="casa-test__masonry-item" {{ block.shopify_attributes }}>
            {%- render 'casa-test-card', block: block, star_color: star_color -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
    {%- endif -%}

    {%- comment -%} ═══ MARQUEE LAYOUT ═══ {%- endcomment -%}
    {%- if layout == 'marquee' -%}
    <div class="casa-test__marquee{% if pause_on_hover %} casa-test__marquee--pausable{% endif %}">
      {%- comment -%} Row 1 — scrolls left {%- endcomment -%}
      <div class="casa-test__marquee-row casa-test__marquee-row--left">
        <div class="casa-test__marquee-track">
          {%- for block in section.blocks -%}
            {%- if block.type == 'review' -%}
              {%- render 'casa-test-card', block: block, star_color: star_color, compact: true -%}
            {%- endif -%}
          {%- endfor -%}
          {%- comment -%} Duplicate for seamless loop {%- endcomment -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'review' -%}
              {%- render 'casa-test-card', block: block, star_color: star_color, compact: true -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
      {%- comment -%} Row 2 — scrolls right {%- endcomment -%}
      <div class="casa-test__marquee-row casa-test__marquee-row--right">
        <div class="casa-test__marquee-track">
          {%- for block in section.blocks -%}
            {%- if block.type == 'review' -%}
              {%- render 'casa-test-card', block: block, star_color: star_color, compact: true -%}
            {%- endif -%}
          {%- endfor -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'review' -%}
              {%- render 'casa-test-card', block: block, star_color: star_color, compact: true -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
    {%- endif -%}

  </div>
</section>

{%- comment -%} ═══════════════════════════════════════════════════════════════
   STYLES
   ═══════════════════════════════════════════════════════════════ {%- endcomment -%}
<style>
/* ═══════════════════════════════════════════════════════════════
   CASA TESTIMONIALS — Premium Section
   ═══════════════════════════════════════════════════════════════ */

/* ── Base ── */
.casa-test {
  background: var(--ct-bg, #0a0a0f);
  color: var(--ct-text, #fff);
  padding: var(--ct-pad-top, 100px) 0 var(--ct-pad-bottom, 100px);
  overflow: hidden;
  position: relative;
}

.casa-test__inner {
  max-width: var(--ct-max-w, 100%);
  margin: 0 auto;
  padding: 0 24px;
}

/* ── Header ── */
.casa-test__header {
  text-align: center;
  margin-bottom: 56px;
  max-width: 720px;
  margin-left: auto;
  margin-right: auto;
}

.casa-test__tag {
  display: inline-block;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 3px;
  background: linear-gradient(135deg, var(--ct-accent-1, #9333ea), var(--ct-accent-2, #ec4899));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 16px;
}

.casa-test__title {
  font-size: clamp(32px, 5vw, 52px);
  font-weight: 300;
  line-height: 1.15;
  letter-spacing: -0.02em;
  margin: 0 0 16px;
  color: var(--ct-text, #fff);
}

.casa-test__subtitle {
  font-size: clamp(15px, 1.5vw, 18px);
  color: var(--ct-author, rgba(255,255,255,0.5));
  line-height: 1.6;
  margin: 0 0 32px;
  font-weight: 400;
}

/* ── Accent word styles ── */
.casa-test__accent--gradient {
  background: linear-gradient(135deg, var(--ct-accent-1, #9333ea), var(--ct-accent-2, #ec4899));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.casa-test__accent--solid {
  color: var(--ct-accent-1, #9333ea);
}
.casa-test__accent--underline {
  text-decoration: underline;
  text-decoration-color: var(--ct-accent-1, #9333ea);
  text-underline-offset: 6px;
  text-decoration-thickness: 3px;
}
.casa-test__accent--glow {
  color: var(--ct-accent-1, #9333ea);
  text-shadow: 0 0 20px var(--ct-accent-1, #9333ea), 0 0 40px rgba(147, 51, 234, 0.3);
}
.casa-test__accent--shimmer {
  background: linear-gradient(90deg, var(--ct-accent-1, #9333ea) 0%, var(--ct-accent-2, #ec4899) 50%, var(--ct-accent-1, #9333ea) 100%);
  background-size: 200% 100%;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: casa-test-shimmer 3s ease-in-out infinite;
}
@keyframes casa-test-shimmer {
  0% { background-position: 200% center; }
  100% { background-position: -200% center; }
}

/* ── Stats row ── */
.casa-test__stats {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32px;
  flex-wrap: wrap;
}

.casa-test__stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}

.casa-test__stat-value {
  font-size: clamp(28px, 4vw, 40px);
  font-weight: 300;
  letter-spacing: -0.02em;
  color: var(--ct-text, #fff);
}

.casa-test__stat-stars {
  display: flex;
  gap: 2px;
}

.casa-test__stat-label {
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: var(--ct-author, rgba(255,255,255,0.5));
  font-weight: 500;
}

.casa-test__stat-divider {
  width: 1px;
  height: 48px;
  background: rgba(255,255,255,0.1);
  flex-shrink: 0;
}

/* ══════════════════════════════════════════════════════════════
   REVIEW CARD — Glassmorphic
   ══════════════════════════════════════════════════════════════ */
.casa-test__card {
  background: var(--ct-card-bg, rgba(255,255,255,0.05));
  border: 1px solid var(--ct-card-border, rgba(255,255,255,0.1));
  border-radius: 16px;
  padding: 28px;
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94),
              border-color 0.35s ease,
              box-shadow 0.35s ease;
  position: relative;
  overflow: hidden;
}

.casa-test__card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
  opacity: 0;
  transition: opacity 0.35s ease;
}

.casa-test__card:hover {
  transform: translateY(-4px);
  border-color: rgba(255,255,255,0.2);
  box-shadow: 0 16px 48px rgba(0,0,0,0.3);
}

.casa-test__card:hover::before {
  opacity: 1;
}

/* Card: Stars */
.casa-test__card-stars {
  display: flex;
  gap: 2px;
  margin-bottom: 16px;
}

.casa-test__card-stars svg {
  flex-shrink: 0;
}

/* Card: Quote */
.casa-test__card-quote {
  font-size: 15px;
  line-height: 1.7;
  color: var(--ct-quote, rgba(255,255,255,0.75));
  margin: 0 0 20px;
  font-weight: 400;
}

/* Card: Footer (author row) */
.casa-test__card-footer {
  display: flex;
  align-items: center;
  gap: 12px;
}

.casa-test__card-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  flex-shrink: 0;
  overflow: hidden;
  background: linear-gradient(135deg, var(--ct-accent-1, #9333ea), var(--ct-accent-2, #ec4899));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 600;
  color: #fff;
}

.casa-test__card-avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.casa-test__card-info {
  display: flex;
  flex-direction: column;
  gap: 2px;
  min-width: 0;
}

.casa-test__card-author {
  font-size: 14px;
  font-weight: 600;
  color: var(--ct-text, #fff);
  display: flex;
  align-items: center;
  gap: 6px;
}

.casa-test__card-verified {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 16px;
  height: 16px;
  background: #22c55e;
  border-radius: 50%;
  flex-shrink: 0;
}

.casa-test__card-verified svg {
  width: 10px;
  height: 10px;
  color: #fff;
}

.casa-test__card-meta {
  font-size: 12px;
  color: var(--ct-author, rgba(255,255,255,0.5));
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
}

.casa-test__card-product {
  color: var(--ct-accent-1, #9333ea);
  text-decoration: none;
  transition: color 0.2s ease;
}

.casa-test__card-product:hover {
  color: var(--ct-accent-2, #ec4899);
}

.casa-test__card-dot {
  opacity: 0.4;
}

/* ══════════════════════════════════════════════════════════════
   CAROUSEL
   ══════════════════════════════════════════════════════════════ */
.casa-test__carousel-wrap {
  position: relative;
}

.casa-test__carousel {
  display: flex;
  gap: var(--ct-gap, 20px);
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scroll-behavior: smooth;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  padding: 8px 0 16px;
}

.casa-test__carousel::-webkit-scrollbar {
  display: none;
}

.casa-test__carousel > .casa-test__card {
  flex: 0 0 calc((100% - var(--ct-gap, 20px) * (var(--ct-cards, 3) - 1)) / var(--ct-cards, 3));
  scroll-snap-align: start;
  min-width: 280px;
}

/* Arrows */
.casa-test__arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 44px;
  height: 44px;
  border-radius: 50%;
  border: 1px solid rgba(255,255,255,0.15);
  background: rgba(255,255,255,0.05);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  color: var(--ct-text, #fff);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
  transition: background 0.25s ease, border-color 0.25s ease, transform 0.25s ease;
}

.casa-test__arrow:hover {
  background: rgba(255,255,255,0.12);
  border-color: rgba(255,255,255,0.3);
  transform: translateY(-50%) scale(1.05);
}

.casa-test__arrow--prev {
  left: -8px;
}

.casa-test__arrow--next {
  right: -8px;
}

/* ══════════════════════════════════════════════════════════════
   MASONRY
   ══════════════════════════════════════════════════════════════ */
.casa-test__masonry {
  columns: 3;
  column-gap: var(--ct-gap, 20px);
}

.casa-test__masonry-item {
  break-inside: avoid;
  margin-bottom: var(--ct-gap, 20px);
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.6s ease, transform 0.6s ease;
}

.casa-test__masonry-item.casa-test--revealed {
  opacity: 1;
  transform: translateY(0);
}

/* ══════════════════════════════════════════════════════════════
   MARQUEE
   ══════════════════════════════════════════════════════════════ */
.casa-test__marquee {
  display: flex;
  flex-direction: column;
  gap: var(--ct-gap, 20px);
  overflow: hidden;
}

.casa-test__marquee-row {
  overflow: hidden;
  position: relative;
}

/* Fade edges */
.casa-test__marquee-row::before,
.casa-test__marquee-row::after {
  content: '';
  position: absolute;
  top: 0;
  bottom: 0;
  width: 80px;
  z-index: 2;
  pointer-events: none;
}

.casa-test__marquee-row::before {
  left: 0;
  background: linear-gradient(90deg, var(--ct-bg, #0a0a0f), transparent);
}

.casa-test__marquee-row::after {
  right: 0;
  background: linear-gradient(270deg, var(--ct-bg, #0a0a0f), transparent);
}

.casa-test__marquee-track {
  display: flex;
  gap: var(--ct-gap, 20px);
  width: max-content;
}

.casa-test__marquee-row--left .casa-test__marquee-track {
  animation: casa-test-scroll-left var(--ct-marquee-dur, 40s) linear infinite;
}

.casa-test__marquee-row--right .casa-test__marquee-track {
  animation: casa-test-scroll-right var(--ct-marquee-dur, 40s) linear infinite;
}

.casa-test__marquee--pausable:hover .casa-test__marquee-track {
  animation-play-state: paused;
}

@keyframes casa-test-scroll-left {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

@keyframes casa-test-scroll-right {
  0% { transform: translateX(-50%); }
  100% { transform: translateX(0); }
}

/* Marquee cards: slightly compact */
.casa-test__marquee .casa-test__card {
  width: 340px;
  flex-shrink: 0;
  padding: 22px;
}

.casa-test__marquee .casa-test__card-quote {
  font-size: 14px;
  -webkit-line-clamp: 4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* Compact variant for marquee */
.casa-test__card--compact {
  padding: 22px;
}

.casa-test__card--compact .casa-test__card-quote {
  font-size: 14px;
  -webkit-line-clamp: 4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ══════════════════════════════════════════════════════════════
   RESPONSIVE
   ══════════════════════════════════════════════════════════════ */
@media (max-width: 1024px) {
  .casa-test__carousel > .casa-test__card {
    flex: 0 0 calc((100% - var(--ct-gap, 20px)) / 2);
  }

  .casa-test__masonry {
    columns: 2;
  }

  .casa-test__arrow--prev { left: 4px; }
  .casa-test__arrow--next { right: 4px; }
}

@media (max-width: 768px) {
  .casa-test {
    padding: clamp(48px, 10vw, 80px) 0;
  }

  .casa-test__inner {
    padding: 0 16px;
  }

  .casa-test__header {
    margin-bottom: 36px;
  }

  .casa-test__stats {
    gap: 20px;
  }

  .casa-test__stat-value {
    font-size: 28px;
  }

  .casa-test__stat-divider {
    height: 36px;
  }

  .casa-test__carousel > .casa-test__card {
    flex: 0 0 calc(100% - 24px);
    min-width: unset;
  }

  .casa-test__masonry {
    columns: 1;
  }

  .casa-test__arrow {
    width: 36px;
    height: 36px;
  }

  .casa-test__arrow--prev { left: 0; }
  .casa-test__arrow--next { right: 0; }

  .casa-test__marquee .casa-test__card {
    width: 280px;
  }

  .casa-test__card {
    padding: 20px;
  }

  .casa-test__card-quote {
    font-size: 14px;
  }

  .casa-test__marquee-row::before,
  .casa-test__marquee-row::after {
    width: 40px;
  }
}

/* ── Reduced motion ── */
@media (prefers-reduced-motion: reduce) {
  .casa-test__marquee-track {
    animation: none !important;
  }

  .casa-test__accent--shimmer {
    animation: none !important;
  }

  .casa-test__masonry-item {
    opacity: 1;
    transform: none;
    transition: none;
  }

  .casa-test__card {
    transition: none;
  }

  .casa-test__carousel {
    scroll-behavior: auto;
  }
}
</style>

{%- comment -%} ═══════════════════════════════════════════════════════════════
   JAVASCRIPT — Carousel + Masonry reveal
   ═══════════════════════════════════════════════════════════════ {%- endcomment -%}
<script>
(function() {
  const section = document.getElementById('casa-test-{{ sid }}');
  if (!section) return;

  const layout = section.dataset.layout;

  /* ── Carousel ── */
  if (layout === 'carousel') {
    const track = section.querySelector('.casa-test__carousel');
    const prevBtn = section.querySelector('.casa-test__arrow--prev');
    const nextBtn = section.querySelector('.casa-test__arrow--next');
    if (!track) return;

    const getScrollAmount = () => {
      const card = track.querySelector('.casa-test__card');
      if (!card) return 300;
      return card.offsetWidth + parseInt(getComputedStyle(track).gap || '20');
    };

    if (prevBtn) {
      prevBtn.addEventListener('click', () => {
        track.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', () => {
        track.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
      });
    }

    /* Auto-play */
    const autoPlay = section.dataset.autoPlay === 'true';
    const speed = parseInt(section.dataset.autoPlaySpeed || '5') * 1000;

    if (autoPlay && speed > 0) {
      let timer = setInterval(() => {
        const maxScroll = track.scrollWidth - track.clientWidth;
        if (track.scrollLeft >= maxScroll - 10) {
          track.scrollTo({ left: 0, behavior: 'smooth' });
        } else {
          track.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
        }
      }, speed);

      track.addEventListener('mouseenter', () => clearInterval(timer));
      track.addEventListener('mouseleave', () => {
        timer = setInterval(() => {
          const maxScroll = track.scrollWidth - track.clientWidth;
          if (track.scrollLeft >= maxScroll - 10) {
            track.scrollTo({ left: 0, behavior: 'smooth' });
          } else {
            track.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
          }
        }, speed);
      });
    }
  }

  /* ── Masonry reveal ── */
  if (layout === 'masonry') {
    const items = section.querySelectorAll('.casa-test__masonry-item');
    if (!items.length) return;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      items.forEach(item => item.classList.add('casa-test--revealed'));
      return;
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry, i) => {
        if (entry.isIntersecting) {
          setTimeout(() => {
            entry.target.classList.add('casa-test--revealed');
          }, i * 80);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

    items.forEach(item => observer.observe(item));
  }
})();
</script>

