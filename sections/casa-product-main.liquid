            { "value": "refresh", "label": "Refresh (Returns)" },
            { "value": "lock", "label": "Lock (Secure)" },
            { "value": "clock", "label": "Clock (Fast)" },
            { "value": "gift", "label": "Gift" },
            { "value": "star", "label": "Star" },
            { "value": "check", "label": "Check" }
          ],
          "default": "truck"
        },
        { "type": "text", "id": "badge_1_text", "label": "Text", "default": "Free Shipping" },
        { "type": "header", "content": "Badge 2" },
        {
          "type": "select", "id": "badge_2_icon", "label": "Icon",
          "options": [
            { "value": "truck", "label": "Truck (Shipping)" },
            { "value": "shield-check", "label": "Shield (Warranty)" },
            { "value": "refresh", "label": "Refresh (Returns)" },
            { "value": "lock", "label": "Lock (Secure)" },
            { "value": "clock", "label": "Clock (Fast)" },
            { "value": "gift", "label": "Gift" },
            { "value": "star", "label": "Star" },
            { "value": "check", "label": "Check" }
          ],
          "default": "shield-check"
        },
        { "type": "text", "id": "badge_2_text", "label": "Text", "default": "2-Year Warranty" },
        { "type": "header", "content": "Badge 3" },
        {
          "type": "select", "id": "badge_3_icon", "label": "Icon",
          "options": [
            { "value": "truck", "label": "Truck (Shipping)" },
            { "value": "shield-check", "label": "Shield (Warranty)" },
            { "value": "refresh", "label": "Refresh (Returns)" },
            { "value": "lock", "label": "Lock (Secure)" },
            { "value": "clock", "label": "Clock (Fast)" },
            { "value": "gift", "label": "Gift" },
