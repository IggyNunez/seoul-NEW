{%- comment -%}
  Seoul Glow Lab — Hero Showcase Section
  4 layouts: editorial-split, lifestyle-banner, category-carousel, product-grid
  Feminine chic aesthetic with product category showcase
{%- endcomment -%}

{%- liquid
  assign layout = section.settings.layout | default: 'editorial-split'
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign accent_word = section.settings.accent_word
  assign description = section.settings.description
  assign bg_color = section.settings.bg_color | default: '#F8EBDA'
  assign text_color = section.settings.text_color | default: '#5E0A02'
  assign accent_color = section.settings.accent_color | default: '#B0C3FA'
  assign accent_color_2 = section.settings.accent_color_2 | default: '#EA7940'
  assign cta_text = section.settings.cta_text | default: 'Shop Now'
  assign cta_link = section.settings.cta_link
  assign cta2_text = section.settings.cta2_text
  assign cta2_link = section.settings.cta2_link
  assign collection = section.settings.collection
  assign bg_image = section.settings.bg_image
  assign bg_video = section.settings.bg_video
  assign overlay_opacity = section.settings.overlay_opacity | default: 40
  assign product_limit = section.settings.product_limit | default: 4
  assign enable_animation = section.settings.enable_animation | default: true
  assign pad_top = section.settings.padding_top | default: 80
  assign pad_bot = section.settings.padding_bottom | default: 80

  assign display_heading = heading
  if accent_word != blank and heading contains accent_word
    assign parts = heading | split: accent_word
    assign display_heading = parts[0] | append: '<span class="sgl-hero__accent">' | append: accent_word | append: '</span>' | append: parts[1]
  endif
-%}

<section
  class="sgl-hero sgl-hero--{{ layout }}{% if enable_animation %} sgl-hero--animated{% endif %}"
  style="
    --sgl-hero-bg: {{ bg_color }};
    --sgl-hero-text: {{ text_color }};
    --sgl-hero-accent: {{ accent_color }};
    --sgl-hero-accent-2: {{ accent_color_2 }};
    --sgl-hero-pad-top: {{ pad_top }}px;
    --sgl-hero-pad-bot: {{ pad_bot }}px;
    --sgl-hero-overlay: {{ overlay_opacity | divided_by: 100.0 }};
  "
  {{ section.shopify_attributes }}
>

  {%- comment -%} ── Background Media ── {%- endcomment -%}
  {%- if bg_image != blank or bg_video != blank -%}
    <div class="sgl-hero__media">
      {%- if bg_video != blank -%}
        <video autoplay muted loop playsinline class="sgl-hero__video">
          <source src="{{ bg_video }}" type="video/mp4">
        </video>
      {%- elsif bg_image != blank -%}
        {{ bg_image | image_url: width: 1920 | image_tag: class: 'sgl-hero__bg-img', loading: 'eager' }}
      {%- endif -%}
      <div class="sgl-hero__overlay"></div>
    </div>
  {%- endif -%}

  <div class="sgl-hero__container">

    {%- case layout -%}

    {%- comment -%} ════════════════════════════════════════
       LAYOUT 1: Editorial Split
       Left: text + CTA + category pills
       Right: product grid (2x2)
    ════════════════════════════════════════ {%- endcomment -%}
    {%- when 'editorial-split' -%}

      <div class="sgl-hero__split">
        <div class="sgl-hero__text-col">
          {%- if subheading != blank -%}
            <div class="sgl-hero__tag">{{ subheading }}</div>
          {%- endif -%}
          {%- if heading != blank -%}
            <h1 class="sgl-hero__title">{{ display_heading }}</h1>
          {%- endif -%}
          {%- if description != blank -%}
            <p class="sgl-hero__desc">{{ description }}</p>
          {%- endif -%}

          {%- if cta_text != blank -%}
            <div class="sgl-hero__ctas">
              <a href="{{ cta_link | default: '#' }}" class="sgl-hero__btn sgl-hero__btn--primary">{{ cta_text }}</a>
              {%- if cta2_text != blank -%}
                <a href="{{ cta2_link | default: '#' }}" class="sgl-hero__btn sgl-hero__btn--secondary">{{ cta2_text }}</a>
              {%- endif -%}
            </div>
          {%- endif -%}

          {%- comment -%} Category pills from blocks {%- endcomment -%}
          {%- assign has_categories = false -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'category' -%}{%- assign has_categories = true -%}{%- break -%}{%- endif -%}
          {%- endfor -%}
          {%- if has_categories -%}
            <div class="sgl-hero__pills">
              {%- for block in section.blocks -%}
                {%- if block.type == 'category' and block.settings.collection != blank -%}
                  <a href="{{ block.settings.collection.url }}" class="sgl-hero__pill" {{ block.shopify_attributes }}>
                    {%- if block.settings.collection.image != blank -%}
                      {{ block.settings.collection.image | image_url: width: 64, height: 64, crop: 'center' | image_tag: class: 'sgl-hero__pill-img' }}
                    {%- endif -%}
                    <span>{{ block.settings.label | default: block.settings.collection.title }}</span>
                  </a>
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>

        <div class="sgl-hero__product-col">
          {%- if collection != blank -%}
            <div class="sgl-hero__product-grid">
              {%- for product in collections[collection].products limit: product_limit -%}
                <a href="{{ product.url }}" class="sgl-hero__card" style="--i: {{ forloop.index }}">
                  <div class="sgl-hero__card-img">
                    {%- if product.featured_image != blank -%}
                      {{ product.featured_image | image_url: width: 400, height: 400, crop: 'center' | image_tag: loading: 'eager', class: 'sgl-hero__card-photo' }}
                    {%- endif -%}
                    {%- if product.compare_at_price > product.price -%}
                      <span class="sgl-hero__card-badge">Sale</span>
                    {%- elsif product.tags contains 'new' -%}
                      <span class="sgl-hero__card-badge sgl-hero__card-badge--new">New</span>
                    {%- endif -%}
                  </div>
                  <div class="sgl-hero__card-info">
                    <div class="sgl-hero__card-name">{{ product.title }}</div>
                    <div class="sgl-hero__card-price">{{ product.price | money }}</div>
                  </div>
                </a>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      </div>

    {%- comment -%} ════════════════════════════════════════
       LAYOUT 2: Lifestyle Banner
       Full-width bg + text overlay + floating product cards
    ════════════════════════════════════════ {%- endcomment -%}
    {%- when 'lifestyle-banner' -%}

      <div class="sgl-hero__banner">
        <div class="sgl-hero__banner-text">
          {%- if subheading != blank -%}
            <div class="sgl-hero__tag sgl-hero__tag--light">{{ subheading }}</div>
          {%- endif -%}
          {%- if heading != blank -%}
            <h1 class="sgl-hero__title sgl-hero__title--light">{{ display_heading }}</h1>
          {%- endif -%}
          {%- if description != blank -%}
            <p class="sgl-hero__desc sgl-hero__desc--light">{{ description }}</p>
          {%- endif -%}
          {%- if cta_text != blank -%}
            <div class="sgl-hero__ctas">
              <a href="{{ cta_link | default: '#' }}" class="sgl-hero__btn sgl-hero__btn--white">{{ cta_text }}</a>
              {%- if cta2_text != blank -%}
                <a href="{{ cta2_link | default: '#' }}" class="sgl-hero__btn sgl-hero__btn--glass">{{ cta2_text }}</a>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>

        {%- if collection != blank -%}
          <div class="sgl-hero__floating-cards">
            {%- for product in collections[collection].products limit: product_limit -%}
              <a href="{{ product.url }}" class="sgl-hero__float-card" style="--i: {{ forloop.index }}">
                <div class="sgl-hero__float-card-img">
                  {%- if product.featured_image != blank -%}
                    {{ product.featured_image | image_url: width: 300, height: 380, crop: 'center' | image_tag: loading: 'eager', class: 'sgl-hero__card-photo' }}
                  {%- endif -%}
                </div>
                <div class="sgl-hero__float-card-info">
                  <span class="sgl-hero__float-card-name">{{ product.title | truncate: 28 }}</span>
                  <span class="sgl-hero__float-card-price">{{ product.price | money }}</span>
                </div>
              </a>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

    {%- comment -%} ════════════════════════════════════════
       LAYOUT 3: Category Carousel
       Headline + horizontal scroll of collection cards
    ════════════════════════════════════════ {%- endcomment -%}
    {%- when 'category-carousel' -%}

      <div class="sgl-hero__carousel-wrap">
        <div class="sgl-hero__carousel-header">
          {%- if subheading != blank -%}
            <div class="sgl-hero__tag">{{ subheading }}</div>
          {%- endif -%}
          {%- if heading != blank -%}
            <h1 class="sgl-hero__title sgl-hero__title--center">{{ display_heading }}</h1>
          {%- endif -%}
          {%- if description != blank -%}
            <p class="sgl-hero__desc sgl-hero__desc--center">{{ description }}</p>
          {%- endif -%}
        </div>

        <div class="sgl-hero__carousel">
          {%- for block in section.blocks -%}
            {%- if block.type == 'category' and block.settings.collection != blank -%}
              {%- assign cat = block.settings.collection -%}
              <a href="{{ cat.url }}" class="sgl-hero__cat-card" style="--i: {{ forloop.index }}" {{ block.shopify_attributes }}>
                <div class="sgl-hero__cat-card-img">
                  {%- if cat.image != blank -%}
                    {{ cat.image | image_url: width: 400, height: 500, crop: 'center' | image_tag: loading: 'eager', class: 'sgl-hero__cat-card-photo' }}
                  {%- elsif cat.products.first.featured_image != blank -%}
                    {{ cat.products.first.featured_image | image_url: width: 400, height: 500, crop: 'center' | image_tag: loading: 'eager', class: 'sgl-hero__cat-card-photo' }}
                  {%- else -%}
                    <div class="sgl-hero__cat-card-placeholder"></div>
                  {%- endif -%}
                </div>
                <div class="sgl-hero__cat-card-info">
                  <div class="sgl-hero__cat-card-name">{{ block.settings.label | default: cat.title }}</div>
                  <div class="sgl-hero__cat-card-count">{{ cat.products_count }} products</div>
                </div>
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if cta_text != blank -%}
          <div class="sgl-hero__ctas" style="justify-content: center; margin-top: 32px;">
            <a href="{{ cta_link | default: '#' }}" class="sgl-hero__btn sgl-hero__btn--primary">{{ cta_text }}</a>
          </div>
        {%- endif -%}
      </div>

    {%- comment -%} ════════════════════════════════════════
       LAYOUT 4: Product Showcase Grid
       1 large + 3 small products, magazine style
    ════════════════════════════════════════ {%- endcomment -%}
    {%- when 'product-grid' -%}

      <div class="sgl-hero__showcase">
        <div class="sgl-hero__showcase-header">
          {%- if subheading != blank -%}
            <div class="sgl-hero__tag">{{ subheading }}</div>
          {%- endif -%}
          {%- if heading != blank -%}
            <h1 class="sgl-hero__title">{{ display_heading }}</h1>
          {%- endif -%}
          {%- if description != blank -%}
            <p class="sgl-hero__desc">{{ description }}</p>
          {%- endif -%}
          {%- if cta_text != blank -%}
            <div class="sgl-hero__ctas">
              <a href="{{ cta_link | default: '#' }}" class="sgl-hero__btn sgl-hero__btn--primary">{{ cta_text }}</a>
              {%- if cta2_text != blank -%}
                <a href="{{ cta2_link | default: '#' }}" class="sgl-hero__btn sgl-hero__btn--secondary">{{ cta2_text }}</a>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>

        {%- if collection != blank -%}
          <div class="sgl-hero__magazine-grid">
            {%- for product in collections[collection].products limit: 4 -%}
              <a href="{{ product.url }}" class="sgl-hero__mag-card{% if forloop.first %} sgl-hero__mag-card--featured{% endif %}" style="--i: {{ forloop.index }}">
                <div class="sgl-hero__mag-card-img">
                  {%- if product.featured_image != blank -%}
                    {{ product.featured_image | image_url: width: 600, height: 700, crop: 'center' | image_tag: loading: 'eager', class: 'sgl-hero__card-photo' }}
                  {%- endif -%}
                  <div class="sgl-hero__mag-card-overlay">
                    <div class="sgl-hero__mag-card-name">{{ product.title }}</div>
                    <div class="sgl-hero__mag-card-price">{{ product.price | money }}</div>
                    <span class="sgl-hero__mag-card-btn">Shop Now</span>
                  </div>
                </div>
              </a>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

    {%- endcase -%}

  </div>
</section>

<style>
  /* ═══════════════════════════════════════════════════════
     SGL HERO SHOWCASE — Chic Feminine Skincare Hero
     ═══════════════════════════════════════════════════════ */

  .sgl-hero {
    position: relative;
    background: var(--sgl-hero-bg, #fdf8f5);
    color: var(--sgl-hero-text, #2d2028);
    overflow: hidden;
  }

  .sgl-hero__container {
    position: relative;
    z-index: 2;
    max-width: 1400px;
    margin: 0 auto;
    padding: var(--sgl-hero-pad-top) clamp(20px, 4vw, 60px) var(--sgl-hero-pad-bot);
  }

  /* ── Background Media ── */
  .sgl-hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .sgl-hero__bg-img,
  .sgl-hero__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .sgl-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, var(--sgl-hero-overlay, 0.4));
  }

  /* ── Typography ── */
  .sgl-hero__tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--sgl-hero-accent);
    margin-bottom: 16px;
  }

  .sgl-hero__tag--light { color: rgba(255,255,255,0.7); }

  .sgl-hero__title {
    font-size: clamp(2rem, 5vw, 3.8rem);
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 20px;
    max-width: 600px;
  }

  .sgl-hero__title--light { color: #fff; }
  .sgl-hero__title--center { text-align: center; max-width: 700px; margin-left: auto; margin-right: auto; }

  .sgl-hero__accent {
    background: linear-gradient(135deg, var(--sgl-hero-accent), var(--sgl-hero-accent-2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-weight: 400;
  }

  .sgl-hero__desc {
    font-size: clamp(0.95rem, 1.2vw, 1.1rem);
    line-height: 1.65;
    color: var(--sgl-hero-text);
    opacity: 0.7;
    max-width: 480px;
    margin: 0 0 28px;
  }

  .sgl-hero__desc--light { color: rgba(255,255,255,0.75); }
  .sgl-hero__desc--center { text-align: center; margin-left: auto; margin-right: auto; }

  /* ── CTA Buttons ── */
  .sgl-hero__ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .sgl-hero__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 50px;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .sgl-hero__btn--primary {
    background: var(--sgl-hero-text, #2d2028);
    color: var(--sgl-hero-bg, #fdf8f5);
    border: none;
  }
  .sgl-hero__btn--primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.15);
    opacity: 0.9;
  }

  .sgl-hero__btn--secondary {
    background: transparent;
    color: var(--sgl-hero-text);
    border: 1.5px solid rgba(0,0,0,0.18);
  }
  .sgl-hero__btn--secondary:hover {
    border-color: var(--sgl-hero-text);
    background: rgba(0,0,0,0.04);
  }

  .sgl-hero__btn--white {
    background: #fff;
    color: #2d2028;
    border: none;
  }
  .sgl-hero__btn--white:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(255,255,255,0.3);
  }

  .sgl-hero__btn--glass {
    background: rgba(255,255,255,0.15);
    color: #fff;
    border: 1px solid rgba(255,255,255,0.25);
    backdrop-filter: blur(10px);
  }
  .sgl-hero__btn--glass:hover {
    background: rgba(255,255,255,0.25);
  }

  /* ── Category Pills ── */
  .sgl-hero__pills {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 32px;
  }

  .sgl-hero__pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px 8px 8px;
    background: rgba(0,0,0,0.03);
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 50px;
    text-decoration: none;
    color: var(--sgl-hero-text);
    font-size: 0.8rem;
    font-weight: 500;
    transition: all 0.25s ease;
  }
  .sgl-hero__pill:hover {
    background: rgba(176, 195, 250, 0.08);
    border-color: rgba(176, 195, 250, 0.2);
    transform: translateY(-1px);
  }

  .sgl-hero__pill-img {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    object-fit: cover;
  }

  /* ════════════════════════════════════════
     LAYOUT 1: Editorial Split
     ════════════════════════════════════════ */
  .sgl-hero__split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(32px, 5vw, 80px);
    align-items: center;
    min-height: 520px;
  }

  .sgl-hero__product-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .sgl-hero__card {
    text-decoration: none;
    color: var(--sgl-hero-text);
    border-radius: 16px;
    overflow: hidden;
    background: #fff;
    box-shadow: 0 4px 20px rgba(0,0,0,0.04);
    transition: all 0.3s ease;
  }
  .sgl-hero__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.08);
  }

  .sgl-hero__card-img {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    background: #f8f4f0;
  }

  .sgl-hero__card-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .sgl-hero__card:hover .sgl-hero__card-photo {
    transform: scale(1.06);
  }

  .sgl-hero__card-badge {
    position: absolute;
    top: 10px;
    left: 10px;
    padding: 4px 10px;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 50px;
    background: linear-gradient(135deg, var(--sgl-hero-accent), var(--sgl-hero-accent-2));
    color: #fff;
  }
  .sgl-hero__card-badge--new {
    background: linear-gradient(135deg, #1B4900, #F2FFA0);
  }

  .sgl-hero__card-info {
    padding: 12px 14px 14px;
  }

  .sgl-hero__card-name {
    font-size: 0.82rem;
    font-weight: 500;
    line-height: 1.3;
    margin-bottom: 4px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .sgl-hero__card-price {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--sgl-hero-accent);
  }

  /* ════════════════════════════════════════
     LAYOUT 2: Lifestyle Banner
     ════════════════════════════════════════ */
  .sgl-hero--lifestyle-banner { min-height: 85vh; }
  .sgl-hero--lifestyle-banner .sgl-hero__container {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 85vh;
  }

  .sgl-hero__banner {
    position: relative;
  }

  .sgl-hero__banner-text {
    max-width: 580px;
    margin-bottom: 48px;
  }

  .sgl-hero__floating-cards {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 8px;
    scrollbar-width: none;
  }
  .sgl-hero__floating-cards::-webkit-scrollbar { display: none; }

  .sgl-hero__float-card {
    flex: 0 0 200px;
    scroll-snap-align: start;
    text-decoration: none;
    color: #fff;
    border-radius: 16px;
    overflow: hidden;
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255,255,255,0.15);
    transition: all 0.3s ease;
  }
  .sgl-hero__float-card:hover {
    transform: translateY(-6px);
    background: rgba(255,255,255,0.18);
  }

  .sgl-hero__float-card-img {
    aspect-ratio: 3/4;
    overflow: hidden;
  }
  .sgl-hero__float-card-img .sgl-hero__card-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .sgl-hero__float-card:hover .sgl-hero__card-photo {
    transform: scale(1.06);
  }

  .sgl-hero__float-card-info {
    padding: 12px 14px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .sgl-hero__float-card-name {
    font-size: 0.78rem;
    font-weight: 500;
    opacity: 0.9;
  }

  .sgl-hero__float-card-price {
    font-size: 0.75rem;
    font-weight: 600;
    opacity: 0.7;
  }

  /* ════════════════════════════════════════
     LAYOUT 3: Category Carousel
     ════════════════════════════════════════ */
  .sgl-hero__carousel-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .sgl-hero__carousel {
    display: flex;
    gap: 20px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding: 8px 0 16px;
    scrollbar-width: none;
  }
  .sgl-hero__carousel::-webkit-scrollbar { display: none; }

  .sgl-hero__cat-card {
    flex: 0 0 240px;
    scroll-snap-align: start;
    text-decoration: none;
    color: var(--sgl-hero-text);
    border-radius: 20px;
    overflow: hidden;
    background: #fff;
    box-shadow: 0 4px 20px rgba(0,0,0,0.04);
    transition: all 0.3s ease;
  }
  .sgl-hero__cat-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.08);
  }

  .sgl-hero__cat-card-img {
    aspect-ratio: 4/5;
    overflow: hidden;
    background: #f8f4f0;
  }

  .sgl-hero__cat-card-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .sgl-hero__cat-card:hover .sgl-hero__cat-card-photo {
    transform: scale(1.06);
  }

  .sgl-hero__cat-card-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #B0C3FA, #FFBF9F);
  }

  .sgl-hero__cat-card-info {
    padding: 16px 18px 20px;
  }

  .sgl-hero__cat-card-name {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 4px;
  }

  .sgl-hero__cat-card-count {
    font-size: 0.78rem;
    color: var(--sgl-hero-text);
    opacity: 0.5;
  }

  /* ════════════════════════════════════════
     LAYOUT 4: Product Showcase Grid (Magazine)
     ════════════════════════════════════════ */
  .sgl-hero__showcase {
    display: grid;
    grid-template-columns: 380px 1fr;
    gap: clamp(32px, 4vw, 60px);
    align-items: start;
  }

  .sgl-hero__showcase-header {
    position: sticky;
    top: 120px;
  }

  .sgl-hero__magazine-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 16px;
  }

  .sgl-hero__mag-card {
    text-decoration: none;
    color: #fff;
    border-radius: 20px;
    overflow: hidden;
    transition: all 0.3s ease;
  }
  .sgl-hero__mag-card:hover {
    transform: translateY(-4px);
  }

  .sgl-hero__mag-card--featured {
    grid-column: 1 / -1;
  }

  .sgl-hero__mag-card-img {
    position: relative;
    aspect-ratio: 3/4;
    overflow: hidden;
    background: #f8f4f0;
    border-radius: 20px;
  }
  .sgl-hero__mag-card--featured .sgl-hero__mag-card-img {
    aspect-ratio: 2/1;
  }

  .sgl-hero__mag-card-img .sgl-hero__card-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  .sgl-hero__mag-card:hover .sgl-hero__card-photo {
    transform: scale(1.04);
  }

  .sgl-hero__mag-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.65) 0%, transparent 60%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 24px;
  }

  .sgl-hero__mag-card-name {
    font-size: 1.1rem;
    font-weight: 500;
    margin-bottom: 4px;
  }
  .sgl-hero__mag-card--featured .sgl-hero__mag-card-name {
    font-size: 1.4rem;
  }

  .sgl-hero__mag-card-price {
    font-size: 0.85rem;
    opacity: 0.8;
    margin-bottom: 12px;
  }

  .sgl-hero__mag-card-btn {
    display: inline-block;
    padding: 8px 20px;
    background: rgba(255,255,255,0.15);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 50px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #fff;
    transition: all 0.25s ease;
    width: fit-content;
  }
  .sgl-hero__mag-card:hover .sgl-hero__mag-card-btn {
    background: rgba(255,255,255,0.3);
  }

  /* ════════════════════════════════════════
     ANIMATIONS
     ════════════════════════════════════════ */
  .sgl-hero--animated .sgl-hero__card,
  .sgl-hero--animated .sgl-hero__float-card,
  .sgl-hero--animated .sgl-hero__cat-card,
  .sgl-hero--animated .sgl-hero__mag-card {
    opacity: 0;
    transform: translateY(20px);
    animation: sgl-hero-reveal 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--i, 1) * 100ms + 200ms);
  }

  .sgl-hero--animated .sgl-hero__title {
    opacity: 0;
    transform: translateY(16px);
    animation: sgl-hero-reveal 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: 0ms;
  }

  .sgl-hero--animated .sgl-hero__tag {
    opacity: 0;
    animation: sgl-hero-reveal 0.5s ease forwards;
    animation-delay: 0ms;
  }

  .sgl-hero--animated .sgl-hero__desc {
    opacity: 0;
    transform: translateY(10px);
    animation: sgl-hero-reveal 0.6s ease forwards;
    animation-delay: 150ms;
  }

  .sgl-hero--animated .sgl-hero__ctas {
    opacity: 0;
    transform: translateY(10px);
    animation: sgl-hero-reveal 0.6s ease forwards;
    animation-delay: 300ms;
  }

  .sgl-hero--animated .sgl-hero__pills {
    opacity: 0;
    transform: translateY(10px);
    animation: sgl-hero-reveal 0.6s ease forwards;
    animation-delay: 400ms;
  }

  @keyframes sgl-hero-reveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ════════════════════════════════════════
     MOBILE
     ════════════════════════════════════════ */
  @media (max-width: 749px) {

    .sgl-hero__container {
      padding: 40px 20px 48px;
    }

    /* ── Typography mobile ── */
    .sgl-hero__tag {
      font-size: 0.62rem;
      letter-spacing: 0.15em;
      margin-bottom: 10px;
    }

    .sgl-hero__title {
      font-size: 1.75rem;
      line-height: 1.15;
      margin-bottom: 12px;
      max-width: 100%;
    }

    .sgl-hero__title--center { text-align: left; margin-left: 0; }

    .sgl-hero__desc {
      font-size: 0.85rem;
      line-height: 1.55;
      max-width: 100%;
      margin-bottom: 20px;
    }

    .sgl-hero__desc--center { text-align: left; }

    /* ── Buttons mobile: side by side, compact ── */
    .sgl-hero__ctas {
      gap: 8px;
    }

    .sgl-hero__btn {
      padding: 12px 20px;
      font-size: 0.72rem;
      border-radius: 50px;
    }

    /* ── Category pills: horizontal scroll ── */
    .sgl-hero__pills {
      flex-wrap: nowrap;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      margin: 20px -20px 0;
      padding: 0 20px 4px;
      gap: 8px;
    }
    .sgl-hero__pills::-webkit-scrollbar { display: none; }

    .sgl-hero__pill {
      flex: 0 0 auto;
      scroll-snap-align: start;
      white-space: nowrap;
      font-size: 0.72rem;
      padding: 5px 12px 5px 5px;
    }

    .sgl-hero__pill-img {
      width: 22px;
      height: 22px;
    }

    /* ════════════════════════════════════
       LAYOUT 1: Editorial Split — Mobile
       Stack text above, 2-col product grid
       ════════════════════════════════════ */
    .sgl-hero__split {
      grid-template-columns: 1fr;
      gap: 24px;
      min-height: auto;
    }

    .sgl-hero__product-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }

    .sgl-hero__card {
      border-radius: 12px;
    }

    .sgl-hero__card-img {
      aspect-ratio: 1;
    }

    .sgl-hero__card-info {
      padding: 8px 10px 10px;
    }

    .sgl-hero__card-name {
      font-size: 0.72rem;
      -webkit-line-clamp: 2;
    }

    .sgl-hero__card-price {
      font-size: 0.7rem;
    }

    .sgl-hero__card-badge {
      font-size: 0.55rem;
      padding: 2px 6px;
      top: 6px;
      left: 6px;
    }

    /* ════════════════════════════════════
       LAYOUT 2: Lifestyle Banner — Mobile
       ════════════════════════════════════ */
    .sgl-hero--lifestyle-banner {
      min-height: auto;
    }
    .sgl-hero--lifestyle-banner .sgl-hero__container {
      min-height: auto;
      padding-top: 80px;
      padding-bottom: 40px;
    }

    .sgl-hero__banner-text {
      margin-bottom: 24px;
    }

    .sgl-hero__floating-cards {
      margin: 0 -20px;
      padding: 0 20px 8px;
      gap: 10px;
    }

    .sgl-hero__float-card {
      flex: 0 0 140px;
    }

    .sgl-hero__float-card-img {
      aspect-ratio: 3/4;
    }

    .sgl-hero__float-card-info {
      padding: 8px 10px;
    }

    .sgl-hero__float-card-name {
      font-size: 0.7rem;
    }

    .sgl-hero__float-card-price {
      font-size: 0.65rem;
    }

    /* ════════════════════════════════════
       LAYOUT 3: Category Carousel — Mobile
       ════════════════════════════════════ */
    .sgl-hero__carousel-header {
      text-align: left;
      margin-bottom: 20px;
    }

    .sgl-hero__carousel {
      margin: 0 -20px;
      padding: 4px 20px 12px;
      gap: 12px;
    }

    .sgl-hero__cat-card {
      flex: 0 0 44vw;
      max-width: 200px;
      border-radius: 14px;
    }

    .sgl-hero__cat-card-img {
      aspect-ratio: 1;
    }

    .sgl-hero__cat-card-info {
      padding: 10px 12px 14px;
    }

    .sgl-hero__cat-card-name {
      font-size: 0.85rem;
    }

    .sgl-hero__cat-card-count {
      font-size: 0.7rem;
    }

    /* ════════════════════════════════════
       LAYOUT 4: Product Grid — Mobile
       ════════════════════════════════════ */
    .sgl-hero__showcase {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .sgl-hero__showcase-header {
      position: static;
    }

    .sgl-hero__magazine-grid {
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }

    .sgl-hero__mag-card--featured {
      grid-column: 1 / -1;
    }

    .sgl-hero__mag-card--featured .sgl-hero__mag-card-img {
      aspect-ratio: 16/10;
    }

    .sgl-hero__mag-card-img {
      aspect-ratio: 3/4;
      border-radius: 12px;
    }

    .sgl-hero__mag-card-overlay {
      padding: 14px;
    }

    .sgl-hero__mag-card-name {
      font-size: 0.8rem;
    }
    .sgl-hero__mag-card--featured .sgl-hero__mag-card-name {
      font-size: 1rem;
    }

    .sgl-hero__mag-card-price {
      font-size: 0.75rem;
    }

    .sgl-hero__mag-card-btn {
      padding: 6px 12px;
      font-size: 0.6rem;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .sgl-hero--animated * {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>

