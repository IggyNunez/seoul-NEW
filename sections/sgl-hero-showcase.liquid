    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "Enable animations",
      "default": true
    }
  ],
  "blocks": [
