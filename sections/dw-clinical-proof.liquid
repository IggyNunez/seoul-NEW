{% comment %}
  DoingWell Clinical Proof Section v2
  - Animated circular stat rings that fill on scroll
  - Count-up animation for percentages
  - Glowing certification badge with pulse effect
  - Floating athlete endorsement card
  - Cyber gradient background with orbs
  - Staggered entrance animations
{% endcomment %}

<section 
  class="dw-clinical"
  data-clinical-section
  style="
    --clinical-bg: {{ section.settings.background_color }};
    --clinical-bg-2: {{ section.settings.background_color_2 }};
    --clinical-text: {{ section.settings.text_color }};
    --clinical-accent: {{ section.settings.accent_color }};
    --clinical-glow-1: {{ section.settings.glow_color_1 }};
    --clinical-glow-2: {{ section.settings.glow_color_2 }};
    --clinical-stat-ring: {{ section.settings.stat_ring_color }};
    --clinical-stat-bg: {{ section.settings.stat_ring_bg }};
    --clinical-badge-bg: {{ section.settings.badge_bg_color }};
    --clinical-badge-text: {{ section.settings.badge_text_color }};
    --clinical-btn-bg: {{ section.settings.button_bg_color }};
    --clinical-btn-text: {{ section.settings.button_text_color }};
    --clinical-btn-radius: {{ section.settings.button_radius }}px;
    --clinical-btn-gradient-1: {{ section.settings.button_gradient_1 }};
    --clinical-btn-gradient-2: {{ section.settings.button_gradient_2 }};
    --clinical-padding-desktop: {{ section.settings.padding_desktop }}px;
    --clinical-padding-mobile: {{ section.settings.padding_mobile }}px;
  "
>
  <!-- Background Effects -->
  <div class="dw-clinical__bg">
    {%- if section.settings.enable_gradient_bg -%}
      <div class="dw-clinical__bg-gradient"></div>
    {%- endif -%}
    {%- if section.settings.enable_orbs -%}
      <div class="dw-clinical__bg-orbs">
        <div class="dw-clinical__orb dw-clinical__orb--1"></div>
        <div class="dw-clinical__orb dw-clinical__orb--2"></div>
        <div class="dw-clinical__orb dw-clinical__orb--3"></div>
      </div>
    {%- endif -%}
    {%- if section.settings.enable_grid -%}
      <div class="dw-clinical__bg-grid"></div>
    {%- endif -%}
  </div>

  <div class="dw-clinical__container">
    <!-- Content Side -->
    <div class="dw-clinical__content">
      {%- if section.settings.eyebrow != blank -%}
        <div class="dw-clinical__eyebrow">
          <span class="dw-clinical__eyebrow-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
          </span>
          <span class="dw-clinical__eyebrow-text">{{ section.settings.eyebrow }}</span>
        </div>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="dw-clinical__heading{% if section.settings.heading_gradient %} dw-clinical__heading--gradient{% endif %}">
          {{ section.settings.heading | newline_to_br }}
        </h2>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <p class="dw-clinical__description">{{ section.settings.description }}</p>
      {%- endif -%}

      <!-- Certification Badge -->
      {%- if section.settings.show_badge -%}
        <div class="dw-clinical__badge">
          <div class="dw-clinical__badge-glow"></div>
          <div class="dw-clinical__badge-border"></div>
          <div class="dw-clinical__badge-inner">
            <div class="dw-clinical__badge-icon">
              {%- if section.settings.badge_icon != blank -%}
                <img 
                  src="{{ section.settings.badge_icon | image_url: width: 120 }}"
                  alt="{{ section.settings.badge_title }}"
                  width="48"
                  height="48"
                >
              {%- else -%}
                <svg viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/>
                </svg>
              {%- endif -%}
              <span class="dw-clinical__badge-pulse"></span>
            </div>
            <div class="dw-clinical__badge-content">
              <span class="dw-clinical__badge-title">{{ section.settings.badge_title }}</span>
              <span class="dw-clinical__badge-subtitle">{{ section.settings.badge_subtitle }}</span>
            </div>
            {%- if section.settings.athlete_name != blank -%}
              <div class="dw-clinical__badge-divider"></div>
              <div class="dw-clinical__badge-athlete">
                {%- if section.settings.athlete_image != blank -%}
                  <div class="dw-clinical__athlete-img">
                    <img 
                      src="{{ section.settings.athlete_image | image_url: width: 100 }}"
                      alt="{{ section.settings.athlete_name }}"
                      width="44"
                      height="44"
                    >
                  </div>
                {%- endif -%}
                <div class="dw-clinical__athlete-info">
                  <span class="dw-clinical__athlete-label">Trusted by</span>
                  <span class="dw-clinical__athlete-name">{{ section.settings.athlete_name }}</span>
                  {%- if section.settings.athlete_title != blank -%}
                    <span class="dw-clinical__athlete-title">{{ section.settings.athlete_title }}</span>
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}

      <!-- Buttons -->
      <div class="dw-clinical__buttons">
        {%- if section.settings.button_1_text != blank -%}
          <a href="{{ section.settings.button_1_url }}" class="dw-clinical__btn dw-clinical__btn--{{ section.settings.button_1_style }}">
            <span class="dw-clinical__btn-bg"></span>
            <span class="dw-clinical__btn-text">{{ section.settings.button_1_text }}</span>
          </a>
        {%- endif -%}
        {%- if section.settings.button_2_text != blank -%}
          <a href="{{ section.settings.button_2_url }}" class="dw-clinical__btn dw-clinical__btn--{{ section.settings.button_2_style }}">
            <span class="dw-clinical__btn-bg"></span>
            <span class="dw-clinical__btn-text">{{ section.settings.button_2_text }}</span>
          </a>
        {%- endif -%}
      </div>
    </div>

    <!-- Stats Side -->
    <div class="dw-clinical__stats">
      {%- if section.settings.stats_title != blank -%}
        <h3 class="dw-clinical__stats-title">{{ section.settings.stats_title }}</h3>
      {%- endif -%}

      <div class="dw-clinical__stats-grid">
        {%- if section.settings.stat_1_value != blank -%}
          {%- assign stat_1_num = section.settings.stat_1_value | remove: '%' | remove: '+' | remove: 'x' | plus: 0 -%}
          <div class="dw-clinical__stat" data-stat style="--stat-index: 1;">
            <div class="dw-clinical__stat-ring" data-stat-ring data-value="{{ stat_1_num }}">
              <svg viewBox="0 0 120 120">
                <circle class="dw-clinical__ring-bg" cx="60" cy="60" r="54"/>
                <circle class="dw-clinical__ring-fill" cx="60" cy="60" r="54" data-ring-fill/>
              </svg>
              <div class="dw-clinical__stat-value">
                <span class="dw-clinical__stat-num" data-count-to="{{ stat_1_num }}">0</span>
                <span class="dw-clinical__stat-suffix">{{ section.settings.stat_1_value | remove: stat_1_num }}</span>
              </div>
            </div>
            <p class="dw-clinical__stat-text">{{ section.settings.stat_1_text }}</p>
          </div>
        {%- endif -%}

        {%- if section.settings.stat_2_value != blank -%}
          {%- assign stat_2_num = section.settings.stat_2_value | remove: '%' | remove: '+' | remove: 'x' | plus: 0 -%}
          <div class="dw-clinical__stat" data-stat style="--stat-index: 2;">
            <div class="dw-clinical__stat-ring" data-stat-ring data-value="{{ stat_2_num }}">
              <svg viewBox="0 0 120 120">
                <circle class="dw-clinical__ring-bg" cx="60" cy="60" r="54"/>
                <circle class="dw-clinical__ring-fill" cx="60" cy="60" r="54" data-ring-fill/>
              </svg>
              <div class="dw-clinical__stat-value">
                <span class="dw-clinical__stat-num" data-count-to="{{ stat_2_num }}">0</span>
                <span class="dw-clinical__stat-suffix">{{ section.settings.stat_2_value | remove: stat_2_num }}</span>
              </div>
            </div>
            <p class="dw-clinical__stat-text">{{ section.settings.stat_2_text }}</p>
          </div>
        {%- endif -%}

        {%- if section.settings.stat_3_value != blank -%}
          {%- assign stat_3_num = section.settings.stat_3_value | remove: '%' | remove: '+' | remove: 'x' | plus: 0 -%}
          <div class="dw-clinical__stat" data-stat style="--stat-index: 3;">
            <div class="dw-clinical__stat-ring" data-stat-ring data-value="{{ stat_3_num }}">
              <svg viewBox="0 0 120 120">
                <circle class="dw-clinical__ring-bg" cx="60" cy="60" r="54"/>
                <circle class="dw-clinical__ring-fill" cx="60" cy="60" r="54" data-ring-fill/>
              </svg>
              <div class="dw-clinical__stat-value">
                <span class="dw-clinical__stat-num" data-count-to="{{ stat_3_num }}">0</span>
                <span class="dw-clinical__stat-suffix">{{ section.settings.stat_3_value | remove: stat_3_num }}</span>
              </div>
            </div>
            <p class="dw-clinical__stat-text">{{ section.settings.stat_3_text }}</p>
          </div>
        {%- endif -%}

        {%- if section.settings.stat_4_value != blank -%}
          {%- assign stat_4_num = section.settings.stat_4_value | remove: '%' | remove: '+' | remove: 'x' | plus: 0 -%}
          <div class="dw-clinical__stat" data-stat style="--stat-index: 4;">
            <div class="dw-clinical__stat-ring" data-stat-ring data-value="{{ stat_4_num }}">
              <svg viewBox="0 0 120 120">
                <circle class="dw-clinical__ring-bg" cx="60" cy="60" r="54"/>
                <circle class="dw-clinical__ring-fill" cx="60" cy="60" r="54" data-ring-fill/>
              </svg>
              <div class="dw-clinical__stat-value">
                <span class="dw-clinical__stat-num" data-count-to="{{ stat_4_num }}">0</span>
                <span class="dw-clinical__stat-suffix">{{ section.settings.stat_4_value | remove: stat_4_num }}</span>
              </div>
            </div>
            <p class="dw-clinical__stat-text">{{ section.settings.stat_4_text }}</p>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>

  <!-- Disclaimer -->
  {%- if section.settings.disclaimer != blank -%}
    <div class="dw-clinical__disclaimer">
      <p>{{ section.settings.disclaimer }}</p>
    </div>
  {%- endif -%}
</section>

<style>
  /* ==========================================
     BASE
     ========================================== */
  
  .dw-clinical {
    position: relative;
    background: var(--clinical-bg);
    color: var(--clinical-text);
    padding: var(--clinical-padding-mobile) 20px;
    overflow: hidden;
    font-family: 'Poppins', sans-serif;
  }

  @media (min-width: 750px) {
    .dw-clinical {
      padding: var(--clinical-padding-desktop) 50px;
    }
  }

  /* ==========================================
     BACKGROUND EFFECTS
     ========================================== */

  .dw-clinical__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .dw-clinical__bg-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--clinical-bg) 0%, var(--clinical-bg-2) 100%);
  }

  /* Floating Orbs */
  .dw-clinical__bg-orbs {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .dw-clinical__orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.4;
  }

  .dw-clinical__orb--1 {
    width: 500px;
    height: 500px;
    background: var(--clinical-glow-1);
    top: -200px;
    left: -100px;
    animation: clinical-orb-1 20s ease-in-out infinite;
  }

  .dw-clinical__orb--2 {
    width: 400px;
    height: 400px;
    background: var(--clinical-glow-2);
    bottom: -150px;
    right: -50px;
    animation: clinical-orb-2 25s ease-in-out infinite;
  }

  .dw-clinical__orb--3 {
    width: 300px;
    height: 300px;
    background: var(--clinical-accent);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    animation: clinical-orb-3 18s ease-in-out infinite;
  }

  @keyframes clinical-orb-1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(50px, 30px) scale(1.1); }
    66% { transform: translate(-30px, 50px) scale(0.9); }
  }

  @keyframes clinical-orb-2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(-40px, -30px) scale(0.95); }
    66% { transform: translate(30px, -40px) scale(1.05); }
  }

  @keyframes clinical-orb-3 {
    0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.3; }
    50% { transform: translate(-50%, -50%) scale(1.3); opacity: 0.5; }
  }

  /* Grid Pattern */
  .dw-clinical__bg-grid {
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    opacity: 0.5;
  }

  /* ==========================================
     CONTAINER
     ========================================== */

  .dw-clinical__container {
    position: relative;
    z-index: 2;
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 50px;
  }

  @media (min-width: 990px) {
    .dw-clinical__container {
      flex-direction: row;
      align-items: center;
      gap: 80px;
    }
  }

  /* ==========================================
     CONTENT SIDE
     ========================================== */

  .dw-clinical__content {
    flex: 1;
    text-align: center;
  }

  @media (min-width: 990px) {
    .dw-clinical__content {
      text-align: left;
      max-width: 550px;
    }
  }

  /* Eyebrow */
  .dw-clinical__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
    padding: 8px 16px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 30px;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .dw-clinical__eyebrow-icon {
    width: 18px;
    height: 18px;
    color: var(--clinical-accent);
  }

  .dw-clinical__eyebrow-icon svg {
    width: 100%;
    height: 100%;
  }

  .dw-clinical__eyebrow-text {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--clinical-accent);
  }

  /* Heading */
  .dw-clinical__heading {
    font-size: 32px;
    font-weight: 700;
    line-height: 1.15;
    margin: 0 0 20px 0;
    letter-spacing: -0.02em;
  }

  .dw-clinical__heading--gradient {
    background: linear-gradient(135deg, var(--clinical-text) 30%, var(--clinical-accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  @media (min-width: 750px) {
    .dw-clinical__heading {
      font-size: 44px;
    }
  }

  @media (min-width: 990px) {
    .dw-clinical__heading {
      font-size: 52px;
      margin-bottom: 24px;
    }
  }

  /* Description */
  .dw-clinical__description {
    font-size: 15px;
    line-height: 1.7;
    color: var(--clinical-text);
    opacity: 0.8;
    margin: 0 0 28px 0;
    max-width: 500px;
  }

  @media (min-width: 990px) {
    .dw-clinical__description {
      font-size: 16px;
      margin: 0 0 32px 0;
    }
  }

  @media (max-width: 989px) {
    .dw-clinical__description {
      margin-left: auto;
      margin-right: auto;
    }
  }

  /* ==========================================
     CERTIFICATION BADGE
     ========================================== */

  .dw-clinical__badge {
    position: relative;
    display: inline-flex;
    margin-bottom: 32px;
  }

  @media (min-width: 990px) {
    .dw-clinical__badge {
      margin-bottom: 40px;
    }
  }

  .dw-clinical__badge-glow {
    position: absolute;
    inset: -10px;
    background: radial-gradient(ellipse at center, var(--clinical-accent) 0%, transparent 70%);
    opacity: 0.2;
    filter: blur(20px);
    animation: badge-glow-pulse 3s ease-in-out infinite;
  }

  @keyframes badge-glow-pulse {
    0%, 100% { opacity: 0.15; transform: scale(1); }
    50% { opacity: 0.3; transform: scale(1.05); }
  }

  .dw-clinical__badge-border {
    position: absolute;
    inset: 0;
    border-radius: 16px;
    padding: 2px;
    background: linear-gradient(
      135deg,
      var(--clinical-glow-1),
      var(--clinical-glow-2),
      var(--clinical-glow-1)
    );
    background-size: 200% 200%;
    animation: badge-border-shift 4s linear infinite;
    -webkit-mask: 
      linear-gradient(#fff 0 0) content-box, 
      linear-gradient(#fff 0 0);
    mask: 
      linear-gradient(#fff 0 0) content-box, 
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
  }

  @keyframes badge-border-shift {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .dw-clinical__badge-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding: 20px 24px;
    background: var(--clinical-badge-bg);
    border-radius: 14px;
    z-index: 2;
  }

  @media (min-width: 750px) {
    .dw-clinical__badge-inner {
      flex-direction: row;
      gap: 20px;
      padding: 16px 28px;
    }
  }

  .dw-clinical__badge-icon {
    position: relative;
    width: 48px;
    height: 48px;
    flex-shrink: 0;
    color: var(--clinical-accent);
  }

  .dw-clinical__badge-icon img,
  .dw-clinical__badge-icon svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .dw-clinical__badge-pulse {
    position: absolute;
    inset: -6px;
    border: 2px solid var(--clinical-accent);
    border-radius: 50%;
    animation: badge-pulse 2s ease-out infinite;
  }

  @keyframes badge-pulse {
    0% { transform: scale(1); opacity: 0.6; }
    100% { transform: scale(1.5); opacity: 0; }
  }

  .dw-clinical__badge-content {
    display: flex;
    flex-direction: column;
    text-align: center;
  }

  @media (min-width: 750px) {
    .dw-clinical__badge-content {
      text-align: left;
    }
  }

  .dw-clinical__badge-title {
    font-size: 12px;
    font-weight: 800;
    color: var(--clinical-badge-text);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .dw-clinical__badge-subtitle {
    font-size: 12px;
    color: var(--clinical-accent);
    font-weight: 600;
  }

  .dw-clinical__badge-divider {
    width: 1px;
    height: 40px;
    background: rgba(0, 0, 0, 0.1);
    display: none;
  }

  @media (min-width: 750px) {
    .dw-clinical__badge-divider {
      display: block;
    }
  }

  .dw-clinical__badge-athlete {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .dw-clinical__athlete-img {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid var(--clinical-accent);
  }

  .dw-clinical__athlete-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .dw-clinical__athlete-info {
    display: flex;
    flex-direction: column;
    text-align: left;
  }

  .dw-clinical__athlete-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--clinical-badge-text);
    opacity: 0.6;
  }

  .dw-clinical__athlete-name {
    font-size: 13px;
    font-weight: 700;
    color: var(--clinical-badge-text);
  }

  .dw-clinical__athlete-title {
    font-size: 11px;
    color: var(--clinical-accent);
    font-weight: 500;
  }

  /* ==========================================
     BUTTONS
     ========================================== */

  .dw-clinical__buttons {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  @media (min-width: 750px) {
    .dw-clinical__buttons {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 16px;
    }
  }

  @media (max-width: 989px) {
    .dw-clinical__buttons {
      align-items: stretch;
    }
  }

  .dw-clinical__btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 32px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    border-radius: var(--clinical-btn-radius, 6px);
    cursor: pointer;
    border: 2px solid transparent;
    font-family: 'Poppins', sans-serif;
    overflow: hidden;
    transition: all 0.3s ease;
  }

  @media (min-width: 750px) {
    .dw-clinical__btn {
      padding: 18px 40px;
      font-size: 13px;
    }
  }

  .dw-clinical__btn:hover {
    transform: translateY(-2px);
  }

  .dw-clinical__btn-text {
    position: relative;
    z-index: 2;
  }

  /* Primary */
  .dw-clinical__btn--primary {
    background: var(--clinical-btn-bg);
    color: var(--clinical-btn-text);
  }

  .dw-clinical__btn--primary:hover {
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
  }

  /* Secondary */
  .dw-clinical__btn--secondary {
    background: transparent;
    color: var(--clinical-text);
    border-color: var(--clinical-text);
  }

  .dw-clinical__btn--secondary:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  /* Gradient */
  .dw-clinical__btn--gradient {
    background: transparent;
    color: var(--clinical-text);
    border: none;
  }

  .dw-clinical__btn--gradient .dw-clinical__btn-bg {
    position: absolute;
    inset: 0;
    border-radius: var(--clinical-btn-radius, 6px);
    padding: 2px;
    background: linear-gradient(
      90deg,
      var(--clinical-btn-gradient-1),
      var(--clinical-btn-gradient-2),
      var(--clinical-btn-gradient-1)
    );
    background-size: 200% 100%;
    animation: btn-gradient-shift 3s linear infinite;
    -webkit-mask: 
      linear-gradient(#fff 0 0) content-box, 
      linear-gradient(#fff 0 0);
    mask: 
      linear-gradient(#fff 0 0) content-box, 
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
  }

  .dw-clinical__btn--gradient::after {
    content: '';
    position: absolute;
    inset: 2px;
    background: var(--clinical-bg);
    border-radius: calc(var(--clinical-btn-radius, 6px) - 2px);
    z-index: 1;
  }

  @keyframes btn-gradient-shift {
    0% { background-position: 0% 50%; }
    100% { background-position: 200% 50%; }
  }

  /* Glow */
  .dw-clinical__btn--glow {
    background: var(--clinical-accent);
    color: var(--clinical-btn-text);
    border: none;
    box-shadow: 0 0 30px var(--clinical-accent);
    animation: btn-glow-pulse 2s ease-in-out infinite;
  }

  @keyframes btn-glow-pulse {
    0%, 100% { box-shadow: 0 0 20px var(--clinical-accent); }
    50% { box-shadow: 0 0 40px var(--clinical-accent), 0 0 60px var(--clinical-accent); }
  }

  .dw-clinical__btn--glow:hover {
    animation: none;
    box-shadow: 0 0 50px var(--clinical-accent);
  }

  /* ==========================================
     STATS SIDE
     ========================================== */

  .dw-clinical__stats {
    flex: 1;
  }

  @media (min-width: 990px) {
    .dw-clinical__stats {
      max-width: 550px;
    }
  }

  .dw-clinical__stats-title {
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--clinical-text);
    opacity: 0.6;
    text-align: center;
    margin: 0 0 24px 0;
  }

  @media (min-width: 990px) {
    .dw-clinical__stats-title {
      text-align: left;
      margin-bottom: 32px;
    }
  }

  .dw-clinical__stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  @media (min-width: 750px) {
    .dw-clinical__stats-grid {
      gap: 32px;
    }
  }

  /* ==========================================
     STAT ITEM
     ========================================== */

  .dw-clinical__stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    opacity: 0;
    transform: translateY(20px);
    animation: stat-enter 0.6s ease forwards;
    animation-delay: calc(var(--stat-index, 1) * 0.15s);
    animation-play-state: paused;
  }

  .dw-clinical__stat.is-visible {
    animation-play-state: running;
  }

  @keyframes stat-enter {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Circular Ring */
  .dw-clinical__stat-ring {
    position: relative;
    width: 100px;
    height: 100px;
    margin-bottom: 16px;
  }

  @media (min-width: 750px) {
    .dw-clinical__stat-ring {
      width: 120px;
      height: 120px;
    }
  }

  .dw-clinical__stat-ring svg {
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
  }

  .dw-clinical__ring-bg {
    fill: none;
    stroke: var(--clinical-stat-bg, rgba(255, 255, 255, 0.1));
    stroke-width: 8;
  }

  .dw-clinical__ring-fill {
    fill: none;
    stroke: var(--clinical-stat-ring, var(--clinical-accent));
    stroke-width: 8;
    stroke-linecap: round;
    stroke-dasharray: 339.292;
    stroke-dashoffset: 339.292;
    transition: stroke-dashoffset 1.5s ease-out;
    filter: drop-shadow(0 0 8px var(--clinical-stat-ring, var(--clinical-accent)));
  }

  .dw-clinical__stat.is-visible .dw-clinical__ring-fill {
    stroke-dashoffset: var(--ring-offset, 339.292);
  }

  /* Stat Value */
  .dw-clinical__stat-value {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .dw-clinical__stat-num {
    font-size: 28px;
    font-weight: 700;
    color: var(--clinical-text);
    line-height: 1;
  }

  @media (min-width: 750px) {
    .dw-clinical__stat-num {
      font-size: 36px;
    }
  }

  .dw-clinical__stat-suffix {
    font-size: 16px;
    font-weight: 600;
    color: var(--clinical-accent);
  }

  @media (min-width: 750px) {
    .dw-clinical__stat-suffix {
      font-size: 20px;
    }
  }

  /* Stat Text */
  .dw-clinical__stat-text {
    font-size: 12px;
    line-height: 1.5;
    color: var(--clinical-text);
    opacity: 0.7;
    margin: 0;
    max-width: 150px;
  }

  @media (min-width: 750px) {
    .dw-clinical__stat-text {
      font-size: 13px;
    }
  }

  /* ==========================================
     DISCLAIMER
     ========================================== */

  .dw-clinical__disclaimer {
    position: relative;
    z-index: 2;
    max-width: 1400px;
    margin: 50px auto 0;
    padding-top: 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .dw-clinical__disclaimer p {
    font-size: 11px;
    color: var(--clinical-text);
    opacity: 0.5;
    margin: 0;
    line-height: 1.6;
    text-align: center;
  }

  @media (min-width: 990px) {
    .dw-clinical__disclaimer p {
      text-align: left;
    }
  }

  /* ==========================================
     REDUCED MOTION
     ========================================== */

  @media (prefers-reduced-motion: reduce) {
    .dw-clinical__orb,
    .dw-clinical__badge-glow,
    .dw-clinical__badge-border,
    .dw-clinical__badge-pulse,
    .dw-clinical__btn--glow,
    .dw-clinical__btn--gradient .dw-clinical__btn-bg {
      animation: none;
    }

    .dw-clinical__stat {
      opacity: 1;
      transform: none;
    }

    .dw-clinical__ring-fill {
      transition: none;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.querySelector('[data-clinical-section]');
    if (!section) return;

    const stats = section.querySelectorAll('[data-stat]');
    const circumference = 2 * Math.PI * 54; // radius = 54

    // Intersection Observer for triggering animations
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const stat = entry.target;
          stat.classList.add('is-visible');

          // Animate ring fill
          const ring = stat.querySelector('[data-stat-ring]');
          const ringFill = ring.querySelector('[data-ring-fill]');
          const value = parseInt(ring.dataset.value) || 0;
          const percent = Math.min(value, 100) / 100;
          const offset = circumference * (1 - percent);
          
          ringFill.style.setProperty('--ring-offset', offset);
          ringFill.style.strokeDashoffset = offset;

          // Count up animation
          const numEl = stat.querySelector('[data-count-to]');
          const target = parseInt(numEl.dataset.countTo) || 0;
          animateCount(numEl, 0, target, 1500);

          observer.unobserve(stat);
        }
      });
    }, { threshold: 0.3 });

    stats.forEach(stat => observer.observe(stat));

    // Count animation function
    function animateCount(el, start, end, duration) {
      const startTime = performance.now();
      
      function update(currentTime) {
        const elapsed = currentTime - startTime;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3); // ease-out cubic
        const current = Math.round(start + (end - start) * eased);
        
        el.textContent = current;
        
        if (progress < 1) {
          requestAnimationFrame(update);
        }
      }
      
      requestAnimationFrame(update);
    }
  });
</script>

