{% comment %}
  DoingWell Bottom CTA Section
  - Prominent conversion strip
  - Optional sticky behavior
  - Gradient/glow button options
  - Trust badges/microcopy
  - Full responsive controls
{% endcomment %}

<section 
  class="dw-cta{% if section.settings.enable_sticky %} dw-cta--sticky{% endif %}{% if section.settings.enable_animations %} dw-cta--animate{% endif %}"
  style="
    --cta-padding-top-desktop: {{ section.settings.padding_top_desktop }}px;
    --cta-padding-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;
    --cta-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --cta-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --cta-bg: {{ section.settings.bg_color }};
    --cta-text: {{ section.settings.text_color }};
    --cta-accent: {{ section.settings.accent_color }};
    --cta-max-width: {{ section.settings.max_width }}px;
    --cta-glow-1: {{ section.settings.glow_color_1 }};
    --cta-glow-2: {{ section.settings.glow_color_2 }};
    --cta-glow-opacity: {{ section.settings.glow_opacity | divided_by: 100.0 }};
  "
>
  {%- if section.settings.enable_glow -%}
    <div class="dw-cta__glow">
      <div class="dw-cta__glow-orb dw-cta__glow-orb--1"></div>
      <div class="dw-cta__glow-orb dw-cta__glow-orb--2"></div>
    </div>
  {%- endif -%}

  <div class="dw-cta__container dw-cta__container--{{ section.settings.layout }}">
    <!-- Content -->
    <div class="dw-cta__content">
      {%- if section.settings.eyebrow != blank -%}
        <span class="dw-cta__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      
      {%- if section.settings.heading != blank -%}
        <h2 class="dw-cta__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      
      {%- if section.settings.subheading != blank -%}
        <p class="dw-cta__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}

      <!-- Trust badges -->
      {%- if section.settings.show_badges -%}
        <div class="dw-cta__badges">
          {%- for block in section.blocks -%}
            {%- if block.type == 'badge' -%}
              <span class="dw-cta__badge" {{ block.shopify_attributes }}>
                {%- if block.settings.icon != 'none' -%}
                  <span class="dw-cta__badge-icon">
                    {%- case block.settings.icon -%}
                      {%- when 'check' -%}
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                      {%- when 'shield' -%}
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                      {%- when 'truck' -%}
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
                      {%- when 'lock' -%}
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                      {%- when 'star' -%}
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                      {%- when 'heart' -%}
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                      {%- when 'zap' -%}
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
                    {%- endcase -%}
                  </span>
                {%- endif -%}
                {{ block.settings.text }}
              </span>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <!-- Button Area -->
    <div class="dw-cta__action">
      {%- if section.settings.button_label != blank -%}
        <a 
          href="{{ section.settings.button_link }}" 
          class="dw-cta__btn dw-cta__btn--{{ section.settings.button_style }}{% if section.settings.button_style == 'gradient' or section.settings.button_style == 'gradient-glow' %} dw-cta__btn--gradient-animate{% endif %}"
          style="
            --btn-gradient-1: {{ section.settings.button_gradient_1 }};
            --btn-gradient-2: {{ section.settings.button_gradient_2 }};
            {% if section.settings.button_bg != blank %}--btn-bg: {{ section.settings.button_bg }};{% endif %}
            {% if section.settings.button_text_color != blank %}--btn-text: {{ section.settings.button_text_color }};{% endif %}
          "
        >
          <span>{{ section.settings.button_label }}</span>
        </a>
      {%- endif -%}
      
      {%- if section.settings.microcopy != blank -%}
        <p class="dw-cta__microcopy">{{ section.settings.microcopy }}</p>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  /* ==========================================
     BOTTOM CTA BASE
     ========================================== */
  
  .dw-cta {
    position: relative;
    padding: var(--cta-padding-top-mobile) 20px var(--cta-padding-bottom-mobile);
    background: var(--cta-bg, #0a0a0a);
    color: var(--cta-text, #ffffff);
    overflow: hidden;
  }

  @media (min-width: 750px) {
    .dw-cta {
      padding: var(--cta-padding-top-desktop) 50px var(--cta-padding-bottom-desktop);
    }
  }

  /* Sticky behavior */
  .dw-cta--sticky {
    position: sticky;
    bottom: 0;
    z-index: 100;
    box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.3);
  }

  /* ==========================================
     GLOW EFFECT
     ========================================== */
  
  .dw-cta__glow {
    position: absolute;
    inset: 0;
    overflow: hidden;
    opacity: var(--cta-glow-opacity, 0.5);
    pointer-events: none;
  }

  .dw-cta__glow-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
  }

  .dw-cta__glow-orb--1 {
    width: 300px;
    height: 200px;
    background: var(--cta-glow-1, #C4D600);
    top: -50%;
    left: 10%;
    animation: cta-glow 6s ease-in-out infinite;
  }

  .dw-cta__glow-orb--2 {
    width: 250px;
    height: 180px;
    background: var(--cta-glow-2, #00d4ff);
    bottom: -50%;
    right: 10%;
    animation: cta-glow 8s ease-in-out infinite reverse;
  }

  @keyframes cta-glow {
    0%, 100% { opacity: 0.5; transform: scale(1); }
    50% { opacity: 0.8; transform: scale(1.1); }
  }

  /* ==========================================
     CONTAINER
     ========================================== */
  
  .dw-cta__container {
    position: relative;
    z-index: 1;
    max-width: var(--cta-max-width, 1000px);
    margin: 0 auto;
  }

  /* Layout: Stacked */
  .dw-cta__container--stacked {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 24px;
  }

  /* Layout: Split */
  .dw-cta__container--split {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  @media (min-width: 750px) {
    .dw-cta__container--split {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 40px;
    }

    .dw-cta__container--split .dw-cta__content {
      text-align: left;
    }

    .dw-cta__container--split .dw-cta__action {
      flex-shrink: 0;
    }
  }

  /* Layout: Minimal */
  .dw-cta__container--minimal {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
  }

  @media (min-width: 750px) {
    .dw-cta__container--minimal {
      flex-direction: row;
      justify-content: center;
      gap: 24px;
    }

    .dw-cta__container--minimal .dw-cta__content {
      text-align: left;
    }
  }

  /* ==========================================
     CONTENT
     ========================================== */
  
  .dw-cta__content {
    text-align: center;
  }

  .dw-cta__eyebrow {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--cta-accent, #C4D600);
    margin-bottom: 8px;
  }

  .dw-cta__heading {
    font-size: 22px;
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 8px;
    letter-spacing: -0.01em;
  }

  @media (min-width: 750px) {
    .dw-cta__heading {
      font-size: 28px;
    }
  }

  .dw-cta__subheading {
    font-size: 14px;
    line-height: 1.5;
    opacity: 0.75;
    margin: 0;
  }

  @media (min-width: 750px) {
    .dw-cta__subheading {
      font-size: 16px;
    }
  }

  /* ==========================================
     BADGES
     ========================================== */
  
  .dw-cta__badges {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px 16px;
    margin-top: 16px;
  }

  .dw-cta__container--split .dw-cta__badges {
    justify-content: flex-start;
  }

  .dw-cta__badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    opacity: 0.7;
  }

  .dw-cta__badge-icon {
    color: var(--cta-accent, #C4D600);
    display: flex;
  }

  /* ==========================================
     ACTION
     ========================================== */
  
  .dw-cta__action {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }

  .dw-cta__container--split .dw-cta__action {
    align-items: flex-end;
  }

  .dw-cta__microcopy {
    font-size: 12px;
    opacity: 0.6;
    margin: 0;
    text-align: center;
  }

  /* ==========================================
     BUTTON STYLES
     ========================================== */
  
  .dw-cta__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 36px;
    font-size: 20px;
    font-weight: 600;
    text-decoration: none;
    border-radius: 40px;
    transition: all 0.2s ease;
    cursor: pointer;
    border: 2px solid transparent;
    position: relative;
    white-space: nowrap;
  }

  @media (min-width: 750px) {
    .dw-cta__btn {
      padding: 18px 44px;
      font-size: 20px;
    }
  }

  /* Primary */
  .dw-cta__btn--primary {
    background: var(--btn-bg, var(--cta-accent, #C4D600));
    color: var(--btn-text, #0a0a0a);
    border-color: var(--btn-bg, var(--cta-accent, #C4D600));
  }

  .dw-cta__btn--primary:hover {
    filter: brightness(0.9);
    transform: translateY(-2px);
  }

  /* Secondary */
  .dw-cta__btn--secondary {
    background: transparent;
    color: var(--btn-text, var(--cta-text, #ffffff));
    border-color: var(--btn-bg, rgba(255,255,255,0.3));
  }

  .dw-cta__btn--secondary:hover {
    background: rgba(255,255,255,0.1);
    border-color: var(--cta-accent);
  }

  /* White */
  .dw-cta__btn--white {
    background: var(--btn-bg, #ffffff);
    color: var(--btn-text, #0a0a0a);
    border-color: var(--btn-bg, #ffffff);
  }

  .dw-cta__btn--white:hover {
    filter: brightness(0.95);
    transform: translateY(-2px);
  }

  /* Gradient */
  .dw-cta__btn--gradient {
    background: transparent;
    color: var(--btn-text, #ffffff);
    border: none;
    position: relative;
    z-index: 1;
    border-radius: 6px;
    overflow: hidden;
  }

  .dw-cta__btn--gradient::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 6px;
    padding: 2px;
    background: linear-gradient(
      90deg,
      var(--btn-gradient-1, #C4D600),
      var(--btn-gradient-2, #00d4ff),
      var(--btn-gradient-1, #C4D600),
      var(--btn-gradient-2, #00d4ff)
    );
    background-size: 300% 100%;
    -webkit-mask: 
      linear-gradient(#fff 0 0) content-box, 
      linear-gradient(#fff 0 0);
    mask: 
      linear-gradient(#fff 0 0) content-box, 
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    z-index: -1;
  }

  .dw-cta__btn--gradient-animate::before {
    animation: cta-gradient-shift 3s linear infinite;
  }

  .dw-cta__btn--gradient:hover::before {
    animation: cta-gradient-shift 1.5s linear infinite;
  }

  .dw-cta__btn--gradient::after {
    content: '';
    position: absolute;
    inset: 2px;
    border-radius: 4px;
    background: var(--btn-bg, #0a0a0a);
    z-index: -1;
  }

  .dw-cta__btn--gradient span {
    position: relative;
    z-index: 2;
  }

  /* Gradient Glow */
  .dw-cta__btn--gradient-glow {
    background: transparent;
    color: var(--btn-text, #ffffff);
    border: none;
    position: relative;
    z-index: 1;
    border-radius: 6px;
    overflow: visible;
  }

  .dw-cta__btn--gradient-glow::before {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 10px;
    background: linear-gradient(
      90deg,
      var(--btn-gradient-1, #C4D600),
      var(--btn-gradient-2, #00d4ff),
      var(--btn-gradient-1, #C4D600),
      var(--btn-gradient-2, #00d4ff)
    );
    background-size: 300% 100%;
    z-index: -2;
    animation: cta-gradient-shift 3s linear infinite;
    filter: blur(10px);
    opacity: 0.7;
  }

  .dw-cta__btn--gradient-glow::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 6px;
    background: var(--btn-bg, #0a0a0a);
    z-index: -1;
  }

  .dw-cta__btn--gradient-glow:hover::before {
    filter: blur(14px);
    opacity: 1;
    animation: cta-gradient-shift 1.5s linear infinite;
  }

  .dw-cta__btn--gradient-glow span {
    position: relative;
    z-index: 2;
  }

  @keyframes cta-gradient-shift {
    0% { background-position: 0% 50%; }
    100% { background-position: 300% 50%; }
  }

  /* ==========================================
     ANIMATIONS
     ========================================== */
  
  .dw-cta--animate .dw-cta__container {
    opacity: 0;
    transform: translateY(20px);
    animation: cta-fade-up 700ms ease forwards;
  }

  @keyframes cta-fade-up {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Reduce motion */
  @media (prefers-reduced-motion: reduce) {
    .dw-cta--animate .dw-cta__container,
    .dw-cta__glow-orb {
      animation: none;
      opacity: 1;
      transform: none;
    }

    .dw-cta__btn--gradient-animate::before,
    .dw-cta__btn--gradient-glow::before {
      animation: none;
    }
  }
</style>

{% schema %}
{
  "name": "DW Bottom CTA",
  "tag": "section",
  "class": "dw-cta-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ready to join the Insider Club?"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Limited to 4,000 boxes. 1 per person."
    },
    {
      "type": "checkbox",
      "id": "show_badges",
      "label": "Show trust badges",
      "default": true
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Preorder now — $50 + $4.99 shipping"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        { "value": "primary", "label": "Primary (accent)" },
        { "value": "secondary", "label": "Secondary (outline)" },
        { "value": "white", "label": "White" },
        { "value": "gradient", "label": "Cyber Gradient ✨" },
        { "value": "gradient-glow", "label": "Cyber Glow ✨" }
      ],
      "default": "primary"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background",
      "info": "Leave blank for default"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "info": "Leave blank for default"
    },
    {
      "type": "color",
      "id": "button_gradient_1",
      "label": "Gradient color 1",
      "default": "#C4D600"
    },
    {
      "type": "color",
      "id": "button_gradient_2",
      "label": "Gradient color 2",
      "default": "#00d4ff"
    },
    {
      "type": "textarea",
      "id": "microcopy",
      "label": "Microcopy below button",
      "default": "Non-refundable preorder. Ships late January."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "stacked", "label": "Stacked (centered)" },
        { "value": "split", "label": "Split (text left, button right)" },
        { "value": "minimal", "label": "Minimal (inline)" }
      ],
      "default": "stacked"
    },
    {
      "type": "checkbox",
      "id": "enable_sticky",
      "label": "Sticky to bottom",
      "default": false,
      "info": "Section sticks to bottom of viewport"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 600,
      "max": 1200,
      "step": 50,
      "default": 900,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#0a0a0a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#C4D600"
    },
    {
      "type": "header",
      "content": "Animated Glow"
    },
    {
      "type": "checkbox",
      "id": "enable_glow",
      "label": "Enable background glow",
      "default": false
    },
    {
      "type": "color",
      "id": "glow_color_1",
      "label": "Glow color 1",
      "default": "#C4D600"
    },
    {
      "type": "color",
      "id": "glow_color_2",
      "label": "Glow color 2",
      "default": "#00d4ff"
    },
    {
      "type": "range",
      "id": "glow_opacity",
      "label": "Glow opacity",
      "min": 10,
      "max": 100,
      "step": 10,
      "default": 30,
      "unit": "%"
    },
    {
      "type": "header",
      "content": "Desktop Spacing"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 10,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 10,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Mobile Spacing"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top",
      "min": 0,
      "max": 80,
      "step": 10,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom",
      "min": 0,
      "max": 80,
      "step": 10,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Animations"
    },
    {
      "type": "checkbox",
      "id": "enable_animations",
      "label": "Enable entrance animations",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Trust Badge",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "check", "label": "✓ Check" },
            { "value": "shield", "label": "🛡 Shield" },
            { "value": "truck", "label": "🚚 Truck" },
            { "value": "lock", "label": "🔒 Lock" },
            { "value": "star", "label": "⭐ Star" },
            { "value": "heart", "label": "❤️ Heart" },
            { "value": "zap", "label": "⚡ Lightning" }
          ],
          "default": "check"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Clean hydration"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DW Bottom CTA",
