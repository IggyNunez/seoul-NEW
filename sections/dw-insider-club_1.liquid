{% comment %}
  DoingWell Insider Club Section
  - Membership value proposition block
  - Giveaway highlights with icons
  - Benefit cards or list layout
  - Animated glow/gradient effects
  - Full mobile/desktop responsive controls
{% endcomment %}

<section 
  class="dw-insider{% if section.settings.enable_animations %} dw-insider--animate{% endif %}"
  data-animation="{{ section.settings.animation_style }}"
  style="
    --insider-padding-top-desktop: {{ section.settings.padding_top_desktop }}px;
    --insider-padding-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;
    --insider-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --insider-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --insider-bg: {{ section.settings.bg_color }};
    --insider-text: {{ section.settings.text_color }};
    --insider-accent: {{ section.settings.accent_color }};
    --insider-card-bg: {{ section.settings.card_bg_color }};
    --insider-card-border: {{ section.settings.card_border_color }};
    --insider-glow-1: {{ section.settings.glow_color_1 }};
    --insider-glow-2: {{ section.settings.glow_color_2 }};
    --insider-glow-opacity: {{ section.settings.glow_opacity | divided_by: 100.0 }};
    --insider-max-width: {{ section.settings.max_width }}px;
    --insider-animation-duration: {{ section.settings.animation_duration }}ms;
    --insider-animation-stagger: {{ section.settings.animation_stagger }}ms;
    --insider-bg-position-desktop: {{ section.settings.bg_image_position_desktop }};
    --insider-bg-position-mobile: {{ section.settings.bg_image_position_mobile }};
    --insider-overlay-opacity: {{ section.settings.bg_overlay_opacity | divided_by: 100.0 }};
  "
>
  <!-- Background -->
  <div class="dw-insider__bg">
    {%- if section.settings.bg_image_desktop != blank -%}
      {%- assign mobile_bg = section.settings.bg_image_mobile | default: section.settings.bg_image_desktop -%}
      <picture class="dw-insider__bg-image">
        <source 
          media="(max-width: 749px)" 
          srcset="{{ mobile_bg | image_url: width: 750 }},
                  {{ mobile_bg | image_url: width: 1500 }} 2x"
        >
        <source 
          media="(min-width: 750px)" 
          srcset="{{ section.settings.bg_image_desktop | image_url: width: 1920 }},
                  {{ section.settings.bg_image_desktop | image_url: width: 3840 }} 2x"
        >
        <img 
          src="{{ section.settings.bg_image_desktop | image_url: width: 1920 }}" 
          alt=""
          loading="lazy"
          width="{{ section.settings.bg_image_desktop.width }}"
          height="{{ section.settings.bg_image_desktop.height }}"
        >
      </picture>
      <div class="dw-insider__bg-overlay"></div>
    {%- endif -%}
    
    {%- if section.settings.enable_glow -%}
      <div class="dw-insider__glow dw-insider__glow--{{ section.settings.glow_style }}">
        <div class="dw-insider__glow-orb dw-insider__glow-orb--1"></div>
        <div class="dw-insider__glow-orb dw-insider__glow-orb--2"></div>
      </div>
    {%- endif -%}
  </div>

  <div class="dw-insider__container">
    <!-- Header -->
    {%- if section.settings.label != blank or section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="dw-insider__header dw-insider__header--{{ section.settings.header_alignment }}">
        {%- if section.settings.label != blank -%}
          <span class="dw-insider__label dw-insider__animate-item" style="--item-index: 1;">
            {%- if section.settings.label_icon != 'none' -%}
              <span class="dw-insider__label-icon">
                {%- case section.settings.label_icon -%}
                  {%- when 'star' -%}
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                  {%- when 'lightning' -%}
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
                  {%- when 'shield' -%}
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                  {%- when 'crown' -%}
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M2.5 19h19v2h-19zm19.57-9.36c-.21-.8-1.04-1.28-1.84-1.06l-3.23.86-3.97-6.59a1.5 1.5 0 0 0-2.56 0L6.5 9.44l-3.23-.86c-.8-.22-1.63.26-1.84 1.06-.21.8.26 1.62 1.06 1.84l3.23.86L4.5 19h15l-1.22-6.66 3.23-.86c.8-.22 1.27-1.04 1.06-1.84z"></path></svg>
                  {%- when 'users' -%}
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                {%- endcase -%}
              </span>
            {%- endif -%}
            {{ section.settings.label }}
          </span>
        {%- endif -%}
        
        {%- if section.settings.heading != blank -%}
          <h2 class="dw-insider__heading dw-insider__animate-item" style="--item-index: 2;">
            {{ section.settings.heading | newline_to_br }}
          </h2>
        {%- endif -%}
        
        {%- if section.settings.subheading != blank -%}
          <p class="dw-insider__subheading dw-insider__animate-item" style="--item-index: 3;">
            {{ section.settings.subheading }}
          </p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <!-- Benefits -->
    <div class="dw-insider__benefits dw-insider__benefits--{{ section.settings.layout }}">
      {%- assign benefit_index = 3 -%}
      {%- for block in section.blocks -%}
        {%- assign benefit_index = benefit_index | plus: 1 -%}
        
        {%- case block.type -%}
          {%- when 'benefit' -%}
            <div 
              class="dw-insider__benefit dw-insider__animate-item"
              style="--item-index: {{ benefit_index }};"
              {{ block.shopify_attributes }}
            >
              {%- if block.settings.icon != 'none' or block.settings.custom_icon != blank -%}
                <div class="dw-insider__benefit-icon" style="
                  --icon-bg: {{ block.settings.icon_bg_color }};
                  --icon-color: {{ block.settings.icon_color }};
                ">
                  {%- if block.settings.custom_icon != blank -%}
                    <img 
                      src="{{ block.settings.custom_icon | image_url: width: 96 }}" 
                      alt="" 
                      width="32" 
                      height="32"
                      loading="lazy"
                    >
                  {%- else -%}
                    {%- case block.settings.icon -%}
                      {%- when 'star' -%}
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                      {%- when 'gift' -%}
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"></polyline><rect x="2" y="7" width="20" height="5"></rect><line x1="12" y1="22" x2="12" y2="7"></line><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"></path><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"></path></svg>
                      {%- when 'ticket' -%}
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"></path><path d="M13 5v2"></path><path d="M13 17v2"></path><path d="M13 11v2"></path></svg>
                      {%- when 'flask' -%}
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 22h12a2 2 0 0 0 1.73-3L14 9V2H10v7L4.27 19A2 2 0 0 0 6 22z"></path><path d="M8 2h8"></path><path d="M7 15h10"></path></svg>
                      {%- when 'bell' -%}
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
                      {%- when 'zap' -%}
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
                      {%- when 'crown' -%}
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M2.5 19h19v2h-19zm19.57-9.36c-.21-.8-1.04-1.28-1.84-1.06l-3.23.86-3.97-6.59a1.5 1.5 0 0 0-2.56 0L6.5 9.44l-3.23-.86c-.8-.22-1.63.26-1.84 1.06-.21.8.26 1.62 1.06 1.84l3.23.86L4.5 19h15l-1.22-6.66 3.23-.86c.8-.22 1.27-1.04 1.06-1.84z"></path></svg>
                      {%- when 'trophy' -%}
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"></path><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"></path><path d="M4 22h16"></path><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"></path><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"></path><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"></path></svg>
                      {%- when 'users' -%}
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                      {%- when 'lock' -%}
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                      {%- when 'eye' -%}
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                      {%- when 'check-circle' -%}
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                    {%- endcase -%}
                  {%- endif -%}
                </div>
              {%- endif -%}
              
              <div class="dw-insider__benefit-content">
                {%- if block.settings.title != blank -%}
                  <h3 class="dw-insider__benefit-title">{{ block.settings.title }}</h3>
                {%- endif -%}
                {%- if block.settings.description != blank -%}
                  <p class="dw-insider__benefit-desc">{{ block.settings.description }}</p>
                {%- endif -%}
                {%- if block.settings.highlight != blank -%}
                  <span class="dw-insider__benefit-highlight" style="--highlight-color: {{ block.settings.highlight_color }};">
                    {{ block.settings.highlight }}
                  </span>
                {%- endif -%}
              </div>
            </div>

          {%- when 'giveaway' -%}
            <div 
              class="dw-insider__giveaway dw-insider__animate-item"
              style="
                --item-index: {{ benefit_index }};
                --giveaway-bg: {{ block.settings.bg_color }};
                --giveaway-border: {{ block.settings.border_color }};
                --giveaway-accent: {{ block.settings.accent_color }};
              "
              {{ block.shopify_attributes }}
            >
              {%- if block.settings.badge != blank -%}
                <span class="dw-insider__giveaway-badge">{{ block.settings.badge }}</span>
              {%- endif -%}
              
              <div class="dw-insider__giveaway-icon">
                {%- if block.settings.custom_icon != blank -%}
                  <img 
                    src="{{ block.settings.custom_icon | image_url: width: 128 }}" 
                    alt="" 
                    width="48" 
                    height="48"
                    loading="lazy"
                  >
                {%- else -%}
                  {%- case block.settings.icon -%}
                    {%- when 'gift' -%}
                      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"></polyline><rect x="2" y="7" width="20" height="5"></rect><line x1="12" y1="22" x2="12" y2="7"></line><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"></path><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"></path></svg>
                    {%- when 'ticket' -%}
                      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"></path><path d="M13 5v2"></path><path d="M13 17v2"></path><path d="M13 11v2"></path></svg>
                    {%- when 'trophy' -%}
                      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"></path><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"></path><path d="M4 22h16"></path><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"></path><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"></path><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"></path></svg>
                    {%- when 'dollar' -%}
                      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
                  {%- endcase -%}
                {%- endif -%}
              </div>
              
              <div class="dw-insider__giveaway-content">
                {%- if block.settings.title != blank -%}
                  <h3 class="dw-insider__giveaway-title">{{ block.settings.title }}</h3>
                {%- endif -%}
                {%- if block.settings.value != blank -%}
                  <span class="dw-insider__giveaway-value">{{ block.settings.value }}</span>
                {%- endif -%}
                {%- if block.settings.description != blank -%}
                  <p class="dw-insider__giveaway-desc">{{ block.settings.description }}</p>
                {%- endif -%}
              </div>
            </div>

          {%- when 'divider' -%}
            <div 
              class="dw-insider__divider dw-insider__animate-item"
              style="
                --item-index: {{ benefit_index }};
                --divider-color: {{ block.settings.color }};
              "
              {{ block.shopify_attributes }}
            ></div>

        {%- endcase -%}
      {%- endfor -%}
    </div>

    <!-- Footer / Fine Print -->
    {%- if section.settings.footer_text != blank -%}
      <div class="dw-insider__footer dw-insider__animate-item" style="--item-index: {{ benefit_index | plus: 1 }};">
        {{ section.settings.footer_text }}
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  /* ==========================================
     INSIDER CLUB BASE
     ========================================== */
  
  .dw-insider {
    position: relative;
    padding: var(--insider-padding-top-mobile) 20px var(--insider-padding-bottom-mobile);
    background: var(--insider-bg, #0a0a0a);
    color: var(--insider-text, #ffffff);
    overflow: hidden;
  }

  @media (min-width: 750px) {
    .dw-insider {
      padding: var(--insider-padding-top-desktop) 50px var(--insider-padding-bottom-desktop);
    }
  }

  /* ==========================================
     BACKGROUND & GLOW
     ========================================== */
  
  .dw-insider__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  /* Background Image */
  .dw-insider__bg-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .dw-insider__bg-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--insider-bg-position-mobile, center center);
  }

  @media (min-width: 750px) {
    .dw-insider__bg-image img {
      object-position: var(--insider-bg-position-desktop, center center);
    }
  }

  .dw-insider__bg-overlay {
    position: absolute;
    inset: 0;
    background: var(--insider-bg, #0a0a0a);
    opacity: var(--insider-overlay-opacity, 0.7);
  }

  /* Glow Effect */

  .dw-insider__glow {
    position: absolute;
    inset: 0;
    opacity: var(--insider-glow-opacity, 0.5);
  }

  .dw-insider__glow-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
  }

  .dw-insider__glow-orb--1 {
    width: 40%;
    height: 60%;
    background: var(--insider-glow-1, #C4D600);
    top: -20%;
    left: -10%;
    animation: insider-glow-1 8s ease-in-out infinite;
  }

  .dw-insider__glow-orb--2 {
    width: 35%;
    height: 50%;
    background: var(--insider-glow-2, #00d4ff);
    bottom: -15%;
    right: -5%;
    animation: insider-glow-2 10s ease-in-out infinite;
  }

  @keyframes insider-glow-1 {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.6; }
    50% { transform: translate(10%, 10%) scale(1.1); opacity: 0.4; }
  }

  @keyframes insider-glow-2 {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.5; }
    50% { transform: translate(-10%, -5%) scale(1.15); opacity: 0.7; }
  }

  /* Glow Styles */
  .dw-insider__glow--pulse .dw-insider__glow-orb {
    animation: insider-pulse 4s ease-in-out infinite;
  }

  @keyframes insider-pulse {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(1.2); }
  }

  .dw-insider__glow--soft .dw-insider__glow-orb {
    filter: blur(150px);
    animation: insider-soft 12s ease-in-out infinite;
  }

  @keyframes insider-soft {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.5; }
  }

  .dw-insider__glow--corners .dw-insider__glow-orb--1 {
    top: -30%;
    left: -20%;
    width: 50%;
    height: 50%;
  }

  .dw-insider__glow--corners .dw-insider__glow-orb--2 {
    bottom: -30%;
    right: -20%;
    width: 50%;
    height: 50%;
  }

  /* ==========================================
     CONTAINER
     ========================================== */
  
  .dw-insider__container {
    position: relative;
    z-index: 1;
    max-width: var(--insider-max-width, 1200px);
    margin: 0 auto;
  }

  /* ==========================================
     HEADER
     ========================================== */
  
  .dw-insider__header {
    margin-bottom: 40px;
  }

  @media (min-width: 750px) {
    .dw-insider__header {
      margin-bottom: 50px;
    }
  }

  .dw-insider__header--left { text-align: left; }
  .dw-insider__header--center { text-align: center; }
  .dw-insider__header--right { text-align: right; }

  .dw-insider__label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: rgba(196, 214, 0, 0.15);
    color: var(--insider-accent, #C4D600);
    border: 1px solid rgba(196, 214, 0, 0.3);
    border-radius: 100px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 20px;
  }

  .dw-insider__label-icon {
    display: flex;
    align-items: center;
  }

  .dw-insider__heading {
    font-size: 28px;
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 16px;
    letter-spacing: -0.02em;
  }

  @media (min-width: 750px) {
    .dw-insider__heading {
      font-size: 40px;
      margin-bottom: 20px;
    }
  }

  .dw-insider__subheading {
    font-size: 16px;
    line-height: 1.6;
    opacity: 0.8;
    margin: 0;
    max-width: 600px;
  }

  .dw-insider__header--center .dw-insider__subheading {
    margin-left: auto;
    margin-right: auto;
  }

  @media (min-width: 750px) {
    .dw-insider__subheading {
      font-size: 18px;
    }
  }

  /* ==========================================
     BENEFITS LAYOUT
     ========================================== */
  
  .dw-insider__benefits {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  @media (min-width: 750px) {
    .dw-insider__benefits--grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }

    .dw-insider__benefits--grid-3 {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }

    .dw-insider__benefits--list {
      flex-direction: column;
      gap: 16px;
      max-width: 700px;
    }
  }

  /* ==========================================
     BENEFIT CARD
     ========================================== */
  
  .dw-insider__benefit {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 20px;
    background: var(--insider-card-bg, rgba(255,255,255,0.05));
    border: 1px solid var(--insider-card-border, rgba(255,255,255,0.1));
    border-radius: 12px;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .dw-insider__benefit:hover {
    border-color: var(--insider-accent, #C4D600);
    transform: translateY(-2px);
  }

  @media (min-width: 750px) {
    .dw-insider__benefit {
      padding: 24px;
      gap: 20px;
    }
  }

  /* Card layout variant */
  .dw-insider__benefits--cards .dw-insider__benefit {
    flex-direction: column;
    text-align: center;
    align-items: center;
  }

  .dw-insider__benefit-icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--icon-bg, rgba(196, 214, 0, 0.15));
    color: var(--icon-color, #C4D600);
    border-radius: 12px;
  }

  .dw-insider__benefit-icon img {
    width: 28px;
    height: 28px;
    object-fit: contain;
  }

  .dw-insider__benefit-content {
    flex: 1;
    min-width: 0;
  }

  .dw-insider__benefit-title {
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 6px;
    color: inherit;
  }

  @media (min-width: 750px) {
    .dw-insider__benefit-title {
      font-size: 18px;
      margin-bottom: 8px;
    }
  }

  .dw-insider__benefit-desc {
    font-size: 14px;
    line-height: 1.5;
    opacity: 0.75;
    margin: 0;
  }

  @media (min-width: 750px) {
    .dw-insider__benefit-desc {
      font-size: 15px;
    }
  }

  .dw-insider__benefit-highlight {
    display: inline-block;
    margin-top: 10px;
    padding: 4px 10px;
    background: rgba(196, 214, 0, 0.15);
    color: var(--highlight-color, #C4D600);
    border-radius: 4px;
    font-size: 12px;
    font-weight: 600;
  }

  /* ==========================================
     GIVEAWAY CARD
     ========================================== */
  
  .dw-insider__giveaway {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 30px 24px;
    background: var(--giveaway-bg, linear-gradient(135deg, rgba(196, 214, 0, 0.1) 0%, rgba(0, 212, 255, 0.1) 100%));
    border: 2px solid var(--giveaway-border, rgba(196, 214, 0, 0.3));
    border-radius: 16px;
    overflow: hidden;
  }

  .dw-insider__giveaway::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent 0%, rgba(255,255,255,0.03) 100%);
    pointer-events: none;
  }

  .dw-insider__giveaway-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    padding: 4px 10px;
    background: var(--giveaway-accent, #C4D600);
    color: #0a0a0a;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border-radius: 4px;
  }

  .dw-insider__giveaway-icon {
    width: 72px;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    margin-bottom: 16px;
    color: var(--giveaway-accent, #C4D600);
  }

  .dw-insider__giveaway-icon img {
    width: 40px;
    height: 40px;
    object-fit: contain;
  }

  .dw-insider__giveaway-content {
    position: relative;
    z-index: 1;
  }

  .dw-insider__giveaway-title {
    font-size: 14px;
    font-weight: 500;
    opacity: 0.8;
    margin: 0 0 8px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .dw-insider__giveaway-value {
    display: block;
    font-size: 28px;
    font-weight: 700;
    color: var(--giveaway-accent, #C4D600);
    margin-bottom: 8px;
  }

  @media (min-width: 750px) {
    .dw-insider__giveaway-value {
      font-size: 32px;
    }
  }

  .dw-insider__giveaway-desc {
    font-size: 14px;
    line-height: 1.5;
    opacity: 0.7;
    margin: 0;
  }

  /* ==========================================
     DIVIDER
     ========================================== */
  
  .dw-insider__divider {
    height: 1px;
    background: var(--divider-color, rgba(255,255,255,0.1));
    margin: 10px 0;
  }

  @media (min-width: 750px) {
    .dw-insider__benefits--grid .dw-insider__divider,
    .dw-insider__benefits--grid-3 .dw-insider__divider {
      grid-column: 1 / -1;
    }
  }

  /* ==========================================
     FOOTER
     ========================================== */
  
  .dw-insider__footer {
    margin-top: 30px;
    padding-top: 20px;
    border-top: 1px solid rgba(255,255,255,0.1);
    font-size: 13px;
    opacity: 0.6;
    text-align: center;
  }

  .dw-insider__footer a {
    color: var(--insider-accent, #C4D600);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  @media (min-width: 750px) {
    .dw-insider__footer {
      margin-top: 40px;
      font-size: 14px;
    }
  }

  /* ==========================================
     ANIMATIONS
     ========================================== */
  
  .dw-insider--animate .dw-insider__animate-item {
    opacity: 0;
    animation-fill-mode: forwards;
    animation-duration: var(--insider-animation-duration, 800ms);
    animation-delay: calc(var(--item-index, 1) * var(--insider-animation-stagger, 100ms));
  }

  .dw-insider--animate[data-animation="fade-up"] .dw-insider__animate-item {
    animation-name: insider-fade-up;
  }

  @keyframes insider-fade-up {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .dw-insider--animate[data-animation="fade-in"] .dw-insider__animate-item {
    animation-name: insider-fade-in;
  }

  @keyframes insider-fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .dw-insider--animate[data-animation="scale-up"] .dw-insider__animate-item {
    animation-name: insider-scale-up;
  }

  @keyframes insider-scale-up {
    from { opacity: 0; transform: scale(0.95); }
    to { opacity: 1; transform: scale(1); }
  }

  .dw-insider--animate[data-animation="slide-up"] .dw-insider__animate-item {
    animation-name: insider-slide-up;
  }

  @keyframes insider-slide-up {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Reduce motion */
  @media (prefers-reduced-motion: reduce) {
    .dw-insider--animate .dw-insider__animate-item,
    .dw-insider__glow-orb {
      animation: none;
      opacity: 1;
    }
  }
