<script>
  (function() {
    const section = document.querySelector('[data-section-id="{{ section.id }}"]');
    if (!section) return;

    const tabs = section.querySelectorAll('.casa-pprev__tab');
    const layers = section.querySelectorAll('.casa-pprev__media-layer');
    const descs = section.querySelectorAll('[data-mode-desc]');
    const splitDetails = section.querySelectorAll('.casa-pprev__split-detail');
    const progressBar = section.querySelector('.casa-pprev__progress-bar');

    const autoPlay = section.dataset.autoPlay === 'true';
    const autoSpeed = parseInt(section.dataset.autoSpeed, 10) * 1000 || 5000;
    const modeCount = parseInt(section.dataset.modeCount, 10) || 0;

    let activeIndex = 0;
    let autoTimer = null;
    let isPaused = false;

    function activateMode(index) {
      if (index < 0 || index >= modeCount || index === activeIndex) return;
      const prevIndex = activeIndex;
      activeIndex = index;

      /* Tabs */
      tabs.forEach(function(tab) {
        const i = parseInt(tab.dataset.modeIndex, 10);
        const isActive = i === index;
        tab.classList.toggle('casa-pprev__tab--active', isActive);
        tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });

      /* Media layers */
      layers.forEach(function(layer) {
        const i = parseInt(layer.dataset.modeIndex, 10);
        const isActive = i === index;
        layer.classList.toggle('casa-pprev__media-layer--active', isActive);
        if (layer.hasAttribute('aria-hidden')) {
          layer.setAttribute('aria-hidden', isActive ? 'false' : 'true');
        }
        /* Video play/pause */
        var video = layer.querySelector('video');
        if (video) {
          if (isActive) {
            video.play().catch(function() {});
          } else {
            video.pause();
          }
        }
      });

      /* Descriptions (fullscreen) */
      descs.forEach(function(desc) {
        var i = parseInt(desc.dataset.modeDesc, 10);
        desc.classList.toggle('casa-pprev__mode-desc--active', i === index);
      });

      /* Split details */
      splitDetails.forEach(function(detail) {
        var i = parseInt(detail.dataset.modeDesc, 10);
        detail.classList.toggle('casa-pprev__split-detail--active', i === index);
      });

      resetProgress();
    }

    /* Click handlers */
    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        var idx = parseInt(tab.dataset.modeIndex, 10);
        activateMode(idx);
        stopAutoPlay();
        if (autoPlay) startAutoPlay();
      });
    });

    /* Keyboard navigation */
    section.addEventListener('keydown', function(e) {
      if (!e.target.classList.contains('casa-pprev__tab')) return;
      var isVertical = e.target.closest('.casa-pprev__tabs--vertical');
      var prevKey = isVertical ? 'ArrowUp' : 'ArrowLeft';
      var nextKey = isVertical ? 'ArrowDown' : 'ArrowRight';
      var newIndex = activeIndex;

      if (e.key === nextKey) {
        newIndex = (activeIndex + 1) % modeCount;
        e.preventDefault();
      } else if (e.key === prevKey) {
        newIndex = (activeIndex - 1 + modeCount) % modeCount;
        e.preventDefault();
      } else if (e.key === 'Home') {
        newIndex = 0;
        e.preventDefault();
      } else if (e.key === 'End') {
        newIndex = modeCount - 1;
        e.preventDefault();
      } else {
        return;
      }
      activateMode(newIndex);
      /* Focus the new active tab */
      tabs.forEach(function(t) {
        if (parseInt(t.dataset.modeIndex, 10) === newIndex) t.focus();
      });
    });

    /* Touch swipe */
    var touchStartX = 0;
    var touchStartY = 0;
    section.addEventListener('touchstart', function(e) {
      touchStartX = e.changedTouches[0].screenX;
      touchStartY = e.changedTouches[0].screenY;
    }, { passive: true });
    section.addEventListener('touchend', function(e) {
      var dx = e.changedTouches[0].screenX - touchStartX;
      var dy = e.changedTouches[0].screenY - touchStartY;
      if (Math.abs(dx) < 50 || Math.abs(dy) > Math.abs(dx)) return;
      if (dx < 0) {
        activateMode((activeIndex + 1) % modeCount);
      } else {
        activateMode((activeIndex - 1 + modeCount) % modeCount);
      }
    }, { passive: true });

    /* Auto-play */
    function resetProgress() {
      if (!progressBar) return;
      progressBar.classList.remove('casa-pprev__progress-bar--running');
      progressBar.style.width = '0%';
      void progressBar.offsetWidth; /* reflow */
      progressBar.style.setProperty('--pprev-auto-speed', (autoSpeed / 1000) + 's');
      if (autoPlay && !isPaused) {
        progressBar.style.animationDuration = (autoSpeed / 1000) + 's';
        progressBar.classList.add('casa-pprev__progress-bar--running');
      }
    }

    function startAutoPlay() {
      if (!autoPlay || modeCount < 2) return;
      isPaused = false;
      stopAutoPlay();
      resetProgress();
      autoTimer = setInterval(function() {
        var next = (activeIndex + 1) % modeCount;
        activateMode(next);
      }, autoSpeed);
    }

    function stopAutoPlay() {
      if (autoTimer) {
        clearInterval(autoTimer);
        autoTimer = null;
      }
    }

    /* Pause on hover / focus */
    section.addEventListener('mouseenter', function() {
      if (autoPlay) {
        isPaused = true;
        stopAutoPlay();
        if (progressBar) progressBar.classList.remove('casa-pprev__progress-bar--running');
      }
    });
    section.addEventListener('mouseleave', function() {
      if (autoPlay) {
        isPaused = false;
        startAutoPlay();
      }
    });

    /* Init */
    if (autoPlay && modeCount > 1) startAutoPlay();
  })();
</script>

