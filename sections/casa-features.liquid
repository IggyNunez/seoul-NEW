{%- comment -%}
  Seoul Glow Lab - Features Section
  "Why Choose OctaMirror" feature grid for PDP
{%- endcomment -%}

{%- liquid
  assign tag_text = section.settings.tag_text | default: 'FEATURES'
  assign title = section.settings.title | default: 'Why Choose OctaMirror'
  assign subtitle = section.settings.subtitle | default: 'Premium craftsmanship meets cutting-edge technology'

  # Accent colors
  assign accent_primary = section.settings.accent_primary | default: '#9333ea'
  assign accent_secondary = section.settings.accent_secondary | default: '#ec4899'

  # Background
  assign bg_style = section.settings.background_style | default: 'light'

  # Layout
  assign columns = section.settings.columns | default: 3
  assign icon_size = section.settings.icon_size | default: 48
  assign image_size = section.settings.image_size | default: 48

  # Colors
  assign bg_color = section.settings.bg_color
  assign text_color = section.settings.text_color
  assign title_color = section.settings.title_color
  assign subtitle_color = section.settings.subtitle_color
  assign tag_color = section.settings.tag_color
  assign card_title_color = section.settings.card_title_color
  assign card_text_color = section.settings.card_text_color
  assign icon_color = section.settings.icon_color
  assign card_bg_color = section.settings.card_bg_color
  assign card_border_color = section.settings.card_border_color

  # Padding
  assign padding_top = section.settings.padding_top | default: 100
  assign padding_bottom = section.settings.padding_bottom | default: 100
  assign padding_mobile_top = section.settings.padding_mobile_top | default: 60
  assign padding_mobile_bottom = section.settings.padding_mobile_bottom | default: 60
-%}

<section
  class="casa-features casa-features--bg-{{ bg_style }}"
  id="casa-features-{{ section.id }}"
  style="
    --cf-accent-primary: {{ accent_primary }};
    --cf-accent-secondary: {{ accent_secondary }};
    --cf-padding-top: {{ padding_top }}px;
    --cf-padding-bottom: {{ padding_bottom }}px;
    --cf-padding-mobile-top: {{ padding_mobile_top }}px;
    --cf-padding-mobile-bottom: {{ padding_mobile_bottom }}px;
    --cf-columns: {{ columns }};
    --cf-icon-size: {{ icon_size }}px;
    --cf-image-size: {{ image_size }}px;
    {%- if bg_color != blank %}--cf-bg: {{ bg_color }};{% endif -%}
    {%- if text_color != blank %}--cf-text: {{ text_color }};{% endif -%}
    {%- if title_color != blank %}--cf-title-color: {{ title_color }};{% endif -%}
    {%- if subtitle_color != blank %}--cf-subtitle-color: {{ subtitle_color }};{% endif -%}
    {%- if tag_color != blank %}--cf-tag-color: {{ tag_color }};{% endif -%}
    {%- if card_title_color != blank %}--cf-card-title: {{ card_title_color }};{% endif -%}
    {%- if card_text_color != blank %}--cf-card-text: {{ card_text_color }};{% endif -%}
    {%- if icon_color != blank %}--cf-icon-color: {{ icon_color }};{% endif -%}
    {%- if card_bg_color != blank %}--cf-card-bg: {{ card_bg_color }};{% endif -%}
    {%- if card_border_color != blank %}--cf-card-border: {{ card_border_color }};{% endif -%}
  "
>
  <div class="casa-features__container">
    {%- comment -%} Header {%- endcomment -%}
    <div class="casa-features__header casa-features__reveal" style="--card-i: 0">
      {%- if tag_text != blank -%}
        <span class="casa-features__tag"><span class="casa-features__tag-dot"></span>{{ tag_text }}</span>
      {%- endif -%}

      {%- if title != blank -%}
        <h2 class="casa-features__title">{{ title }}</h2>
      {%- endif -%}

      {%- if subtitle != blank -%}
        <p class="casa-features__subtitle">{{ subtitle }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} Features Grid {%- endcomment -%}
    <div class="casa-features__grid">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'feature' -%}
            <div class="casa-features__card casa-features__reveal" style="--card-i: {{ forloop.index0 }}" {{ block.shopify_attributes }}>
              <div class="casa-features__card-glow"></div>
              <div class="casa-features__icon-wrapper{% if block.settings.custom_image != blank %} casa-features__icon-wrapper--img{% endif %}">
                {%- if block.settings.custom_image != blank -%}
                  <img
                    src="{{ block.settings.custom_image | image_url: width: 200, height: 200, crop: 'center' }}"
                    alt="{{ block.settings.title | escape }}"
                    width="{{ image_size }}"
                    height="{{ image_size }}"
                    loading="lazy"
                    class="casa-features__icon-img"
                  >
                {%- else -%}
                  {%- render 'casa-icon', icon: block.settings.icon, size: icon_size -%}
                {%- endif -%}
              </div>
              <h3 class="casa-features__card-title">{{ block.settings.title }}</h3>
              <p class="casa-features__card-text">{{ block.settings.description }}</p>
            </div>
          {%- when '@app' -%}
            <div {{ block.shopify_attributes }}>
              {%- render block -%}
            </div>
          {%- when 'custom-liquid' -%}
            <div {{ block.shopify_attributes }}>
              {{ block.settings.custom_liquid }}
            </div>
        {%- endcase -%}
      {%- endfor -%}

      {%- comment -%} Default cards if no blocks {%- endcomment -%}
      {%- if section.blocks.size == 0 -%}
        <div class="casa-features__card">
          <div class="casa-features__icon-wrapper">
            {%- render 'casa-icon', icon: 'palette', size: 24 -%}
          </div>
          <h3 class="casa-features__card-title">16M+ Colors</h3>
          <p class="casa-features__card-text">Endless color options</p>
        </div>
        <div class="casa-features__card">
          <div class="casa-features__icon-wrapper">
            {%- render 'casa-icon', icon: 'smartphone', size: 24 -%}
          </div>
          <h3 class="casa-features__card-title">Smart Control</h3>
          <p class="casa-features__card-text">App & voice enabled</p>
        </div>
        <div class="casa-features__card">
          <div class="casa-features__icon-wrapper">
            {%- render 'casa-icon', icon: 'music', size: 24 -%}
          </div>
          <h3 class="casa-features__card-title">Music Reactive</h3>
          <p class="casa-features__card-text">Syncs to your beats</p>
        </div>
        <div class="casa-features__card">
          <div class="casa-features__icon-wrapper">
            {%- render 'casa-icon', icon: 'mirror', size: 24 -%}
          </div>
          <h3 class="casa-features__card-title">Real Mirror</h3>
          <p class="casa-features__card-text">Dual purpose design</p>
        </div>
        <div class="casa-features__card">
          <div class="casa-features__icon-wrapper">
            {%- render 'casa-icon', icon: 'zap', size: 24 -%}
          </div>
          <h3 class="casa-features__card-title">Easy Install</h3>
          <p class="casa-features__card-text">Ready in 15 min</p>
        </div>
        <div class="casa-features__card">
          <div class="casa-features__icon-wrapper">
            {%- render 'casa-icon', icon: 'globe', size: 24 -%}
          </div>
          <h3 class="casa-features__card-title">Worldwide</h3>
          <p class="casa-features__card-text">100V-240V compatible</p>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

