{% stylesheet %}
/* ══════════════════════════════════════════════════════════════════════════
   CASA FEATURES SECTION
   "Why Choose OctaMirror" feature grid for PDP
   ══════════════════════════════════════════════════════════════════════════ */

.casa-features {
  --cf-accent-primary: #9333ea;
  --cf-accent-secondary: #ec4899;
  --cf-padding-top: 100px;
  --cf-padding-bottom: 100px;
  --cf-padding-mobile-top: 60px;
  --cf-padding-mobile-bottom: 60px;

  padding: var(--cf-padding-top) 0 var(--cf-padding-bottom);
  position: relative;
}

/* ── Background Variants ── */
.casa-features--bg-light {
  background: #f8f8fa;
}

.casa-features--bg-white {
  background: #ffffff;
}

.casa-features--bg-dark {
  background: #0a0a0f;
}

/* ── Container ── */
.casa-features__container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 24px;
}

/* ── Header ── */
.casa-features__header {
  text-align: center;
  margin-bottom: 56px;
}

.casa-features__tag {
  display: inline-block;
  font-size: 12px;
  font-weight: 600;
  color: var(--cf-tag-color, var(--cf-accent-primary));
  text-transform: uppercase;
  letter-spacing: 2px;
  margin-bottom: 16px;
}

.casa-features__title {
  font-size: clamp(28px, 5vw, 42px);
  font-weight: 300;
  color: var(--cf-title-color, #0a0a0a);
  margin: 0 0 16px 0;
  letter-spacing: -0.5px;
  line-height: 1.2;
}

.casa-features--bg-dark .casa-features__title {
  color: var(--cf-title-color, #ffffff);
}

.casa-features__subtitle {
  font-size: 16px;
  color: var(--cf-subtitle-color, #6b7280);
  margin: 0;
  max-width: 500px;
  margin-left: auto;
  margin-right: auto;
  line-height: 1.6;
}

.casa-features--bg-dark .casa-features__subtitle {
  color: var(--cf-subtitle-color, rgba(255, 255, 255, 0.6));
}

/* ══════════════════════════════════════════════════════════════════════════
   FEATURES GRID
   ══════════════════════════════════════════════════════════════════════════ */

.casa-features__grid {
  display: grid;
  grid-template-columns: repeat(var(--cf-columns, 3), 1fr);
  gap: 24px;
}
.casa-features[style*="--cf-bg"] {
  background: var(--cf-bg) !important;
}

/* ══════════════════════════════════════════════════════════════════════════
   FEATURE CARD
   ══════════════════════════════════════════════════════════════════════════ */

.casa-features__card {
  background: var(--cf-card-bg, #ffffff);
  border: 1px solid var(--cf-card-border, #e5e5e5);
  border-radius: 12px;
  padding: 32px 28px;
  text-align: center;
  transition: all 0.3s ease;
}

.casa-features--bg-dark .casa-features__card {
  background: rgba(255, 255, 255, 0.03);
  border-color: rgba(255, 255, 255, 0.08);
}

.casa-features--bg-dark .casa-features__icon-wrapper {
  background: linear-gradient(135deg, rgba(147, 51, 234, 0.15), rgba(236, 72, 153, 0.15));
}

.casa-features__card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
}

.casa-features--bg-dark .casa-features__card:hover {
  box-shadow: 0 12px 32px rgba(0, 0, 0, 0.3);
  border-color: rgba(255, 255, 255, 0.12);
}

/* ── Icon Wrapper ── */
.casa-features__icon-wrapper {
  width: calc(var(--cf-icon-size, 24px) + 28px);
  height: calc(var(--cf-icon-size, 24px) + 28px);
  border-radius: 12px;
  background: linear-gradient(135deg, rgba(147, 51, 234, 0.1), rgba(236, 72, 153, 0.1));
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20px;
  color: var(--cf-icon-color, var(--cf-accent-primary));
}

.casa-features__icon-wrapper svg {
  width: var(--cf-icon-size, 24px);
  height: var(--cf-icon-size, 24px);
  stroke: currentColor;
  fill: none;
}

.casa-features__icon-wrapper--img {
  width: var(--cf-image-size, 48px);
  height: var(--cf-image-size, 48px);
  background: transparent;
  overflow: hidden;
  padding: 0;
}

.casa-features__icon-img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  border-radius: inherit;
}

/* ── Card Content ── */
.casa-features__card-title {
  font-size: 18px;
  font-weight: 600;
  color: var(--cf-card-title, #0a0a0a);
  margin: 0 0 10px 0;
  line-height: 1.3;
}

.casa-features--bg-dark .casa-features__card-title {
  color: #ffffff;
}

.casa-features__card-text {
  font-size: 14px;
  color: var(--cf-card-text, #6b7280);
  margin: 0;
  line-height: 1.6;
}

.casa-features--bg-dark .casa-features__card-text {
  color: rgba(255, 255, 255, 0.6);
}

/* ══════════════════════════════════════════════════════════════════════════
   RESPONSIVE
   ══════════════════════════════════════════════════════════════════════════ */

@media (max-width: 900px) {
  .casa-features__grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
}

@media (max-width: 600px) {
  .casa-features__grid {
    grid-template-columns: repeat(1, 1fr);
    gap: 16px;
  }
}

@media (max-width: 768px) {
  .casa-features {
    padding: var(--cf-padding-mobile-top) 0 var(--cf-padding-mobile-bottom);
  }

  .casa-features__container {
    padding: 0 16px;
  }

  .casa-features__header {
    margin-bottom: 40px;
  }

  .casa-features__tag {
    font-size: 11px;
    margin-bottom: 12px;
  }

  .casa-features__subtitle {
    font-size: 14px;
  }

  .casa-features__grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .casa-features__card {
    padding: 24px 20px;
    border-radius: 12px;
  }

  .casa-features__icon-wrapper {
    width: 46px;
    height: 46px;
    border-radius: 10px;
    margin: 0 auto 16px;
  }

  .casa-features__icon-wrapper svg {
    width: 22px;
    height: 22px;
  }

  .casa-features__card-title {
    font-size: 16px;
    margin-bottom: 8px;
  }

  .casa-features__card-text {
    font-size: 13px;
    line-height: 1.5;
  }
}

@media (max-width: 400px) {
  .casa-features__grid {
    gap: 12px;
  }

  .casa-features__card {
    padding: 20px 16px;
    border-radius: 10px;
  }

  .casa-features__icon-wrapper {
    width: 42px;
    height: 42px;
    margin: 0 auto 14px;
  }

  .casa-features__icon-wrapper svg {
    width: 20px;
    height: 20px;
  }

  .casa-features__card-title {
    font-size: 15px;
  }

  .casa-features__card-text {
    font-size: 12px;
  }
}
{% endstylesheet %}

<style>
/* ── Scroll Reveal ── */
.casa-features__reveal {
  opacity: 0;
  transform: translateY(30px);
  transition: opacity 0.6s cubic-bezier(0.4, 0, 0.2, 1),
              transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  transition-delay: calc(var(--card-i, 0) * 0.1s);
}
.casa-features__reveal.is-visible {
  opacity: 1;
  transform: translateY(0);
}

/* ── Tag animated dot ── */
.casa-features__tag {
  display: inline-flex !important;
  align-items: center;
  gap: 8px;
}
.casa-features__tag-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--cf-accent-primary);
