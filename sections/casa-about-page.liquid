{%- comment -%}
  Seoul Glow Lab — About Page Section
  Block-based: hero, image_text, stats_row, featured_collection
{%- endcomment -%}

{%- liquid
  assign bg = section.settings.bg_color | default: '#0a0a0f'
  assign text = section.settings.text_color | default: '#f5f5f5'
  assign muted = section.settings.muted_color | default: '#9ca3af'
  assign accent1 = section.settings.accent_primary | default: '#9333ea'
  assign accent2 = section.settings.accent_secondary | default: '#ec4899'
  assign pt = section.settings.padding_top | default: 80
  assign pb = section.settings.padding_bottom | default: 80
  assign gap = section.settings.section_gap | default: 60

  assign hero_sub_color = section.settings.hero_subheading_color | default: accent1
  assign hero_head_color = section.settings.hero_heading_color | default: '#ffffff'
  assign hero_desc_color = section.settings.hero_description_color | default: muted

  assign iwt_sub = section.settings.iwt_subheading_color | default: accent1
  assign iwt_head = section.settings.iwt_heading_color | default: '#ffffff'
  assign iwt_content = section.settings.iwt_content_color | default: '#d1d5db'
  assign iwt_btn_bg = section.settings.iwt_button_bg | default: accent1
  assign iwt_btn_text = section.settings.iwt_button_text | default: '#ffffff'
  assign iwt_img_radius = section.settings.iwt_image_radius | default: 12

  assign stats_label = section.settings.stats_label_color | default: muted
  assign stats_card_bg = section.settings.stats_card_bg | default: '#111118'
  assign stats_card_border = section.settings.stats_card_border | default: '#1f1f2e'
  assign stats_num_color = section.settings.stats_number_color

  assign fc_heading = section.settings.fc_heading_color | default: '#ffffff'
  assign fc_price = section.settings.fc_price_color | default: '#ffffff'
-%}

<section
  class="casa-aboutp"
  style="
    --cap-bg: {{ bg }};
    --cap-text: {{ text }};
    --cap-muted: {{ muted }};
    --cap-a1: {{ accent1 }};
    --cap-a2: {{ accent2 }};
    --cap-pt: {{ pt }}px;
    --cap-pb: {{ pb }}px;
    --cap-gap: {{ gap }}px;
    --cap-hero-sub: {{ hero_sub_color }};
    --cap-hero-head: {{ hero_head_color }};
    --cap-hero-desc: {{ hero_desc_color }};
    --cap-iwt-sub: {{ iwt_sub }};
    --cap-iwt-head: {{ iwt_head }};
    --cap-iwt-content: {{ iwt_content }};
    --cap-iwt-btn-bg: {{ iwt_btn_bg }};
    --cap-iwt-btn-text: {{ iwt_btn_text }};
    --cap-iwt-radius: {{ iwt_img_radius }}px;
    --cap-stats-label: {{ stats_label }};
    --cap-stats-card-bg: {{ stats_card_bg }};
    --cap-stats-card-border: {{ stats_card_border }};
    {%- if stats_num_color != blank %}--cap-stats-num: {{ stats_num_color }};{% endif -%}
    --cap-fc-heading: {{ fc_heading }};
    --cap-fc-price: {{ fc_price }};
  "
>
  {%- for block in section.blocks -%}
    {%- case block.type -%}

      {%- comment -%} ── HERO ── {%- endcomment -%}
      {%- when 'hero' -%}
        <div class="casa-aboutp__hero" {{ block.shopify_attributes }}>
          <div class="casa-aboutp__hero-inner casa-aboutp__reveal">
            {%- if block.settings.subheading != blank -%}
              <span class="casa-aboutp__sub">{{ block.settings.subheading }}</span>
            {%- endif -%}
            {%- if block.settings.heading != blank -%}
              <h1 class="casa-aboutp__hero-h">{{ block.settings.heading }}</h1>
            {%- endif -%}
            {%- if block.settings.description != blank -%}
              <p class="casa-aboutp__hero-p">{{ block.settings.description }}</p>
            {%- endif -%}
          </div>
          <div class="casa-aboutp__hero-glow"></div>
        </div>

      {%- comment -%} ── IMAGE + TEXT ── {%- endcomment -%}
      {%- when 'image_text' -%}
        {%- liquid
          assign pos = block.settings.image_position | default: 'start'
        -%}
        <div class="casa-aboutp__it casa-aboutp__it--{{ pos }}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <div class="casa-aboutp__it-img casa-aboutp__reveal">
              <img
                src="{{ block.settings.image | image_url: width: 800 }}"
                srcset="
                  {{ block.settings.image | image_url: width: 400 }} 400w,
                  {{ block.settings.image | image_url: width: 600 }} 600w,
                  {{ block.settings.image | image_url: width: 800 }} 800w
                "
                sizes="(max-width: 749px) 100vw, 50vw"
                alt="{{ block.settings.heading | escape }}"
                loading="lazy"
                width="800"
                height="{{ 800 | divided_by: block.settings.image.aspect_ratio | round }}"
              >
            </div>
          {%- endif -%}

          <div class="casa-aboutp__it-body casa-aboutp__reveal">
            {%- if block.settings.subheading != blank -%}
              <span class="casa-aboutp__sub">{{ block.settings.subheading }}</span>
            {%- endif -%}
            {%- if block.settings.heading != blank -%}
              <h2 class="casa-aboutp__it-h">{{ block.settings.heading }}</h2>
            {%- endif -%}
            {%- if block.settings.content != blank -%}
              <div class="casa-aboutp__it-rt">{{ block.settings.content }}</div>
            {%- endif -%}
            {%- if block.settings.button_text != blank -%}
              <a href="{{ block.settings.button_url | default: '#' }}" class="casa-aboutp__btn">
                {{ block.settings.button_text }}
              </a>
            {%- endif -%}
          </div>
        </div>

      {%- comment -%} ── STATS ROW ── {%- endcomment -%}
      {%- when 'stats_row' -%}
        <div class="casa-aboutp__stats" {{ block.shopify_attributes }}>
          <div class="casa-aboutp__stats-inner">
            {%- for i in (1..3) -%}
              {%- liquid
                assign num_key   = 'stat_number_' | append: i
                assign label_key = 'stat_label_' | append: i
                assign num_val   = block.settings[num_key]
                assign label_val = block.settings[label_key]
              -%}
              {%- if num_val != blank -%}
                <div class="casa-aboutp__stat casa-aboutp__reveal">
                  <span class="casa-aboutp__stat-num" data-target="{{ num_val }}">{{ num_val }}</span>
                  {%- if label_val != blank -%}
                    <span class="casa-aboutp__stat-lbl">{{ label_val }}</span>
                  {%- endif -%}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>

      {%- comment -%} ── FEATURED COLLECTION ── {%- endcomment -%}
      {%- when 'featured_collection' -%}
        {%- liquid
          assign fc = block.settings.collection
          assign fc_limit = block.settings.products_to_show | default: 4
        -%}
        <div class="casa-aboutp__fc" {{ block.shopify_attributes }}>
          {%- if block.settings.heading != blank -%}
            <h2 class="casa-aboutp__fc-h casa-aboutp__reveal">{{ block.settings.heading }}</h2>
          {%- endif -%}

          {%- if fc != blank and fc.products.size > 0 -%}
            <div class="casa-aboutp__fc-grid">
              {%- for product in fc.products limit: fc_limit -%}
                <a href="{{ product.url }}" class="casa-aboutp__fc-card casa-aboutp__reveal">
                  {%- if product.featured_image != blank -%}
                    <div class="casa-aboutp__fc-img">
                      <img
                        src="{{ product.featured_image | image_url: width: 400 }}"
                        alt="{{ product.title | escape }}"
                        loading="lazy"
                        width="400"
                        height="{{ 400 | divided_by: product.featured_image.aspect_ratio | round }}"
                      >
                    </div>
                  {%- endif -%}
                  <div class="casa-aboutp__fc-info">
                    <span class="casa-aboutp__fc-title">{{ product.title }}</span>
                    <span class="casa-aboutp__fc-price">{{ product.price | money }}</span>
                  </div>
                </a>
              {%- endfor -%}
            </div>
          {%- else -%}
            <p class="casa-aboutp__fc-empty">Select a collection in the theme editor.</p>
          {%- endif -%}
        </div>

    {%- endcase -%}
  {%- endfor -%}

  {%- comment -%} App blocks {%- endcomment -%}
  {%- for block in section.blocks -%}
    {%- if block.type == '@app' -%}
      <div class="casa-app-block" {{ block.shopify_attributes }}>
        {% render block %}
      </div>
    {%- endif -%}
  {%- endfor -%}
</section>

{%- comment -%} ═══════════════ STYLES ═══════════════ {%- endcomment -%}
<style>
  /* ── Base ── */
  .casa-aboutp {
    --_bg: var(--cap-bg, #0a0a0f);
    --_text: var(--cap-text, #f5f5f5);
    --_a1: var(--cap-a1, #9333ea);
    --_a2: var(--cap-a2, #ec4899);
    background: var(--_bg);
    color: var(--_text);
    padding-top: var(--cap-pt, 80px);
    padding-bottom: var(--cap-pb, 80px);
    overflow: hidden;
    font-family: inherit;
    display: flex;
    flex-direction: column;
    gap: var(--cap-gap, 60px);
  }
  .casa-aboutp *, .casa-aboutp *::before, .casa-aboutp *::after { box-sizing: border-box; }

  /* ── Scroll reveal ── */
  .casa-aboutp__reveal {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity .7s cubic-bezier(.22,1,.36,1), transform .7s cubic-bezier(.22,1,.36,1);
  }
  .casa-aboutp__reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Shared sub-label ── */
  .casa-aboutp__sub {
    display: inline-block;
    font-size: .75rem;
    font-weight: 600;
    letter-spacing: .15em;
    text-transform: uppercase;
    color: var(--cap-iwt-sub, var(--_a1));
    margin-bottom: .75rem;
  }

  /* ── Shared button ── */
  .casa-aboutp__btn {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    margin-top: 1.5rem;
    padding: .85rem 2rem;
    font-size: .8rem;
    font-weight: 600;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--cap-iwt-btn-text, #fff);
    background: var(--cap-iwt-btn-bg, var(--_a1));
    border: none;
    border-radius: 6px;
    text-decoration: none;
    transition: opacity .3s, transform .3s, box-shadow .3s;
    cursor: pointer;
  }
  .casa-aboutp__btn:hover { opacity: .88; transform: translateY(-2px); box-shadow: 0 8px 24px rgba(147,51,234,0.3); }

  /* ═══════════════════════ HERO ═══════════════════════ */
  .casa-aboutp__hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: 55vh;
    padding: 4rem 1.5rem;
  }
  .casa-aboutp__hero-inner { position: relative; z-index: 2; max-width: 720px; }
  .casa-aboutp__hero .casa-aboutp__sub {
    color: var(--cap-hero-sub, var(--_a1));
  }
  .casa-aboutp__hero-h {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.15;
    margin: 0 0 1.25rem;
    color: var(--cap-hero-head, #fff);
  }
  .casa-aboutp__hero-p {
    font-size: clamp(.95rem, 1.8vw, 1.15rem);
    line-height: 1.7;
    color: var(--cap-hero-desc, rgba(255,255,255,.7));
    max-width: 600px;
    margin: 0 auto;
  }
  .casa-aboutp__hero-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    background:
      radial-gradient(ellipse 50% 60% at 50% 40%, rgba(147,51,234,.12) 0%, transparent 70%),
      radial-gradient(ellipse 40% 50% at 60% 70%, rgba(236,72,153,.08) 0%, transparent 70%);
  }

  /* ═══════════════════════ IMAGE + TEXT ═══════════════════════ */
  .casa-aboutp__it {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
    align-items: center;
  }
  @media (min-width: 750px) {
    .casa-aboutp__it { grid-template-columns: 1fr 1fr; gap: 3.5rem; }
    .casa-aboutp__it--end .casa-aboutp__it-img { order: 2; }
    .casa-aboutp__it--end .casa-aboutp__it-body { order: 1; }
  }
  .casa-aboutp__it-img {
    border-radius: var(--cap-iwt-radius, 14px);
    overflow: hidden;
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.06);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .casa-aboutp__it-img img { display: block; width: 100%; height: auto; object-fit: cover; }
  .casa-aboutp__it-h {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 1rem;
    color: var(--cap-iwt-head, var(--_text));
  }
  .casa-aboutp__it-rt {
    font-size: .95rem;
    line-height: 1.75;
    color: var(--cap-iwt-content, rgba(255,255,255,.7));
  }
  .casa-aboutp__it-rt p { margin: 0 0 1rem; }
  .casa-aboutp__it-rt p:last-child { margin-bottom: 0; }

  /* ═══════════════════════ STATS ═══════════════════════ */
  .casa-aboutp__stats {
    padding: 4rem 1.5rem;
    position: relative;
  }
  .casa-aboutp__stats::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(147,51,234,.06), rgba(236,72,153,.06));
    border-top: 1px solid rgba(255,255,255,.06);
    border-bottom: 1px solid rgba(255,255,255,.06);
    pointer-events: none;
  }
  .casa-aboutp__stats-inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 2rem 3.5rem;
    max-width: 900px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .casa-aboutp__stat {
    text-align: center;
    flex: 1 1 180px;
    min-width: 140px;
    padding: 1.5rem 1rem;
    border-radius: 14px;
    background: var(--cap-stats-card-bg, rgba(255,255,255,.03));
    border: 1px solid var(--cap-stats-card-border, rgba(255,255,255,.06));
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }
  .casa-aboutp__stat-num {
    display: block;
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 700;
    color: var(--cap-stats-num, transparent);
    background: linear-gradient(135deg, var(--_a1), var(--_a2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: var(--cap-stats-num, transparent);
    background-clip: text;
    line-height: 1.1;
    margin-bottom: .35rem;
  }
  .casa-aboutp__stat-lbl {
    display: block;
    font-size: .8rem;
    font-weight: 500;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--cap-stats-label, rgba(255,255,255,.55));
  }

  /* ═══════════════════════ FEATURED COLLECTION ═══════════════════════ */
  .casa-aboutp__fc {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 1.5rem 1rem;
    text-align: center;
  }
  .casa-aboutp__fc-h {
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 700;
    margin: 0 0 2rem;
  }
  .casa-aboutp__fc-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }
  @media (min-width: 750px) {
    .casa-aboutp__fc-grid { grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
  }
  .casa-aboutp__fc-card {
    text-decoration: none;
    color: var(--_text);
    border-radius: 12px;
    overflow: hidden;
    background: rgba(255,255,255,.03);
    border: 1px solid rgba(255,255,255,.06);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: transform .35s cubic-bezier(.22,1,.36,1), border-color .35s;
  }
  .casa-aboutp__fc-card:hover {
    transform: translateY(-4px);
    border-color: rgba(147,51,234,.3);
  }
  .casa-aboutp__fc-img { aspect-ratio: 1/1; overflow: hidden; }
  .casa-aboutp__fc-img img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s; }
  .casa-aboutp__fc-card:hover .casa-aboutp__fc-img img { transform: scale(1.05); }
  .casa-aboutp__fc-info { padding: .75rem .75rem 1rem; text-align: left; }
  .casa-aboutp__fc-title { display: block; font-size: .85rem; font-weight: 600; margin-bottom: .25rem; }
  .casa-aboutp__fc-price { font-size: .8rem; color: rgba(255,255,255,.5); }
  .casa-aboutp__fc-empty { color: rgba(255,255,255,.4); font-size: .9rem; }
</style>

{%- comment -%} ═══════════════ SCROLL REVEAL JS ═══════════════ {%- endcomment -%}
<script>
  (function(){
    const els = document.querySelectorAll('.casa-aboutp__reveal');
    if (!els.length) return;
    const io = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });
    els.forEach(function(el){ io.observe(el); });
  })();
</script>

{% schema %}
{
  "name": "About Page",
  "tag": "section",
  "class": "casa-about-page-section",
  "settings": [
    { "type": "header", "content": "Colors — General" },
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#0a0a0f" },
    { "type": "color", "id": "text_color", "label": "Body text color", "default": "#f5f5f5" },
    { "type": "color", "id": "muted_color", "label": "Muted text color", "info": "Descriptions, subtitles", "default": "#9ca3af" },
    { "type": "color", "id": "accent_primary", "label": "Primary accent", "default": "#9333ea" },
    { "type": "color", "id": "accent_secondary", "label": "Secondary accent", "default": "#ec4899" },
    { "type": "header", "content": "Colors — Hero" },
    { "type": "color", "id": "hero_subheading_color", "label": "Hero subheading color", "default": "#9333ea" },
    { "type": "color", "id": "hero_heading_color", "label": "Hero heading color", "default": "#ffffff" },
    { "type": "color", "id": "hero_description_color", "label": "Hero description color", "default": "#9ca3af" },
    { "type": "header", "content": "Colors — Image + Text sections" },
    { "type": "color", "id": "iwt_subheading_color", "label": "Subheading color", "default": "#9333ea" },
    { "type": "color", "id": "iwt_heading_color", "label": "Heading color", "default": "#ffffff" },
    { "type": "color", "id": "iwt_content_color", "label": "Content text color", "default": "#d1d5db" },
    { "type": "color", "id": "iwt_button_bg", "label": "Button background", "default": "#9333ea" },
    { "type": "color", "id": "iwt_button_text", "label": "Button text color", "default": "#ffffff" },
    { "type": "range", "id": "iwt_image_radius", "label": "Image border radius", "min": 0, "max": 32, "step": 2, "default": 12, "unit": "px" },
    { "type": "header", "content": "Colors — Stats Row" },
    { "type": "color", "id": "stats_number_color", "label": "Stats number color", "info": "Leave blank for gradient accent" },
    { "type": "color", "id": "stats_label_color", "label": "Stats label color", "default": "#9ca3af" },
    { "type": "color", "id": "stats_card_bg", "label": "Stats card background", "default": "#111118" },
    { "type": "color", "id": "stats_card_border", "label": "Stats card border", "default": "#1f1f2e" },
    { "type": "header", "content": "Colors — Featured Collection" },
    { "type": "color", "id": "fc_heading_color", "label": "Heading color", "default": "#ffffff" },
    { "type": "color", "id": "fc_card_bg", "label": "Product card background" },
    { "type": "color", "id": "fc_price_color", "label": "Price color", "default": "#ffffff" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "section_gap", "label": "Gap between sections", "min": 20, "max": 120, "step": 4, "unit": "px", "default": 60 }
  ],
  "blocks": [
    {
      "type": "hero",
      "name": "Hero",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "default": "About Us"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "We Dream. We Envision. We Innovate."
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "We want the future of Home Decor to look different from its past. We partner with the finest artisans and materials around the globe to craft pieces that transform every room into a statement of elegance."
        }
      ]
    },
    {
      "type": "image_text",
      "name": "Image + Text",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "image_position",
          "label": "Image position",
          "options": [
            { "value": "start", "label": "Left" },
            { "value": "end", "label": "Right" }
          ],
          "default": "start"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "default": "Our Mission"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Excellence At Every Step"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>We partner with the finest artisans and materials around the globe. Every piece passes rigorous quality checks to ensure it meets the Seoul Glow Lab standard of excellence.</p>"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Button link"
        }
      ]
    },
