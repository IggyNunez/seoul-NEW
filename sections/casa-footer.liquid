        { "value": "refresh", "label": "Returns" },
        { "value": "clock", "label": "Clock" },
        { "value": "lock", "label": "Lock" }
      ],
      "default": "clock"
    },
    {
      "type": "text",
      "id": "trust_4_title",
      "label": "Badge 4 title",
      "default": "2-Year Warranty"
    },
    {
      "type": "text",
      "id": "trust_4_subtitle",
      "label": "Badge 4 subtitle",
