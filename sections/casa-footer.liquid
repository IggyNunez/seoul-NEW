{% stylesheet %}
.casa-footer-section {
  padding: 0 !important;
  margin: 0;
}

.casa-footer {
  background: var(--footer-bg, linear-gradient(180deg, #0a0a0f 0%, #0f0f18 100%));
  color: var(--footer-text, #ffffff);
  position: relative;
  overflow: hidden;
}

.casa-footer::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 800px;
  height: 400px;
  background: radial-gradient(ellipse, rgba(147, 51, 234, 0.12) 0%, transparent 70%);
  pointer-events: none;
}

/* CTA Section */
.casa-footer__cta {
  position: relative;
  padding: 56px 40px;
  text-align: center;
  border-bottom: 1px solid var(--footer-border, rgba(255, 255, 255, 0.08));
  background: var(--footer-cta-bg, transparent);
}

.casa-footer__cta-content {
  max-width: 600px;
  margin: 0 auto;
}

.casa-footer__cta h3 {
  font-size: 32px;
  font-weight: 300;
  margin: 0 0 10px 0;
  line-height: 1.3;
}

.casa-footer__cta h3 span {
  background: linear-gradient(90deg, var(--footer-cta-accent, #9333ea), #ec4899);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.casa-footer__cta p {
  color: var(--footer-cta-text, rgba(255, 255, 255, 0.6));
  margin: 0 0 20px 0;
  font-size: 15px;
}

.casa-footer__cta-buttons {
  display: flex;
  gap: 12px;
  justify-content: center;
  flex-wrap: wrap;
}

.casa-footer__btn {
  padding: 12px 28px;
  font-size: 14px;
  border-radius: 10px;
  font-weight: 600;
  text-decoration: none;
  transition: all 0.3s ease;
  display: inline-block;
}

.casa-footer__btn--primary {
  background: var(--footer-cta-btn-bg, linear-gradient(135deg, #9333ea, #ec4899));
  color: var(--footer-cta-btn-text, #ffffff);
}

.casa-footer__btn--primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 12px 24px -6px rgba(147, 51, 234, 0.5);
}

.casa-footer__btn--secondary {
  background: rgba(255, 255, 255, 0.08);
  color: #ffffff;
  border: 1px solid rgba(255, 255, 255, 0.15);
}

.casa-footer__btn--secondary:hover {
  background: rgba(255, 255, 255, 0.12);
}

/* Main Footer Grid */
.casa-footer__main {
  display: flex;
  flex-wrap: wrap;
  gap: 32px;
  padding: 48px 60px;
  position: relative;
  max-width: 1440px;
  margin: 0 auto;
}

/* Column sizing — brand is wider, menu cols share the rest equally */
.casa-footer__brand {
  flex: 1.5;
  min-width: 200px;
}

.casa-footer__brand-title {
  font-size: 18px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--footer-heading, var(--footer-text, #ffffff));
  margin: 12px 0 8px;
  line-height: 1.3;
}

.casa-footer__follow-shop {
  margin: 12px 0 8px;
}

.casa-footer__col {
  flex: 1;
  min-width: 130px;
}

.casa-footer__newsletter {
  flex: 1.5;
  min-width: 220px;
}

/* Brand Column */
.casa-footer__logo-link {
  display: block;
  text-decoration: none;
  margin-bottom: 14px;
}

.casa-footer__logo-img {
  display: block;
  width: auto;
  object-fit: contain;
}

.casa-footer__logo {
  font-size: 20px;
  font-weight: 300;
  letter-spacing: 3px;
  display: block;
  color: #ffffff;
}

.casa-footer__brand p {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.5);
  line-height: 1.7;
  margin: 0 0 20px 0;
}

.casa-footer__social {
  display: flex;
  gap: 10px;
}

.casa-footer__social-icon {
  width: 40px;
  height: 40px;
  border-radius: 10px;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid var(--footer-border, rgba(255, 255, 255, 0.1));
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  color: var(--footer-social, #ffffff);
}

.casa-footer__social-icon:hover {
  background: var(--footer-social-hover, #9333ea);
  border-color: var(--footer-social-hover, #9333ea);
  transform: translateY(-2px);
  color: #ffffff;
}

.casa-footer__social-icon svg {
  fill: currentColor;
}

/* Menu Columns */
.casa-footer__col h4 {
  font-size: 12px;
  font-weight: 600;
  margin: 0 0 20px 0;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: var(--footer-heading, rgba(255, 255, 255, 0.9));
}

.casa-footer__col a {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  color: var(--footer-muted, rgba(255, 255, 255, 0.5));
  text-decoration: none;
  margin-bottom: 12px;
  transition: all 0.2s ease;
}

.casa-footer__col a:hover {
  color: var(--footer-link-hover, #ffffff);
  transform: translateX(4px);
}

.casa-footer__col a svg {
  opacity: 0;
  transition: opacity 0.2s ease;
  stroke: currentColor;
  flex-shrink: 0;
}

.casa-footer__col a:hover svg {
  opacity: 1;
}

/* Newsletter */
.casa-footer__newsletter h4 {
  font-size: 12px;
  font-weight: 600;
  margin: 0 0 10px 0;
  text-transform: uppercase;
  letter-spacing: 1.5px;
}

.casa-footer__newsletter > p {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.5);
  margin: 0 0 14px 0;
  line-height: 1.6;
}

.casa-footer__newsletter-form {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.casa-footer__newsletter-input {
  padding: 12px 14px;
  background: var(--footer-nl-input-bg, rgba(255, 255, 255, 0.05));
  border: 1px solid var(--footer-nl-input-border, rgba(255, 255, 255, 0.15));
  border-radius: 8px;
  color: var(--footer-text, #ffffff);
  font-size: 13px;
  font-family: inherit;
  outline: none;
  transition: all 0.3s ease;
}

.casa-footer__newsletter-input::placeholder {
  color: var(--footer-muted, rgba(255, 255, 255, 0.4));
}

.casa-footer__newsletter-input:focus {
  border-color: var(--footer-nl-btn-bg, #9333ea);
  background: var(--footer-nl-input-bg, rgba(255, 255, 255, 0.08));
}

.casa-footer__newsletter-btn {
  padding: 12px 18px;
  background: var(--footer-nl-btn-bg, linear-gradient(135deg, #9333ea, #ec4899));
  border: none;
  border-radius: 8px;
  color: var(--footer-nl-btn-text, #ffffff);
  font-size: 13px;
  font-weight: 600;
  font-family: inherit;
  cursor: pointer;
  transition: all 0.3s ease;
}

.casa-footer__newsletter-btn:hover {
  transform: translateY(-2px);
  filter: brightness(1.15);
  box-shadow: 0 8px 20px rgba(147, 51, 234, 0.4);
}

.casa-footer__newsletter-note {
  font-size: 11px;
  color: rgba(255, 255, 255, 0.35);
  margin: 4px 0 0 0;
}

/* Trust Badges */
.casa-footer__trust {
  padding: 32px 60px;
  border-top: 1px solid var(--footer-border, rgba(255, 255, 255, 0.08));
  border-bottom: 1px solid var(--footer-border, rgba(255, 255, 255, 0.08));
  background: var(--footer-trust-bg, transparent);
  max-width: 1440px;
  margin: 0 auto;
}

.casa-footer__trust-badges {
  display: flex;
  justify-content: center;
  gap: 48px;
  flex-wrap: wrap;
}

/* Bottom Bar */
.casa-footer__bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24px 60px;
  flex-wrap: wrap;
  gap: 16px;
  max-width: 1440px;
  margin: 0 auto;
}

.casa-footer__bottom-left {
  display: flex;
  align-items: center;
  gap: 24px;
  flex-wrap: wrap;
}

.casa-footer__bottom p {
  font-size: 12px;
  color: var(--footer-muted, rgba(255, 255, 255, 0.4));
  margin: 0;
}

.casa-footer__legal {
  display: flex;
  gap: 20px;
}

.casa-footer__legal a {
  font-size: 12px;
  color: var(--footer-muted, rgba(255, 255, 255, 0.4));
  text-decoration: none;
  transition: color 0.2s ease;
}

.casa-footer__legal a:hover {
  color: #ffffff;
}

.casa-footer__payments {
  display: flex;
  gap: 8px;
  align-items: center;
}

.casa-footer__payment-icon {
  height: 22px;
  width: auto;
  opacity: 0.5;
  transition: opacity 0.2s ease;
}

.casa-footer__payment-icon:hover {
  opacity: 1;
}

/* Responsive */
@media (max-width: 1200px) {
  .casa-footer__main {
    gap: 28px;
    padding: 40px 32px;
  }

  .casa-footer__brand {
    flex-basis: 100%;
  }

  .casa-footer__cta {
    padding: 48px 32px;
  }

  .casa-footer__trust,
  .casa-footer__bottom {
    padding-left: 32px;
    padding-right: 32px;
  }
}

@media (max-width: 900px) {
  .casa-footer__brand {
    flex-basis: 100%;
  }

  .casa-footer__newsletter {
    flex-basis: 100%;
  }

  .casa-footer__col {
    min-width: 45%;
  }

  .casa-footer__trust-badges {
    gap: 24px;
  }
}

@media (max-width: 600px) {
  .casa-footer__cta {
    padding: 40px 20px;
  }

  .casa-footer__cta h3 {
    font-size: 24px;
  }

  .casa-footer__cta p {
    font-size: 14px;
  }

  .casa-footer__cta-buttons {
    flex-direction: column;
  }

  .casa-footer__btn {
    width: 100%;
    text-align: center;
  }

  .casa-footer__main {
    padding: 36px 20px;
    gap: 20px 16px;
  }

  .casa-footer__col {
    min-width: 45%;
  }

  .casa-footer__brand,
  .casa-footer__newsletter {
    grid-column: span 2;
  }

  .casa-footer__col h4 {
    font-size: 13px;
    margin-bottom: 12px;
  }

  .casa-footer__col a {
    font-size: 13px;
    padding: 4px 0;
  }

  .casa-footer__trust {
    padding: 20px 16px;
  }

  .casa-footer__trust-badges {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .casa-footer__trust-badges .casa-trust-badge--footer {
    gap: 8px;
  }

  .casa-footer__trust-badges .casa-trust-badge--footer .casa-trust-badge__icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
  }

  .casa-footer__trust-badges .casa-trust-badge--footer .casa-trust-badge__icon svg {
    width: 18px;
    height: 18px;
  }

  .casa-footer__trust-badges .casa-trust-badge--footer .casa-trust-badge__title {
    font-size: 12px;
  }

  .casa-footer__trust-badges .casa-trust-badge--footer .casa-trust-badge__subtitle {
    font-size: 10px;
  }

  .casa-footer__bottom {
    flex-direction: column;
    text-align: center;
    padding: 20px;
  }

  .casa-footer__bottom-left {
    flex-direction: column;
    gap: 12px;
  }

  .casa-footer__legal {
    justify-content: center;
    flex-wrap: wrap;
    gap: 12px;
  }
}
{% endstylesheet %}
