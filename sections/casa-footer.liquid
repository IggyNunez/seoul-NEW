{%- comment -%}
  Seoul Glow Lab Footer Section
  CTA banner + 6-column mega footer + trust badges + bottom bar
{%- endcomment -%}

<footer
  class="casa-footer"
  style="
    {%- if section.settings.bg_color != blank %}--footer-bg: {{ section.settings.bg_color }};{% endif -%}
    {%- if section.settings.text_color != blank %}--footer-text: {{ section.settings.text_color }};{% endif -%}
    {%- if section.settings.muted_color != blank %}--footer-muted: {{ section.settings.muted_color }};{% endif -%}
    {%- if section.settings.heading_color != blank %}--footer-heading: {{ section.settings.heading_color }};{% endif -%}
    {%- if section.settings.link_hover_color != blank %}--footer-link-hover: {{ section.settings.link_hover_color }};{% endif -%}
    {%- if section.settings.border_color != blank %}--footer-border: {{ section.settings.border_color }};{% endif -%}
    {%- if section.settings.newsletter_btn_bg != blank %}--footer-nl-btn-bg: {{ section.settings.newsletter_btn_bg }};{% endif -%}
    {%- if section.settings.newsletter_btn_text != blank %}--footer-nl-btn-text: {{ section.settings.newsletter_btn_text }};{% endif -%}
    {%- if section.settings.newsletter_input_bg != blank %}--footer-nl-input-bg: {{ section.settings.newsletter_input_bg }};{% endif -%}
    {%- if section.settings.newsletter_input_border != blank %}--footer-nl-input-border: {{ section.settings.newsletter_input_border }};{% endif -%}
    {%- if section.settings.trust_icon_color != blank %}--footer-trust-icon: {{ section.settings.trust_icon_color }};{% endif -%}
    {%- if section.settings.trust_icon_bg != blank %}--footer-trust-icon-bg: {{ section.settings.trust_icon_bg }};{% endif -%}
    {%- if section.settings.trust_text_color != blank %}--footer-trust-text: {{ section.settings.trust_text_color }};{% endif -%}
    {%- if section.settings.trust_bg_color != blank %}--footer-trust-bg: {{ section.settings.trust_bg_color }};{% endif -%}
    {%- if section.settings.social_icon_color != blank %}--footer-social: {{ section.settings.social_icon_color }};{% endif -%}
    {%- if section.settings.social_icon_hover != blank %}--footer-social-hover: {{ section.settings.social_icon_hover }};{% endif -%}
    {%- if section.settings.cta_bg != blank %}--footer-cta-bg: {{ section.settings.cta_bg }};{% endif -%}
    {%- if section.settings.cta_text != blank %}--footer-cta-text: {{ section.settings.cta_text }};{% endif -%}
    {%- if section.settings.cta_btn_bg != blank %}--footer-cta-btn-bg: {{ section.settings.cta_btn_bg }};{% endif -%}
    {%- if section.settings.cta_btn_text != blank %}--footer-cta-btn-text: {{ section.settings.cta_btn_text }};{% endif -%}
    {%- if section.settings.cta_accent != blank %}--footer-cta-accent: {{ section.settings.cta_accent }};{% endif -%}
  "
>
  {%- comment -%} CTA Section {%- endcomment -%}
  {%- if section.settings.show_cta -%}
    <div class="casa-footer__cta">
      <div class="casa-footer__cta-content">
        <h3>
          {{ section.settings.cta_title_1 | default: 'Ready to Transform Your' }}
          <span>{{ section.settings.cta_title_highlight | default: 'Space?' }}</span>
        </h3>
        <p>{{ section.settings.cta_subtitle | default: "Join 50,000+ happy customers who've discovered the magic of Seoul Glow Lab" }}</p>
        <div class="casa-footer__cta-buttons">
          {%- if section.settings.cta_button_1_text != blank -%}
            <a href="{{ section.settings.cta_button_1_link }}" class="casa-footer__btn casa-footer__btn--primary">
              {{ section.settings.cta_button_1_text }}
            </a>
          {%- endif -%}
          {%- if section.settings.cta_button_2_text != blank -%}
            <a href="{{ section.settings.cta_button_2_link }}" class="casa-footer__btn casa-footer__btn--secondary">
              {{ section.settings.cta_button_2_text }}
            </a>
          {%- endif -%}
        </div>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} Main Footer {%- endcomment -%}
  <div class="casa-footer__main">
    {%- comment -%} Brand Column {%- endcomment -%}
    <div class="casa-footer__brand">
      {%- if section.settings.logo_image != blank -%}
        <a href="/" class="casa-footer__logo-link">
          <img
            src="{{ section.settings.logo_image | image_url: width: 400 }}"
            alt="{{ shop.name }}"
            loading="lazy"
            class="casa-footer__logo-img"
            height="{{ section.settings.logo_height | default: 40 }}"
          >
        </a>
      {%- else -%}
        <a href="/" class="casa-footer__logo-link">
          <span class="casa-footer__logo">{{ section.settings.logo_text | default: 'SEOUL GLOW LAB' }}</span>
        </a>
      {%- endif -%}
      {%- if section.settings.brand_title != blank -%}
        <h3 class="casa-footer__brand-title">{{ section.settings.brand_title }}</h3>
      {%- endif -%}
      <p>{{ section.settings.brand_description | default: 'House of Light. We create mesmerizing lighting and décor that transforms ordinary spaces into extraordinary experiences.' }}</p>
      {%- if section.settings.show_follow_on_shop -%}
        <div class="casa-footer__follow-shop">
          {{ shop | login_button: action: 'follow' }}
        </div>
      {%- endif -%}
      <div class="casa-footer__social">
        {%- if section.settings.social_instagram != blank -%}
          <a href="{{ section.settings.social_instagram }}" class="casa-footer__social-icon" aria-label="Instagram" target="_blank" rel="noopener">
            {%- render 'casa-icon', icon: 'instagram', size: 20 -%}
          </a>
        {%- endif -%}
        {%- if section.settings.social_tiktok != blank -%}
          <a href="{{ section.settings.social_tiktok }}" class="casa-footer__social-icon" aria-label="TikTok" target="_blank" rel="noopener">
            {%- render 'casa-icon', icon: 'tiktok', size: 20 -%}
          </a>
        {%- endif -%}
        {%- if section.settings.social_pinterest != blank -%}
          <a href="{{ section.settings.social_pinterest }}" class="casa-footer__social-icon" aria-label="Pinterest" target="_blank" rel="noopener">
            {%- render 'casa-icon', icon: 'pinterest', size: 20 -%}
          </a>
        {%- endif -%}
        {%- if section.settings.social_youtube != blank -%}
          <a href="{{ section.settings.social_youtube }}" class="casa-footer__social-icon" aria-label="YouTube" target="_blank" rel="noopener">
            {%- render 'casa-icon', icon: 'youtube', size: 20 -%}
          </a>
        {%- endif -%}
        {%- if section.settings.social_facebook != blank -%}
          <a href="{{ section.settings.social_facebook }}" class="casa-footer__social-icon" aria-label="Facebook" target="_blank" rel="noopener">
            {%- render 'casa-icon', icon: 'facebook', size: 20 -%}
          </a>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} Menu Columns {%- endcomment -%}
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'menu' -%}
          <div class="casa-footer__col" {{ block.shopify_attributes }}>
            <h4>{{ block.settings.title }}</h4>
            {%- assign menu = linklists[block.settings.menu] -%}
            {%- if menu != blank -%}
              {%- for link in menu.links -%}
                <a href="{{ link.url }}">
                  {{ link.title }}
                  {%- render 'casa-icon', icon: 'chevron-right', size: 14 -%}
                </a>
              {%- endfor -%}
            {%- else -%}
              {%- comment -%} Fallback links based on column title {%- endcomment -%}
              {%- assign col_title = block.settings.title | downcase -%}
              {%- if col_title == 'shop' -%}
                <a href="/collections">All Products {%- render 'casa-icon', icon: 'chevron-right', size: 14 -%}</a>
                <a href="/collections/best-sellers">Best Sellers {%- render 'casa-icon', icon: 'chevron-right', size: 14 -%}</a>
                <a href="/collections/infinity-mirrors">Infinity Mirrors {%- render 'casa-icon', icon: 'chevron-right', size: 14 -%}</a>
                <a href="/collections/new-arrivals">New Arrivals {%- render 'casa-icon', icon: 'chevron-right', size: 14 -%}</a>
                <a href="/collections/sale">Sale {%- render 'casa-icon', icon: 'chevron-right', size: 14 -%}</a>
              {%- elsif col_title == 'support' -%}
                <a href="/pages/contact">Contact Us {%- render 'casa-icon', icon: 'chevron-right', size: 14 -%}</a>
                <a href="/pages/faq">FAQ {%- render 'casa-icon', icon: 'chevron-right', size: 14 -%}</a>
                <a href="/apps/track-order">Track Order {%- render 'casa-icon', icon: 'chevron-right', size: 14 -%}</a>
                <a href="/policies/shipping-policy">Shipping Info {%- render 'casa-icon', icon: 'chevron-right', size: 14 -%}</a>
                <a href="/policies/refund-policy">Returns {%- render 'casa-icon', icon: 'chevron-right', size: 14 -%}</a>
              {%- elsif col_title == 'company' -%}
                <a href="/pages/about">Our Story {%- render 'casa-icon', icon: 'chevron-right', size: 14 -%}</a>
                <a href="/pages/reviews">Reviews {%- render 'casa-icon', icon: 'chevron-right', size: 14 -%}</a>
                <a href="/pages/affiliate">Affiliate Program {%- render 'casa-icon', icon: 'chevron-right', size: 14 -%}</a>
                <a href="/blogs/press">Press {%- render 'casa-icon', icon: 'chevron-right', size: 14 -%}</a>
              {%- elsif col_title == 'resources' -%}
                <a href="/pages/size-guide">Size Guide {%- render 'casa-icon', icon: 'chevron-right', size: 14 -%}</a>
                <a href="/pages/installation">Installation Guide {%- render 'casa-icon', icon: 'chevron-right', size: 14 -%}</a>
                <a href="/pages/style-quiz">Style Quiz {%- render 'casa-icon', icon: 'chevron-right', size: 14 -%}</a>
                <a href="/blogs/journal">Blog {%- render 'casa-icon', icon: 'chevron-right', size: 14 -%}</a>
              {%- endif -%}
            {%- endif -%}
          </div>

        {%- when 'newsletter' -%}
          <div class="casa-footer__newsletter" {{ block.shopify_attributes }}>
            <h4>{{ block.settings.title | default: 'Stay Illuminated' }}</h4>
            <p>{{ block.settings.description | default: 'Get 15% off your first order + exclusive access to new drops and VIP sales' }}</p>
            {%- form 'customer', class: 'casa-footer__newsletter-form' -%}
              <input type="hidden" name="contact[tags]" value="newsletter,footer">
              <input
                type="email"
                name="contact[email]"
                class="casa-footer__newsletter-input"
                placeholder="{{ block.settings.placeholder | default: 'Enter your email' }}"
                required
                autocomplete="email"
              >
              <button type="submit" class="casa-footer__newsletter-btn">
                {{ block.settings.button_text | default: 'Subscribe & Save 15%' }}
              </button>
            {%- endform -%}
            {%- if block.settings.note != blank -%}
              <p class="casa-footer__newsletter-note">{{ block.settings.note }}</p>
            {%- endif -%}
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>

  {%- comment -%} Trust Badges {%- endcomment -%}
  {%- if section.settings.show_trust_badges -%}
    <div class="casa-footer__trust">
      <div class="casa-footer__trust-badges">
        {%- if section.settings.trust_1_title != blank -%}
          {%- render 'casa-trust-badge',
            icon: section.settings.trust_1_icon,
            title: section.settings.trust_1_title,
            subtitle: section.settings.trust_1_subtitle,
            variant: 'footer'
          -%}
        {%- endif -%}
        {%- if section.settings.trust_2_title != blank -%}
          {%- render 'casa-trust-badge',
            icon: section.settings.trust_2_icon,
            title: section.settings.trust_2_title,
            subtitle: section.settings.trust_2_subtitle,
            variant: 'footer'
          -%}
        {%- endif -%}
        {%- if section.settings.trust_3_title != blank -%}
          {%- render 'casa-trust-badge',
            icon: section.settings.trust_3_icon,
            title: section.settings.trust_3_title,
            subtitle: section.settings.trust_3_subtitle,
            variant: 'footer'
          -%}
        {%- endif -%}
        {%- if section.settings.trust_4_title != blank -%}
          {%- render 'casa-trust-badge',
            icon: section.settings.trust_4_icon,
            title: section.settings.trust_4_title,
            subtitle: section.settings.trust_4_subtitle,
            variant: 'footer'
          -%}
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} Bottom Bar {%- endcomment -%}
  <div class="casa-footer__bottom">
    <div class="casa-footer__bottom-left">
      <p>&copy; {{ 'now' | date: '%Y' }} {{ section.settings.logo_text | default: 'Casa Di Lumo' }}. All rights reserved.</p>
      <div class="casa-footer__legal">
        {%- assign legal_menu = linklists[section.settings.legal_menu] -%}
        {%- if legal_menu != blank -%}
          {%- for link in legal_menu.links -%}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {%- endfor -%}
        {%- else -%}
          <a href="{{ routes.privacy_policy_url }}">Privacy Policy</a>
          <a href="{{ routes.terms_of_service_url }}">Terms of Service</a>
        {%- endif -%}
      </div>
    </div>
    <div class="casa-footer__payments">
      {%- if section.settings.show_payment_icons -%}
        {{ 'visa' | payment_type_svg_tag: class: 'casa-footer__payment-icon' }}
        {{ 'master' | payment_type_svg_tag: class: 'casa-footer__payment-icon' }}
        {{ 'american_express' | payment_type_svg_tag: class: 'casa-footer__payment-icon' }}
        {{ 'paypal' | payment_type_svg_tag: class: 'casa-footer__payment-icon' }}
        {{ 'apple_pay' | payment_type_svg_tag: class: 'casa-footer__payment-icon' }}
        {{ 'google_pay' | payment_type_svg_tag: class: 'casa-footer__payment-icon' }}
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Casa Footer",
  "tag": "section",
  "class": "casa-footer-section",
  "settings": [
    {
      "type": "header",
      "content": "CTA Banner"
    },
    {
      "type": "checkbox",
      "id": "show_cta",
      "label": "Show CTA banner",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_title_1",
      "label": "Title part 1",
      "default": "Ready to Transform Your"
    },
    {
      "type": "text",
      "id": "cta_title_highlight",
      "label": "Title highlight",
      "default": "Space?"
    },
    {
      "type": "text",
      "id": "cta_subtitle",
      "label": "Subtitle",
      "default": "Join 50,000+ happy customers who've discovered the magic of Seoul Glow Lab"
    },
    {
      "type": "text",
      "id": "cta_button_1_text",
      "label": "Button 1 text",
      "default": "Shop Best Sellers"
    },
    {
      "type": "url",
      "id": "cta_button_1_link",
      "label": "Button 1 link"
    },
    {
      "type": "text",
      "id": "cta_button_2_text",
      "label": "Button 2 text",
      "default": "Take the Quiz"
    },
    {
      "type": "url",
      "id": "cta_button_2_link",
      "label": "Button 2 link"
    },
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo image",
      "info": "Overrides logo text when set"
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Logo height",
      "min": 20,
      "max": 80,
      "step": 2,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "info": "Fallback when no logo image is set",
      "default": "SEOUL GLOW LAB"
    },
    {
      "type": "text",
      "id": "brand_title",
      "label": "Brand title",
      "info": "Large text below logo (e.g., tagline)",
      "placeholder": "Nordic, Modern & Minimalist"
    },
    {
      "type": "textarea",
      "id": "brand_description",
      "label": "Brand description",
      "default": "House of Light. We create mesmerizing lighting and décor that transforms ordinary spaces into extraordinary experiences."
    },
    {
      "type": "checkbox",
      "id": "show_follow_on_shop",
      "label": "Show 'Follow on Shop' button",
      "default": false
    },
    {
      "type": "header",
      "content": "Social Links"
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "social_tiktok",
      "label": "TikTok URL"
    },
    {
      "type": "url",
      "id": "social_pinterest",
      "label": "Pinterest URL"
    },
    {
      "type": "url",
      "id": "social_youtube",
      "label": "YouTube URL"
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "Facebook URL"
    },
    {
      "type": "header",
      "content": "Trust Badges"
    },
    {
      "type": "checkbox",
      "id": "show_trust_badges",
      "label": "Show trust badges",
      "default": true
    },
    {
      "type": "select",
      "id": "trust_1_icon",
      "label": "Badge 1 icon",
      "options": [
        { "value": "shield", "label": "Shield" },
        { "value": "truck", "label": "Truck" },
        { "value": "refresh", "label": "Returns" },
        { "value": "clock", "label": "Clock" },
        { "value": "lock", "label": "Lock" }
      ],
      "default": "shield"
    },
    {
      "type": "text",
      "id": "trust_1_title",
      "label": "Badge 1 title",
      "default": "Secure Payments"
    },
    {
      "type": "text",
      "id": "trust_1_subtitle",
      "label": "Badge 1 subtitle",
      "default": "256-bit SSL encryption"
    },
    {
      "type": "select",
      "id": "trust_2_icon",
      "label": "Badge 2 icon",
      "options": [
        { "value": "shield", "label": "Shield" },
        { "value": "truck", "label": "Truck" },
        { "value": "refresh", "label": "Returns" },
        { "value": "clock", "label": "Clock" },
        { "value": "lock", "label": "Lock" }
      ],
      "default": "truck"
    },
    {
      "type": "text",
      "id": "trust_2_title",
      "label": "Badge 2 title",
      "default": "Free Express Shipping"
    },
    {
      "type": "text",
      "id": "trust_2_subtitle",
      "label": "Badge 2 subtitle",
      "default": "Worldwide delivery"
    },
    {
      "type": "select",
      "id": "trust_3_icon",
      "label": "Badge 3 icon",
      "options": [
        { "value": "shield", "label": "Shield" },
        { "value": "truck", "label": "Truck" },
        { "value": "refresh", "label": "Returns" },
        { "value": "clock", "label": "Clock" },
        { "value": "lock", "label": "Lock" }
      ],
      "default": "refresh"
    },
    {
      "type": "text",
      "id": "trust_3_title",
      "label": "Badge 3 title",
      "default": "30-Day Returns"
    },
    {
      "type": "text",
      "id": "trust_3_subtitle",
      "label": "Badge 3 subtitle",
      "default": "No questions asked"
    },
    {
      "type": "select",
      "id": "trust_4_icon",
      "label": "Badge 4 icon",
      "options": [
        { "value": "shield", "label": "Shield" },
