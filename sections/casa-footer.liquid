  /* Override base theme input background for dark footer */
  .casa-footer__newsletter-input,
  .casa-footer__newsletter-input:hover,
  .casa-footer__newsletter-input:focus {
    background-color: rgba(255, 255, 255, 0.05) !important;
    border-color: rgba(255, 255, 255, 0.15);
    color: #ffffff;
  }
  .casa-footer__newsletter-input:focus {
    border-color: #9333ea !important;
    background-color: rgba(255, 255, 255, 0.08) !important;
  }
  .casa-footer__newsletter-input:-webkit-autofill,
  .casa-footer__newsletter-input:-webkit-autofill:hover,
  .casa-footer__newsletter-input:-webkit-autofill:focus,
  .casa-footer__newsletter-input:-webkit-autofill:active {
    -webkit-box-shadow: 0 0 0 1000px #0f0f18 inset !important;
