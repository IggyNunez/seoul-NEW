    },
    {
      "type": "color",
      "id": "trust_bg_color",
      "label": "Trust bar background"
    },
    {
      "type": "header",
      "content": "Social Icons"
    },
    {
      "type": "color",
      "id": "social_icon_color",
      "label": "Social icon color"
    },
    {
      "type": "color",
      "id": "social_icon_hover",
      "label": "Social icon hover color"
    },
    {
      "type": "header",
      "content": "CTA Banner Colors"
    },
    {
      "type": "color",
      "id": "cta_bg",
      "label": "CTA background"
    },
    {
      "type": "color",
      "id": "cta_text",
      "label": "CTA text"
    },
    {
      "type": "color",
      "id": "cta_btn_bg",
      "label": "CTA button background"
    },
    {
      "type": "color",
