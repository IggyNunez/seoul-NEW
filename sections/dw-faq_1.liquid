{% comment %}
  DoingWell FAQ Section v2
  - Cyber-themed with animated effects
  - Glowing active accordion items
  - Animated gradient borders
  - Staggered entrance animations
  - Number indicators with glow
  - Full button customization including radius
{% endcomment %}

<section 
  class="dw-faq"
  data-faq-section
  style="
    --faq-bg: {{ section.settings.background_color }};
    --faq-text: {{ section.settings.text_color }};
    --faq-heading-color: {{ section.settings.heading_color }};
    --faq-accent: {{ section.settings.accent_color }};
    --faq-border: {{ section.settings.border_color }};
    --faq-glow-1: {{ section.settings.glow_color_1 }};
    --faq-glow-2: {{ section.settings.glow_color_2 }};
    --faq-padding-desktop: {{ section.settings.padding_desktop }}px;
    --faq-padding-mobile: {{ section.settings.padding_mobile }}px;
    --faq-split-ratio: {{ section.settings.content_width }}%;
    --faq-btn-bg: {{ section.settings.button_bg_color }};
    --faq-btn-text: {{ section.settings.button_text_color }};
    --faq-btn-border: {{ section.settings.button_border_color }};
    --faq-btn-radius: {{ section.settings.button_radius }}px;
    --faq-btn-gradient-1: {{ section.settings.button_gradient_1 }};
    --faq-btn-gradient-2: {{ section.settings.button_gradient_2 }};
    --faq-bg-position-desktop: {{ section.settings.bg_image_position_desktop }};
    --faq-bg-position-mobile: {{ section.settings.bg_image_position_mobile }};
    --faq-bg-overlay-opacity: {{ section.settings.bg_overlay_opacity | divided_by: 100.0 }};
  "
>
  <!-- Background Image -->
  {%- liquid
    assign mobile_bg = section.settings.bg_image_mobile | default: section.settings.bg_image_desktop
  -%}
  {%- if section.settings.bg_image_desktop != blank -%}
    <div class="dw-faq__bg-image-wrapper">
      <picture class="dw-faq__bg-picture">
        {%- if mobile_bg != blank -%}
          <source 
            media="(max-width: 989px)" 
            srcset="{{ mobile_bg | image_url: width: 1000 }},
                    {{ mobile_bg | image_url: width: 2000 }} 2x"
          >
        {%- endif -%}
        <source 
          media="(min-width: 990px)" 
          srcset="{{ section.settings.bg_image_desktop | image_url: width: 1920 }},
                  {{ section.settings.bg_image_desktop | image_url: width: 3840 }} 2x"
        >
        <img 
          src="{{ section.settings.bg_image_desktop | image_url: width: 1920 }}" 
          alt=""
          loading="lazy"
          class="dw-faq__bg-img"
        >
      </picture>
      <div class="dw-faq__bg-overlay"></div>
    </div>
  {%- endif -%}

  {%- if section.settings.enable_background_glow -%}
    <div class="dw-faq__bg-glow">
      <div class="dw-faq__bg-orb dw-faq__bg-orb--1"></div>
      <div class="dw-faq__bg-orb dw-faq__bg-orb--2"></div>
    </div>
  {%- endif -%}

  <div class="dw-faq__container">
    <!-- Image Side -->
    <div class="dw-faq__media">
      {%- if section.settings.image != blank -%}
        <div class="dw-faq__image-wrapper">
          {%- if section.settings.enable_image_glow -%}
            <div class="dw-faq__image-glow"></div>
          {%- endif -%}
          {%- if section.settings.enable_image_border -%}
            <div class="dw-faq__image-border"></div>
          {%- endif -%}
          <img 
            src="{{ section.settings.image | image_url: width: 1200 }}"
            alt="{{ section.settings.image.alt | default: 'FAQ image' | escape }}"
            loading="lazy"
            class="dw-faq__image"
          >
        </div>
      {%- else -%}
        <div class="dw-faq__image-placeholder">
          <div class="dw-faq__placeholder-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
              <circle cx="12" cy="12" r="10"/>
              <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
              <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
          </div>
        </div>
      {%- endif -%}
    </div>

    <!-- Content Side -->
    <div class="dw-faq__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="dw-faq__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="dw-faq__heading{% if section.settings.heading_gradient %} dw-faq__heading--gradient{% endif %}">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="dw-faq__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}

      <div class="dw-faq__list" data-faq-list>
        {%- for block in section.blocks -%}
          <div 
            class="dw-faq__item{% if forloop.first and section.settings.first_open %} is-open{% endif %}"
            data-faq-item
            style="--item-index: {{ forloop.index }};"
            {{ block.shopify_attributes }}
          >
            {%- if section.settings.show_numbers -%}
              <div class="dw-faq__item-number">
                <span class="dw-faq__item-number-text">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
                <div class="dw-faq__item-number-glow"></div>
              </div>
            {%- endif -%}
            
            <div class="dw-faq__item-content">
              <div class="dw-faq__item-border"></div>
              
              <button type="button" class="dw-faq__question" data-faq-trigger>
                <span class="dw-faq__question-text">{{ block.settings.question }}</span>
                <span class="dw-faq__icon">
                  <span class="dw-faq__icon-bar dw-faq__icon-bar--h"></span>
                  <span class="dw-faq__icon-bar dw-faq__icon-bar--v"></span>
                </span>
              </button>
              
              <div class="dw-faq__answer" data-faq-answer>
                <div class="dw-faq__answer-inner">
                  {{ block.settings.answer }}
                </div>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>

      {%- if section.settings.button_text != blank -%}
        <div class="dw-faq__cta">
          <a href="{{ section.settings.button_url }}" class="dw-faq__button dw-faq__button--{{ section.settings.button_style }}">
            <span class="dw-faq__button-bg"></span>
            <span class="dw-faq__button-text">{{ section.settings.button_text }}</span>
            {%- if section.settings.button_icon -%}
              <span class="dw-faq__button-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="5" y1="12" x2="19" y2="12"/>
                  <polyline points="12 5 19 12 12 19"/>
                </svg>
              </span>
            {%- endif -%}
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  /* ==========================================
     BASE
     ========================================== */
  
  .dw-faq {
    position: relative;
    background: var(--faq-bg);
    color: var(--faq-text);
    font-family: 'Poppins', sans-serif;
    overflow: hidden;
  }

  /* ==========================================
     BACKGROUND IMAGE
     ========================================== */

  .dw-faq__bg-image-wrapper {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .dw-faq__bg-picture {
    display: block;
    width: 100%;
    height: 100%;
  }

  .dw-faq__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--faq-bg-position-mobile);
  }

  @media (min-width: 990px) {
    .dw-faq__bg-img {
      object-position: var(--faq-bg-position-desktop);
    }
  }

  .dw-faq__bg-overlay {
    position: absolute;
    inset: 0;
    background: var(--faq-bg);
    opacity: var(--faq-bg-overlay-opacity, 0.85);
  }

  .dw-faq__container {
    position: relative;
    display: flex;
    flex-direction: column;
    z-index: 3;
  }

  @media (min-width: 990px) {
    .dw-faq__container {
      flex-direction: row;
      min-height: 700px;
    }
  }

  /* ==========================================
     BACKGROUND GLOW
     ========================================== */

  .dw-faq__bg-glow {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 2;
  }

  .dw-faq__bg-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.2;
  }

  .dw-faq__bg-orb--1 {
    width: 500px;
    height: 500px;
    background: var(--faq-glow-1);
    top: -150px;
    right: -100px;
    animation: faq-orb-drift 20s ease-in-out infinite;
  }

  .dw-faq__bg-orb--2 {
    width: 400px;
    height: 400px;
    background: var(--faq-glow-2);
    bottom: -100px;
    left: 20%;
    animation: faq-orb-drift 20s ease-in-out infinite reverse;
  }

  @keyframes faq-orb-drift {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(40px, 30px); }
  }

  /* ==========================================
     IMAGE SIDE
     ========================================== */

  .dw-faq__media {
    position: relative;
    min-height: 350px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
  }

  @media (min-width: 990px) {
    .dw-faq__media {
      flex: 0 0 calc(100% - var(--faq-split-ratio, 50%));
      order: 2;
      min-height: auto;
      padding: 60px;
    }
  }

  .dw-faq__image-wrapper {
    position: relative;
    max-width: 100%;
    max-height: 100%;
  }

  .dw-faq__image {
    position: relative;
    max-width: 100%;
    max-height: 500px;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 12px;
    z-index: 2;
  }

  @media (min-width: 990px) {
    .dw-faq__image {
      max-height: 600px;
    }
  }

  /* Image Glow */
  .dw-faq__image-glow {
    position: absolute;
    inset: -20px;
    background: radial-gradient(ellipse at center, var(--faq-accent) 0%, transparent 70%);
    opacity: 0.3;
    filter: blur(40px);
    z-index: 1;
    animation: faq-image-glow 4s ease-in-out infinite;
  }

  @keyframes faq-image-glow {
    0%, 100% { opacity: 0.2; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(1.05); }
  }

  /* Image Animated Border */
  .dw-faq__image-border {
    position: absolute;
    inset: -4px;
    border-radius: 16px;
    background: linear-gradient(
      135deg,
      var(--faq-glow-1),
      var(--faq-glow-2),
      var(--faq-glow-1)
    );
    background-size: 200% 200%;
    animation: faq-border-shift 4s linear infinite;
    z-index: 1;
    opacity: 0.8;
  }

  .dw-faq__image-border::after {
    content: '';
    position: absolute;
    inset: 3px;
    background: var(--faq-bg);
    border-radius: 13px;
  }

  @keyframes faq-border-shift {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  /* Placeholder */
  .dw-faq__image-placeholder {
    width: 300px;
    height: 400px;
    background: linear-gradient(135deg, rgba(255,255,255,0.03) 0%, rgba(255,255,255,0.08) 100%);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px dashed var(--faq-border);
  }

  .dw-faq__placeholder-icon {
    width: 80px;
    height: 80px;
    color: var(--faq-accent);
    opacity: 0.3;
  }

  .dw-faq__placeholder-icon svg {
    width: 100%;
    height: 100%;
  }

  /* ==========================================
     CONTENT SIDE
     ========================================== */

  .dw-faq__content {
    position: relative;
    padding: var(--faq-padding-mobile) 20px;
    z-index: 3;
  }

  @media (min-width: 990px) {
    .dw-faq__content {
      flex: 0 0 var(--faq-split-ratio, 50%);
      order: 1;
      padding: var(--faq-padding-desktop) 60px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
  }

  /* Eyebrow */
  .dw-faq__eyebrow {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--faq-accent);
    margin: 0 0 16px 0;
  }

  @media (min-width: 750px) {
    .dw-faq__eyebrow {
      font-size: 12px;
    }
  }

  /* Heading */
  .dw-faq__heading {
    font-size: 32px;
    font-weight: 700;
    color: var(--faq-heading-color);
    margin: 0 0 16px 0;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .dw-faq__heading--gradient {
    background: linear-gradient(135deg, var(--faq-heading-color), var(--faq-accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  @media (min-width: 750px) {
    .dw-faq__heading {
      font-size: 48px;
      margin-bottom: 20px;
    }
  }

  /* Subheading */
  .dw-faq__subheading {
    font-size: 15px;
    color: var(--faq-text);
    opacity: 0.7;
    margin: 0 0 32px 0;
    line-height: 1.6;
    max-width: 500px;
  }

  @media (min-width: 750px) {
    .dw-faq__subheading {
      font-size: 16px;
      margin-bottom: 40px;
    }
  }

  /* ==========================================
     FAQ LIST
     ========================================== */

  .dw-faq__list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  @media (min-width: 750px) {
    .dw-faq__list {
      gap: 16px;
    }
  }

  /* ==========================================
     FAQ ITEM
     ========================================== */

  .dw-faq__item {
    display: flex;
    gap: 16px;
    opacity: 0;
    transform: translateX(-20px);
    animation: faq-item-enter 0.5s ease forwards;
    animation-delay: calc(var(--item-index, 1) * 0.08s);
  }

  @keyframes faq-item-enter {
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* Number Indicator */
  .dw-faq__item-number {
    position: relative;
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .dw-faq__item-number-text {
    font-size: 12px;
    font-weight: 700;
    color: var(--faq-text);
    opacity: 0.3;
    transition: all 0.3s ease;
    z-index: 2;
    position: relative;
  }

  .dw-faq__item-number-glow {
    position: absolute;
    inset: 0;
    background: var(--faq-accent);
    border-radius: 50%;
    opacity: 0;
    filter: blur(10px);
    transition: opacity 0.3s ease;
  }

  .dw-faq__item.is-open .dw-faq__item-number-text {
    color: var(--faq-accent);
    opacity: 1;
  }

  .dw-faq__item.is-open .dw-faq__item-number-glow {
    opacity: 0.3;
    animation: faq-number-pulse 2s ease-in-out infinite;
  }

  @keyframes faq-number-pulse {
    0%, 100% { opacity: 0.2; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(1.2); }
  }

  /* Item Content Container */
  .dw-faq__item-content {
    flex: 1;
    position: relative;
    background: rgba(255, 255, 255, 0.03);
    border-radius: 12px;
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .dw-faq__item:hover .dw-faq__item-content {
    background: rgba(255, 255, 255, 0.05);
  }

  .dw-faq__item.is-open .dw-faq__item-content {
    background: rgba(255, 255, 255, 0.06);
  }

  /* Animated Border */
  .dw-faq__item-border {
    position: absolute;
    inset: 0;
    border-radius: 12px;
    padding: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      var(--faq-border) 50%,
      transparent 100%
    );
    -webkit-mask: 
      linear-gradient(#fff 0 0) content-box, 
      linear-gradient(#fff 0 0);
    mask: 
      linear-gradient(#fff 0 0) content-box, 
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0.5;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .dw-faq__item.is-open .dw-faq__item-border {
    background: linear-gradient(
      90deg,
      var(--faq-glow-1),
      var(--faq-glow-2),
      var(--faq-glow-1)
    );
    background-size: 200% 100%;
    animation: faq-active-border 2s linear infinite;
    opacity: 1;
  }

  @keyframes faq-active-border {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* Question Button */
  .dw-faq__question {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 20px;
    background: transparent;
    border: none;
    cursor: pointer;
    text-align: left;
    font-family: inherit;
  }

  @media (min-width: 750px) {
    .dw-faq__question {
      padding: 20px 24px;
    }
  }

  .dw-faq__question-text {
    font-size: 14px;
    font-weight: 600;
    color: var(--faq-text);
    line-height: 1.4;
    transition: color 0.3s ease;
  }

  @media (min-width: 750px) {
    .dw-faq__question-text {
      font-size: 15px;
    }
  }

  .dw-faq__item.is-open .dw-faq__question-text {
    color: var(--faq-accent);
  }

  /* Icon */
  .dw-faq__icon {
    position: relative;
    flex-shrink: 0;
    width: 24px;
    height: 24px;
  }

  .dw-faq__icon-bar {
    position: absolute;
    background: var(--faq-accent);
    border-radius: 2px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .dw-faq__icon-bar--h {
    width: 14px;
    height: 2px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .dw-faq__icon-bar--v {
    width: 2px;
    height: 14px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .dw-faq__item.is-open .dw-faq__icon-bar--v {
    transform: translate(-50%, -50%) rotate(90deg);
    opacity: 0;
  }

  .dw-faq__item.is-open .dw-faq__icon-bar--h {
    background: var(--faq-glow-1);
    box-shadow: 0 0 10px var(--faq-glow-1);
  }

  /* Answer */
  .dw-faq__answer {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .dw-faq__item.is-open .dw-faq__answer {
    grid-template-rows: 1fr;
  }

  .dw-faq__answer-inner {
    overflow: hidden;
    padding: 0 20px;
    opacity: 0;
    transform: translateY(-10px);
    transition: all 0.3s ease 0.1s;
  }

  @media (min-width: 750px) {
    .dw-faq__answer-inner {
      padding: 0 24px;
    }
  }

  .dw-faq__item.is-open .dw-faq__answer-inner {
    padding-bottom: 20px;
    opacity: 1;
    transform: translateY(0);
  }

  @media (min-width: 750px) {
    .dw-faq__item.is-open .dw-faq__answer-inner {
      padding-bottom: 24px;
    }
  }

  .dw-faq__answer-inner p {
    font-size: 14px;
    line-height: 1.7;
    color: var(--faq-text);
    opacity: 0.8;
    margin: 0 0 12px 0;
  }

  .dw-faq__answer-inner p:last-child {
    margin-bottom: 0;
  }

  @media (min-width: 750px) {
    .dw-faq__answer-inner p {
      font-size: 15px;
    }
  }

  /* ==========================================
     CTA BUTTON
     ========================================== */

  .dw-faq__cta {
    margin-top: 32px;
  }

  @media (min-width: 750px) {
    .dw-faq__cta {
      margin-top: 40px;
    }
  }

  .dw-faq__button {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 16px 32px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    border-radius: var(--faq-btn-radius, 30px);
    cursor: pointer;
    border: 2px solid transparent;
    font-family: 'Poppins', sans-serif;
    overflow: hidden;
    transition: all 0.3s ease;
  }

  @media (min-width: 750px) {
    .dw-faq__button {
      padding: 18px 40px;
      font-size: 13px;
    }
  }

  .dw-faq__button:hover {
    transform: translateY(-2px);
  }

  .dw-faq__button-text {
    position: relative;
    z-index: 2;
  }

  .dw-faq__button-icon {
    position: relative;
    z-index: 2;
    width: 18px;
    height: 18px;
    transition: transform 0.3s ease;
  }

  .dw-faq__button-icon svg {
    width: 100%;
    height: 100%;
  }

  .dw-faq__button:hover .dw-faq__button-icon {
    transform: translateX(4px);
  }

  /* Primary Style */
  .dw-faq__button--primary {
    background: var(--faq-btn-bg);
    color: var(--faq-btn-text);
    border-color: var(--faq-btn-border, var(--faq-btn-bg));
  }

  .dw-faq__button--primary:hover {
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
  }

  /* Secondary Style */
  .dw-faq__button--secondary {
    background: transparent;
    color: var(--faq-btn-text);
    border-color: var(--faq-btn-border, var(--faq-btn-text));
  }

  .dw-faq__button--secondary:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  /* Gradient Style */
  .dw-faq__button--gradient {
    background: transparent;
    color: var(--faq-btn-text);
    border: none;
  }

  .dw-faq__button--gradient .dw-faq__button-bg {
    position: absolute;
    inset: 0;
    border-radius: var(--faq-btn-radius, 30px);
    padding: 2px;
    background: linear-gradient(
      90deg,
      var(--faq-btn-gradient-1),
      var(--faq-btn-gradient-2),
      var(--faq-btn-gradient-1)
    );
    background-size: 200% 100%;
    animation: faq-btn-gradient 3s linear infinite;
    -webkit-mask: 
      linear-gradient(#fff 0 0) content-box, 
      linear-gradient(#fff 0 0);
    mask: 
      linear-gradient(#fff 0 0) content-box, 
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
  }

  .dw-faq__button--gradient::after {
    content: '';
    position: absolute;
    inset: 2px;
    background: var(--faq-bg);
    border-radius: calc(var(--faq-btn-radius, 30px) - 2px);
    z-index: 1;
  }

  @keyframes faq-btn-gradient {
    0% { background-position: 0% 50%; }
    100% { background-position: 200% 50%; }
  }

  .dw-faq__button--gradient:hover .dw-faq__button-bg {
    animation-duration: 1.5s;
  }

  /* Glow Style */
  .dw-faq__button--glow {
    background: var(--faq-btn-bg);
    color: var(--faq-btn-text);
    border: none;
    box-shadow: 0 0 20px var(--faq-btn-bg);
    animation: faq-btn-glow 2s ease-in-out infinite;
  }

  @keyframes faq-btn-glow {
    0%, 100% { box-shadow: 0 0 20px var(--faq-btn-bg); }
    50% { box-shadow: 0 0 40px var(--faq-btn-bg), 0 0 60px var(--faq-btn-bg); }
  }

  .dw-faq__button--glow:hover {
    animation: none;
    box-shadow: 0 0 50px var(--faq-btn-bg);
  }

  /* Gradient Glow Style */
  .dw-faq__button--gradient-glow {
    background: var(--faq-accent);
    color: var(--faq-btn-text);
    border: none;
  }

  .dw-faq__button--gradient-glow .dw-faq__button-bg {
    position: absolute;
    inset: -4px;
    border-radius: calc(var(--faq-btn-radius, 30px) + 4px);
    background: linear-gradient(
      90deg,
      var(--faq-btn-gradient-1),
      var(--faq-btn-gradient-2),
      var(--faq-btn-gradient-1)
    );
    background-size: 200% 100%;
    animation: faq-btn-gradient 3s linear infinite;
    filter: blur(12px);
    opacity: 0.6;
    z-index: -1;
  }

  .dw-faq__button--gradient-glow:hover .dw-faq__button-bg {
    opacity: 1;
    animation-duration: 1.5s;
  }

  /* ==========================================
     REDUCED MOTION
     ========================================== */

  @media (prefers-reduced-motion: reduce) {
    .dw-faq__bg-orb,
    .dw-faq__image-glow,
    .dw-faq__image-border,
    .dw-faq__item-number-glow,
    .dw-faq__item-border,
    .dw-faq__button--glow,
    .dw-faq__button--gradient .dw-faq__button-bg,
    .dw-faq__button--gradient-glow .dw-faq__button-bg {
      animation: none;
    }

    .dw-faq__item {
      opacity: 1;
      transform: none;
    }

    .dw-faq__answer {
      transition: none;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const faqSection = document.querySelector('[data-faq-section]');
    if (!faqSection) return;

    const faqItems = faqSection.querySelectorAll('[data-faq-item]');
    
    faqItems.forEach(item => {
      const trigger = item.querySelector('[data-faq-trigger]');
      
      trigger.addEventListener('click', function() {
        const isOpen = item.classList.contains('is-open');
        
        // Close all other items
        faqItems.forEach(otherItem => {
          if (otherItem !== item) {
            otherItem.classList.remove('is-open');
          }
        });
        
        // Toggle current item
        item.classList.toggle('is-open', !isOpen);
      });
    });

    // Intersection Observer for entrance animations
    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.style.animationPlayState = 'running';
          }
        });
      }, { threshold: 0.1 });

      faqItems.forEach(item => {
        item.style.animationPlayState = 'paused';
        observer.observe(item);
      });
    }
  });
</script>

