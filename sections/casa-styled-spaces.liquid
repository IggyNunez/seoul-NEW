{% stylesheet %}
/* ══════════════════════════════════════════════════════════════════════════
   CDL STYLED SPACES — Bento gallery grid
   Featured card (2col × 2row) + smaller 4:3 cards
   ══════════════════════════════════════════════════════════════════════════ */

.cdl-spaces {
  background: var(--cdls-bg, #ffffff);
  color: var(--cdls-text, #0a0a0a);
  padding: var(--cdls-pt, 100px) 0 var(--cdls-pb, 100px);
}

/* ── Container ── */
.cdl-spaces__container {
  max-width: var(--cdl-spaces-max-w, 100%);
  margin: 0 auto;
  padding: 0 var(--cdl-spaces-px, 24px);
}

/* ── Header ── */
.cdl-spaces__header {
  text-align: center;
  margin-bottom: 56px;
}

.cdl-spaces__tag {
  display: inline-block;
  font-size: 12px;
  font-weight: 600;
  color: var(--cdls-tag, #9333ea);
  text-transform: uppercase;
  letter-spacing: 2px;
  margin-bottom: 16px;
}

.cdl-spaces__heading {
  font-size: clamp(28px, 5vw, 42px);
  font-weight: 300;
  color: var(--cdls-text, #0a0a0a);
  margin: 0 0 16px 0;
  letter-spacing: -0.5px;
  line-height: 1.2;
}

.cdl-spaces__subtitle {
  font-size: 16px;
  color: var(--cdls-subtitle, #6b7280);
  max-width: 520px;
  margin: 0 auto;
  line-height: 1.6;
}

/* ══════════════════════════════════════════════════════════════════════════
   BENTO GRID
   Desktop: 3 columns — featured spans 2 col + 2 row (LEFT side)
   ══════════════════════════════════════════════════════════════════════════ */

.cdl-spaces__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  grid-template-rows: auto auto;
  gap: 24px;
}

/* ── Card base ── */
.cdl-spaces__card {
  position: relative;
  border-radius: 20px;
  overflow: hidden;
  cursor: pointer;
  text-decoration: none;
  color: #fff;
  display: block;
  aspect-ratio: 4 / 3;
  transition: transform 0.35s ease;
}

.cdl-spaces__card:hover {
  transform: scale(1.02);
}

/* No-content cards: no overlay, no hover box */
.cdl-spaces__card--no-content {
  cursor: default;
}
.cdl-spaces__card--no-content:hover {
  transform: scale(1.01);
}

/* ── Featured card: spans 2 col + 2 row ── */
.cdl-spaces__card--featured {
  grid-column: span 2;
  grid-row: span 2;
  aspect-ratio: auto;
}

/* ── Image ── */
.cdl-spaces__img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
}

.cdl-spaces__card:hover .cdl-spaces__img {
  transform: scale(1.06);
}

/* ── Video background ── */
.cdl-spaces__video {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 0;
  transition: transform 0.5s ease;
}

.cdl-spaces__card:hover .cdl-spaces__video {
  transform: scale(1.06);
}

/* When a video is present, hide the poster image once video loads */
.cdl-spaces__img--poster {
  z-index: 0;
}

.cdl-spaces__card--has-video .cdl-spaces__img--poster {
  opacity: 1;
  transition: opacity 0.6s ease;
}

/* ── Overlay gradient ── */
.cdl-spaces__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.6) 0%, transparent 60%);
  pointer-events: none;
}

/* ── Card content (bottom-left) ── */
.cdl-spaces__card-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 2;
  display: flex;
  align-items: flex-end;
  gap: 12px;
  padding: 24px;
}

/* ── Label — glassmorphism pill ── */
.cdl-spaces__label {
  background: rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  padding: 12px 24px;
  border-radius: 10px;
  color: #fff;
  font-size: 16px;
  font-weight: 500;
  transition: background 0.3s ease;
  white-space: nowrap;
}

.cdl-spaces__card:hover .cdl-spaces__label {
  background: var(--cdls-tag, #9333ea);
  opacity: 0.9;
}

/* ── Caption (shown on featured or hover) ── */
.cdl-spaces__caption {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 400;
  opacity: 0;
  transform: translateY(6px);
  transition: opacity 0.3s ease, transform 0.3s ease;
}

.cdl-spaces__card:hover .cdl-spaces__caption {
  opacity: 1;
  transform: translateY(0);
}

.cdl-spaces__card--featured .cdl-spaces__caption {
  opacity: 1;
  transform: none;
}

/* ── Fallback gradient backgrounds ── */
.cdl-spaces__card:nth-child(1) { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); }
.cdl-spaces__card:nth-child(2) { background: linear-gradient(135deg, #2d132c 0%, #801336 50%, #c72c41 100%); }
.cdl-spaces__card:nth-child(3) { background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 50%, #3d3d3d 100%); }
.cdl-spaces__card:nth-child(4) { background: linear-gradient(135deg, #0d7377 0%, #14a3a8 50%, #32e0c4 100%); }
.cdl-spaces__card:nth-child(5) { background: linear-gradient(135deg, #4a1942 0%, #6b2d5c 50%, #893168 100%); }
.cdl-spaces__card:nth-child(6) { background: linear-gradient(135deg, #1e3c72 0%, #2a5298 50%, #3a7bd5 100%); }

/* ══════════════════════════════════════════════════════════════════════════
   RESPONSIVE — Tablet
   ══════════════════════════════════════════════════════════════════════════ */

@media (max-width: 1024px) {
  .cdl-spaces__container {
    padding: 0 24px;
  }

  .cdl-spaces__grid {
    gap: 16px;
  }

  .cdl-spaces__label {
    font-size: 14px;
    padding: 10px 18px;
  }

  .cdl-spaces__card-content {
    padding: 20px;
  }
}

/* ══════════════════════════════════════════════════════════════════════════
   RESPONSIVE — Mobile
   ══════════════════════════════════════════════════════════════════════════ */

@media (max-width: 768px) {
  .cdl-spaces {
    padding: var(--cdls-mpt, 60px) 0 var(--cdls-mpb, 60px);
  }

  .cdl-spaces__container {
    padding: 0 16px;
  }

  .cdl-spaces__header {
    margin-bottom: 32px;
  }

  .cdl-spaces__tag {
    font-size: 11px;
    margin-bottom: 12px;
  }

  .cdl-spaces__subtitle {
    font-size: 14px;
  }

  /* Mobile grid: featured full-width 16:9, rest 2-col squares */
  .cdl-spaces__grid {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto;
    gap: 8px;
  }

  .cdl-spaces__card {
    border-radius: 12px;
    aspect-ratio: 1 / 1;
  }

  .cdl-spaces__card--featured {
    grid-column: 1 / -1;
    grid-row: auto;
    aspect-ratio: 16 / 9;
  }

  .cdl-spaces__card-content {
    padding: 12px;
  }

  .cdl-spaces__label {
    font-size: 10px;
    font-weight: 500;
    padding: 6px 12px;
    border-radius: 6px;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .cdl-spaces__caption {
    display: none;
  }

  /* When last card should span full-width (odd count) */
  .cdl-spaces__grid--last-wide > .cdl-spaces__card:last-child:not(.cdl-spaces__card--featured) {
    grid-column: 1 / -1;
    aspect-ratio: 16 / 9;
  }
}

@media (max-width: 480px) {
  .cdl-spaces__card-content {
    padding: 10px;
  }

  .cdl-spaces__label {
    font-size: 9px;
    padding: 5px 10px;
  }
}
{% endstylesheet %}
