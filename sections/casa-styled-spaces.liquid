{%- comment -%}
  Seoul Glow Lab - Styled Spaces Gallery
  Bento grid: first card featured (spans 2 col + 2 row), remaining 4/3 aspect cards
  Conversion section — shows product in real room settings
{%- endcomment -%}

{%- liquid
  assign s = section.settings
  assign tag_text  = s.tag_text
  assign heading   = s.heading
  assign subtitle  = s.subtitle

  assign bg_color   = s.bg_color | default: '#ffffff'
  assign text_color = s.text_color | default: '#0a0a0a'
  assign tag_color  = s.tag_color | default: '#9333ea'
  assign subtitle_color = s.subtitle_color | default: '#6b7280'

  assign mobile_last_card = s.mobile_last_card | default: 'auto'

  assign padding_top          = s.padding_top | default: 100
  assign padding_bottom       = s.padding_bottom | default: 100
  assign padding_mobile_top   = s.padding_mobile_top | default: 60
  assign padding_mobile_bottom = s.padding_mobile_bottom | default: 60
-%}

<section
  class="cdl-spaces"
  id="cdl-spaces-{{ section.id }}"
  style="
    --cdls-bg: {{ bg_color }};
    --cdls-text: {{ text_color }};
    --cdls-pt: {{ padding_top }}px;
    --cdls-pb: {{ padding_bottom }}px;
    --cdls-tag: {{ tag_color }};
    --cdls-subtitle: {{ subtitle_color }};
    --cdls-mpt: {{ padding_mobile_top }}px;
    --cdls-mpb: {{ padding_mobile_bottom }}px;
    --cdl-spaces-max-w: {% case section.settings.section_width %}{% when 'full' %}100%{% when 'wide' %}1600px{% when 'narrow' %}1200px{% else %}1400px{% endcase %};
    --cdl-spaces-px: {% if section.settings.section_width == 'full' %}24px{% else %}40px{% endif %};
  "
>
  <div class="cdl-spaces__container">
    {%- comment -%} Header {%- endcomment -%}
    <div class="cdl-spaces__header">
      {%- if tag_text != blank -%}
        <span class="cdl-spaces__tag">{{ tag_text }}</span>
      {%- endif -%}
      {%- if heading != blank -%}
        <h2 class="cdl-spaces__heading">{{ heading }}</h2>
      {%- endif -%}
      {%- if subtitle != blank -%}
        <p class="cdl-spaces__subtitle">{{ subtitle }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} Bento Grid {%- endcomment -%}
    {%- liquid
      assign non_featured_count = 0
      for block in section.blocks
        unless forloop.first
          if block.type == 'space'
            assign non_featured_count = non_featured_count | plus: 1
          endif
        endunless
      endfor
      assign is_odd = non_featured_count | modulo: 2
      assign show_last_wide = false
      if mobile_last_card == 'wide'
        assign show_last_wide = true
      elsif mobile_last_card == 'auto' and is_odd == 1
        assign show_last_wide = true
      endif
    -%}
    <div class="cdl-spaces__grid{% if show_last_wide %} cdl-spaces__grid--last-wide{% endif %}">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'space' -%}
            {%- liquid
              assign has_hosted_video = false
              assign has_ext_video = false
              if block.settings.video != blank
                assign has_hosted_video = true
              endif
              if block.settings.video_url != blank
                assign has_ext_video = true
              endif
            -%}
            {%- assign _has_link = false -%}
            {%- if block.settings.link != blank -%}{%- assign _has_link = true -%}{%- endif -%}
            {%- assign _has_content = false -%}
            {%- if block.settings.title != blank or block.settings.caption != blank -%}{%- assign _has_content = true -%}{%- endif -%}
            <{% if _has_link %}a href="{{ block.settings.link }}"{% else %}div{% endif %}
              class="cdl-spaces__card{% if forloop.first %} cdl-spaces__card--featured{% endif %}{% if has_hosted_video or has_ext_video %} cdl-spaces__card--has-video{% endif %}{% unless _has_content %} cdl-spaces__card--no-content{% endunless %}"
              {{ block.shopify_attributes }}
            >
              {%- comment -%} Video background (Shopify-hosted takes priority) {%- endcomment -%}
              {%- if has_hosted_video -%}
                <video
                  class="cdl-spaces__video"
                  autoplay
                  loop
                  muted
                  playsinline
                  {%- if block.settings.image != blank %}
                    poster="{{ block.settings.image | image_url: width: 1400 }}"
                  {%- endif %}
                >
                  {%- for source in block.settings.video.sources -%}
                    <source src="{{ source.url }}" type="{{ source.mime_type }}">
                  {%- endfor -%}
                </video>
              {%- elsif has_ext_video -%}
                <video
                  class="cdl-spaces__video"
                  src="{{ block.settings.video_url }}"
                  autoplay
                  loop
                  muted
                  playsinline
                  {%- if block.settings.image != blank %}
                    poster="{{ block.settings.image | image_url: width: 1400 }}"
                  {%- endif %}
                ></video>
              {%- endif -%}

              {%- comment -%} Image background (fallback when no video, or poster for video) {%- endcomment -%}
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 1400 }}"
                  srcset="
                    {{ block.settings.image | image_url: width: 600 }} 600w,
                    {{ block.settings.image | image_url: width: 900 }} 900w,
                    {{ block.settings.image | image_url: width: 1400 }} 1400w
                  "
                  sizes="{% if forloop.first %}(max-width: 768px) 100vw, 66vw{% else %}(max-width: 768px) 50vw, 33vw{% endif %}"
                  alt="{{ block.settings.title | escape }}"
                  class="cdl-spaces__img{% if has_hosted_video or has_ext_video %} cdl-spaces__img--poster{% endif %}"
                  loading="lazy"
                  width="700"
                  height="525"
                >
              {%- endif -%}
              {%- if _has_content -%}
                <div class="cdl-spaces__overlay"></div>
                <div class="cdl-spaces__card-content">
                  {%- if block.settings.title != blank -%}
                    <span class="cdl-spaces__label">{{ block.settings.title }}</span>
                  {%- endif -%}
                  {%- if block.settings.caption != blank -%}
                    <span class="cdl-spaces__caption">{{ block.settings.caption }}</span>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </{% if _has_link %}a{% else %}div{% endif %}>
          {%- when '@app' -%}
            <div {{ block.shopify_attributes }}>
              {%- render block -%}
            </div>
          {%- when 'custom-liquid' -%}
            <div {{ block.shopify_attributes }}>
              {{ block.settings.custom_liquid }}
            </div>
        {%- endcase -%}
      {%- endfor -%}

      {%- comment -%} Fallback if no blocks {%- endcomment -%}
      {%- if section.blocks.size == 0 -%}
        <div class="cdl-spaces__card cdl-spaces__card--featured">
          <div class="cdl-spaces__overlay"></div>
          <div class="cdl-spaces__card-content">
            <span class="cdl-spaces__label">Gaming Setup</span>
          </div>
        </div>
        <div class="cdl-spaces__card">
          <div class="cdl-spaces__overlay"></div>
          <div class="cdl-spaces__card-content">
            <span class="cdl-spaces__label">Living Room</span>
          </div>
        </div>
        <div class="cdl-spaces__card">
          <div class="cdl-spaces__overlay"></div>
          <div class="cdl-spaces__card-content">
            <span class="cdl-spaces__label">Home Office</span>
          </div>
        </div>
        <div class="cdl-spaces__card">
          <div class="cdl-spaces__overlay"></div>
          <div class="cdl-spaces__card-content">
            <span class="cdl-spaces__label">Bedroom</span>
          </div>
        </div>
        <div class="cdl-spaces__card">
          <div class="cdl-spaces__overlay"></div>
          <div class="cdl-spaces__card-content">
            <span class="cdl-spaces__label">Entertainment Room</span>
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<script>
(function() {
  var root = document.getElementById('cdl-spaces-{{ section.id }}');
  if (!root) return;

  /* Fade out poster image once video starts playing */
  root.querySelectorAll('.cdl-spaces__card--has-video').forEach(function(card) {
    var video = card.querySelector('.cdl-spaces__video');
    var poster = card.querySelector('.cdl-spaces__img--poster');
    if (!video || !poster) return;

    video.addEventListener('playing', function() {
      poster.style.opacity = '0';
    }, { once: true });
  });

  /* Pause off-screen videos for performance */
  if ('IntersectionObserver' in window) {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        var video = entry.target;
        if (entry.isIntersecting) {
          video.play().catch(function() {});
        } else {
          video.pause();
        }
      });
    }, { rootMargin: '100px' });

    root.querySelectorAll('.cdl-spaces__video').forEach(function(v) {
      observer.observe(v);
    });
  }
})();
</script>

