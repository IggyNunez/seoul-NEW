        { "type": "question", "settings": { "question": "I received a wrong item. What should I do?", "answer": "<p>We sincerely apologize for the mix-up. Please contact us at <strong>hello@seoulglow.com</strong> with your order number, details of the item you received versus what you ordered, and a photo of the incorrect item. Our team will arrange for the correct item to be sent to you as quickly as possible.</p>" } },
        { "type": "question", "settings": { "question": "I received a damaged item. What should I do?", "answer": "<p>We're sorry to hear that. Please report any damage to <strong>hello@seoulglow.com</strong> within 48 hours of receiving your order. Include photos of the damaged item and packaging. We will arrange a <strong>free replacement or full refund</strong> — whichever you prefer.</p>" } },
        { "type": "question", "settings": { "question": "Can I change my order after placing it?", "answer": "<p>Yes, changes may be possible if your order has not yet shipped. Please contact our support team with your <strong>order number</strong> and the modification you'd like. We'll do our best to accommodate your request.</p>" } },
        { "type": "question", "settings": { "question": "What currency are orders processed in?", "answer": "<p>All orders are processed in your <strong>local currency</strong>. No currency conversion is needed — what you see at checkout is what you pay.</p>" } },
        { "type": "question", "settings": { "question": "Can I track my order?", "answer": "<p>Absolutely! Once your order ships, you'll receive a <strong>confirmation email with a tracking ID</strong>. Please allow 1–3 business days for tracking information to become active in the carrier's system.</p>" } },
        { "type": "question", "settings": { "question": "Can I return my order?", "answer": "<p>Yes. Email our support team within <strong>30 days</strong> of receiving your order to initiate a return. During holiday sales, we offer an extended <strong>60-day return window</strong> for your convenience.</p>" } },

        { "type": "category", "settings": { "title": "Shipping", "icon": "truck" } },
        { "type": "question", "settings": { "question": "Do you ship internationally?", "answer": "<p>Yes! We offer <strong>free worldwide shipping</strong> via DHL, FedEx, and UPS. No matter where you are, we'll deliver your order to your doorstep.</p>" } },
        { "type": "question", "settings": { "question": "Will multiple products be shipped separately?", "answer": "<p>For larger products, items may ship in <strong>separate packages</strong> to ensure safe delivery. If you receive one package before the other, please allow a few additional days for the remaining items to arrive.</p>" } },
        { "type": "question", "settings": { "question": "How long will it take to receive my order?", "answer": "<p>Most orders arrive within <strong>3–7 business days</strong> via our express delivery service. Delivery times may vary slightly based on your location.</p>" } },
        { "type": "question", "settings": { "question": "What shipping carriers do you use?", "answer": "<p>We partner with <strong>DHL, FedEx, and UPS</strong>. The carrier is selected automatically based on your delivery address to ensure the fastest and most reliable service.</p>" } },
        { "type": "question", "settings": { "question": "What if my package is lost or stolen?", "answer": "<p>Please first file a report with the shipping carrier. Then contact us at <strong>hello@seoulglow.com</strong> and we'll work together to resolve the situation and ensure you receive your order.</p>" } },

