        { "type": "question", "settings": { "question": "What warranty do your products come with?", "answer": "<p>All Seoul Glow Lab products include a <strong>2-Year Warranty</strong> covering manufacturing defects and malfunctions. If an issue arises, we'll provide a full replacement or refund.</p>" } },
        { "type": "question", "settings": { "question": "How long will the product last?", "answer": "<p>Our LED lighting is rated for <strong>50,000+ hours</strong> of use. That's over <strong>13 years</strong> at 10 hours of daily use — exceptional longevity for premium lighting.</p>" } },
        { "type": "question", "settings": { "question": "Do your products come with a plug?", "answer": "<p>Yes. All products include a <strong>UL-listed plug</strong> that is compatible worldwide with any standard outlet (100V–240V). No adapters needed.</p>" } },

