    text-align: center;
    font-size: 14px;
    color: var(--cart-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .dw-cart__continue-btn:hover {
    color: var(--cart-accent);
  }

  /* Trust Badges */
  .dw-cart__trust {
    display: flex;
    flex-wrap: wrap;
    gap: 12px 16px;
    margin-top: 24px;
    padding-top: 20px;
