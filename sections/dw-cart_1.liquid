    font-weight: 700;
  }

  .dw-cart__summary-note {
    font-size: 12px;
    color: var(--cart-muted);
    margin: 0 0 20px;
  }

  /* Cart Note */
  .dw-cart__note {
    margin-bottom: 20px;
  }

  .dw-cart__note-label {
    display: block;
    font-size: 13px;
    font-weight: 500;
    margin-bottom: 8px;
  }

  .dw-cart__note-input {
