    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--cart-muted);
  }

  .dw-cart__trust-item svg {
    color: var(--cart-accent);
    flex-shrink: 0;
  }

  /* ==========================================
     BUTTONS
     ========================================== */
  
  .dw-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 28px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    border-radius: 6px;
    border: 2px solid transparent;
    cursor: pointer;
    transition: all 0.2s ease;
    position: relative;
  }

  .dw-btn--full {
    width: 100%;
  }

  .dw-btn--primary {
    background: var(--cart-accent);
    color: var(--cart-accent-text);
    border-color: var(--cart-accent);
  }

  .dw-btn--primary:hover {
    filter: brightness(0.9);
  }

  .dw-btn--secondary {
    background: transparent;
    color: var(--cart-text);
    border-color: var(--cart-border);
  }

  .dw-btn--secondary:hover {
    border-color: var(--cart-accent);
    color: var(--cart-accent);
  }

  .dw-btn--gradient {
    background: transparent;
    color: var(--cart-text);
    border: none;
    overflow: hidden;
  }

  .dw-btn--gradient::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 6px;
    padding: 2px;
    background: linear-gradient(90deg, var(--cart-accent), #e08fbc, var(--cart-accent));
    background-size: 200% 100%;
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    animation: gradient-shift 3s linear infinite;
  }

  .dw-btn--gradient::after {
    content: '';
    position: absolute;
    inset: 2px;
    background: var(--cart-bg);
    border-radius: 4px;
    z-index: -1;
  }

  .dw-btn--gradient span {
    position: relative;
    z-index: 1;
  }

  .dw-btn--gradient-glow {
    background: var(--cart-accent);
    color: var(--cart-accent-text);
    border: none;
    box-shadow: 0 0 20px rgba(198, 215, 107, 0.4);
  }

  .dw-btn--gradient-glow:hover {
    box-shadow: 0 0 30px rgba(198, 215, 107, 0.6);
  }

  @keyframes gradient-shift {
    0% { background-position: 0% 50%; }
    100% { background-position: 200% 50%; }
  }

  /* ==========================================
     UPSELLS
     ========================================== */
  
  .dw-cart__blocks {
    margin-top: 48px;
  }

  .dw-cart__upsell {
    background: var(--cart-card-bg);
    border: 1px solid var(--cart-border);
    border-radius: 12px;
    padding: 24px;
  }

  .dw-cart__upsell-title {
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 16px;
  }

  .dw-cart__upsell-products {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 16px;
  }

  .dw-cart__upsell-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px;
    background: var(--cart-bg);
    border: 1px solid var(--cart-border);
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease;
  }

  .dw-cart__upsell-item:hover {
    border-color: var(--cart-accent);
  }

  .dw-cart__upsell-image {
    width: 60px;
    height: 60px;
    border-radius: 6px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .dw-cart__upsell-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .dw-cart__upsell-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .dw-cart__upsell-name {
    font-size: 14px;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .dw-cart__upsell-price {
    font-size: 13px;
    color: var(--cart-accent);
    font-weight: 600;
  }

  /* ==========================================
     REDUCED MOTION
     ========================================== */
  
  @media (prefers-reduced-motion: reduce) {
    .dw-cart__glow-orb,
    .dw-btn--gradient::before {
      animation: none;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const cartSection = document.querySelector('.dw-cart');
    if (!cartSection) return;

    // Quantity buttons
    cartSection.querySelectorAll('[data-action]').forEach(button => {
      button.addEventListener('click', function() {
        const action = this.dataset.action;
        const line = parseInt(this.dataset.line);
        const input = cartSection.querySelector(`input[data-line="${line}"]`);
        
        if (!input) return;
        
        let quantity = parseInt(input.value);
        
        if (action === 'increase') {
          quantity++;
        } else if (action === 'decrease') {
          quantity = Math.max(0, quantity - 1);
        } else if (action === 'remove') {
          quantity = 0;
        }
        
        updateCart(line, quantity);
      });
    });

    // Quantity input change
    cartSection.querySelectorAll('.dw-cart__qty-input').forEach(input => {
      input.addEventListener('change', function() {
        const line = parseInt(this.dataset.line);
        const quantity = Math.max(0, parseInt(this.value) || 0);
        updateCart(line, quantity);
      });
    });

    // Cart note
    const noteInput = cartSection.querySelector('.dw-cart__note-input');
    if (noteInput) {
      let noteTimeout;
      noteInput.addEventListener('input', function() {
        clearTimeout(noteTimeout);
        noteTimeout = setTimeout(() => {
          updateCartNote(this.value);
        }, 500);
      });
    }

    function updateCart(line, quantity) {
      fetch('/cart/change.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          line: line,
          quantity: quantity
        })
      })
      .then(response => response.json())
      .then(data => {
        window.location.reload();
      })
      .catch(error => {
        console.error('Error updating cart:', error);
      });
    }

    function updateCartNote(note) {
      fetch('/cart/update.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          note: note
        })
      })
      .catch(error => {
        console.error('Error updating note:', error);
      });
    }
  });
</script>

