  /* Quantity Controls */
  .dw-cart__item-quantity {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--cart-border);
    border-radius: 6px;
    overflow: hidden;
    margin-top: auto;
    width: fit-content;
  }

  .dw-cart__qty-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
