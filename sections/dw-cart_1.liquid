    height: 32px;
    text-align: center;
    font-size: 14px;
    font-weight: 500;
    background: transparent;
    border: none;
    border-left: 1px solid var(--cart-border);
    border-right: 1px solid var(--cart-border);
    color: inherit;
    -moz-appearance: textfield;
  }

  .dw-cart__qty-input::-webkit-outer-spin-button,
  .dw-cart__qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  /* Item Actions (Desktop) */
  .dw-cart__item-actions {
    display: none;
    flex-direction: column;
    align-items: flex-end;
    justify-content: space-between;
    gap: 8px;
  }

  @media (min-width: 750px) {
    .dw-cart__item-actions {
      display: flex;
    }
  }

  .dw-cart__item-price--desktop {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
  }

  .dw-cart__price {
    font-size: 15px;
    font-weight: 600;
  }

  .dw-cart__price--compare {
    font-size: 13px;
    font-weight: 400;
    color: var(--cart-muted);
    text-decoration: line-through;
  }

  .dw-cart__price--sale {
    color: var(--cart-accent);
  }

  .dw-cart__remove-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: transparent;
    border: 1px solid var(--cart-border);
    border-radius: 6px;
    color: var(--cart-muted);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .dw-cart__remove-btn:hover {
    background: #ef4444;
    border-color: #ef4444;
    color: #fff;
  }

  /* ==========================================
     SUMMARY SIDEBAR
     ========================================== */
  
  .dw-cart__summary {
    position: relative;
    background: var(--cart-summary-bg);
    border: 1px solid var(--cart-border);
    border-radius: 12px;
    overflow: hidden;
    height: fit-content;
  }

  .dw-cart__summary--sticky {
    position: sticky;
    top: 120px;
  }

  .dw-cart__summary--glass {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  .dw-cart--light .dw-cart__summary--glass {
    background: rgba(0, 0, 0, 0.02);
  }

  /* Cyber Border */
  .dw-cart__summary-border {
    position: absolute;
    inset: 0;
    border-radius: 12px;
    padding: 2px;
    background: linear-gradient(135deg, var(--cart-accent), transparent 50%, var(--cart-accent));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    opacity: 0.5;
  }

  .dw-cart__summary-inner {
    padding: 24px;
    position: relative;
  }

  @media (min-width: 750px) {
    .dw-cart__summary-inner {
      padding: 32px;
    }
  }

  .dw-cart__summary-title {
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 24px;
  }

  .dw-cart__summary-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 0;
  }

  .dw-cart__summary-label {
    font-size: 14px;
    color: var(--cart-muted);
  }

  .dw-cart__summary-row--discount .dw-cart__summary-label {
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--cart-accent);
  }

  .dw-cart__summary-value {
    font-size: 14px;
    font-weight: 500;
  }

  .dw-cart__summary-value--muted {
    font-weight: 400;
    color: var(--cart-muted);
    font-size: 13px;
  }

  .dw-cart__summary-value--discount {
    color: var(--cart-accent);
  }

  .dw-cart__summary-divider {
