{% comment %}
  DoingWell Comparison Chart Section v2
  - Cyber-themed with animated gradients
  - Glowing win indicators
  - Staggered entrance animations
  - Dramatic visual hierarchy
  - Floating product images with glow
  - Victory counter
{% endcomment %}

<section 
  class="dw-compare"
  data-compare-section
  style="
    --compare-bg: {{ section.settings.background_color }};
    --compare-text: {{ section.settings.text_color }};
    --compare-accent: {{ section.settings.accent_color }};
    --compare-win: {{ section.settings.win_color }};
    --compare-lose: {{ section.settings.lose_color }};
    --compare-glow-1: {{ section.settings.glow_color_1 }};
    --compare-glow-2: {{ section.settings.glow_color_2 }};
    --compare-header-bg: {{ section.settings.header_bg_color }};
    --compare-row-bg: {{ section.settings.row_bg_color }};
    --compare-row-alt-bg: {{ section.settings.row_alt_bg_color }};
    --compare-border: {{ section.settings.border_color }};
    --compare-padding-desktop: {{ section.settings.padding_desktop }}px;
    --compare-padding-mobile: {{ section.settings.padding_mobile }}px;
  "
>
  {%- if section.settings.enable_background_glow -%}
    <div class="dw-compare__bg-glow">
      <div class="dw-compare__bg-orb dw-compare__bg-orb--1"></div>
      <div class="dw-compare__bg-orb dw-compare__bg-orb--2"></div>
    </div>
  {%- endif -%}

  <div class="dw-compare__container">
    {%- if section.settings.heading != blank -%}
      <h2 class="dw-compare__heading">
        <span class="dw-compare__heading-text{% if section.settings.heading_gradient %} dw-compare__heading-text--gradient{% endif %}">{{ section.settings.heading }}</span>
      </h2>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="dw-compare__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="dw-compare__table-wrapper">
      <!-- Product Images with Glow -->
      <div class="dw-compare__products">
        <div class="dw-compare__product dw-compare__product--winner">
          {%- if section.settings.enable_winner_badge -%}
            <div class="dw-compare__winner-badge">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>
              <span>WINNER</span>
            </div>
          {%- endif -%}
          <div class="dw-compare__product-glow"></div>
          {%- if section.settings.product_1_image != blank -%}
            <img 
              src="{{ section.settings.product_1_image | image_url: width: 400 }}"
              alt="{{ section.settings.product_1_name | escape }}"
              loading="lazy"
              class="dw-compare__product-img"
            >
          {%- endif -%}
        </div>
        <div class="dw-compare__vs">
          <span>VS</span>
        </div>
        <div class="dw-compare__product dw-compare__product--loser">
          {%- if section.settings.product_2_image != blank -%}
            <img 
              src="{{ section.settings.product_2_image | image_url: width: 400 }}"
              alt="{{ section.settings.product_2_name | escape }}"
              loading="lazy"
              class="dw-compare__product-img dw-compare__product-img--muted"
            >
          {%- endif -%}
        </div>
      </div>

      <!-- Comparison Table -->
      <div class="dw-compare__table" data-compare-table>
        <!-- Animated Border -->
        <div class="dw-compare__table-border"></div>
        
        <!-- Header Row -->
        <div class="dw-compare__header">
          <div class="dw-compare__header-cell dw-compare__header-cell--winner">
            <span class="dw-compare__header-name">{{ section.settings.product_1_name }}</span>
            {%- assign win_count = 0 -%}
            {%- for block in section.blocks -%}
              {%- unless block.settings.product_2_has_feature -%}
                {%- assign win_count = win_count | plus: 1 -%}
              {%- endunless -%}
            {%- endfor -%}
            <span class="dw-compare__score" data-win-count="{{ win_count }}">
              <span class="dw-compare__score-num">{{ win_count }}</span>
              <span class="dw-compare__score-label">WINS</span>
            </span>
          </div>
          <div class="dw-compare__header-cell dw-compare__header-cell--loser">
            <span class="dw-compare__header-name">{{ section.settings.product_2_name }}</span>
          </div>
        </div>

        <!-- Comparison Rows -->
        <div class="dw-compare__rows" data-compare-rows>
          {%- assign visible_rows = section.settings.visible_rows -%}
          {%- for block in section.blocks -%}
            {%- assign is_win = true -%}
            {%- if block.settings.product_2_has_feature -%}
              {%- assign is_win = false -%}
            {%- endif -%}
            <div 
              class="dw-compare__row{% if forloop.index > visible_rows %} dw-compare__row--hidden{% endif %}{% if is_win %} dw-compare__row--win{% endif %}"
              data-row-index="{{ forloop.index }}"
              style="--row-index: {{ forloop.index }};"
              {{ block.shopify_attributes }}
            >
              <!-- Left Cell (Your Product - Winner) -->
              <div class="dw-compare__cell dw-compare__cell--left{% if is_win %} dw-compare__cell--winning{% endif %}">
                {%- if is_win -%}
                  <span class="dw-compare__icon dw-compare__icon--check">
                    <span class="dw-compare__icon-glow"></span>
                    <svg viewBox="0 0 24 24" fill="none">
                      <circle cx="12" cy="12" r="10" fill="currentColor"/>
                      <path d="M8 12l3 3 5-5" stroke="#000" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                {%- else -%}
                  <span class="dw-compare__icon dw-compare__icon--check dw-compare__icon--neutral">
                    <svg viewBox="0 0 24 24" fill="none">
                      <circle cx="12" cy="12" r="10" fill="currentColor" opacity="0.3"/>
                      <path d="M8 12l3 3 5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                {%- endif -%}
                <div class="dw-compare__cell-content">
                  <span class="dw-compare__cell-text{% if is_win %} dw-compare__cell-text--highlight{% endif %}">{{ block.settings.product_1_text }}</span>
                  {%- if block.settings.product_1_subtext != blank -%}
                    <span class="dw-compare__cell-subtext{% if is_win %} dw-compare__cell-subtext--highlight{% endif %}">{{ block.settings.product_1_subtext }}</span>
                  {%- endif -%}
                </div>
              </div>
              
              <!-- Right Cell (Competitor) -->
              <div class="dw-compare__cell dw-compare__cell--right{% unless block.settings.product_2_has_feature %} dw-compare__cell--losing{% endunless %}">
                {%- if block.settings.product_2_has_feature -%}
                  <span class="dw-compare__icon dw-compare__icon--check dw-compare__icon--neutral">
                    <svg viewBox="0 0 24 24" fill="none">
                      <circle cx="12" cy="12" r="10" fill="currentColor" opacity="0.3"/>
                      <path d="M8 12l3 3 5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                {%- else -%}
                  <span class="dw-compare__icon dw-compare__icon--x">
                    <svg viewBox="0 0 24 24" fill="none">
                      <circle cx="12" cy="12" r="10" fill="currentColor" opacity="0.2"/>
                      <path d="M15 9l-6 6M9 9l6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                {%- endif -%}
                <div class="dw-compare__cell-content">
                  <span class="dw-compare__cell-text dw-compare__cell-text--muted">{{ block.settings.product_2_text }}</span>
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>

        <!-- See More Toggle -->
        {%- if section.blocks.size > visible_rows -%}
          <button type="button" class="dw-compare__toggle" data-compare-toggle>
            <span class="dw-compare__toggle-text">
              <span class="dw-compare__toggle-more">{{ section.settings.see_more_text }} <span class="dw-compare__toggle-count">(+{{ section.blocks.size | minus: visible_rows }} more)</span></span>
              <span class="dw-compare__toggle-less">{{ section.settings.see_less_text }}</span>
            </span>
            <span class="dw-compare__toggle-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </span>
          </button>
        {%- endif -%}
      </div>
    </div>

    <!-- CTA Button -->
    {%- if section.settings.button_text != blank -%}
      <div class="dw-compare__cta">
        {%- if section.settings.button_opens_modal and section.settings.modal_image != blank -%}
          <button type="button" class="dw-compare__button dw-compare__button--{{ section.settings.button_style }}" data-compare-modal-open>
            <span class="dw-compare__button-bg"></span>
            <span class="dw-compare__button-text">{{ section.settings.button_text }}</span>
          </button>
        {%- else -%}
          <a href="{{ section.settings.button_url }}" class="dw-compare__button dw-compare__button--{{ section.settings.button_style }}">
            <span class="dw-compare__button-bg"></span>
            <span class="dw-compare__button-text">{{ section.settings.button_text }}</span>
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>

  <!-- Modal -->
  {%- if section.settings.button_opens_modal and section.settings.modal_image != blank -%}
    <div class="dw-compare__modal" data-compare-modal aria-hidden="true">
      <div class="dw-compare__modal-overlay" data-compare-modal-close></div>
      <div class="dw-compare__modal-container">
        <button type="button" class="dw-compare__modal-close" data-compare-modal-close aria-label="Close modal">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
        <div class="dw-compare__modal-content">
          <img 
            src="{{ section.settings.modal_image | image_url: width: 1800 }}"
            alt="Supplement Facts"
            loading="lazy"
          >
        </div>
      </div>
    </div>
  {%- endif -%}
</section>

<style>
  /* ==========================================
     BASE & CONTAINER
     ========================================== */
  
  .dw-compare {
    position: relative;
    background: var(--compare-bg);
    color: var(--compare-text);
    padding: var(--compare-padding-mobile) 20px;
    font-family: 'Poppins', sans-serif;
    overflow: hidden;
  }

  @media (min-width: 750px) {
    .dw-compare {
      padding: var(--compare-padding-desktop) 50px;
    }
  }

  .dw-compare__container {
    position: relative;
    max-width: 1000px;
    margin: 0 auto;
    z-index: 2;
  }

  /* ==========================================
     BACKGROUND GLOW
     ========================================== */

  .dw-compare__bg-glow {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 1;
  }

  .dw-compare__bg-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.3;
    animation: compare-bg-float 15s ease-in-out infinite;
  }

  .dw-compare__bg-orb--1 {
    width: 400px;
    height: 400px;
    background: var(--compare-glow-1);
    top: -100px;
    left: -100px;
  }

  .dw-compare__bg-orb--2 {
    width: 300px;
    height: 300px;
    background: var(--compare-glow-2);
    bottom: -50px;
    right: -50px;
    animation-delay: -7s;
  }

  @keyframes compare-bg-float {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(30px, 20px) scale(1.1); }
  }

  /* ==========================================
     HEADING
     ========================================== */

  .dw-compare__heading {
    text-align: center;
    margin: 0 0 16px 0;
  }

  .dw-compare__heading-text {
    font-size: 32px;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .dw-compare__heading-text--gradient {
    background: linear-gradient(135deg, var(--compare-win), var(--compare-glow-2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  @media (min-width: 750px) {
    .dw-compare__heading-text {
      font-size: 48px;
    }
  }

  .dw-compare__subheading {
    text-align: center;
    font-size: 16px;
    opacity: 0.7;
    margin: 0 0 40px 0;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  @media (min-width: 750px) {
    .dw-compare__subheading {
      font-size: 18px;
      margin-bottom: 50px;
    }
  }

  /* ==========================================
     PRODUCT IMAGES
     ========================================== */

  .dw-compare__products {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-bottom: -20px;
    position: relative;
    z-index: 3;
  }

  @media (min-width: 750px) {
    .dw-compare__products {
      gap: 40px;
      margin-bottom: -30px;
    }
  }

  .dw-compare__product {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .dw-compare__product--winner {
    animation: compare-float 4s ease-in-out infinite;
  }

  @keyframes compare-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  .dw-compare__product-glow {
    position: absolute;
    width: 120%;
    height: 120%;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, var(--compare-win) 0%, transparent 70%);
    opacity: 0.4;
    filter: blur(30px);
    animation: compare-pulse-glow 3s ease-in-out infinite;
  }

  @keyframes compare-pulse-glow {
    0%, 100% { opacity: 0.3; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 0.5; transform: translate(-50%, -50%) scale(1.1); }
  }

  .dw-compare__product-img {
    position: relative;
    max-width: 100px;
    height: auto;
    z-index: 2;
  }

  @media (min-width: 750px) {
    .dw-compare__product-img {
      max-width: 140px;
    }
  }

  .dw-compare__product-img--muted {
    opacity: 0.5;
    filter: grayscale(30%);
  }

  /* Winner Badge */
  .dw-compare__winner-badge {
    position: absolute;
    top: -35px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 4px;
    background: var(--compare-win);
    color: #000;
    padding: 4px 10px;
    border-radius: 20px;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.1em;
    white-space: nowrap;
    animation: compare-badge-glow 2s ease-in-out infinite;
  }

  @media (min-width: 750px) {
    .dw-compare__winner-badge {
      top: -40px;
      font-size: 10px;
      padding: 5px 12px;
    }
  }

  .dw-compare__winner-badge svg {
    width: 12px;
    height: 12px;
  }

  @keyframes compare-badge-glow {
    0%, 100% { box-shadow: 0 0 10px var(--compare-win); }
    50% { box-shadow: 0 0 20px var(--compare-win), 0 0 30px var(--compare-win); }
  }

  /* VS Badge */
  .dw-compare__vs {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: var(--compare-bg);
    border: 2px solid var(--compare-border);
    border-radius: 50%;
    font-size: 11px;
    font-weight: 700;
    color: var(--compare-text);
    opacity: 0.6;
    z-index: 4;
  }

  @media (min-width: 750px) {
    .dw-compare__vs {
      width: 50px;
      height: 50px;
      font-size: 13px;
    }
  }

  /* ==========================================
     TABLE
     ========================================== */

  .dw-compare__table {
    position: relative;
    background: var(--compare-row-bg);
    border-radius: 16px;
    overflow: hidden;
  }

  /* Animated Gradient Border */
  .dw-compare__table-border {
    position: absolute;
    inset: 0;
    border-radius: 16px;
    padding: 2px;
    background: linear-gradient(
      90deg,
      var(--compare-glow-1),
      var(--compare-glow-2),
      var(--compare-glow-1),
      var(--compare-glow-2)
    );
    background-size: 300% 100%;
    -webkit-mask: 
      linear-gradient(#fff 0 0) content-box, 
      linear-gradient(#fff 0 0);
    mask: 
      linear-gradient(#fff 0 0) content-box, 
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    animation: compare-border-shift 4s linear infinite;
    pointer-events: none;
  }

  @keyframes compare-border-shift {
    0% { background-position: 0% 50%; }
    100% { background-position: 300% 50%; }
  }

  /* Header */
  .dw-compare__header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: var(--compare-header-bg);
  }

  .dw-compare__header-cell {
    padding: 55px 16px 16px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  @media (min-width: 750px) {
    .dw-compare__header-cell {
      padding: 65px 24px 20px;
      gap: 10px;
    }
  }

  .dw-compare__header-cell--winner {
    border-right: 1px solid rgba(255,255,255,0.1);
  }

  .dw-compare__header-name {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #fff;
  }

  @media (min-width: 750px) {
    .dw-compare__header-name {
      font-size: 13px;
    }
  }

  .dw-compare__header-cell--loser .dw-compare__header-name {
    opacity: 0.6;
  }

  /* Score Badge */
  .dw-compare__score {
    display: flex;
    align-items: center;
    gap: 6px;
    background: var(--compare-win);
    color: #000;
    padding: 4px 12px;
    border-radius: 20px;
    animation: compare-score-pulse 2s ease-in-out infinite;
  }

  .dw-compare__score-num {
    font-size: 16px;
    font-weight: 800;
  }

  .dw-compare__score-label {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.1em;
  }

  @keyframes compare-score-pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.05); }
  }

  /* ==========================================
     ROWS
     ========================================== */

  .dw-compare__rows {
    display: flex;
    flex-direction: column;
  }

  .dw-compare__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-bottom: 1px solid var(--compare-border);
    opacity: 0;
    animation: compare-row-enter 0.5s ease forwards;
    animation-delay: calc(var(--row-index, 1) * 0.05s);
  }

  .dw-compare__row:last-child {
    border-bottom: none;
  }

  .dw-compare__row:nth-child(even) {
    background: var(--compare-row-alt-bg);
  }

  .dw-compare__row--hidden {
    display: none;
  }

  .dw-compare__table.is-expanded .dw-compare__row--hidden {
    display: grid;
  }

  @keyframes compare-row-enter {
    from {
      opacity: 0;
      transform: translateX(-20px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* Win Row Highlight */
  .dw-compare__row--win {
    position: relative;
  }

  .dw-compare__row--win::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--compare-win);
    box-shadow: 0 0 10px var(--compare-win);
  }

  /* Cells */
  .dw-compare__cell {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 14px 12px;
    transition: background 0.2s ease;
  }

  @media (min-width: 750px) {
    .dw-compare__cell {
      padding: 18px 24px;
      gap: 14px;
    }
  }

  .dw-compare__cell--left {
    border-right: 1px solid var(--compare-border);
  }

  .dw-compare__row:hover .dw-compare__cell {
    background: rgba(255,255,255,0.03);
  }

  .dw-compare__cell--winning {
    background: rgba(196, 214, 0, 0.05);
  }

  .dw-compare__row:hover .dw-compare__cell--winning {
    background: rgba(196, 214, 0, 0.1);
  }

  .dw-compare__cell--losing {
    background: rgba(255, 100, 100, 0.03);
  }

  /* Cell Content */
  .dw-compare__cell-content {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
    min-width: 0;
  }

  .dw-compare__cell-text {
    font-size: 12px;
    font-weight: 500;
    color: var(--compare-text);
    line-height: 1.4;
  }

  @media (min-width: 750px) {
    .dw-compare__cell-text {
      font-size: 14px;
    }
  }

  .dw-compare__cell-text--highlight {
    font-weight: 700;
    color: var(--compare-win);
  }

  .dw-compare__cell-text--muted {
    opacity: 0.5;
  }

  .dw-compare__cell-subtext {
    font-size: 10px;
    font-weight: 600;
    color: var(--compare-text);
    opacity: 0.5;
  }

  @media (min-width: 750px) {
    .dw-compare__cell-subtext {
      font-size: 11px;
    }
  }

  .dw-compare__cell-subtext--highlight {
    color: var(--compare-glow-2);
    opacity: 1;
  }

  /* ==========================================
     ICONS
     ========================================== */

  .dw-compare__icon {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    position: relative;
  }

  @media (min-width: 750px) {
    .dw-compare__icon {
      width: 26px;
      height: 26px;
    }
  }

  .dw-compare__icon svg {
    width: 100%;
    height: 100%;
    position: relative;
    z-index: 2;
  }

  /* Winning Check with Glow */
  .dw-compare__icon--check {
    color: var(--compare-win);
  }

  .dw-compare__icon--check:not(.dw-compare__icon--neutral) .dw-compare__icon-glow {
    position: absolute;
    inset: -4px;
    background: var(--compare-win);
    border-radius: 50%;
    filter: blur(8px);
    opacity: 0.5;
    animation: compare-icon-glow 2s ease-in-out infinite;
  }

  @keyframes compare-icon-glow {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(1.2); }
  }

  .dw-compare__icon--neutral {
    color: var(--compare-text);
    opacity: 0.4;
  }

  .dw-compare__icon--x {
    color: var(--compare-lose);
  }

  /* ==========================================
     SEE MORE TOGGLE
     ========================================== */

  .dw-compare__toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 16px 24px;
    background: transparent;
    border: none;
    border-top: 1px solid var(--compare-border);
    font-family: 'Poppins', sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: var(--compare-win);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  @media (min-width: 750px) {
    .dw-compare__toggle {
      font-size: 14px;
      padding: 18px 24px;
    }
  }

  .dw-compare__toggle:hover {
    background: rgba(196, 214, 0, 0.1);
  }

  .dw-compare__toggle-count {
    opacity: 0.6;
    font-weight: 400;
  }

  .dw-compare__toggle-icon {
    width: 20px;
    height: 20px;
    transition: transform 0.3s ease;
  }

  .dw-compare__toggle-icon svg {
    width: 100%;
    height: 100%;
    stroke: var(--compare-win);
  }

  .dw-compare__toggle-less {
    display: none;
  }

  .dw-compare__table.is-expanded .dw-compare__toggle-more {
    display: none;
  }

  .dw-compare__table.is-expanded .dw-compare__toggle-less {
    display: inline;
  }

  .dw-compare__table.is-expanded .dw-compare__toggle-icon {
    transform: rotate(180deg);
  }

  /* ==========================================
     CTA BUTTON
     ========================================== */

  .dw-compare__cta {
    display: flex;
    justify-content: center;
    margin-top: 40px;
  }

  @media (min-width: 750px) {
    .dw-compare__cta {
      margin-top: 50px;
    }
  }

  .dw-compare__button {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 18px 48px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    border-radius: 50px;
    cursor: pointer;
    border: none;
    font-family: 'Poppins', sans-serif;
    overflow: hidden;
    transition: transform 0.2s ease;
  }

  @media (min-width: 750px) {
    .dw-compare__button {
      padding: 20px 56px;
      font-size: 13px;
    }
  }

  .dw-compare__button:hover {
    transform: translateY(-2px);
  }

  .dw-compare__button-text {
    position: relative;
    z-index: 2;
  }

  /* Primary Button */
  .dw-compare__button--primary {
    background: var(--compare-win);
    color: #000;
  }

  .dw-compare__button--primary:hover {
    box-shadow: 0 0 30px var(--compare-win);
  }

  /* Gradient Button */
  .dw-compare__button--gradient {
    background: transparent;
    color: var(--compare-text);
  }

  .dw-compare__button--gradient .dw-compare__button-bg {
    position: absolute;
    inset: 0;
    border-radius: 50px;
    padding: 2px;
    background: linear-gradient(
      90deg,
      var(--compare-glow-1),
      var(--compare-glow-2),
      var(--compare-glow-1),
      var(--compare-glow-2)
    );
    background-size: 300% 100%;
    -webkit-mask: 
      linear-gradient(#fff 0 0) content-box, 
      linear-gradient(#fff 0 0);
    mask: 
      linear-gradient(#fff 0 0) content-box, 
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    animation: compare-border-shift 3s linear infinite;
  }

  .dw-compare__button--gradient::after {
    content: '';
    position: absolute;
    inset: 2px;
    border-radius: 48px;
    background: var(--compare-bg);
    z-index: 1;
  }

  .dw-compare__button--gradient:hover .dw-compare__button-bg {
    animation-duration: 1.5s;
  }

  /* Glow Button */
  .dw-compare__button--glow {
    background: var(--compare-win);
    color: #000;
    box-shadow: 0 0 20px var(--compare-win);
    animation: compare-btn-glow 2s ease-in-out infinite;
  }

  @keyframes compare-btn-glow {
    0%, 100% { box-shadow: 0 0 20px var(--compare-win); }
    50% { box-shadow: 0 0 40px var(--compare-win), 0 0 60px var(--compare-win); }
  }

  .dw-compare__button--glow:hover {
    animation: none;
    box-shadow: 0 0 50px var(--compare-win);
  }

  /* ==========================================
     MODAL
     ========================================== */

  .dw-compare__modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .dw-compare__modal.is-open {
    opacity: 1;
    visibility: visible;
  }

  .dw-compare__modal-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.9);
    backdrop-filter: blur(10px);
    cursor: pointer;
  }

  .dw-compare__modal-container {
    position: relative;
    max-width: 95vw;
    max-height: 90vh;
    background: #111;
    border-radius: 12px;
    overflow: hidden;
    transform: scale(0.9);
    transition: transform 0.3s ease;
    box-shadow: 0 0 50px rgba(196, 214, 0, 0.3);
  }

  .dw-compare__modal.is-open .dw-compare__modal-container {
    transform: scale(1);
  }

  @media (min-width: 750px) {
    .dw-compare__modal-container {
      max-width: 90vw;
      max-height: 85vh;
    }
  }

  .dw-compare__modal-close {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 40px;
    height: 40px;
    background: var(--compare-win);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #000;
    transition: all 0.2s ease;
    z-index: 10;
  }

  .dw-compare__modal-close:hover {
    transform: scale(1.1);
    box-shadow: 0 0 20px var(--compare-win);
  }

  .dw-compare__modal-close svg {
    width: 20px;
    height: 20px;
  }

  .dw-compare__modal-content {
    overflow: auto;
    max-height: 90vh;
  }

  @media (min-width: 750px) {
    .dw-compare__modal-content {
      max-height: 85vh;
    }
  }

  .dw-compare__modal-content img {
    display: block;
    width: 100%;
    height: auto;
  }

  body.dw-modal-open {
    overflow: hidden;
  }

  /* ==========================================
     REDUCED MOTION
     ========================================== */

  @media (prefers-reduced-motion: reduce) {
    .dw-compare__bg-orb,
    .dw-compare__product--winner,
    .dw-compare__product-glow,
    .dw-compare__winner-badge,
    .dw-compare__table-border,
    .dw-compare__score,
    .dw-compare__row,
    .dw-compare__icon--check .dw-compare__icon-glow,
    .dw-compare__button--glow,
    .dw-compare__button--gradient .dw-compare__button-bg {
      animation: none;
    }

    .dw-compare__row {
      opacity: 1;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // See More Toggle
    const table = document.querySelector('[data-compare-table]');
    const toggle = document.querySelector('[data-compare-toggle]');
    
    if (table && toggle) {
      toggle.addEventListener('click', function() {
        table.classList.toggle('is-expanded');
        
        // Re-trigger animations for newly visible rows
        if (table.classList.contains('is-expanded')) {
          const hiddenRows = table.querySelectorAll('.dw-compare__row--hidden');
          hiddenRows.forEach((row, index) => {
            row.style.animation = 'none';
            row.offsetHeight; // Trigger reflow
            row.style.animation = `compare-row-enter 0.4s ease forwards`;
            row.style.animationDelay = `${index * 0.03}s`;
          });
        }
      });
    }

    // Modal functionality
    const modal = document.querySelector('[data-compare-modal]');
    const modalOpenBtn = document.querySelector('[data-compare-modal-open]');
    const modalCloseBtns = document.querySelectorAll('[data-compare-modal-close]');

    function openModal() {
      if (modal) {
        modal.classList.add('is-open');
        modal.setAttribute('aria-hidden', 'false');
        document.body.classList.add('dw-modal-open');
      }
    }

    function closeModal() {
      if (modal) {
        modal.classList.remove('is-open');
        modal.setAttribute('aria-hidden', 'true');
        document.body.classList.remove('dw-modal-open');
      }
    }

    if (modalOpenBtn) {
      modalOpenBtn.addEventListener('click', openModal);
    }

    modalCloseBtns.forEach(btn => {
      btn.addEventListener('click', closeModal);
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && modal && modal.classList.contains('is-open')) {
        closeModal();
      }
    });

    // Intersection Observer for entrance animations
    const section = document.querySelector('[data-compare-section]');
    if (section && 'IntersectionObserver' in window) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });

      observer.observe(section);
    }
  });
</script>

