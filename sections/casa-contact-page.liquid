<style>
  /* ============================================
     Seoul Glow Lab — Contact Page
     Prefix: casa-contactp
     ============================================ */

  .casa-contactp {
    --cp-accent-purple: {{ section.settings.accent_purple | default: '#9333ea' }};
    --cp-accent-pink: {{ section.settings.accent_pink | default: '#ec4899' }};
    --cp-bg: {{ section.settings.bg_color | default: '#0a0a0f' }};
    --cp-card-bg: rgba(255, 255, 255, 0.03);
    --cp-card-border: rgba(255, 255, 255, 0.06);
    --cp-text: #e4e4e7;
    --cp-text-muted: #a1a1aa;
    --cp-radius: 16px;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: var(--cp-bg);
    color: var(--cp-text);
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    overflow: hidden;
  }

  .casa-contactp *,
  .casa-contactp *::before,
  .casa-contactp *::after {
    box-sizing: border-box;
  }

  /* ---- Container ---- */
  .casa-contactp__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ---- Hero ---- */
  .casa-contactp__hero {
    text-align: center;
    margin-bottom: 64px;
  }

  .casa-contactp__badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 16px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--cp-accent-purple);
    border: 1px solid rgba(147, 51, 234, 0.25);
    background: rgba(147, 51, 234, 0.08);
    margin-bottom: 24px;
  }

  .casa-contactp__title {
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 16px;
    background: linear-gradient(135deg, #ffffff 0%, #a1a1aa 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .casa-contactp__subtitle {
    font-size: clamp(16px, 2vw, 20px);
    color: var(--cp-text-muted);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* ---- Card Grid ---- */
  .casa-contactp__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 64px;
  }

  @media (max-width: 768px) {
    .casa-contactp__grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }

  /* ---- Contact Card ---- */
  .casa-contactp__card {
    position: relative;
    background: var(--cp-card-bg);
    border: 1px solid var(--cp-card-border);
    border-radius: var(--cp-radius);
    padding: 32px 28px;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: border-color 0.3s ease, transform 0.3s ease;
  }

  .casa-contactp__card:hover {
    border-color: rgba(147, 51, 234, 0.2);
    transform: translateY(-2px);
  }

  .casa-contactp__card-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    background: linear-gradient(135deg, rgba(147, 51, 234, 0.15), rgba(236, 72, 153, 0.1));
    border: 1px solid rgba(147, 51, 234, 0.15);
  }

  .casa-contactp__card-icon svg {
    width: 22px;
    height: 22px;
    stroke: var(--cp-accent-purple);
    fill: none;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .casa-contactp__card-title {
    font-size: 18px;
    font-weight: 600;
    color: #fff;
    margin: 0 0 12px;
  }

  .casa-contactp__card-content {
    font-size: 15px;
    line-height: 1.7;
    color: var(--cp-text-muted);
  }

  .casa-contactp__card-content a {
    color: var(--cp-accent-purple);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .casa-contactp__card-content a:hover {
    color: var(--cp-accent-pink);
  }

  .casa-contactp__card-content p {
    margin: 0 0 8px;
  }
  .casa-contactp__card-content p:last-child {
    margin-bottom: 0;
  }

  /* ---- Form Embed ---- */
  .casa-contactp__form-section {
    margin-bottom: 64px;
  }

  .casa-contactp__form-wrapper {
    position: relative;
    background: var(--cp-card-bg);
    border: 1px solid var(--cp-card-border);
    border-radius: var(--cp-radius);
    padding: 48px 40px;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .casa-contactp__form-heading {
    font-size: clamp(22px, 3vw, 28px);
    font-weight: 600;
    color: #fff;
    margin: 0 0 8px;
    text-align: center;
  }

  .casa-contactp__form-sub {
    font-size: 15px;
    color: var(--cp-text-muted);
    margin: 0 0 32px;
    text-align: center;
  }

  @media (max-width: 768px) {
    .casa-contactp__form-wrapper {
      padding: 32px 20px;
    }
  }

  /* ---- Text Block (SMS notice etc) ---- */
  .casa-contactp__text-block {
    position: relative;
    background: var(--cp-card-bg);
    border: 1px solid var(--cp-card-border);
    border-radius: var(--cp-radius);
    padding: 40px 36px;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    margin-bottom: 48px;
    text-align: center;
  }

  .casa-contactp__text-block-heading {
    font-size: clamp(20px, 2.5vw, 24px);
    font-weight: 600;
    color: #fff;
    margin: 0 0 16px;
  }

  .casa-contactp__text-block-content {
    font-size: 15px;
    line-height: 1.7;
    color: var(--cp-text-muted);
    max-width: 640px;
    margin: 0 auto;
  }

  .casa-contactp__text-block-content a {
    color: var(--cp-accent-purple);
    text-decoration: none;
  }

  .casa-contactp__text-block-content a:hover {
    color: var(--cp-accent-pink);
  }

  .casa-contactp__text-block-content p {
    margin: 0 0 8px;
  }
  .casa-contactp__text-block-content p:last-child {
    margin-bottom: 0;
  }

  /* ---- Glow accents ---- */
  .casa-contactp__glow {
    position: absolute;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.08;
    pointer-events: none;
    z-index: 0;
  }
  .casa-contactp__glow--purple {
    background: var(--cp-accent-purple);
    top: -100px;
    left: -50px;
  }
  .casa-contactp__glow--pink {
    background: var(--cp-accent-pink);
    bottom: -100px;
    right: -50px;
  }

  .casa-contactp__hero,
  .casa-contactp__grid,
  .casa-contactp__form-section,
  .casa-contactp__text-block {
    position: relative;
    z-index: 1;
  }

  /* ---- Divider ---- */
  .casa-contactp__divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(147, 51, 234, 0.2), rgba(236, 72, 153, 0.15), transparent);
    margin: 0 0 64px;
    border: none;
  }
</style>

<section class="casa-contactp" data-section-id="{{ section.id }}">
  {%- comment -%} Ambient glow orbs {%- endcomment -%}
  <div class="casa-contactp__glow casa-contactp__glow--purple"></div>
  <div class="casa-contactp__glow casa-contactp__glow--pink"></div>

  <div class="casa-contactp__container">

    {%- comment -%} ===== HERO ===== {%- endcomment -%}
    <div class="casa-contactp__hero">
      {%- if section.settings.badge_text != blank -%}
        <span class="casa-contactp__badge">{{ section.settings.badge_text }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h1 class="casa-contactp__title">{{ section.settings.heading }}</h1>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="casa-contactp__subtitle">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} ===== CONTACT CARDS ===== {%- endcomment -%}
    {%- assign cards = section.blocks | where: 'type', 'contact_card' -%}
    {%- if cards.size > 0 -%}
      <div class="casa-contactp__grid">
        {%- for block in cards -%}
          <div class="casa-contactp__card" {{ block.shopify_attributes }}>
            <div class="casa-contactp__card-icon">
              {%- case block.settings.icon -%}
                {%- when 'email' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                {%- when 'phone' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                {%- when 'location' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                {%- when 'clock' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                {%- when 'message' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="m3 21 1.9-5.7a8.5 8.5 0 1 1 3.8 3.8z"/></svg>
                {%- when 'heart' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
                {%- else -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
              {%- endcase -%}
            </div>
            {%- if block.settings.title != blank -%}
              <h3 class="casa-contactp__card-title">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.content != blank -%}
              <div class="casa-contactp__card-content">{{ block.settings.content }}</div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <hr class="casa-contactp__divider">

    {%- comment -%} ===== FORM EMBEDS ===== {%- endcomment -%}
    {%- assign forms = section.blocks | where: 'type', 'form_embed' -%}
    {%- for block in forms -%}
      <div class="casa-contactp__form-section" {{ block.shopify_attributes }}>
        <div class="casa-contactp__form-wrapper">
          {%- if block.settings.heading != blank -%}
            <h2 class="casa-contactp__form-heading">{{ block.settings.heading }}</h2>
          {%- endif -%}
          {%- if block.settings.subheading != blank -%}
            <p class="casa-contactp__form-sub">{{ block.settings.subheading }}</p>
          {%- endif -%}
          {{ block.settings.custom_liquid }}
        </div>
      </div>
    {%- endfor -%}

    {%- comment -%} ===== TEXT BLOCKS ===== {%- endcomment -%}
    {%- assign texts = section.blocks | where: 'type', 'text_block' -%}
    {%- for block in texts -%}
      <div class="casa-contactp__text-block" {{ block.shopify_attributes }}>
        {%- if block.settings.heading != blank -%}
          <h2 class="casa-contactp__text-block-heading">{{ block.settings.heading }}</h2>
        {%- endif -%}
        {%- if block.settings.content != blank -%}
          <div class="casa-contactp__text-block-content">{{ block.settings.content }}</div>
        {%- endif -%}
      </div>
    {%- endfor -%}

  </div>

  {%- comment -%} App blocks {%- endcomment -%}
  {%- for block in section.blocks -%}
    {%- if block.type == '@app' -%}
      <div class="casa-app-block" {{ block.shopify_attributes }}>
        {% render block %}
      </div>
    {%- endif -%}
  {%- endfor -%}
</section>

{% schema %}
{
  "name": "Casa Contact Page",
  "tag": "section",
  "class": "casa-contactp-section",
  "settings": [
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Get In Touch"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Contact Us"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "We're here to help. Reach out to our team and we'll get back to you as soon as possible."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "accent_purple",
      "label": "Accent purple",
      "default": "#9333ea"
    },
    {
      "type": "color",
      "id": "accent_pink",
      "label": "Accent pink",
      "default": "#ec4899"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#0a0a0f"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 80,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "contact_card",
      "name": "Contact Card",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "email", "label": "Email" },
            { "value": "phone", "label": "Phone" },
            { "value": "location", "label": "Location" },
            { "value": "clock", "label": "Clock" },
            { "value": "message", "label": "Message" },
            { "value": "heart", "label": "Heart" }
          ],
          "default": "email"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Email Us"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Get in touch with us</p>"
        }
      ]
    },
    {
      "type": "form_embed",
      "name": "Form Embed",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Send Us a Message"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "default": "Fill out the form below and our team will respond within 24 hours."
        },
        {
          "type": "liquid",
          "id": "custom_liquid",
          "label": "Form embed code",
          "info": "Paste your Gorgias or other contact form embed code here.",
          "default": "<div data-gorgias-contact-form-uid=\"sj8s4v1g\"></div><script defer src=\"https://contact.gorgias.help/api/contact-forms/loader.js?v=2\" data-gorgias-loader-contact-form></script>"
        }
      ]
    },
    {
      "type": "text_block",
      "name": "Text Block",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Need Help?"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Reach out to us and we'll be happy to assist.</p>"
        }
      ]
    },
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "Casa Contact Page",
      "blocks": [
        {
          "type": "contact_card",
          "settings": {
            "icon": "email",
            "title": "Email Us",
            "content": "<p><a href=\"mailto:hello@seoulglow.com\">hello@seoulglow.com</a></p><p>We typically respond within 24 hours.</p>"
          }
        },
        {
          "type": "contact_card",
          "settings": {
            "icon": "phone",
            "title": "Call Us",
            "content": "<p><a href=\"tel:+14044100199\">+1 (404)-410-0199</a></p><p>MON–SAT 9:00 AM – 5:00 PM EST</p>"
          }
        },
        {
          "type": "contact_card",
          "settings": {
            "icon": "location",
            "title": "Visit Us",
            "content": "<p>Casa Di Lumo LLC</p><p>4225 JVL Industrial Park Dr</p><p>Building 2 Suite 204</p><p>Marietta, GA 30066</p>"
          }
        },
        {
          "type": "form_embed",
          "settings": {
            "heading": "Send Us a Message",
            "subheading": "Fill out the form below and our team will respond within 24 hours.",
            "custom_liquid": "<div data-gorgias-contact-form-uid=\"sj8s4v1g\"></div><script defer src=\"https://contact.gorgias.help/api/contact-forms/loader.js?v=2\" data-gorgias-loader-contact-form></script>"
          }
        },
        {
          "type": "text_block",
          "settings": {
            "heading": "Prefer to Text?",
