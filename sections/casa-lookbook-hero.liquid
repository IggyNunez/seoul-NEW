  ],
  "presets": [
    {
      "name": "Lookbook Hero",
      "category": "Lookbook",
      "settings": {
        "full_height": true,
        "enable_parallax": true,
        "show_scroll_indicator": true,
        "overlay_opacity": 50,
        "content_align": "center",
        "badge_text": "Home Office",
        "heading": "Design Your Dream Space",
        "accent_word": "Dream",
        "subtitle": "Curated lighting collections to transform every corner of your home into a statement of modern luxury.",
