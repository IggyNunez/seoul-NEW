        "cta_style": "gradient",
        "bg_color": "#0a0a0f",
        "text_color": "#ffffff",
        "text_muted": "#a0a0b0",
        "accent_primary": "#9333ea",
        "accent_secondary": "#ec4899"
      },
      "blocks": [
        { "type": "mood_tag", "settings": { "text": "Modern", "icon": "✨" } },
        { "type": "mood_tag", "settings": { "text": "Minimalist", "icon": "◽" } },
        { "type": "mood_tag", "settings": { "text": "Cozy", "icon": "🕯️" } },
        { "type": "mood_tag", "settings": { "text": "Ambient", "icon": "💡" } }
      ]
    }
  ],
  "templates": ["page"]
}
{% endschema %}
