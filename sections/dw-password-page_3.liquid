{% comment %}
  DoingWell Password Page Section
  - Full-screen password gate for secret preorder
  - Animated glow background effects
  - Full mobile/desktop responsive controls
  - Custom styled password input
  - Gradient/glow button options
  - Entrance animations
  - Error/success states
{% endcomment %}

{%- liquid
  assign has_logo = false
  assign has_bullets = false
  for block in section.blocks
    if block.type == 'logo' and block.settings.image != blank
      assign has_logo = true
    endif
    if block.type == 'bullets'
      assign has_bullets = true
    endif
  endfor
-%}

<section 
  class="dw-password{% if section.settings.enable_animations %} dw-password--animate{% endif %}"
  data-animation="{{ section.settings.animation_style }}"
  style="
    --pw-min-height: {{ section.settings.min_height }}vh;
    --pw-padding-top-desktop: {{ section.settings.padding_top_desktop }}px;
    --pw-padding-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;
    --pw-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --pw-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --pw-content-max-width: {{ section.settings.content_max_width }}px;
    --pw-text-color: {{ section.settings.text_color }};
    --pw-bg-color: {{ section.settings.bg_color }};
    --pw-animation-duration: {{ section.settings.animation_duration }}ms;
    --pw-animation-stagger: {{ section.settings.animation_stagger }}ms;
    --pw-glow-color-1: {{ section.settings.glow_color_1 }};
    --pw-glow-color-2: {{ section.settings.glow_color_2 }};
    --pw-glow-color-3: {{ section.settings.glow_color_3 }};
    --pw-glow-opacity: {{ section.settings.glow_opacity | divided_by: 100.0 }};
    --pw-input-bg: {{ section.settings.input_bg_color }};
    --pw-input-border: {{ section.settings.input_border_color }};
    --pw-input-text: {{ section.settings.input_text_color }};
    --pw-input-focus-border: {{ section.settings.input_focus_border_color }};
    --pw-error-color: {{ section.settings.error_color }};
  "
>
  <!-- Background Layer -->
  <div class="dw-password__bg">
    {%- if section.settings.bg_image != blank -%}
      <picture class="dw-password__bg-image">
        {%- if section.settings.bg_image_mobile != blank -%}
          <source 
            media="(max-width: 749px)" 
            srcset="{{ section.settings.bg_image_mobile | image_url: width: 750 }},
                    {{ section.settings.bg_image_mobile | image_url: width: 1500 }} 2x"
          >
        {%- endif -%}
        <img 
          src="{{ section.settings.bg_image | image_url: width: 1920 }}" 
          srcset="{{ section.settings.bg_image | image_url: width: 1920 }},
                  {{ section.settings.bg_image | image_url: width: 3840 }} 2x"
          alt=""
          loading="eager"
          fetchpriority="high"
        >
      </picture>
      {%- if section.settings.bg_overlay_opacity > 0 -%}
        <div class="dw-password__bg-overlay" style="
          background: {{ section.settings.bg_overlay_color }};
          opacity: {{ section.settings.bg_overlay_opacity | divided_by: 100.0 }};
        "></div>
      {%- endif -%}
    {%- endif -%}

    {%- if section.settings.enable_glow -%}
      <div class="dw-password__glow dw-password__glow--{{ section.settings.glow_style }}">
        <div class="dw-password__glow-orb dw-password__glow-orb--1"></div>
        <div class="dw-password__glow-orb dw-password__glow-orb--2"></div>
        <div class="dw-password__glow-orb dw-password__glow-orb--3"></div>
      </div>
    {%- endif -%}
  </div>

  <!-- Content Layer -->
  <div class="dw-password__container">
    <div class="dw-password__content dw-password__content--{{ section.settings.text_alignment }} dw-password__content--mobile-{{ section.settings.text_alignment_mobile }}">
      <div class="dw-password__content-inner">
        {%- assign block_index = 0 -%}
        {%- for block in section.blocks -%}
          {%- case block.type -%}

            {%- when 'logo' -%}
              {%- assign block_index = block_index | plus: 1 -%}
              <div 
                class="dw-password__logo dw-password__block"
                style="
                  --logo-width-desktop: {{ block.settings.width_desktop }}px;
                  --logo-width-mobile: {{ block.settings.width_mobile }}px;
                  --logo-margin-desktop: {{ block.settings.margin_bottom_desktop }}px;
                  --logo-margin-mobile: {{ block.settings.margin_bottom_mobile }}px;
                  --block-index: {{ block_index }};
                "
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.image != blank -%}
                  <img 
                    src="{{ block.settings.image | image_url: width: 600 }}"
                    alt="{{ block.settings.image.alt | default: shop.name | escape }}"
                    loading="eager"
                    width="{{ block.settings.image.width }}"
                    height="{{ block.settings.image.height }}"
                  >
                {%- else -%}
                  <span class="dw-password__logo-placeholder">{{ shop.name }}</span>
                {%- endif -%}
              </div>

            {%- when 'badge' -%}
              {%- assign block_index = block_index | plus: 1 -%}
              <div 
                class="dw-password__badge dw-password__block"
                style="
                  --badge-bg: {{ block.settings.bg_color }};
                  --badge-text: {{ block.settings.text_color }};
                  --badge-border: {{ block.settings.border_color }};
                  --badge-size-desktop: {{ block.settings.size_desktop }}px;
                  --badge-size-mobile: {{ block.settings.size_mobile }}px;
                  --badge-margin-desktop: {{ block.settings.margin_bottom_desktop }}px;
                  --badge-margin-mobile: {{ block.settings.margin_bottom_mobile }}px;
                  --block-index: {{ block_index }};
                "
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.icon != 'none' -%}
                  <span class="dw-password__badge-icon">
                    {%- case block.settings.icon -%}
                      {%- when 'lock' -%}
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                      {%- when 'star' -%}
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                      {%- when 'lightning' -%}
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
                      {%- when 'key' -%}
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"></path></svg>
                      {%- when 'shield' -%}
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                    {%- endcase -%}
                  </span>
                {%- endif -%}
                <span>{{ block.settings.text }}</span>
              </div>

            {%- when 'eyebrow' -%}
              {%- assign block_index = block_index | plus: 1 -%}
              <p 
                class="dw-password__eyebrow dw-password__block"
                style="
                  --eyebrow-size-desktop: {{ block.settings.size_desktop }}px;
                  --eyebrow-size-mobile: {{ block.settings.size_mobile }}px;
                  --eyebrow-color: {{ block.settings.color | default: 'inherit' }};
                  --eyebrow-margin-desktop: {{ block.settings.margin_bottom_desktop }}px;
                  --eyebrow-margin-mobile: {{ block.settings.margin_bottom_mobile }}px;
                  --block-index: {{ block_index }};
                "
                {{ block.shopify_attributes }}
              >
                {{ block.settings.text }}
              </p>

            {%- when 'heading' -%}
              {%- assign block_index = block_index | plus: 1 -%}
              <{{ block.settings.heading_tag }} 
                class="dw-password__heading dw-password__block"
                style="
                  --heading-size-desktop: {{ block.settings.size_desktop }}px;
                  --heading-size-mobile: {{ block.settings.size_mobile }}px;
                  --heading-line-height: {{ block.settings.line_height }};
                  --heading-font-weight: {{ block.settings.font_weight }};
                  --heading-color: {{ block.settings.color | default: 'inherit' }};
                  --heading-margin-desktop: {{ block.settings.margin_bottom_desktop }}px;
                  --heading-margin-mobile: {{ block.settings.margin_bottom_mobile }}px;
                  --block-index: {{ block_index }};
                "
                {{ block.shopify_attributes }}
              >
                {{ block.settings.text | newline_to_br }}
              </{{ block.settings.heading_tag }}>

            {%- when 'subheading' -%}
              {%- assign block_index = block_index | plus: 1 -%}
              <p 
                class="dw-password__subheading dw-password__block"
                style="
                  --subheading-size-desktop: {{ block.settings.size_desktop }}px;
                  --subheading-size-mobile: {{ block.settings.size_mobile }}px;
                  --subheading-max-width: {{ block.settings.max_width }}px;
                  --subheading-opacity: {{ block.settings.opacity | divided_by: 100.0 }};
                  --subheading-margin-desktop: {{ block.settings.margin_bottom_desktop }}px;
                  --subheading-margin-mobile: {{ block.settings.margin_bottom_mobile }}px;
                  --block-index: {{ block_index }};
                "
                {{ block.shopify_attributes }}
              >
                {{ block.settings.text }}
              </p>

            {%- when 'text' -%}
              {%- assign block_index = block_index | plus: 1 -%}
              <div 
                class="dw-password__text dw-password__block"
                style="
                  --text-size-desktop: {{ block.settings.size_desktop }}px;
                  --text-size-mobile: {{ block.settings.size_mobile }}px;
                  --text-max-width: {{ block.settings.max_width }}px;
                  --text-opacity: {{ block.settings.opacity | divided_by: 100.0 }};
                  --text-margin-desktop: {{ block.settings.margin_bottom_desktop }}px;
                  --text-margin-mobile: {{ block.settings.margin_bottom_mobile }}px;
                  --block-index: {{ block_index }};
                "
                {{ block.shopify_attributes }}
              >
                {{ block.settings.text }}
              </div>

            {%- when 'bullets' -%}
              {%- assign block_index = block_index | plus: 1 -%}
              {%- assign bullet_items = block.settings.items | newline_to_br | split: '<br />' -%}
              <ul 
                class="dw-password__bullets dw-password__bullets--{{ block.settings.layout }} dw-password__block"
                style="
                  --bullets-size-desktop: {{ block.settings.size_desktop }}px;
                  --bullets-size-mobile: {{ block.settings.size_mobile }}px;
                  --bullets-gap: {{ block.settings.gap }}px;
                  --bullets-icon-color: {{ block.settings.icon_color }};
                  --bullets-max-width: {{ block.settings.max_width }}px;
                  --bullets-margin-desktop: {{ block.settings.margin_bottom_desktop }}px;
                  --bullets-margin-mobile: {{ block.settings.margin_bottom_mobile }}px;
                  --block-index: {{ block_index }};
                "
                {{ block.shopify_attributes }}
              >
                {%- for item in bullet_items -%}
                  {%- assign item_text = item | strip -%}
                  {%- if item_text != blank -%}
                    <li class="dw-password__bullet-item">
                      <span class="dw-password__bullet-icon">
                        {%- case block.settings.icon -%}
                          {%- when 'check' -%}
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                          {%- when 'dot' -%}
                            <svg width="8" height="8" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10"></circle></svg>
                          {%- when 'arrow' -%}
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                          {%- when 'star' -%}
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                          {%- when 'lightning' -%}
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
                        {%- endcase -%}
                      </span>
                      <span class="dw-password__bullet-text">{{ item_text }}</span>
                    </li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>

            {%- when 'divider' -%}
              {%- assign block_index = block_index | plus: 1 -%}
              <div 
                class="dw-password__divider dw-password__block"
                style="
                  --divider-width: {{ block.settings.width }}%;
                  --divider-height: {{ block.settings.height }}px;
                  --divider-color: {{ block.settings.color }};
                  --divider-margin-desktop: {{ block.settings.margin_bottom_desktop }}px;
                  --divider-margin-mobile: {{ block.settings.margin_bottom_mobile }}px;
                  --block-index: {{ block_index }};
                "
                {{ block.shopify_attributes }}
              ></div>

            {%- when 'spacer' -%}
              {%- assign block_index = block_index | plus: 1 -%}
              <div 
                class="dw-password__spacer dw-password__block"
                style="
                  --spacer-height-desktop: {{ block.settings.height_desktop }}px;
                  --spacer-height-mobile: {{ block.settings.height_mobile }}px;
                  --block-index: {{ block_index }};
                "
                {{ block.shopify_attributes }}
              ></div>

            {%- when 'password_form' -%}
              {%- assign block_index = block_index | plus: 1 -%}
              <div 
                class="dw-password__form-wrap dw-password__block"
                style="
                  --form-max-width: {{ block.settings.max_width }}px;
                  --form-margin-desktop: {{ block.settings.margin_bottom_desktop }}px;
                  --form-margin-mobile: {{ block.settings.margin_bottom_mobile }}px;
                  --block-index: {{ block_index }};
                "
                {{ block.shopify_attributes }}
              >
                {%- form 'storefront_password', class: 'dw-password__form' -%}
                  <div class="dw-password__form-inner dw-password__form-inner--{{ block.settings.layout }}">
                    <div class="dw-password__input-wrap">
                      {%- if block.settings.show_label -%}
                        <label for="password-input-{{ section.id }}" class="dw-password__label">
                          {{ block.settings.label }}
                        </label>
                      {%- endif -%}
                      <div class="dw-password__input-container">
                        {%- if block.settings.show_lock_icon -%}
                          <span class="dw-password__input-icon">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                          </span>
                        {%- endif -%}
                        <input 
                          type="password" 
                          name="password" 
                          id="password-input-{{ section.id }}"
                          class="dw-password__input{% if block.settings.show_lock_icon %} dw-password__input--has-icon{% endif %}"
                          placeholder="{{ block.settings.placeholder }}"
                          autocomplete="current-password"
                          required
                        >
                      </div>
                      {%- if form.errors -%}
                        <p class="dw-password__error">
                          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                          {{ block.settings.error_message }}
                        </p>
                      {%- endif -%}
                    </div>
                    
                    <button 
                      type="submit" 
                      class="dw-password__submit dw-btn dw-btn--{{ block.settings.button_style }}{% if block.settings.button_style == 'gradient' or block.settings.button_style == 'gradient-glow' %} dw-btn--gradient-animate{% endif %}{% if block.settings.button_full_width %} dw-btn--full{% endif %}"
                      style="
                        --btn-gradient-1: {{ block.settings.button_gradient_1 }};
                        --btn-gradient-2: {{ block.settings.button_gradient_2 }};
                        {% if block.settings.button_bg != blank %}--btn-bg: {{ block.settings.button_bg }};{% endif %}
                        {% if block.settings.button_text_color != blank %}--btn-text-color: {{ block.settings.button_text_color }};{% endif %}
                        {% if block.settings.button_border_color != blank %}--btn-border-color: {{ block.settings.button_border_color }};{% endif %}
                      "
                    >
                      <span>{{ block.settings.button_text }}</span>
                    </button>
                  </div>
                {%- endform -%}
              </div>

            {%- when 'support_text' -%}
              {%- assign block_index = block_index | plus: 1 -%}
              <div 
                class="dw-password__support dw-password__block"
                style="
                  --support-size-desktop: {{ block.settings.size_desktop }}px;
                  --support-size-mobile: {{ block.settings.size_mobile }}px;
                  --support-opacity: {{ block.settings.opacity | divided_by: 100.0 }};
                  --support-margin-desktop: {{ block.settings.margin_bottom_desktop }}px;
                  --support-margin-mobile: {{ block.settings.margin_bottom_mobile }}px;
                  --block-index: {{ block_index }};
                "
                {{ block.shopify_attributes }}
              >
                {{ block.settings.text }}
              </div>

          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<style>
  /* ==========================================
     PASSWORD PAGE BASE
     ========================================== */
  
  .dw-password {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: var(--pw-min-height, 100vh);
    color: var(--pw-text-color, #ffffff);
    overflow: hidden;
    padding: var(--pw-padding-top-mobile) 20px var(--pw-padding-bottom-mobile);
  }

  @media (min-width: 750px) {
    .dw-password {
      padding: var(--pw-padding-top-desktop) 50px var(--pw-padding-bottom-desktop);
    }
  }

  /* ==========================================
     BACKGROUND LAYER
     ========================================== */
  
  .dw-password__bg {
    position: absolute;
    inset: 0;
    background: var(--pw-bg-color, #0a0a0a);
    z-index: 0;
  }

  .dw-password__bg-image {
    position: absolute;
    inset: 0;
  }

  .dw-password__bg-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .dw-password__bg-overlay {
    position: absolute;
    inset: 0;
  }

  /* ==========================================
     ANIMATED GLOW EFFECTS
     ========================================== */
  
  .dw-password__glow {
    position: absolute;
    inset: 0;
    overflow: hidden;
    opacity: var(--pw-glow-opacity, 0.7);
  }

  .dw-password__glow-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.6;
    animation: pw-glow-float 8s ease-in-out infinite;
  }

  .dw-password__glow-orb--1 {
    width: 50%;
    height: 50%;
    background: var(--pw-glow-color-1, #C4D600);
    top: -15%;
    left: -10%;
    animation-delay: 0s;
  }

  .dw-password__glow-orb--2 {
    width: 45%;
    height: 45%;
    background: var(--pw-glow-color-2, #00d4ff);
    bottom: -10%;
    right: -5%;
    animation-delay: -3s;
  }

  .dw-password__glow-orb--3 {
    width: 35%;
    height: 35%;
    background: var(--pw-glow-color-3, #8b00ff);
    top: 40%;
    left: 60%;
    animation-delay: -5s;
  }

  @keyframes pw-glow-float {
    0%, 100% {
      transform: translate(0, 0) scale(1);
      opacity: 0.6;
    }
    25% {
      transform: translate(15%, 10%) scale(1.15);
      opacity: 0.5;
    }
    50% {
      transform: translate(-10%, 20%) scale(0.9);
      opacity: 0.7;
    }
    75% {
      transform: translate(-15%, -10%) scale(1.1);
      opacity: 0.55;
    }
  }

  /* Glow Style: Pulse */
  .dw-password__glow--pulse .dw-password__glow-orb {
    animation: pw-glow-pulse 4s ease-in-out infinite;
  }

  @keyframes pw-glow-pulse {
    0%, 100% {
      opacity: 0.4;
      transform: scale(1);
    }
    50% {
      opacity: 0.8;
      transform: scale(1.3);
    }
  }

  /* Glow Style: Wave */
  .dw-password__glow--wave .dw-password__glow-orb {
    animation: pw-glow-wave 6s ease-in-out infinite;
  }

  @keyframes pw-glow-wave {
    0%, 100% {
      transform: translateY(0) scale(1);
    }
    50% {
      transform: translateY(-25%) scale(1.15);
    }
  }

  /* Glow Style: Spin */
  .dw-password__glow--spin .dw-password__glow-orb {
    animation: pw-glow-spin 20s linear infinite;
    transform-origin: 50% 100%;
  }

  .dw-password__glow--spin .dw-password__glow-orb--2 {
    animation-direction: reverse;
    animation-duration: 25s;
  }

  .dw-password__glow--spin .dw-password__glow-orb--3 {
    animation-duration: 30s;
  }

  @keyframes pw-glow-spin {
    from { transform: rotate(0deg) translateX(30%); }
    to { transform: rotate(360deg) translateX(30%); }
  }

  /* Glow Style: Soft */
  .dw-password__glow--soft .dw-password__glow-orb {
    filter: blur(150px);
    opacity: 0.4;
    animation: pw-glow-soft 12s ease-in-out infinite;
  }

  @keyframes pw-glow-soft {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.5; }
  }

  /* Glow Style: Cyber */
  .dw-password__glow--cyber .dw-password__glow-orb {
    filter: blur(80px);
    animation: pw-glow-cyber 3s ease-in-out infinite;
  }

  .dw-password__glow--cyber .dw-password__glow-orb--1 {
    animation-delay: 0s;
  }

  .dw-password__glow--cyber .dw-password__glow-orb--2 {
    animation-delay: -1s;
  }

  .dw-password__glow--cyber .dw-password__glow-orb--3 {
    animation-delay: -2s;
  }

  @keyframes pw-glow-cyber {
    0%, 100% {
      opacity: 0.5;
      filter: blur(80px);
    }
    50% {
      opacity: 0.9;
      filter: blur(60px);
    }
  }

  /* ==========================================
     CONTENT CONTAINER
     ========================================== */
  
  .dw-password__container {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
  }

  .dw-password__content {
    display: flex;
    justify-content: center;
  }

  .dw-password__content-inner {
    max-width: var(--pw-content-max-width, 600px);
    display: flex;
    flex-direction: column;
  }

  /* Text Alignment */
  .dw-password__content--left { text-align: left; }
  .dw-password__content--center { text-align: center; }
  .dw-password__content--right { text-align: right; }

  .dw-password__content--center .dw-password__content-inner {
    align-items: center;
  }

  .dw-password__content--right .dw-password__content-inner {
    align-items: flex-end;
  }

  .dw-password__content--left .dw-password__content-inner {
    align-items: flex-start;
  }

  /* Mobile Alignment */
  @media (max-width: 749px) {
    .dw-password__content--mobile-left { text-align: left; }
    .dw-password__content--mobile-center { text-align: center; }
    .dw-password__content--mobile-right { text-align: right; }

    .dw-password__content--mobile-center .dw-password__content-inner {
      align-items: center;
    }

    .dw-password__content--mobile-right .dw-password__content-inner {
      align-items: flex-end;
    }

    .dw-password__content--mobile-left .dw-password__content-inner {
      align-items: flex-start;
    }
  }

  /* ==========================================
     BLOCKS
     ========================================== */

  /* Logo */
  .dw-password__logo {
    margin-bottom: var(--logo-margin-mobile);
  }

  .dw-password__logo img {
    width: var(--logo-width-mobile);
    height: auto;
    max-width: 100%;
  }

  @media (min-width: 750px) {
    .dw-password__logo {
      margin-bottom: var(--logo-margin-desktop);
    }

    .dw-password__logo img {
      width: var(--logo-width-desktop);
    }
  }

  .dw-password__logo-placeholder {
    display: inline-block;
    padding: 15px 30px;
    background: rgba(255,255,255,0.1);
    border: 2px dashed rgba(255,255,255,0.3);
    border-radius: 8px;
    font-size: 18px;
    font-weight: 600;
    opacity: 0.7;
  }

  /* Badge */
  .dw-password__badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    background: var(--badge-bg, rgba(196, 214, 0, 0.15));
    color: var(--badge-text, #C4D600);
    border: 1px solid var(--badge-border, rgba(196, 214, 0, 0.3));
    border-radius: 100px;
    font-size: var(--badge-size-mobile);
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: var(--badge-margin-mobile);
  }

  @media (min-width: 750px) {
    .dw-password__badge {
      font-size: var(--badge-size-desktop);
      margin-bottom: var(--badge-margin-desktop);
    }
  }

  .dw-password__badge-icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Eyebrow */
  .dw-password__eyebrow {
    font-size: var(--eyebrow-size-mobile);
    color: var(--eyebrow-color, inherit);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin: 0 0 var(--eyebrow-margin-mobile);
    font-weight: 500;
    opacity: 0.9;
  }

  @media (min-width: 750px) {
    .dw-password__eyebrow {
      font-size: var(--eyebrow-size-desktop);
      margin-bottom: var(--eyebrow-margin-desktop);
    }
  }

  /* Heading */
  .dw-password__heading {
    font-size: var(--heading-size-mobile);
    line-height: var(--heading-line-height, 1.1);
    font-weight: var(--heading-font-weight, 700);
    color: var(--heading-color, inherit);
    margin: 0 0 var(--heading-margin-mobile);
    letter-spacing: -0.02em;
  }

  @media (min-width: 750px) {
    .dw-password__heading {
      font-size: var(--heading-size-desktop);
      margin-bottom: var(--heading-margin-desktop);
    }
  }

  /* Subheading */
  .dw-password__subheading {
    font-size: var(--subheading-size-mobile);
    line-height: 1.5;
    margin: 0 0 var(--subheading-margin-mobile);
    max-width: var(--subheading-max-width);
    opacity: var(--subheading-opacity, 0.85);
  }

  @media (min-width: 750px) {
    .dw-password__subheading {
      font-size: var(--subheading-size-desktop);
      margin-bottom: var(--subheading-margin-desktop);
    }
  }

  /* Text */
  .dw-password__text {
    font-size: var(--text-size-mobile);
    line-height: 1.6;
    margin: 0 0 var(--text-margin-mobile);
    max-width: var(--text-max-width);
    opacity: var(--text-opacity, 0.85);
  }

  @media (min-width: 750px) {
    .dw-password__text {
      font-size: var(--text-size-desktop);
      margin-bottom: var(--text-margin-desktop);
    }
  }

  .dw-password__text p {
    margin: 0 0 1em;
  }

  .dw-password__text p:last-child {
    margin-bottom: 0;
  }

  /* Bullets */
  .dw-password__bullets {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--bullets-margin-mobile);
    font-size: var(--bullets-size-mobile);
    max-width: var(--bullets-max-width);
  }

  @media (min-width: 750px) {
    .dw-password__bullets {
      font-size: var(--bullets-size-desktop);
      margin-bottom: var(--bullets-margin-desktop);
    }
  }

  .dw-password__bullets--vertical {
    display: flex;
    flex-direction: column;
    gap: var(--bullets-gap);
  }

  .dw-password__bullets--horizontal {
    display: flex;
    flex-wrap: wrap;
    gap: var(--bullets-gap) calc(var(--bullets-gap) * 2);
  }

  .dw-password__bullets--grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--bullets-gap);
  }

  @media (max-width: 749px) {
    .dw-password__bullets--grid {
      grid-template-columns: 1fr;
    }
  }

  .dw-password__bullet-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    text-align: left;
  }

  .dw-password__bullet-icon {
    flex-shrink: 0;
    color: var(--bullets-icon-color, #C4D600);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 2px;
  }

  .dw-password__bullet-text {
    flex: 1;
    opacity: 0.9;
  }

  /* Centered bullets alignment */
  .dw-password__content--center .dw-password__bullets--vertical,
  .dw-password__content--center .dw-password__bullets--grid {
    text-align: left;
  }

  @media (max-width: 749px) {
    .dw-password__content--mobile-center .dw-password__bullets--vertical,
    .dw-password__content--mobile-center .dw-password__bullets--grid {
      text-align: left;
    }
  }

  /* Divider */
  .dw-password__divider {
    width: var(--divider-width, 100%);
    height: var(--divider-height, 1px);
    background: var(--divider-color, rgba(255,255,255,0.2));
    margin-bottom: var(--divider-margin-mobile);
  }

  @media (min-width: 750px) {
    .dw-password__divider {
      margin-bottom: var(--divider-margin-desktop);
    }
  }

  /* Spacer */
  .dw-password__spacer {
    height: var(--spacer-height-mobile);
  }

  @media (min-width: 750px) {
    .dw-password__spacer {
      height: var(--spacer-height-desktop);
    }
  }

  /* Support Text */
  .dw-password__support {
    font-size: var(--support-size-mobile);
    opacity: var(--support-opacity, 0.6);
    margin-bottom: var(--support-margin-mobile);
  }

  .dw-password__support a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .dw-password__support a:hover {
    opacity: 1;
  }

  @media (min-width: 750px) {
    .dw-password__support {
      font-size: var(--support-size-desktop);
      margin-bottom: var(--support-margin-desktop);
    }
  }

  /* ==========================================
     PASSWORD FORM
     ========================================== */
  
  .dw-password__form-wrap {
    width: 100%;
    max-width: var(--form-max-width, 400px);
    margin-bottom: var(--form-margin-mobile);
  }

  @media (min-width: 750px) {
    .dw-password__form-wrap {
      margin-bottom: var(--form-margin-desktop);
    }
  }

  .dw-password__form {
    width: 100%;
  }

  .dw-password__form-inner {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .dw-password__form-inner--inline {
    flex-direction: row;
    gap: 10px;
  }

  @media (max-width: 549px) {
    .dw-password__form-inner--inline {
      flex-direction: column;
    }
  }

  .dw-password__form-inner--inline .dw-password__input-wrap {
    flex: 1;
  }

  .dw-password__input-wrap {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .dw-password__label {
    font-size: 14px;
    font-weight: 500;
    opacity: 0.8;
    text-align: left;
  }

  .dw-password__input-container {
    position: relative;
    display: flex;
    align-items: center;
  }

  .dw-password__input-icon {
    position: absolute;
    left: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--pw-input-text);
    opacity: 0.5;
    pointer-events: none;
    z-index: 1;
  }

  .dw-password__input {
    width: 100%;
    padding: 16px 20px;
    font-size: 16px;
    font-family: inherit;
    color: var(--pw-input-text, #ffffff);
    background: var(--pw-input-bg, rgba(255,255,255,0.08));
    border: 2px solid var(--pw-input-border, rgba(255,255,255,0.15));
    border-radius: 8px;
    outline: none;
    transition: border-color 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
  }

  .dw-password__input--has-icon {
    padding-left: 48px;
  }

  .dw-password__input::placeholder {
    color: var(--pw-input-text, #ffffff);
    opacity: 0.4;
  }

  .dw-password__input:focus {
    border-color: var(--pw-input-focus-border, #C4D600);
    background: rgba(255,255,255,0.1);
    box-shadow: 0 0 0 3px rgba(196, 214, 0, 0.15);
  }

  /* Error State */
  .dw-password__error {
    display: flex;
    align-items: center;
    gap: 8px;
    margin: 8px 0 0;
    padding: 10px 14px;
    font-size: 14px;
    color: var(--pw-error-color, #ff4d4d);
    background: rgba(255, 77, 77, 0.1);
    border: 1px solid rgba(255, 77, 77, 0.3);
    border-radius: 6px;
    text-align: left;
  }

  .dw-password__error svg {
    flex-shrink: 0;
  }

  /* ==========================================
     BUTTON STYLES
     ========================================== */

  .dw-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 32px;
    font-size: 15px;
    font-weight: 600;
    font-family: inherit;
    text-decoration: none;
    border-radius: 8px;
    transition: all 0.2s ease;
    cursor: pointer;
    border: 2px solid transparent;
    position: relative;
    color: var(--btn-text-color, inherit);
    white-space: nowrap;
  }

  .dw-btn--full {
    width: 100%;
  }

  .dw-btn--primary {
    background: var(--btn-bg, #C4D600);
    color: var(--btn-text-color, #0a0a0a);
    border-color: var(--btn-border-color, transparent);
  }

  .dw-btn--primary:hover {
    filter: brightness(1.1);
    transform: translateY(-1px);
  }

  .dw-btn--secondary {
    background: var(--btn-bg, transparent);
    color: var(--btn-text-color, #ffffff);
    border-color: var(--btn-border-color, rgba(255,255,255,0.3));
  }

  .dw-btn--secondary:hover {
    background: rgba(255,255,255,0.1);
    border-color: var(--btn-border-color, rgba(255,255,255,0.5));
  }

  .dw-btn--white {
    background: var(--btn-bg, #ffffff);
    color: var(--btn-text-color, #0a0a0a);
    border-color: var(--btn-border-color, transparent);
  }

  .dw-btn--white:hover {
    filter: brightness(0.95);
    transform: translateY(-1px);
  }

  /* Animated Gradient Button */
  .dw-btn--gradient {
    background: transparent;
    color: var(--btn-text-color, #fff);
    border: none;
    position: relative;
    z-index: 1;
    border-radius: 8px;
    overflow: hidden;
  }

  .dw-btn--gradient::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 8px;
    padding: 2px;
    background: linear-gradient(
      90deg,
      var(--btn-gradient-1, #C4D600),
      var(--btn-gradient-2, #00d4ff),
      var(--btn-gradient-1, #C4D600),
      var(--btn-gradient-2, #00d4ff)
    );
    background-size: 300% 100%;
    -webkit-mask: 
      linear-gradient(#fff 0 0) content-box, 
      linear-gradient(#fff 0 0);
    mask: 
      linear-gradient(#fff 0 0) content-box, 
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    z-index: -1;
  }

  .dw-btn--gradient-animate::before {
    animation: gradient-shift 3s linear infinite;
  }

  .dw-btn--gradient:hover::before {
    animation: gradient-shift 1.5s linear infinite;
  }

  .dw-btn--gradient span {
    position: relative;
    z-index: 2;
  }

  .dw-btn--gradient::after {
    content: '';
    position: absolute;
    inset: 2px;
    border-radius: 6px;
    background: var(--btn-bg, #0a0a0a);
    z-index: -1;
    transition: background 0.3s ease;
  }

  /* Gradient Glow */
  .dw-btn--gradient-glow {
    background: transparent;
    color: var(--btn-text-color, #fff);
    border: none;
    position: relative;
    z-index: 1;
    border-radius: 8px;
    overflow: visible;
  }

  .dw-btn--gradient-glow::before {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 12px;
    background: linear-gradient(
      90deg,
      var(--btn-gradient-1, #C4D600),
      var(--btn-gradient-2, #00d4ff),
      var(--btn-gradient-1, #C4D600),
      var(--btn-gradient-2, #00d4ff)
    );
    background-size: 300% 100%;
    z-index: -2;
    animation: gradient-shift 3s linear infinite;
    filter: blur(12px);
    opacity: 0.7;
  }

  .dw-btn--gradient-glow::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 8px;
    background: var(--btn-bg, #0a0a0a);
    z-index: -1;
  }

  .dw-btn--gradient-glow:hover::before {
    filter: blur(16px);
    opacity: 1;
    animation: gradient-shift 1.5s linear infinite;
  }

  .dw-btn--gradient-glow:hover {
    transform: translateY(-2px);
  }

  .dw-btn--gradient-glow span {
    position: relative;
    z-index: 2;
  }

  @keyframes gradient-shift {
    0% { background-position: 0% 50%; }
    100% { background-position: 300% 50%; }
  }

  /* ==========================================
     ENTRANCE ANIMATIONS
     ========================================== */
  
  .dw-password--animate .dw-password__block {
    opacity: 0;
    animation-fill-mode: forwards;
    animation-duration: var(--pw-animation-duration, 800ms);
    animation-delay: calc(var(--block-index, 1) * var(--pw-animation-stagger, 100ms));
  }

  /* Fade Up */
  .dw-password--animate[data-animation="fade-up"] .dw-password__block {
    animation-name: pw-fade-up;
  }

  @keyframes pw-fade-up {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Fade In */
  .dw-password--animate[data-animation="fade-in"] .dw-password__block {
    animation-name: pw-fade-in;
  }

  @keyframes pw-fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  /* Scale Up */
  .dw-password--animate[data-animation="scale-up"] .dw-password__block {
    animation-name: pw-scale-up;
  }

  @keyframes pw-scale-up {
    from {
      opacity: 0;
      transform: scale(0.9);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  /* Blur In */
  .dw-password--animate[data-animation="blur-in"] .dw-password__block {
    animation-name: pw-blur-in;
  }

  @keyframes pw-blur-in {
    from {
      opacity: 0;
      filter: blur(10px);
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      filter: blur(0);
      transform: translateY(0);
    }
  }

  /* Glitch In */
  .dw-password--animate[data-animation="glitch-in"] .dw-password__block {
    animation-name: pw-glitch-in;
  }

  @keyframes pw-glitch-in {
    0% {
      opacity: 0;
      transform: translateX(-5px);
      filter: blur(4px);
    }
    20% {
      opacity: 0.5;
      transform: translateX(5px);
      filter: blur(2px);
    }
    40% {
      opacity: 0.7;
      transform: translateX(-3px);
      filter: blur(1px);
    }
    60% {
      opacity: 0.9;
      transform: translateX(2px);
      filter: blur(0);
    }
    80% {
      opacity: 1;
      transform: translateX(-1px);
    }
    100% {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* Cyber Reveal */
  .dw-password--animate[data-animation="cyber-reveal"] .dw-password__block {
    animation-name: pw-cyber-reveal;
  }

  @keyframes pw-cyber-reveal {
    0% {
      opacity: 0;
      clip-path: polygon(0 0, 0 0, 0 100%, 0 100%);
    }
    50% {
      opacity: 1;
      clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%);
    }
    100% {
      opacity: 1;
      clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%);
    }
  }

  /* Reduce motion */
  @media (prefers-reduced-motion: reduce) {
    .dw-password--animate .dw-password__block,
    .dw-password__glow-orb,
    .dw-btn--gradient-animate::before {
      animation: none;
      opacity: 1;
    }
  }
</style>

