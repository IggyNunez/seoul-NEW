{%- comment -%}
  SGL Glow Society — rewards program info page.
  Explains earn/redeem, reward tiers, and membership tiers. Content-driven via
  settings so copy can be tweaked in the editor. On-brand SGL styling.
{%- endcomment -%}

{%- liquid
  assign s = section.settings
-%}

<div class="section-background color-{{ s.color_scheme }}"></div>
<div class="sgl-society color-{{ s.color_scheme }}" style="{% render 'spacing-style', settings: s %}">
  <div class="sgl-society__inner">

    <header class="sgl-society__masthead">
      <p class="sgl-society__kicker">{{ s.kicker | default: 'Rewards' }}</p>
      <h1 class="sgl-society__title">{{ s.heading | default: 'SGL Glow Society' }}</h1>
      {%- if s.intro != blank -%}<p class="sgl-society__intro">{{ s.intro }}</p>{%- endif -%}
      {%- if s.cta_text != blank and s.cta_link != blank -%}
        <a href="{{ s.cta_link }}" class="sgl-society__cta">{{ s.cta_text }}</a>
      {%- endif -%}
    </header>

    {%- comment -%} How it works {%- endcomment -%}
    <section class="sgl-society__block">
      <h2 class="sgl-society__h2">{{ s.earn_heading | default: 'How you glow' }}</h2>
      <div class="sgl-society__steps">
        <div class="sgl-society__step">
          <span class="sgl-society__step-num">1</span>
          <h3>Join free</h3>
          <p>Create an account and you're in. Every member is part of the Glow Society.</p>
        </div>
        <div class="sgl-society__step">
          <span class="sgl-society__step-num">2</span>
          <h3>Earn points</h3>
          <p>Earn <strong>1 point for every $1</strong> spent — online or in store.</p>
        </div>
        <div class="sgl-society__step">
          <span class="sgl-society__step-num">3</span>
          <h3>Redeem rewards</h3>
          <p>Turn points into savings on your favorite K-beauty faves.</p>
        </div>
      </div>
    </section>

    {%- comment -%} Reward tiers {%- endcomment -%}
    <section class="sgl-society__block">
      <h2 class="sgl-society__h2">{{ s.rewards_heading | default: 'Redeem your points' }}</h2>
      <ul class="sgl-society__rewards">
        <li><span class="sgl-society__pts">150 pts</span><span class="sgl-society__reward">$5 off a purchase of $50+</span></li>
        <li><span class="sgl-society__pts">300 pts</span><span class="sgl-society__reward">$10 off a purchase of $100+</span></li>
        <li><span class="sgl-society__pts">600 pts</span><span class="sgl-society__reward">$20 off a purchase of $200+</span></li>
        <li><span class="sgl-society__pts">900 pts</span><span class="sgl-society__reward">$30 off a purchase of $250+</span></li>
      </ul>
      <p class="sgl-society__fine">Keep earning beyond 900 points — the largest single reward is 900 pts = $30 off. One reward per transaction. Rewards can't be combined with other discounts, promotions, or sale items, and don't apply to services, event tickets, gift cards, or final sale items.</p>
    </section>

    {%- comment -%} Membership tiers {%- endcomment -%}
    <section class="sgl-society__block">
      <h2 class="sgl-society__h2">{{ s.tiers_heading | default: 'Member tiers' }}</h2>
      <div class="sgl-society__tiers">
        <div class="sgl-society__tier">
          <h3>Glow Member</h3>
          <p class="sgl-society__tier-unlock">Free to join</p>
          <ul>
            <li>Earn 1 point per $1</li>
            <li>Redeem for rewards</li>
            <li>Birthday points</li>
          </ul>
        </div>
        <div class="sgl-society__tier sgl-society__tier--mid">
          <h3>Glow Insider</h3>
          <p class="sgl-society__tier-unlock">Spend $500</p>
          <ul>
            <li>Everything in Glow Member</li>
            <li>24-hour early access to select events</li>
            <li>Birthday gift in store</li>
          </ul>
        </div>
        <div class="sgl-society__tier sgl-society__tier--top">
          <h3>Glow Circle</h3>
          <p class="sgl-society__tier-unlock">Spend $1,000</p>
          <ul>
            <li>Everything in Glow Insider</li>
            <li>48-hour early access to select events</li>
            <li>Priority access to limited-capacity events</li>
            <li>Birthday gift in store</li>
          </ul>
        </div>
      </div>
      <p class="sgl-society__fine">Birthday gifts are selected from Seoul Glow Lab's current mini / travel-size assortment, while supplies last.</p>
    </section>

  </div>
</div>

{% stylesheet %}
  .sgl-society {
    --sgl-periwinkle: #B0C3FA;
    --sgl-bloodred: #5E0A02;
    --sgl-mindaro: #F2FFA0;
    --sgl-cream: #F8EBDA;
    width: 100%;
  }
  .sgl-society__inner { max-width: 1080px; margin-inline: auto; padding-inline: var(--page-margin, 2rem); padding-block: clamp(2rem, 5vw, 4rem); }

  .sgl-society__masthead { text-align: center; margin-bottom: clamp(2.5rem, 5vw, 4rem); }
  .sgl-society__kicker { font-family: var(--font-primary--family); text-transform: uppercase; letter-spacing: 0.22em; font-size: 0.8rem; color: var(--sgl-bloodred); margin: 0 0 0.75rem; }
  .sgl-society__title { font-family: var(--font-primary--family); font-weight: 800; line-height: 1; font-size: clamp(2.6rem, 7vw, 4.5rem); margin: 0; color: var(--color-foreground); }
  .sgl-society__intro { max-width: 40rem; margin: 1rem auto 0; font-size: 1.1rem; line-height: 1.6; color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text, 0.75)); }
  .sgl-society__cta { display: inline-block; margin-top: 1.5rem; font-family: var(--font-primary--family); font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; text-decoration: none; background: var(--sgl-bloodred); color: #fff; padding: 0.85rem 2rem; border-radius: 999px; }
  .sgl-society__cta:hover { background: #7a0d03; }

  .sgl-society__block { margin-bottom: clamp(2.5rem, 5vw, 4rem); }
  .sgl-society__h2 { font-family: var(--font-primary--family); font-weight: 700; font-size: clamp(1.5rem, 3vw, 2.2rem); text-align: center; margin: 0 0 1.75rem; color: var(--color-foreground); }

  .sgl-society__steps { display: grid; grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); gap: 1.25rem; }
  .sgl-society__step { background: var(--color-background, #fff); border: 1px solid var(--sgl-periwinkle); border-radius: 14px; padding: 1.5rem; text-align: center; }
  .sgl-society__step-num { display: inline-flex; align-items: center; justify-content: center; width: 44px; height: 44px; border-radius: 50%; background: var(--sgl-periwinkle); color: var(--sgl-bloodred); font-family: var(--font-primary--family); font-weight: 800; font-size: 1.3rem; margin-bottom: 0.75rem; }
  .sgl-society__step h3 { font-family: var(--font-primary--family); font-weight: 700; margin: 0 0 0.4rem; }
  .sgl-society__step p { margin: 0; font-size: 0.95rem; line-height: 1.5; color: rgb(var(--color-foreground-rgb) / 0.75); }

  .sgl-society__rewards { list-style: none; margin: 0 auto; padding: 0; max-width: 40rem; display: flex; flex-direction: column; gap: 0.6rem; }
  .sgl-society__rewards li { display: flex; align-items: center; gap: 1rem; background: var(--sgl-cream); border-radius: 12px; padding: 0.9rem 1.25rem; }
  .sgl-society__pts { flex: 0 0 90px; font-family: var(--font-primary--family); font-weight: 800; color: var(--sgl-bloodred); font-size: 1.1rem; }
  .sgl-society__reward { font-size: 1rem; }

  .sgl-society__fine { max-width: 44rem; margin: 1.25rem auto 0; font-size: 0.85rem; line-height: 1.55; text-align: center; color: rgb(var(--color-foreground-rgb) / 0.6); }

  .sgl-society__tiers { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.25rem; align-items: start; }
  .sgl-society__tier { background: var(--color-background, #fff); border: 1px solid var(--sgl-periwinkle); border-radius: 16px; padding: 1.75rem 1.5rem; }
  .sgl-society__tier--mid { border-color: var(--sgl-bloodred); }
  .sgl-society__tier--top { background: var(--sgl-cream); border-color: var(--sgl-bloodred); border-width: 2px; }
  .sgl-society__tier h3 { font-family: var(--font-primary--family); font-weight: 800; font-size: 1.35rem; margin: 0 0 0.25rem; color: var(--sgl-bloodred); }
  .sgl-society__tier-unlock { font-family: var(--font-primary--family); text-transform: uppercase; letter-spacing: 0.08em; font-size: 0.78rem; color: rgb(var(--color-foreground-rgb) / 0.6); margin: 0 0 1rem; }
  .sgl-society__tier ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .sgl-society__tier li { position: relative; padding-left: 1.4rem; font-size: 0.95rem; line-height: 1.4; }
  .sgl-society__tier li::before { content: '✦'; position: absolute; left: 0; color: var(--sgl-bloodred); }

  @media (max-width: 640px) {
    .sgl-society__rewards li { flex-direction: column; align-items: flex-start; gap: 0.2rem; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "SGL Glow Society",
  "class": "section-wrapper",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Rewards" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "SGL Glow Society" },
    { "type": "textarea", "id": "intro", "label": "Intro", "default": "Skincare is a ritual — and rituals deserve rewards. Join the Glow Society to earn points on every purchase and unlock member perks." },
    { "type": "text", "id": "cta_text", "label": "Button text", "default": "Join / Sign In" },
    { "type": "url", "id": "cta_link", "label": "Button link" },
    { "type": "text", "id": "earn_heading", "label": "How-it-works heading", "default": "How you glow" },
    { "type": "text", "id": "rewards_heading", "label": "Rewards heading", "default": "Redeem your points" },
    { "type": "text", "id": "tiers_heading", "label": "Tiers heading", "default": "Member tiers" },
    { "type": "color_scheme", "id": "color_scheme", "label": "t:settings.color_scheme", "default": "scheme-1" },
    { "type": "header", "content": "t:content.padding" },
    { "type": "range", "id": "padding-block-start", "label": "t:settings.top", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding-block-end", "label": "t:settings.bottom", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 }
  ],
  "presets": [{ "name": "SGL Glow Society" }]
}
{% endschema %}
