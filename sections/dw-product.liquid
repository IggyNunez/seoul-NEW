                <!-- Stats Grid -->
                <div class="dw-product__clinical-stats">
                  {%- if block.settings.stat_1_value != blank -%}
                    <div class="dw-product__clinical-stat">
                      {%- if block.settings.stat_1_icon != 'none' or block.settings.stat_1_emoji != blank -%}
                        <span class="dw-product__clinical-stat-icon">
                          {%- if block.settings.stat_1_emoji != blank -%}
                            {{ block.settings.stat_1_emoji }}
                          {%- else -%}
                            {%- case block.settings.stat_1_icon -%}
                              {%- when 'lightning' -%}
                                <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
                              {%- when 'heart' -%}
                                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                              {%- when 'moon' -%}
                                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
                              {%- when 'brain' -%}
                                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a9 9 0 0 0-9 9c0 3.6 2.4 6.9 6 8.5V22h6v-2.5c3.6-1.6 6-4.9 6-8.5a9 9 0 0 0-9-9zm-1 16h2v2h-2v-2zm4-3.5c0 .3-.2.5-.5.5h-5c-.3 0-.5-.2-.5-.5v-1c0-.3.2-.5.5-.5h5c.3 0 .5.2.5.5v1z"></path></svg>
                              {%- when 'shield' -%}
                                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                              {%- when 'star' -%}
                                <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                              {%- when 'leaf' -%}
                                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17 8c-4 0-8 4-8 8 0 .5 0 1 .1 1.5C6.5 16.5 5 14 5 11c0-5 5-9 12-9 0 4-2 6-2 6h2s0-4 1-6c0 0 3 3 3 8 0 4-2 7-4 7z"></path></svg>
                              {%- when 'trophy' -%}
                                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3 6h6l-5 4 2 7-6-4-6 4 2-7-5-4h6l3-6z"></path></svg>
                            {%- endcase -%}
                          {%- endif -%}
                        </span>
                      {%- endif -%}
                      <span class="dw-product__clinical-stat-value">{{ block.settings.stat_1_value }}</span>
                      <span class="dw-product__clinical-stat-label">{{ block.settings.stat_1_label }}</span>
                    </div>
                  {%- endif -%}
                  
                  {%- if block.settings.stat_2_value != blank -%}
                    <div class="dw-product__clinical-stat">
                      {%- if block.settings.stat_2_icon != 'none' or block.settings.stat_2_emoji != blank -%}
                        <span class="dw-product__clinical-stat-icon">
                          {%- if block.settings.stat_2_emoji != blank -%}
                            {{ block.settings.stat_2_emoji }}
                          {%- else -%}
                            {%- case block.settings.stat_2_icon -%}
                              {%- when 'lightning' -%}
                                <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
                              {%- when 'heart' -%}
                                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                              {%- when 'moon' -%}
                                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
                              {%- when 'brain' -%}
                                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a9 9 0 0 0-9 9c0 3.6 2.4 6.9 6 8.5V22h6v-2.5c3.6-1.6 6-4.9 6-8.5a9 9 0 0 0-9-9zm-1 16h2v2h-2v-2zm4-3.5c0 .3-.2.5-.5.5h-5c-.3 0-.5-.2-.5-.5v-1c0-.3.2-.5.5-.5h5c.3 0 .5.2.5.5v1z"></path></svg>
                              {%- when 'shield' -%}
                                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                              {%- when 'star' -%}
                                <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                              {%- when 'leaf' -%}
                                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17 8c-4 0-8 4-8 8 0 .5 0 1 .1 1.5C6.5 16.5 5 14 5 11c0-5 5-9 12-9 0 4-2 6-2 6h2s0-4 1-6c0 0 3 3 3 8 0 4-2 7-4 7z"></path></svg>
                              {%- when 'trophy' -%}
                                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3 6h6l-5 4 2 7-6-4-6 4 2-7-5-4h6l3-6z"></path></svg>
                            {%- endcase -%}
                          {%- endif -%}
                        </span>
                      {%- endif -%}
                      <span class="dw-product__clinical-stat-value">{{ block.settings.stat_2_value }}</span>
                      <span class="dw-product__clinical-stat-label">{{ block.settings.stat_2_label }}</span>
                    </div>
                  {%- endif -%}
                  
                  {%- if block.settings.stat_3_value != blank -%}
                    <div class="dw-product__clinical-stat">
                      {%- if block.settings.stat_3_icon != 'none' or block.settings.stat_3_emoji != blank -%}
                        <span class="dw-product__clinical-stat-icon">
                          {%- if block.settings.stat_3_emoji != blank -%}
                            {{ block.settings.stat_3_emoji }}
                          {%- else -%}
                            {%- case block.settings.stat_3_icon -%}
                              {%- when 'lightning' -%}
                                <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
                              {%- when 'heart' -%}
                                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                              {%- when 'moon' -%}
                                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
                              {%- when 'brain' -%}
                                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a9 9 0 0 0-9 9c0 3.6 2.4 6.9 6 8.5V22h6v-2.5c3.6-1.6 6-4.9 6-8.5a9 9 0 0 0-9-9zm-1 16h2v2h-2v-2zm4-3.5c0 .3-.2.5-.5.5h-5c-.3 0-.5-.2-.5-.5v-1c0-.3.2-.5.5-.5h5c.3 0 .5.2.5.5v1z"></path></svg>
                              {%- when 'shield' -%}
                                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                              {%- when 'star' -%}
                                <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                              {%- when 'leaf' -%}
                                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17 8c-4 0-8 4-8 8 0 .5 0 1 .1 1.5C6.5 16.5 5 14 5 11c0-5 5-9 12-9 0 4-2 6-2 6h2s0-4 1-6c0 0 3 3 3 8 0 4-2 7-4 7z"></path></svg>
                              {%- when 'trophy' -%}
                                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3 6h6l-5 4 2 7-6-4-6 4 2-7-5-4h6l3-6z"></path></svg>
                            {%- endcase -%}
                          {%- endif -%}
                        </span>
                      {%- endif -%}
                      <span class="dw-product__clinical-stat-value">{{ block.settings.stat_3_value }}</span>
                      <span class="dw-product__clinical-stat-label">{{ block.settings.stat_3_label }}</span>
                    </div>
                  {%- endif -%}
                  
                  {%- if block.settings.stat_4_value != blank -%}
                    <div class="dw-product__clinical-stat">
                      {%- if block.settings.stat_4_icon != 'none' or block.settings.stat_4_emoji != blank -%}
                        <span class="dw-product__clinical-stat-icon">
                          {%- if block.settings.stat_4_emoji != blank -%}
                            {{ block.settings.stat_4_emoji }}
                          {%- else -%}
                            {%- case block.settings.stat_4_icon -%}
                              {%- when 'lightning' -%}
                                <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
                              {%- when 'heart' -%}
                                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                              {%- when 'moon' -%}
                                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
                              {%- when 'brain' -%}
                                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a9 9 0 0 0-9 9c0 3.6 2.4 6.9 6 8.5V22h6v-2.5c3.6-1.6 6-4.9 6-8.5a9 9 0 0 0-9-9zm-1 16h2v2h-2v-2zm4-3.5c0 .3-.2.5-.5.5h-5c-.3 0-.5-.2-.5-.5v-1c0-.3.2-.5.5-.5h5c.3 0 .5.2.5.5v1z"></path></svg>
                              {%- when 'shield' -%}
                                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                              {%- when 'star' -%}
                                <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                              {%- when 'leaf' -%}
                                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17 8c-4 0-8 4-8 8 0 .5 0 1 .1 1.5C6.5 16.5 5 14 5 11c0-5 5-9 12-9 0 4-2 6-2 6h2s0-4 1-6c0 0 3 3 3 8 0 4-2 7-4 7z"></path></svg>
                              {%- when 'trophy' -%}
                                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3 6h6l-5 4 2 7-6-4-6 4 2-7-5-4h6l3-6z"></path></svg>
                            {%- endcase -%}
                          {%- endif -%}
                        </span>
                      {%- endif -%}
                      <span class="dw-product__clinical-stat-value">{{ block.settings.stat_4_value }}</span>
                      <span class="dw-product__clinical-stat-label">{{ block.settings.stat_4_label }}</span>
                    </div>
                  {%- endif -%}
                </div>
                
                <!-- Disclaimer -->
                {%- if block.settings.disclaimer != blank -%}
                  <p class="dw-product__clinical-disclaimer">{{ block.settings.disclaimer }}</p>
                {%- endif -%}
                
                <!-- Expandable Details -->
                {%- if block.settings.expand_title != blank and block.settings.expand_content != blank -%}
                  <details class="dw-product__clinical-details">
                    <summary class="dw-product__clinical-details-trigger">
                      <span class="dw-product__clinical-details-title">{{ block.settings.expand_title }}</span>
                      <span class="dw-product__clinical-details-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                      </span>
                    </summary>
                    <div class="dw-product__clinical-details-content">
                      <div class="dw-product__clinical-details-body">
                        {{ block.settings.expand_content }}
                      </div>
                      
                      <!-- Certification Badges -->
                      {%- if block.settings.cert_1_image != blank or block.settings.cert_2_image != blank or block.settings.cert_3_image != blank -%}
                        <div class="dw-product__clinical-certs">
                          {%- if block.settings.cert_1_image != blank -%}
                            <div class="dw-product__clinical-cert">
                              <img src="{{ block.settings.cert_1_image | image_url: width: 120 }}" alt="{{ block.settings.cert_1_label | escape }}" loading="lazy">
                              {%- if block.settings.cert_1_label != blank -%}
                                <span class="dw-product__clinical-cert-label">{{ block.settings.cert_1_label }}</span>
                              {%- endif -%}
                            </div>
                          {%- endif -%}
                          {%- if block.settings.cert_2_image != blank -%}
                            <div class="dw-product__clinical-cert">
                              <img src="{{ block.settings.cert_2_image | image_url: width: 120 }}" alt="{{ block.settings.cert_2_label | escape }}" loading="lazy">
                              {%- if block.settings.cert_2_label != blank -%}
                                <span class="dw-product__clinical-cert-label">{{ block.settings.cert_2_label }}</span>
                              {%- endif -%}
                            </div>
                          {%- endif -%}
                          {%- if block.settings.cert_3_image != blank -%}
                            <div class="dw-product__clinical-cert">
                              <img src="{{ block.settings.cert_3_image | image_url: width: 120 }}" alt="{{ block.settings.cert_3_label | escape }}" loading="lazy">
                              {%- if block.settings.cert_3_label != blank -%}
                                <span class="dw-product__clinical-cert-label">{{ block.settings.cert_3_label }}</span>
                              {%- endif -%}
                            </div>
                          {%- endif -%}
                        </div>
                      {%- endif -%}
                    </div>
                  </details>
                {%- endif -%}
              </div>
            
          {%- endcase -%}
        {%- endfor -%}
        
        {%- endform -%}
      </div>
    </div>
    
  </div>
  
  {%- if section.settings.enable_sticky_atc -%}
    <!-- Sticky Add to Cart (Mobile) -->
    <div class="dw-product__sticky-bar">
      <div class="dw-product__sticky-info">
        <span class="dw-product__sticky-title">{{ product.title }}</span>
        <span class="dw-product__sticky-price" data-sticky-price>{{ current_variant.price | money }}</span>
      </div>
      <button 
        type="button"
        class="dw-product__sticky-atc"
        data-sticky-add-to-cart
        {% unless current_variant.available %}disabled{% endunless %}
      >
        {%- if current_variant.available -%}
          Add to Cart
        {%- else -%}
          Sold Out
        {%- endif -%}
      </button>
    </div>
  {%- endif -%}
  
</section>
{% render 'dw-style-js' %}
{% schema %}
{
  "name": "DW Product",
  "tag": "section",
  "class": "dw-product-section",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#0a0a0a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#C4D600"
    },
    {
      "type": "color",
      "id": "accent_text_color",
      "label": "Accent text",
      "default": "#0a0a0a"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Muted text",
      "default": "#888888"
    },
    {
      "type": "color",
