                        {%- endif -%}
                      </div>
                    </div>
                  </details>
                {%- endif -%}
                
                {%- if block.settings.item_5_title != blank -%}
                  <details class="dw-product__accordion-item"{% if block.settings.item_5_open %} open{% endif %}>
                    <summary class="dw-product__accordion-header">
                      <span class="dw-product__accordion-title">{{ block.settings.item_5_title }}</span>
                      <span class="dw-product__accordion-icon">
                        <svg class="dw-product__accordion-plus" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <line x1="12" y1="5" x2="12" y2="19"></line>
                          <line x1="5" y1="12" x2="19" y2="12"></line>
                        </svg>
                        <svg class="dw-product__accordion-minus" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <line x1="5" y1="12" x2="19" y2="12"></line>
                        </svg>
                      </span>
                    </summary>
                    <div class="dw-product__accordion-content">
                      <div class="dw-product__accordion-body">
                        {{ block.settings.item_5_content }}
                        {%- if block.settings.item_5_link_text != blank -%}
                          <a href="{{ block.settings.item_5_link_url }}" class="dw-product__accordion-link">
                            {{ block.settings.item_5_link_text }}
                          </a>
                        {%- endif -%}
                      </div>
                    </div>
                  </details>
                {%- endif -%}
              </div>
            
            {%- when 'video_testimonials' -%}
              <div 
                class="dw-product__videos dw-product__block"
                style="
                  --video-thumb-width: {{ block.settings.thumb_width }}px;
                  --video-thumb-gap: {{ block.settings.thumb_gap }}px;
                  --video-play-color: {{ block.settings.play_button_color }};
                  --video-play-bg: {{ block.settings.play_button_bg }};
                "
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.heading != blank -%}
                  <div class="dw-product__videos-header">
                    <h3 class="dw-product__videos-heading">{{ block.settings.heading }}</h3>
                    <div class="dw-product__videos-arrows">
                      <button type="button" class="dw-product__videos-arrow" data-video-prev aria-label="Previous videos">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <polyline points="15 18 9 12 15 6"></polyline>
                        </svg>
                      </button>
                      <button type="button" class="dw-product__videos-arrow" data-video-next aria-label="Next videos">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <polyline points="9 18 15 12 9 6"></polyline>
                        </svg>
                      </button>
                    </div>
                  </div>
                {%- else -%}
                  <div class="dw-product__videos-arrows dw-product__videos-arrows--standalone">
                    <button type="button" class="dw-product__videos-arrow" data-video-prev aria-label="Previous videos">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="15 18 9 12 15 6"></polyline>
                      </svg>
                    </button>
                    <button type="button" class="dw-product__videos-arrow" data-video-next aria-label="Next videos">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="9 18 15 12 9 6"></polyline>
                      </svg>
                    </button>
                  </div>
                {%- endif -%}
                
                <div class="dw-product__videos-carousel">
                  <div class="dw-product__videos-track">
                    
                    {%- for i in (1..8) -%}
                      {%- assign thumb_key = 'video_' | append: i | append: '_thumbnail' -%}
                      {%- assign video_key = 'video_' | append: i | append: '_url' -%}
                      {%- assign caption_key = 'video_' | append: i | append: '_caption' -%}
                      {%- assign thumb = block.settings[thumb_key] -%}
                      {%- assign video_url = block.settings[video_key] -%}
                      {%- assign caption = block.settings[caption_key] -%}
                      
                      {%- if thumb != blank -%}
                        <button 
                          type="button" class="dw-product__video-thumb"
                          data-video-trigger
                          data-video-url="{{ video_url }}"
                          data-video-caption="{{ caption | escape }}"
                          aria-label="Play video testimonial"
                        >
                          <img 
                            src="{{ thumb | image_url: width: 400 }}"
                            alt="{{ caption | default: 'Video testimonial' | escape }}"
                            loading="lazy"
                            class="dw-product__video-thumb-img"
                          >
                          <span class="dw-product__video-play">
                            <svg viewBox="0 0 24 24" fill="currentColor">
                              <polygon points="5 3 19 12 5 21 5 3"></polygon>
                            </svg>
                          </span>
                          {%- if caption != blank and block.settings.show_captions -%}
                            <span class="dw-product__video-caption">{{ caption }}</span>
                          {%- endif -%}
                        </button>
                      {%- endif -%}
                    {%- endfor -%}
                    
                  </div>
                </div>
              </div>
              
              <!-- Video Modal -->
              <div class="dw-product__video-modal" data-video-modal aria-hidden="true">
                <div class="dw-product__video-modal-backdrop" data-modal-close></div>
                <div class="dw-product__video-modal-content">
                  <button type="button" class="dw-product__video-modal-close" data-modal-close aria-label="Close video">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <line x1="18" y1="6" x2="6" y2="18"></line>
                      <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                  </button>
                  <div class="dw-product__video-modal-player">
                    <video 
                      class="dw-product__video-element" 
                      data-video-player
                      controls
                      playsinline
                      preload="metadata"
                    >
                      <source src="" type="video/mp4">
                    </video>
                  </div>
                </div>
              </div>
            
            {%- when 'clinical_results' -%}
              <div 
                class="dw-product__clinical dw-product__block"
                style="
                  --clinical-bg: {{ block.settings.background_color }};
                  --clinical-text: {{ block.settings.text_color }};
                  --clinical-accent: {{ block.settings.accent_color }};
                  --clinical-stat-color: {{ block.settings.stat_color }};
                  --clinical-muted: {{ block.settings.muted_color }};
                "
