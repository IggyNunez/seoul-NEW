{% comment %}
  DoingWell Product Section
  - IM8-inspired modern product layout
  - Split screen with media gallery + content
  - Subscription toggle with savings display
  - Trust badges with icons
  - Benefits list with animated icons
  - Animated gradient glow effects
  - Full mobile/desktop responsive controls
  - Sticky add-to-cart option
{% endcomment %}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign product_form_id = 'product-form-' | append: section.id
  assign mobile_image = section.settings.mobile_image | default: product.featured_image
-%}

<section 
  class="dw-product{% if section.settings.enable_animations %} dw-product--animate{% endif %}{% if section.settings.enable_sticky_atc %} dw-product--sticky-atc{% endif %}"
  data-section-id="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-product-image="{{ product.featured_image | image_url: width: 100 }}"
  style="
    --product-bg: {{ section.settings.background_color }};
    --product-text: {{ section.settings.text_color }};
    --product-accent: {{ section.settings.accent_color }};
    --product-accent-text: {{ section.settings.accent_text_color }};
    --product-muted: {{ section.settings.muted_color }};
    --product-border: {{ section.settings.border_color }};
    --product-glow-1: {{ section.settings.glow_color_1 }};
    --product-glow-2: {{ section.settings.glow_color_2 }};
    --product-glow-3: {{ section.settings.glow_color_3 }};
    --product-padding-desktop: {{ section.settings.padding_desktop }}px;
    --product-padding-mobile: {{ section.settings.padding_mobile }}px;
    --product-gap-desktop: {{ section.settings.gap_desktop }}px;
    --product-gap-mobile: {{ section.settings.gap_mobile }}px;
    --product-media-ratio: {{ section.settings.media_ratio }};
    --product-content-max-width: {{ section.settings.content_max_width }}px;
  "
>
  <div class="dw-product__container">
    
    <!-- Media Side -->
    <div class="dw-product__media-wrapper">
      {%- if section.settings.enable_media_glow -%}
        <div class="dw-product__glow dw-product__glow--{{ section.settings.glow_style }}">
          <div class="dw-product__glow-bg"></div>
          <div class="dw-product__glow-orb dw-product__glow-orb--1"></div>
          <div class="dw-product__glow-orb dw-product__glow-orb--2"></div>
          <div class="dw-product__glow-orb dw-product__glow-orb--3"></div>
        </div>
      {%- endif -%}
      
      <div class="dw-product__media">
        {%- if product.featured_image != blank -%}
          <div class="dw-product__main-image" data-main-image-container>
            <img 
              src="{{ product.featured_image | image_url: width: 1200 }}" 
              srcset="{{ product.featured_image | image_url: width: 600 }} 600w,
                      {{ product.featured_image | image_url: width: 1200 }} 1200w,
                      {{ product.featured_image | image_url: width: 1800 }} 1800w"
              sizes="(min-width: 750px) 50vw, 100vw"
              alt="{{ product.featured_image.alt | default: product.title | escape }}"
              loading="eager"
              fetchpriority="high"
              class="dw-product__image"
              data-main-image
            >
            
            {%- if product.images.size > 1 -%}
              <!-- Navigation Arrows -->
              <button type="button" class="dw-product__nav dw-product__nav--prev" data-gallery-prev aria-label="Previous image">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="15 18 9 12 15 6"></polyline>
                </svg>
              </button>
              <button type="button" class="dw-product__nav dw-product__nav--next" data-gallery-next aria-label="Next image">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="9 6 15 12 9 18"></polyline>
                </svg>
              </button>
              
              <!-- Image Counter -->
              <div class="dw-product__counter" data-gallery-counter>
                <span data-current-index>1</span> / <span data-total-count>{{ product.images.size }}</span>
              </div>
            {%- endif -%}
          </div>
        {%- else -%}
          <div class="dw-product__image-placeholder">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
              <circle cx="8.5" cy="8.5" r="1.5"></circle>
              <polyline points="21 15 16 10 5 21"></polyline>
            </svg>
          </div>
        {%- endif -%}
        
        {%- if product.images.size > 1 and section.settings.show_thumbnails -%}
  <div class="dw-product__thumbnails-wrapper">
    <!-- Thumbnail Navigation Arrows -->
    {%- if product.images.size > 5 -%}
      <button type="button" class="dw-product__thumb-nav dw-product__thumb-nav--prev" data-thumb-prev aria-label="Previous thumbnails">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
    {%- endif -%}
    
    <div class="dw-product__thumbnails" data-thumbnails-track>
      {%- for image in product.images -%}
        <button 
          type="button"
          class="dw-product__thumbnail{% if forloop.first %} dw-product__thumbnail--active{% endif %}"
          data-thumbnail
          data-index="{{ forloop.index0 }}"
          data-image-url="{{ image | image_url: width: 1200 }}"
          data-image-srcset="{{ image | image_url: width: 600 }} 600w, {{ image | image_url: width: 1200 }} 1200w, {{ image | image_url: width: 1800 }} 1800w"
          data-image-alt="{{ image.alt | default: product.title | escape }}"
          aria-label="View {{ image.alt | default: product.title }}"
        >
          <img 
            src="{{ image | image_url: width: 150 }}"
            alt="{{ image.alt | default: product.title | escape }}"
            loading="lazy"
          >
        </button>
      {%- endfor -%}
    </div>
    
    {%- if product.images.size > 5 -%}
      <button type="button" class="dw-product__thumb-nav dw-product__thumb-nav--next" data-thumb-next aria-label="Next thumbnails">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="9 6 15 12 9 18"></polyline>
        </svg>
      </button>
    {%- endif -%}
  </div>
{%- endif -%}
      </div>
    </div>
    
    <!-- Content Side -->
    <div class="dw-product__content">
      <div class="dw-product__content-inner">
        
        {%- form 'product', product, id: product_form_id, novalidate: 'novalidate', data-type: 'add-to-cart-form', data-product-form: '' -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id>
          
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when '@app' -%}
  <div class="dw-product__app-block dw-product__block" {{ block.shopify_attributes }}>
    {% render block %}
  </div>
            {%- when 'badge' -%}
              <div class="dw-product__badges dw-product__block" {{ block.shopify_attributes }}>
                {%- if block.settings.badge_1 != blank -%}
                  <span class="dw-product__badge dw-product__badge--{{ block.settings.badge_1_style }}">
                    {{ block.settings.badge_1 }}
                  </span>
                {%- endif -%}
                {%- if block.settings.badge_2 != blank -%}
                  <span class="dw-product__badge dw-product__badge--{{ block.settings.badge_2_style }}">
                    {{ block.settings.badge_2 }}
                  </span>
                {%- endif -%}
              </div>
            
            {%- when 'title' -%}
              <{{ block.settings.heading_tag }} 
                class="dw-product__title dw-product__block"
                style="
                  --title-size-desktop: {{ block.settings.size_desktop }}px;
                  --title-size-mobile: {{ block.settings.size_mobile }}px;
                  --title-weight: {{ block.settings.font_weight }};
                "
                {{ block.shopify_attributes }}
              >
                {{ product.title }}
              </{{ block.settings.heading_tag }}>
            
            {%- when 'subtitle' -%}
              <p 
                class="dw-product__subtitle dw-product__block"
                style="
                  --subtitle-size-desktop: {{ block.settings.size_desktop }}px;
                  --subtitle-size-mobile: {{ block.settings.size_mobile }}px;
                "
                {{ block.shopify_attributes }}
              >
                {{ block.settings.text }}
              </p>
            
            {%- when 'rating' -%}
              <div class="dw-product__rating dw-product__block" {{ block.shopify_attributes }}>
                <div class="dw-product__stars">
                  {%- for i in (1..5) -%}
                    <svg class="dw-product__star{% if i <= block.settings.rating %} dw-product__star--filled{% endif %}" viewBox="0 0 24 24" fill="currentColor">
                      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                    </svg>
                  {%- endfor -%}
                </div>
                <span class="dw-product__rating-text">
                  {{ block.settings.rating_text }}
                </span>
              </div>
            
            {%- when 'price' -%}
              <div 
                class="dw-product__price-wrapper dw-product__block"
                style="
                  --price-size: {{ block.settings.price_size }}px;
                  --compare-size: {{ block.settings.compare_size }}px;
                "
                {{ block.shopify_attributes }}
              >
                <div class="dw-product__price" data-price>
                  <span class="dw-product__price-current" data-current-price>
                    {{ current_variant.price | money }}
                  </span>
                  {%- if current_variant.compare_at_price > current_variant.price -%}
                    <span class="dw-product__price-compare" data-compare-price>
                      {{ current_variant.compare_at_price | money }}
                    </span>
                    <span class="dw-product__price-save" data-save-badge>
                      Save {{ current_variant.compare_at_price | minus: current_variant.price | money }}
                    </span>
                  {%- endif -%}
                </div>
                {%- if block.settings.show_per_serving and block.settings.servings > 0 -%}
                  <div class="dw-product__per-serving" data-per-serving>
                    {{ current_variant.price | divided_by: block.settings.servings | money }} per serving
                  </div>
                {%- endif -%}
              </div>
            
            {%- when 'variant_selector' -%}
              {%- unless product.has_only_default_variant -%}
              <div class="dw-product__variants dw-product__block" {{ block.shopify_attributes }}>
                {%- if block.settings.section_title != blank -%}
                  <h3 class="dw-product__variants-title">{{ block.settings.section_title }}</h3>
                {%- endif -%}
                
                {%- if block.settings.selector_style == 'visual_cards' -%}
                  <!-- Visual Product Cards Style -->
                  <div class="dw-product__variant-cards">
                    {%- for variant in product.variants -%}
                      <button 
                        type="button"
                        class="dw-product__variant-card{% if variant == current_variant %} dw-product__variant-card--active{% endif %}{% unless variant.available %} dw-product__variant-card--soldout{% endunless %}"
                        data-variant-card
                        data-variant-id="{{ variant.id }}"
                        {% unless variant.available %}disabled{% endunless %}
                      >
                        {%- comment -%} Badge - check metafield or use first variant as popular {%- endcomment -%}
                        {%- if forloop.first and block.settings.show_popular_badge -%}
                          <span class="dw-product__variant-badge">{{ block.settings.popular_badge_text }}</span>
                        {%- endif -%}
                        
                        {%- comment -%} Variant Image {%- endcomment -%}
                        <div class="dw-product__variant-card-image">
                          {%- if variant.featured_image != blank -%}
                            <img 
                              src="{{ variant.featured_image | image_url: width: 200 }}"
                              alt="{{ variant.title | escape }}"
                              width="100"
                              height="100"
                              loading="lazy"
                            >
                          {%- elsif product.featured_image != blank -%}
                            <img 
                              src="{{ product.featured_image | image_url: width: 200 }}"
                              alt="{{ variant.title | escape }}"
                              width="100"
                              height="100"
                              loading="lazy"
                            >
                          {%- else -%}
                            <div class="dw-product__variant-card-placeholder">
                              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                                <rect x="3" y="3" width="18" height="18" rx="2"></rect>
                                <circle cx="8.5" cy="8.5" r="1.5"></circle>
                                <polyline points="21 15 16 10 5 21"></polyline>
                              </svg>
                            </div>
                          {%- endif -%}
                        </div>
                        
                        {%- comment -%} Variant Info {%- endcomment -%}
                        <div class="dw-product__variant-card-info">
                          <span class="dw-product__variant-card-title">{{ variant.title }}</span>
                          {%- if block.settings.show_variant_details -%}
                            <span class="dw-product__variant-card-details">
                              {%- if variant.weight > 0 -%}
                                ({{ variant.weight | weight_with_unit }})
                              {%- endif -%}
                              {%- if block.settings.show_per_serving and variant.unit_price_measurement -%}
                                {{ variant.unit_price | money }}/{{ variant.unit_price_measurement.reference_unit }}
                              {%- elsif block.settings.per_serving_text != blank -%}
                                {{ block.settings.per_serving_text }}
                              {%- endif -%}
                            </span>
                          {%- endif -%}
                        </div>
                        
                        {%- unless variant.available -%}
                          <span class="dw-product__variant-card-soldout">Sold Out</span>
                        {%- endunless -%}
                      </button>
                    {%- endfor -%}
                  </div>
                  
                {%- elsif block.settings.selector_style == 'subscription' -%}
                  <!-- Subscription Toggle Style -->
                  <div class="dw-product__subscription-toggle">
                    <button 
                      type="button"
                      class="dw-product__sub-option dw-product__sub-option--subscribe dw-product__sub-option--active"
                      data-purchase-type="subscription"
                    >
                      <span class="dw-product__sub-radio"></span>
                      <span class="dw-product__sub-content">
                        <span class="dw-product__sub-label">{{ block.settings.subscribe_label }}</span>
                        <span class="dw-product__sub-price">{{ block.settings.subscribe_price }}</span>
                        {%- if block.settings.subscribe_save != blank -%}
                          <span class="dw-product__sub-save">{{ block.settings.subscribe_save }}</span>
                        {%- endif -%}
                      </span>
                    </button>
                    <button 
                      type="button"
                      class="dw-product__sub-option dw-product__sub-option--onetime"
                      data-purchase-type="onetime"
                    >
                      <span class="dw-product__sub-radio"></span>
                      <span class="dw-product__sub-content">
                        <span class="dw-product__sub-label">{{ block.settings.onetime_label }}</span>
                        <span class="dw-product__sub-price">{{ block.settings.onetime_price }}</span>
                      </span>
                    </button>
                  </div>
                  
                  <div class="dw-product__frequency" data-frequency-selector>
                    <label class="dw-product__frequency-label">Delivery every</label>
                    <select class="dw-product__frequency-select" name="selling_plan">
                      <option value="30">30 days</option>
                      <option value="60">60 days</option>
                      <option value="90">90 days</option>
                    </select>
                  </div>
                  
                {%- else -%}
                  <!-- Standard Variant Buttons -->
                  {%- for option in product.options_with_values -%}
                    <div class="dw-product__option">
                      <label class="dw-product__option-label">{{ option.name }}</label>
                      <div class="dw-product__option-values">
                        {%- for value in option.values -%}
                          <button 
                            type="button"
                            class="dw-product__option-btn{% if option.selected_value == value %} dw-product__option-btn--active{% endif %}"
                            data-option-name="{{ option.name }}"
                            data-option-value="{{ value }}"
                          >
                            {{ value }}
                          </button>
                        {%- endfor -%}
                      </div>
                    </div>
                  {%- endfor -%}
                {%- endif -%}
              </div>
              {%- endunless -%}
            
            {%- when 'subscription_tiers' -%}
              <div class="dw-product__subscription-tiers dw-product__block" {{ block.shopify_attributes }}>
                {%- if block.settings.section_title != blank -%}
                  <h3 class="dw-product__sub-section-title">{{ block.settings.section_title }}</h3>
                {%- endif -%}
                
                <!-- Tier 1: Best Value / Featured -->
                {%- if block.settings.tier1_enabled -%}
                  <div 
                    class="dw-product__sub-tier dw-product__sub-tier--featured{% if block.settings.tier1_selected %} dw-product__sub-tier--selected{% endif %}"
                    data-subscription-tier="1"
                    data-selling-plan="{{ block.settings.tier1_selling_plan }}"
                  >
                    {%- if block.settings.tier1_promo_badge != blank -%}
                      <span class="dw-product__sub-promo-badge">{{ block.settings.tier1_promo_badge }}</span>
                    {%- endif -%}
                    {%- if block.settings.tier1_value_badge != blank -%}
                      <span class="dw-product__sub-value-badge">{{ block.settings.tier1_value_badge }}</span>
                    {%- endif -%}
                    
                    <div class="dw-product__sub-tier-header">
                      <div class="dw-product__sub-tier-radio">
                        <span class="dw-product__sub-tier-radio-dot"></span>
                      </div>
                      <div class="dw-product__sub-tier-info">
                        <span class="dw-product__sub-tier-title">
                          {{ block.settings.tier1_title }}
                          {%- if block.settings.tier1_save_percent != blank -%}
                            <span class="dw-product__sub-tier-save">({{ block.settings.tier1_save_percent }})</span>
                          {%- endif -%}
                        </span>
                        <span class="dw-product__sub-tier-billing">{{ block.settings.tier1_billing_text }}</span>
                      </div>
                      <div class="dw-product__sub-tier-pricing">
                        <div class="dw-product__sub-tier-price">
                          <span class="dw-product__sub-tier-amount">{{ block.settings.tier1_price }}</span>
                          {%- if block.settings.tier1_compare_price != blank -%}
                            <span class="dw-product__sub-tier-compare">{{ block.settings.tier1_compare_price }}</span>
                          {%- endif -%}
                          <span class="dw-product__sub-tier-per">/mo</span>
                        </div>
                        {%- if block.settings.tier1_per_serving != blank -%}
                          <span class="dw-product__sub-tier-serving">{{ block.settings.tier1_per_serving }}</span>
                        {%- endif -%}
                      </div>
                    </div>
                    
                    {%- if block.settings.tier1_benefits != blank -%}
                      <ul class="dw-product__sub-tier-benefits">
                        {%- assign benefits = block.settings.tier1_benefits | newline_to_br | split: '<br />' -%}
                        {%- for benefit in benefits -%}
                          {%- assign benefit_text = benefit | strip -%}
                          {%- if benefit_text != blank -%}
                            <li class="dw-product__sub-benefit">
                              {%- assign first_char = benefit_text | slice: 0, 2 -%}
                              {%- if first_char contains '🔑' or first_char contains '💰' or first_char contains '👨' or first_char contains '🎁' or first_char contains '🚚' or first_char contains '⏸' or first_char contains '✓' or first_char contains '✔' -%}
                                {{ benefit_text }}
                              {%- else -%}
                                <span class="dw-product__sub-benefit-icon">✓</span>
                                {{ benefit_text }}
                              {%- endif -%}
                            </li>
                          {%- endif -%}
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}
                  </div>
                {%- endif -%}
                
                <!-- Tier 2: Standard Subscription -->
                {%- if block.settings.tier2_enabled -%}
                  <div 
                    class="dw-product__sub-tier{% if block.settings.tier2_selected %} dw-product__sub-tier--selected{% endif %}"
                    data-subscription-tier="2"
                    data-selling-plan="{{ block.settings.tier2_selling_plan }}"
                  >
                    <div class="dw-product__sub-tier-header">
                      <div class="dw-product__sub-tier-radio">
                        <span class="dw-product__sub-tier-radio-dot"></span>
                      </div>
                      <div class="dw-product__sub-tier-info">
                        <span class="dw-product__sub-tier-title">
                          {{ block.settings.tier2_title }}
                          {%- if block.settings.tier2_save_percent != blank -%}
                            <span class="dw-product__sub-tier-save">({{ block.settings.tier2_save_percent }})</span>
                          {%- endif -%}
                        </span>
                        <span class="dw-product__sub-tier-billing">{{ block.settings.tier2_billing_text }}</span>
                      </div>
                      <div class="dw-product__sub-tier-pricing">
                        <div class="dw-product__sub-tier-price">
                          <span class="dw-product__sub-tier-amount">{{ block.settings.tier2_price }}</span>
                          {%- if block.settings.tier2_compare_price != blank -%}
                            <span class="dw-product__sub-tier-compare">{{ block.settings.tier2_compare_price }}</span>
                          {%- endif -%}
                          <span class="dw-product__sub-tier-per">/mo</span>
                        </div>
                        {%- if block.settings.tier2_per_serving != blank -%}
                          <span class="dw-product__sub-tier-serving">{{ block.settings.tier2_per_serving }}</span>
                        {%- endif -%}
                      </div>
                    </div>
                    
                    {%- if block.settings.tier2_benefits != blank -%}
                      <ul class="dw-product__sub-tier-benefits">
                        {%- assign benefits = block.settings.tier2_benefits | newline_to_br | split: '<br />' -%}
                        {%- for benefit in benefits -%}
                          {%- assign benefit_text = benefit | strip -%}
                          {%- if benefit_text != blank -%}
                            <li class="dw-product__sub-benefit">
                              {%- assign first_char = benefit_text | slice: 0, 2 -%}
                              {%- if first_char contains '🔑' or first_char contains '💰' or first_char contains '👨' or first_char contains '🎁' or first_char contains '🚚' or first_char contains '⏸' or first_char contains '✓' or first_char contains '✔' -%}
                                {{ benefit_text }}
                              {%- else -%}
                                <span class="dw-product__sub-benefit-icon">✓</span>
                                {{ benefit_text }}
                              {%- endif -%}
                            </li>
                          {%- endif -%}
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}
                  </div>
                {%- endif -%}
                
                <!-- One-Time Purchase Option -->
                {%- if block.settings.onetime_enabled -%}
                  <div 
                    class="dw-product__sub-onetime{% if block.settings.onetime_selected %} dw-product__sub-tier--selected{% endif %}"
                    data-subscription-tier="onetime"
                    data-selling-plan=""
                  >
                    <span class="dw-product__sub-onetime-text">{{ block.settings.onetime_label }}</span>
                    <span class="dw-product__sub-onetime-price">{{ block.settings.onetime_price }}</span>
                  </div>
                {%- endif -%}
              </div>
            
            {%- when 'quantity_atc' -%}
              <div class="dw-product__purchase dw-product__block" {{ block.shopify_attributes }}>
                {%- if block.settings.show_quantity -%}
                  <div class="dw-product__quantity">
                    <button type="button" class="dw-product__qty-btn" data-qty-decrease aria-label="Decrease quantity">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                      </svg>
                    </button>
                    <input 
                      type="number" 
                      class="dw-product__qty-input" 
                      name="quantity" 
                      value="1" 
                      min="1" 
                      max="10"
                      data-quantity
                    >
                    <button type="button" class="dw-product__qty-btn" data-qty-increase aria-label="Increase quantity">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="12" y1="5" x2="12" y2="19"></line>
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                      </svg>
                    </button>
                  </div>
                {%- endif -%}
                <span class="appstle_stand_alone_selector" data-product-handle="{{ product.handle }}" style="display:none;"></span>
                <button 
                  type="submit"
                  class="dw-product__atc dw-product__atc--{{ block.settings.button_style }}{% if block.settings.button_style == 'gradient' or block.settings.button_style == 'gradient-glow' %} dw-product__atc--gradient-animate{% endif %}"
                  data-add-to-cart
                  {% unless current_variant.available %}disabled{% endunless %}
                  style="
                    --atc-gradient-1: {{ block.settings.gradient_1 }};
