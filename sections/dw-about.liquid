{% comment %}
  DW About / Story Section
  - Clean editorial aesthetic
  - Image block support
  - Split layouts
  - Pull quotes
  - Icon lists
  - On-brand DoingWell styling
{% endcomment %}

{%- liquid
  assign mobile_bg = section.settings.bg_image_mobile | default: section.settings.bg_image_desktop
-%}

<section 
  class="dw-about dw-about--{{ section.settings.color_scheme }} dw-about--accent-{{ section.settings.accent_color }}{% if section.settings.enable_scroll_reveal %} dw-about--scroll-reveal{% endif %}"
  data-section-type="dw-about"
  data-section-id="{{ section.id }}"
  style="
    --about-padding-top-desktop: {{ section.settings.padding_top_desktop }}px;
    --about-padding-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;
    --about-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --about-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --about-max-width: {{ section.settings.max_width }}px;
    --about-animation-duration: {{ section.settings.animation_duration }}ms;
    --about-animation-stagger: {{ section.settings.animation_stagger }}ms;
    --about-overlay-opacity: {{ section.settings.bg_overlay_opacity | divided_by: 100.0 }};
  "
>
  <!-- Background Image -->
  {%- if section.settings.bg_image_desktop != blank -%}
    <div class="dw-about__bg">
      <picture class="dw-about__bg-picture">
        {%- if mobile_bg != blank -%}
          <source 
            media="(max-width: 749px)" 
            srcset="{{ mobile_bg | image_url: width: 750 }},
                    {{ mobile_bg | image_url: width: 1500 }} 2x"
          >
        {%- endif -%}
        <source 
          media="(min-width: 750px)" 
          srcset="{{ section.settings.bg_image_desktop | image_url: width: 1920 }},
                  {{ section.settings.bg_image_desktop | image_url: width: 3840 }} 2x"
        >
        <img 
          src="{{ section.settings.bg_image_desktop | image_url: width: 1920 }}" 
          alt=""
          loading="lazy"
          class="dw-about__bg-image"
        >
      </picture>
      <div class="dw-about__bg-overlay"></div>
    </div>
  {%- endif -%}

  <div class="dw-about__container">
    {%- assign item_index = 0 -%}
    
    {%- for block in section.blocks -%}
      {%- assign item_index = item_index | plus: 1 -%}
      
      {%- case block.type -%}
      
        {%- when 'hero' -%}
          <header 
            class="dw-about__hero dw-about__animate-item"
            style="--item-index: {{ item_index }};"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.eyebrow != blank -%}
              <p class="dw-about__eyebrow">{{ block.settings.eyebrow }}</p>
            {%- endif -%}
            
            {%- if block.settings.heading != blank -%}
              <h1 class="dw-about__hero-heading">{{ block.settings.heading | newline_to_br }}</h1>
            {%- endif -%}
            
            {%- if block.settings.subheading != blank -%}
              <p class="dw-about__hero-subheading">{{ block.settings.subheading }}</p>
            {%- endif -%}
          </header>

        {%- when 'text' -%}
          <div 
            class="dw-about__text dw-about__animate-item"
            style="--item-index: {{ item_index }};"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.heading != blank -%}
              <h2 class="dw-about__section-heading">{{ block.settings.heading }}</h2>
            {%- endif -%}
            
            <div class="dw-about__prose">
              {{ block.settings.content }}
            </div>
          </div>

        {%- when 'image' -%}
          <div 
            class="dw-about__image-block dw-about__image-block--{{ block.settings.width }} dw-about__animate-item"
            style="--item-index: {{ item_index }}; --image-border-radius: {{ block.settings.border_radius }}px;"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.image != blank -%}
              <figure class="dw-about__figure{% if block.settings.enable_shadow %} dw-about__figure--shadow{% endif %}">
                <img 
                  src="{{ block.settings.image | image_url: width: 1200 }}"
                  srcset="{{ block.settings.image | image_url: width: 600 }} 600w,
                          {{ block.settings.image | image_url: width: 900 }} 900w,
                          {{ block.settings.image | image_url: width: 1200 }} 1200w"
                  sizes="(max-width: 749px) 100vw, {{ block.settings.width | replace: 'full', '100vw' | replace: 'large', '900px' | replace: 'medium', '700px' | replace: 'small', '500px' }}"
                  alt="{{ block.settings.image.alt | default: '' | escape }}"
                  loading="lazy"
                  class="dw-about__image"
                >
                {%- if block.settings.caption != blank -%}
                  <figcaption class="dw-about__caption">{{ block.settings.caption }}</figcaption>
                {%- endif -%}
              </figure>
            {%- else -%}
              <div class="dw-about__image-placeholder">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                  <circle cx="8.5" cy="8.5" r="1.5"></circle>
                  <polyline points="21 15 16 10 5 21"></polyline>
                </svg>
                <span>Add image</span>
              </div>
            {%- endif -%}
          </div>

        {%- when 'quote' -%}
          <blockquote 
            class="dw-about__quote dw-about__quote--{{ block.settings.style }} dw-about__animate-item"
            style="--item-index: {{ item_index }};"
            {{ block.shopify_attributes }}
          >
            <p class="dw-about__quote-text">{{ block.settings.text }}</p>
            {%- if block.settings.attribution != blank -%}
              <cite class="dw-about__quote-cite">{{ block.settings.attribution }}</cite>
            {%- endif -%}
          </blockquote>

        {%- when 'split' -%}
          <div 
            class="dw-about__split dw-about__split--{{ block.settings.image_side }} dw-about__animate-item"
            style="--item-index: {{ item_index }};"
            {{ block.shopify_attributes }}
          >
            <div class="dw-about__split-media">
              {%- if block.settings.image != blank -%}
                <div class="dw-about__split-image-wrapper">
                  <img 
                    src="{{ block.settings.image | image_url: width: 800 }}"
                    srcset="{{ block.settings.image | image_url: width: 400 }} 400w,
                            {{ block.settings.image | image_url: width: 600 }} 600w,
                            {{ block.settings.image | image_url: width: 800 }} 800w"
                    sizes="(max-width: 749px) 100vw, 50vw"
                    alt="{{ block.settings.image.alt | default: '' | escape }}"
                    loading="lazy"
                    class="dw-about__split-image"
                  >
                </div>
              {%- else -%}
                <div class="dw-about__split-placeholder"></div>
              {%- endif -%}
            </div>
            
            <div class="dw-about__split-content">
              {%- if block.settings.eyebrow != blank -%}
                <p class="dw-about__eyebrow">{{ block.settings.eyebrow }}</p>
              {%- endif -%}
              
              {%- if block.settings.heading != blank -%}
                <h2 class="dw-about__section-heading">{{ block.settings.heading }}</h2>
              {%- endif -%}
              
              <div class="dw-about__prose">
                {{ block.settings.content }}
              </div>
            </div>
          </div>

        {%- when 'list' -%}
          <div 
            class="dw-about__list-block dw-about__animate-item"
            style="--item-index: {{ item_index }};"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.heading != blank -%}
              <h2 class="dw-about__section-heading dw-about__section-heading--centered">{{ block.settings.heading }}</h2>
            {%- endif -%}
            
            {%- if block.settings.intro != blank -%}
              <p class="dw-about__list-intro">{{ block.settings.intro }}</p>
            {%- endif -%}
            
            {%- assign list_items = block.settings.items | newline_to_br | split: '<br />' -%}
            <ul class="dw-about__list dw-about__list--{{ block.settings.layout }} dw-about__list--{{ block.settings.style }}">
              {%- for item in list_items -%}
                {%- assign item_text = item | strip -%}
                {%- if item_text != blank -%}
                  <li class="dw-about__list-item">
                    <span class="dw-about__list-icon">
                      {%- case block.settings.icon -%}
                        {%- when 'check' -%}
                          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                        {%- when 'x' -%}
                          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                        {%- when 'arrow' -%}
                          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                        {%- when 'dot' -%}
                          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="5"></circle></svg>
                        {%- when 'shield' -%}
                          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><polyline points="9 12 11 14 15 10"></polyline></svg>
                        {%- when 'zap' -%}
                          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
                        {%- when 'number' -%}
                          <span class="dw-about__list-number">{{ forloop.index }}</span>
                      {%- endcase -%}
                    </span>
                    <span class="dw-about__list-text">{{ item_text }}</span>
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </div>

        {%- when 'callout' -%}
          <div 
            class="dw-about__callout dw-about__callout--{{ block.settings.style }} dw-about__animate-item"
            style="--item-index: {{ item_index }};"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.heading != blank -%}
              <h3 class="dw-about__callout-heading">{{ block.settings.heading }}</h3>
            {%- endif -%}
            
            {%- if block.settings.content != blank -%}
              <div class="dw-about__callout-content">{{ block.settings.content }}</div>
            {%- endif -%}
          </div>

        {%- when 'signoff' -%}
          <footer 
            class="dw-about__signoff dw-about__animate-item"
            style="--item-index: {{ item_index }};"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.tagline != blank -%}
              <p class="dw-about__signoff-tagline">{{ block.settings.tagline }}</p>
            {%- endif -%}
            
            {%- if block.settings.signature_image != blank -%}
              <img 
                src="{{ block.settings.signature_image | image_url: width: 300 }}"
                alt="{{ block.settings.name | default: 'Signature' | escape }}"
                class="dw-about__signoff-signature"
                loading="lazy"
              >
            {%- elsif block.settings.name != blank -%}
              <p class="dw-about__signoff-name">{{ block.settings.name }}</p>
            {%- endif -%}
          </footer>

        {%- when 'divider' -%}
          <hr 
            class="dw-about__divider dw-about__divider--{{ block.settings.style }}"
            style="--item-index: {{ item_index }};"
            {{ block.shopify_attributes }}
          >

        {%- when 'spacer' -%}
          <div 
            class="dw-about__spacer"
            style="
              --spacer-desktop: {{ block.settings.height_desktop }}px;
              --spacer-mobile: {{ block.settings.height_mobile }}px;
            "
            {{ block.shopify_attributes }}
          ></div>

      {%- endcase -%}
    {%- endfor -%}
  </div>
</section>

<style>
  /* ==========================================
     CSS VARIABLES - Brand Colors
     ========================================== */
  
  .dw-about {
    /* Brand palette */
    --dw-black: #171717;
    --dw-cream: #F8F0E3;
    --dw-lime: #C6D76B;
    --dw-raspberry: #E08FBC;
    --dw-white: #ffffff;
    --dw-gray-light: #E7E7E8;
    --dw-gray-medium: #A0A0A0;
    --dw-gray-dark: #3C3C3C;
  }

  /* ==========================================
     COLOR SCHEMES
     ========================================== */
  
  /* Dark (default) */
  .dw-about--dark {
    --about-bg: var(--dw-black);
    --about-text: var(--dw-white);
    --about-text-muted: var(--dw-gray-medium);
    --about-accent: var(--dw-lime);
    --about-border: rgba(255, 255, 255, 0.1);
    --about-card-bg: rgba(255, 255, 255, 0.03);
    --about-card-border: rgba(255, 255, 255, 0.08);
  }

  /* Light / Cream */
  .dw-about--light {
    --about-bg: var(--dw-cream);
    --about-text: var(--dw-black);
    --about-text-muted: var(--dw-gray-dark);
    --about-accent: var(--dw-lime);
    --about-border: rgba(0, 0, 0, 0.08);
    --about-card-bg: var(--dw-white);
    --about-card-border: var(--dw-gray-light);
  }

  /* White */
  .dw-about--white {
    --about-bg: var(--dw-white);
    --about-text: var(--dw-black);
    --about-text-muted: var(--dw-gray-dark);
    --about-accent: var(--dw-lime);
    --about-border: var(--dw-gray-light);
    --about-card-bg: var(--dw-cream);
    --about-card-border: var(--dw-gray-light);
  }

  /* ==========================================
     ACCENT COLORS
     ========================================== */
  
  .dw-about--accent-lime {
    --about-accent: var(--dw-lime);
  }

  .dw-about--accent-raspberry {
    --about-accent: var(--dw-raspberry);
  }

  /* ==========================================
     BASE STYLES
     ========================================== */
  
  .dw-about {
    position: relative;
    padding: var(--about-padding-top-mobile) 20px var(--about-padding-bottom-mobile);
    background: var(--about-bg);
    color: var(--about-text);
    overflow: hidden;
    font-family: 'Poppins', sans-serif;
  }

  @media (min-width: 750px) {
    .dw-about {
      padding: var(--about-padding-top-desktop) 50px var(--about-padding-bottom-desktop);
    }
  }

  /* ==========================================
     BACKGROUND
     ========================================== */
  
  .dw-about__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .dw-about__bg-picture {
    display: block;
    width: 100%;
    height: 100%;
  }

  .dw-about__bg-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .dw-about__bg-overlay {
    position: absolute;
    inset: 0;
    background: var(--about-bg);
    opacity: var(--about-overlay-opacity);
  }

  /* ==========================================
     CONTAINER
     ========================================== */
  
  .dw-about__container {
    position: relative;
    z-index: 1;
    max-width: var(--about-max-width);
    margin: 0 auto;
  }

  /* ==========================================
     HERO
     ========================================== */
  
  .dw-about__hero {
    text-align: center;
    margin-bottom: 60px;
  }

  @media (min-width: 750px) {
    .dw-about__hero {
      margin-bottom: 80px;
    }
  }

  .dw-about__eyebrow {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--about-accent);
    margin: 0 0 16px;
  }

  @media (min-width: 750px) {
    .dw-about__eyebrow {
      font-size: 12px;
      margin-bottom: 20px;
    }
  }

  .dw-about__hero-heading {
    font-size: 32px;
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0 0 20px;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
    color: var(--about-text);
  }

  @media (min-width: 750px) {
    .dw-about__hero-heading {
      font-size: 48px;
      margin-bottom: 24px;
    }
  }

  .dw-about__hero-subheading {
    font-size: 17px;
    line-height: 1.6;
    color: var(--about-text-muted);
    margin: 0;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  @media (min-width: 750px) {
    .dw-about__hero-subheading {
      font-size: 19px;
    }
  }

  /* ==========================================
     TEXT BLOCK
     ========================================== */
  
  .dw-about__text {
    margin-bottom: 40px;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  @media (min-width: 750px) {
    .dw-about__text {
      margin-bottom: 50px;
    }
  }

  .dw-about__section-heading {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 16px;
    color: var(--about-text);
  }

  @media (min-width: 750px) {
    .dw-about__section-heading {
      font-size: 28px;
      margin-bottom: 20px;
    }
  }

  .dw-about__section-heading--centered {
    text-align: center;
  }

  .dw-about__prose {
    font-size: 16px;
    line-height: 1.75;
    color: var(--about-text-muted);
  }

  @media (min-width: 750px) {
    .dw-about__prose {
      font-size: 17px;
    }
  }

  .dw-about__prose p {
    margin: 0 0 1.4em;
  }

  .dw-about__prose p:last-child {
    margin-bottom: 0;
  }

  .dw-about__prose strong {
    color: var(--about-text);
    font-weight: 600;
  }

  /* ==========================================
     IMAGE BLOCK
     ========================================== */
  
  .dw-about__image-block {
    margin: 40px auto 50px;
  }

  @media (min-width: 750px) {
    .dw-about__image-block {
      margin: 50px auto 60px;
    }
  }

  .dw-about__image-block--small {
    max-width: 500px;
  }

  .dw-about__image-block--medium {
    max-width: 700px;
  }

  .dw-about__image-block--large {
    max-width: 900px;
  }

  .dw-about__image-block--full {
    max-width: 100%;
  }

  .dw-about__figure {
    margin: 0;
    position: relative;
  }

  .dw-about__figure--shadow {
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.12);
    border-radius: var(--image-border-radius, 12px);
    overflow: hidden;
  }

  .dw-about__image {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--image-border-radius, 12px);
  }

  .dw-about__figure--shadow .dw-about__image {
    border-radius: 0;
  }

  .dw-about__caption {
    font-size: 13px;
    color: var(--about-text-muted);
    text-align: center;
    margin-top: 12px;
    font-style: italic;
  }

  .dw-about__image-placeholder {
    aspect-ratio: 16/9;
    background: var(--about-card-bg);
    border: 2px dashed var(--about-border);
    border-radius: var(--image-border-radius, 12px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    color: var(--about-text-muted);
    font-size: 14px;
  }

  /* ==========================================
     QUOTE
     ========================================== */
  
  .dw-about__quote {
    position: relative;
    margin: 50px auto;
    padding: 0;
    border: none;
    text-align: center;
    max-width: 750px;
  }

  @media (min-width: 750px) {
    .dw-about__quote {
      margin: 60px auto;
    }
  }

  .dw-about__quote-text {
    font-size: 22px;
    font-weight: 600;
    line-height: 1.45;
    margin: 0;
    color: var(--about-text);
  }

  @media (min-width: 750px) {
    .dw-about__quote-text {
      font-size: 26px;
    }
  }

  .dw-about__quote-cite {
    display: block;
    font-size: 14px;
    font-style: normal;
    font-weight: 600;
    color: var(--about-accent);
    margin-top: 16px;
  }

  /* Quote styles */
  .dw-about__quote--minimal .dw-about__quote-text {
    font-style: italic;
  }

  .dw-about__quote--bordered {
    padding: 30px;
    border-left: 4px solid var(--about-accent);
    text-align: left;
  }

  @media (min-width: 750px) {
    .dw-about__quote--bordered {
      padding: 40px;
    }
  }

  .dw-about__quote--card {
    padding: 32px 24px;
    background: var(--about-card-bg);
    border: 1px solid var(--about-card-border);
    border-radius: 16px;
  }

  @media (min-width: 750px) {
    .dw-about__quote--card {
      padding: 48px 40px;
    }
  }

  .dw-about__quote--highlight {
    padding: 32px 24px;
    background: linear-gradient(135deg, rgba(198, 215, 107, 0.08) 0%, rgba(198, 215, 107, 0.02) 100%);
    border: 1px solid rgba(198, 215, 107, 0.2);
    border-radius: 16px;
  }

  @media (min-width: 750px) {
    .dw-about__quote--highlight {
      padding: 48px 40px;
    }
  }

  /* ==========================================
     SPLIT LAYOUT
     ========================================== */
  
  .dw-about__split {
    display: flex;
    flex-direction: column;
    gap: 30px;
    margin-bottom: 50px;
    align-items: center;
  }

  @media (min-width: 750px) {
    .dw-about__split {
      flex-direction: row;
      gap: 60px;
      margin-bottom: 70px;
    }

    .dw-about__split--right {
      flex-direction: row-reverse;
    }
  }

  .dw-about__split-media {
    flex: 0 0 100%;
    max-width: 100%;
  }

  @media (min-width: 750px) {
    .dw-about__split-media {
      flex: 0 0 45%;
      max-width: none;
    }
  }

  .dw-about__split-image-wrapper {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
  }

  .dw-about__split-image {
    position: relative;
    width: 100%;
    height: auto;
    display: block;
  }

  .dw-about__split-placeholder {
    aspect-ratio: 4/5;
    background: var(--about-card-bg);
    border: 2px dashed var(--about-border);
    border-radius: 12px;
  }

  .dw-about__split-content {
    flex: 1;
  }

  @media (min-width: 750px) {
    .dw-about__split-content {
      flex: 0 0 50%;
    }
  }

  /* ==========================================
     LIST BLOCK
     ========================================== */
  
  .dw-about__list-block {
    margin-bottom: 50px;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  @media (min-width: 750px) {
    .dw-about__list-block {
      margin-bottom: 60px;
    }
  }

  .dw-about__list-intro {
    font-size: 16px;
    line-height: 1.6;
    text-align: center;
    color: var(--about-text-muted);
    margin: 0 0 24px;
  }

  .dw-about__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .dw-about__list--vertical {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .dw-about__list--grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }

  @media (min-width: 600px) {
    .dw-about__list--grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }
  }

  /* Minimal list style */
  .dw-about__list--minimal .dw-about__list-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 8px 0;
  }

  /* Card list style */
  .dw-about__list--cards .dw-about__list-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 16px 20px;
    background: var(--about-card-bg);
    border: 1px solid var(--about-card-border);
    border-radius: 12px;
    transition: all 0.2s ease;
  }

  .dw-about__list--cards .dw-about__list-item:hover {
    border-color: var(--about-accent);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
  }

  .dw-about__list-icon {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    color: var(--about-accent);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .dw-about__list-icon svg {
    width: 20px;
    height: 20px;
  }

  .dw-about__list-number {
    width: 24px;
    height: 24px;
    background: var(--about-accent);
    color: var(--dw-black);
    border-radius: 50%;
    font-size: 12px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .dw-about__list-text {
    font-size: 15px;
    line-height: 1.5;
    color: var(--about-text);
  }

  /* ==========================================
     CALLOUT BLOCK
     ========================================== */
  
  .dw-about__callout {
    margin: 50px auto;
    max-width: 700px;
    text-align: center;
  }

  @media (min-width: 750px) {
    .dw-about__callout {
      margin: 60px auto;
    }
  }

  .dw-about__callout--card {
    padding: 32px 24px;
    background: var(--about-card-bg);
    border: 1px solid var(--about-card-border);
    border-radius: 16px;
  }

  @media (min-width: 750px) {
    .dw-about__callout--card {
      padding: 40px;
    }
  }

  .dw-about__callout--accent {
    padding: 32px 24px;
    background: linear-gradient(135deg, rgba(198, 215, 107, 0.1) 0%, rgba(198, 215, 107, 0.03) 100%);
    border: 1px solid rgba(198, 215, 107, 0.25);
    border-radius: 16px;
  }

  @media (min-width: 750px) {
    .dw-about__callout--accent {
      padding: 40px;
    }
  }

  .dw-about__callout-heading {
    font-size: 20px;
    font-weight: 700;
    color: var(--about-accent);
    margin: 0 0 12px;
  }

  @media (min-width: 750px) {
    .dw-about__callout-heading {
      font-size: 24px;
    }
  }

  .dw-about__callout-content {
    font-size: 16px;
    line-height: 1.6;
    color: var(--about-text-muted);
  }

  .dw-about__callout-content p {
    margin: 0;
  }

  /* ==========================================
     SIGNOFF
     ========================================== */
  
  .dw-about__signoff {
    text-align: center;
    margin-top: 60px;
  }

  @media (min-width: 750px) {
    .dw-about__signoff {
      margin-top: 70px;
    }
  }

  .dw-about__signoff-tagline {
    font-size: 20px;
    font-weight: 600;
    font-style: italic;
    color: var(--about-accent);
    margin: 0 0 12px;
  }

  @media (min-width: 750px) {
    .dw-about__signoff-tagline {
      font-size: 22px;
    }
  }

  .dw-about__signoff-signature {
    max-width: 160px;
    height: auto;
  }

  @media (min-width: 750px) {
    .dw-about__signoff-signature {
      max-width: 200px;
    }
  }

  .dw-about__signoff-name {
    font-size: 17px;
    font-weight: 600;
    color: var(--about-text);
    margin: 0;
  }

  /* ==========================================
     DIVIDER
     ========================================== */
  
  .dw-about__divider {
    border: none;
    margin: 40px auto;
    max-width: 100px;
  }

  @media (min-width: 750px) {
    .dw-about__divider {
      margin: 50px auto;
    }
  }

  .dw-about__divider--line {
    height: 1px;
    background: var(--about-border);
    max-width: 120px;
  }

  .dw-about__divider--dots::before {
    content: '•  •  •';
    display: block;
    text-align: center;
    color: var(--about-text-muted);
    font-size: 12px;
    letter-spacing: 4px;
  }

  .dw-about__divider--accent {
    height: 3px;
    background: var(--about-accent);
    max-width: 60px;
    border-radius: 2px;
  }

  /* ==========================================
     SPACER
     ========================================== */
  
  .dw-about__spacer {
    height: var(--spacer-mobile);
  }

  @media (min-width: 750px) {
    .dw-about__spacer {
      height: var(--spacer-desktop);
    }
  }

  /* ==========================================
     SCROLL REVEAL
     ========================================== */
  
  .dw-about--scroll-reveal .dw-about__animate-item {
    opacity: 0;
    transform: translateY(24px);
    transition: 
      opacity var(--about-animation-duration) ease,
      transform var(--about-animation-duration) ease;
    transition-delay: calc(var(--item-index, 0) * var(--about-animation-stagger));
  }

  .dw-about--scroll-reveal .dw-about__animate-item.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ==========================================
     REDUCED MOTION
     ========================================== */
  
  @media (prefers-reduced-motion: reduce) {
    .dw-about--scroll-reveal .dw-about__animate-item {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  (function() {
    const section = document.querySelector('[data-section-type="dw-about"].dw-about--scroll-reveal');
    if (!section) return;
    
    const items = section.querySelectorAll('.dw-about__animate-item');
    if (!items.length) return;
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.1,
      rootMargin: '0px 0px -60px 0px'
    });
    
    items.forEach(item => observer.observe(item));
  })();
</script>

