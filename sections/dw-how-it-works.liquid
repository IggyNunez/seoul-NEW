{% comment %}
  DoingWell How It Works / Steps Section
  - Numbered or icon steps
  - Horizontal or vertical layout
  - Connecting lines option
  - Full responsive controls
{% endcomment %}

<section 
  class="dw-steps{% if section.settings.enable_animations %} dw-steps--animate{% endif %}{% if section.settings.enable_scroll_reveal %} dw-steps--scroll-reveal{% endif %}{% if section.settings.enable_gradient_text %} dw-steps--gradient-text{% endif %}{% if section.settings.enable_glass %} dw-steps--glass{% endif %}{% if section.settings.enable_cyber_borders %} dw-steps--cyber-borders{% endif %}"
  data-section-type="dw-how-it-works"
  style="
    --steps-padding-top-desktop: {{ section.settings.padding_top_desktop }}px;
    --steps-padding-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;
    --steps-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --steps-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --steps-bg: {{ section.settings.bg_color }};
    --steps-text: {{ section.settings.text_color }};
    --steps-accent: {{ section.settings.accent_color }};
    --steps-max-width: {{ section.settings.max_width }}px;
    --steps-animation-duration: {{ section.settings.animation_duration }}ms;
    --steps-animation-stagger: {{ section.settings.animation_stagger }}ms;
    --steps-bg-position-desktop: {{ section.settings.bg_image_position_desktop }};
    --steps-bg-position-mobile: {{ section.settings.bg_image_position_mobile }};
    --steps-overlay-opacity: {{ section.settings.bg_overlay_opacity | divided_by: 100.0 }};
  "
>
  <!-- Background -->
  {%- if section.settings.bg_image_desktop != blank -%}
    {%- assign mobile_bg = section.settings.bg_image_mobile | default: section.settings.bg_image_desktop -%}
    <div class="dw-steps__bg">
      <picture class="dw-steps__bg-image">
        <source 
          media="(max-width: 749px)" 
          srcset="{{ mobile_bg | image_url: width: 750 }},
                  {{ mobile_bg | image_url: width: 1500 }} 2x"
        >
        <source 
          media="(min-width: 750px)" 
          srcset="{{ section.settings.bg_image_desktop | image_url: width: 1920 }},
                  {{ section.settings.bg_image_desktop | image_url: width: 3840 }} 2x"
        >
        <img 
          src="{{ section.settings.bg_image_desktop | image_url: width: 1920 }}" 
          alt=""
          loading="lazy"
          width="{{ section.settings.bg_image_desktop.width }}"
          height="{{ section.settings.bg_image_desktop.height }}"
        >
      </picture>
      <div class="dw-steps__bg-overlay"></div>
    </div>
  {%- endif -%}

  <div class="dw-steps__container">
    <!-- Header -->
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="dw-steps__header dw-steps__header--{{ section.settings.header_alignment }}">
        {%- if section.settings.eyebrow != blank -%}
          <span class="dw-steps__eyebrow dw-steps__animate-item" style="--item-index: 1;">
            {{ section.settings.eyebrow }}
          </span>
        {%- endif -%}
        
        {%- if section.settings.heading != blank -%}
          <h2 class="dw-steps__heading dw-steps__animate-item" style="--item-index: 2;">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}
        
        {%- if section.settings.subheading != blank -%}
          <p class="dw-steps__subheading dw-steps__animate-item" style="--item-index: 3;">
            {{ section.settings.subheading }}
          </p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <!-- Steps -->
    <div class="dw-steps__list dw-steps__list--{{ section.settings.layout }}{% if section.settings.show_connector %} dw-steps__list--connected{% endif %}">
      {%- assign step_index = 3 -%}
      {%- assign step_number = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'step' -%}
          {%- assign step_index = step_index | plus: 1 -%}
          {%- assign step_number = step_number | plus: 1 -%}
          
          <div 
            class="dw-steps__item dw-steps__animate-item"
            style="--item-index: {{ step_index }};"
            {{ block.shopify_attributes }}
          >
            <div class="dw-steps__marker">
              {%- if section.settings.marker_style == 'number' -%}
                <span class="dw-steps__number">{{ step_number }}</span>
              {%- elsif section.settings.marker_style == 'icon' and block.settings.icon != 'none' -%}
                <span class="dw-steps__icon">
                  {%- case block.settings.icon -%}
                    {%- when 'mix' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2h8l4 10H4L8 2z"></path><path d="M12 12v10"></path><path d="M8 22h8"></path></svg>
                    {%- when 'shake' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4"></path><path d="m6.34 6.34 2.83 2.83"></path><path d="M2 12h4"></path><path d="m6.34 17.66 2.83-2.83"></path><path d="M12 18v4"></path><path d="m17.66 17.66-2.83-2.83"></path><path d="M18 12h4"></path><path d="m17.66 6.34-2.83 2.83"></path></svg>
                    {%- when 'drink' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2h8l4 10H4L8 2z"></path><path d="m6 12 2 10h8l2-10"></path></svg>
                    {%- when 'perform' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
                    {%- when 'check' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                    {%- when 'droplet' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"></path></svg>
                    {%- when 'heart' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                    {%- when 'star' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                    {%- when 'package' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
                    {%- when 'truck' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
                  {%- endcase -%}
                </span>
              {%- elsif block.settings.custom_icon != blank -%}
                <img 
                  src="{{ block.settings.custom_icon | image_url: width: 96 }}" 
                  alt="" 
                  width="32" 
                  height="32"
                  loading="lazy"
                  class="dw-steps__custom-icon"
                >
              {%- else -%}
                <span class="dw-steps__number">{{ step_number }}</span>
              {%- endif -%}
            </div>
            
            <div class="dw-steps__content">
              {%- if block.settings.label != blank -%}
                <span class="dw-steps__label">{{ block.settings.label }}</span>
              {%- endif -%}
              {%- if block.settings.title != blank -%}
                <h3 class="dw-steps__title">{{ block.settings.title }}</h3>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p class="dw-steps__desc">{{ block.settings.description }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- Footer -->
    {%- if section.settings.footer_text != blank -%}
      <div class="dw-steps__footer dw-steps__animate-item" style="--item-index: {{ step_index | plus: 1 }};">
        {{ section.settings.footer_text }}
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  /* ==========================================
     STEPS BASE
     ========================================== */
  
  .dw-steps {
    position: relative;
    padding: var(--steps-padding-top-mobile) 20px var(--steps-padding-bottom-mobile);
    background: var(--steps-bg, #0a0a0a);
    color: var(--steps-text, #ffffff);
    overflow: hidden;
  }

  @media (min-width: 750px) {
    .dw-steps {
      padding: var(--steps-padding-top-desktop) 50px var(--steps-padding-bottom-desktop);
    }
  }

  /* ==========================================
     BACKGROUND IMAGE
     ========================================== */
  
  .dw-steps__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .dw-steps__bg-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .dw-steps__bg-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--steps-bg-position-mobile, center center);
  }

  @media (min-width: 750px) {
    .dw-steps__bg-image img {
      object-position: var(--steps-bg-position-desktop, center center);
    }
  }

  .dw-steps__bg-overlay {
    position: absolute;
    inset: 0;
    background: var(--steps-bg, #0a0a0a);
    opacity: var(--steps-overlay-opacity, 0.7);
  }

  /* ==========================================
     CONTAINER
     ========================================== */
  
  .dw-steps__container {
    position: relative;
    z-index: 1;
    max-width: var(--steps-max-width, 1000px);
    margin: 0 auto;
  }

  /* ==========================================
     HEADER
     ========================================== */
  
  .dw-steps__header {
    margin-bottom: 40px;
  }

  @media (min-width: 750px) {
    .dw-steps__header {
      margin-bottom: 50px;
    }
  }

  .dw-steps__header--left { text-align: left; }
  .dw-steps__header--center { text-align: center; }
  .dw-steps__header--right { text-align: right; }

  .dw-steps__eyebrow {
    display: inline-block;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--steps-accent, #C4D600);
    margin-bottom: 12px;
  }

  .dw-steps__heading {
    font-size: 26px;
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 12px;
    letter-spacing: -0.02em;
  }

  @media (min-width: 750px) {
    .dw-steps__heading {
      font-size: 36px;
    }
  }

  .dw-steps__subheading {
    font-size: 16px;
    line-height: 1.6;
    opacity: 0.75;
    margin: 0;
  }

  /* ==========================================
     STEPS LIST - VERTICAL
     ========================================== */
  
  .dw-steps__list--vertical {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .dw-steps__list--vertical .dw-steps__item {
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }

  /* Connector line for vertical */
  .dw-steps__list--vertical.dw-steps__list--connected .dw-steps__item {
    position: relative;
  }

  .dw-steps__list--vertical.dw-steps__list--connected .dw-steps__item:not(:last-child)::after {
    content: '';
    position: absolute;
    left: 24px;
    top: 56px;
    width: 2px;
    height: calc(100% + 8px);
    background: linear-gradient(to bottom, var(--steps-accent) 0%, rgba(196, 214, 0, 0.2) 100%);
  }

  /* ==========================================
     STEPS LIST - HORIZONTAL
     ========================================== */
  
  .dw-steps__list--horizontal {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  @media (min-width: 750px) {
    .dw-steps__list--horizontal {
      flex-direction: row;
      gap: 20px;
    }

    .dw-steps__list--horizontal .dw-steps__item {
      flex: 1;
      flex-direction: column;
      text-align: center;
    }

    .dw-steps__list--horizontal .dw-steps__marker {
      margin: 0 auto 16px;
    }
  }

  /* Connector line for horizontal */
  @media (min-width: 750px) {
    .dw-steps__list--horizontal.dw-steps__list--connected .dw-steps__item {
      position: relative;
    }

    .dw-steps__list--horizontal.dw-steps__list--connected .dw-steps__item:not(:last-child)::after {
      content: '';
      position: absolute;
      top: 24px;
      left: calc(50% + 32px);
      width: calc(100% - 64px);
      height: 2px;
      background: linear-gradient(to right, var(--steps-accent) 0%, rgba(196, 214, 0, 0.2) 100%);
    }
  }

  /* ==========================================
     STEPS LIST - CARDS
     ========================================== */
  
  .dw-steps__list--cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  @media (min-width: 750px) {
    .dw-steps__list--cards {
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
  }

  .dw-steps__list--cards .dw-steps__item {
    flex-direction: column;
    text-align: center;
    padding: 28px 24px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    transition: border-color 0.2s ease;
  }

  .dw-steps__list--cards .dw-steps__item:hover {
    border-color: var(--steps-accent);
  }

  .dw-steps__list--cards .dw-steps__marker {
    margin: 0 auto 16px;
  }

  /* ==========================================
     STEP ITEM
     ========================================== */
  
  .dw-steps__item {
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }

  .dw-steps__marker {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(196, 214, 0, 0.15);
    border: 2px solid var(--steps-accent, #C4D600);
    border-radius: 50%;
    color: var(--steps-accent, #C4D600);
  }

  .dw-steps__number {
    font-size: 18px;
    font-weight: 700;
  }

  .dw-steps__icon svg {
    width: 22px;
    height: 22px;
  }

  .dw-steps__custom-icon {
    width: 26px;
    height: 26px;
    object-fit: contain;
  }

  .dw-steps__content {
    flex: 1;
    min-width: 0;
  }

  .dw-steps__label {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--steps-accent, #C4D600);
    margin-bottom: 6px;
  }

  .dw-steps__title {
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 8px;
  }

  @media (min-width: 750px) {
    .dw-steps__title {
      font-size: 20px;
    }
  }

  .dw-steps__desc {
    font-size: 14px;
    line-height: 1.6;
    opacity: 0.75;
    margin: 0;
  }

  @media (min-width: 750px) {
    .dw-steps__desc {
      font-size: 15px;
    }
  }

  /* ==========================================
     FOOTER
     ========================================== */
  
  .dw-steps__footer {
    margin-top: 40px;
    padding: 20px;
    background: rgba(255,255,255,0.03);
    border-radius: 8px;
    font-size: 14px;
    text-align: center;
    opacity: 0.8;
  }

  /* ==========================================
     ANIMATED GRADIENT TEXT
     ========================================== */
  
  .dw-steps--gradient-text .dw-steps__heading {
    background: linear-gradient(
      90deg,
      var(--steps-text, #ffffff) 0%,
      var(--steps-accent, #C4D600) 25%,
      #00d4ff 50%,
      var(--steps-accent, #C4D600) 75%,
      var(--steps-text, #ffffff) 100%
    );
    background-size: 200% auto;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: steps-gradient-text 4s ease-in-out infinite;
  }

  @keyframes steps-gradient-text {
    0%, 100% { background-position: 0% center; }
    50% { background-position: 200% center; }
  }

  /* ==========================================
     GLASSMORPHISM CARDS
     ========================================== */
  
  .dw-steps--glass.dw-steps--cards .dw-steps__step {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 
      0 8px 32px rgba(0, 0, 0, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .dw-steps--glass.dw-steps--cards .dw-steps__step:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(196, 214, 0, 0.3);
  }

  /* ==========================================
     ANIMATED GRADIENT BORDERS
     ========================================== */
  
  .dw-steps--cyber-borders.dw-steps--cards .dw-steps__step {
    position: relative;
    background: transparent;
    border: none;
    z-index: 1;
  }

  .dw-steps--cyber-borders.dw-steps--cards .dw-steps__step::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 12px;
    padding: 1px;
    background: linear-gradient(
      90deg,
      var(--steps-accent, #C4D600),
      #00d4ff,
      var(--steps-accent, #C4D600),
      #00d4ff
    );
    background-size: 300% 100%;
    -webkit-mask: 
      linear-gradient(#fff 0 0) content-box, 
      linear-gradient(#fff 0 0);
    mask: 
      linear-gradient(#fff 0 0) content-box, 
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    animation: steps-cyber-border 4s linear infinite;
    opacity: 0.5;
    z-index: -1;
    transition: opacity 0.3s ease;
  }

  .dw-steps--cyber-borders.dw-steps--cards .dw-steps__step::after {
    content: '';
    position: absolute;
    inset: 1px;
    border-radius: 11px;
    background: var(--steps-bg, #0a0a0a);
    z-index: -1;
  }

  .dw-steps--cyber-borders.dw-steps--cards .dw-steps__step:hover::before {
    opacity: 1;
    animation: steps-cyber-border 2s linear infinite;
  }

  @keyframes steps-cyber-border {
    0% { background-position: 0% 50%; }
    100% { background-position: 300% 50%; }
  }

  /* Combined: Glass + Cyber Borders */
  .dw-steps--glass.dw-steps--cyber-borders.dw-steps--cards .dw-steps__step::after {
    background: rgba(10, 10, 10, 0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  /* ==========================================
     SCROLL REVEAL ANIMATIONS
     ========================================== */
  
  .dw-steps--scroll-reveal .dw-steps__animate-item {
    opacity: 0;
    transform: translateY(30px);
    transition: 
      opacity var(--steps-animation-duration, 700ms) ease,
      transform var(--steps-animation-duration, 700ms) ease;
    transition-delay: calc(var(--item-index, 0) * var(--steps-animation-stagger, 150ms));
  }

  .dw-steps--scroll-reveal .dw-steps__animate-item.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Legacy page-load animations (fallback) */
  .dw-steps--animate:not(.dw-steps--scroll-reveal) .dw-steps__animate-item {
    opacity: 0;
    animation-fill-mode: forwards;
    animation-duration: var(--steps-animation-duration, 700ms);
    animation-delay: calc(var(--item-index, 0) * var(--steps-animation-stagger, 150ms));
    animation-name: steps-fade-up;
  }

  @keyframes steps-fade-up {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Reduce motion */
  @media (prefers-reduced-motion: reduce) {
    .dw-steps--animate .dw-steps__animate-item,
    .dw-steps--scroll-reveal .dw-steps__animate-item,
    .dw-steps--gradient-text .dw-steps__heading,
    .dw-steps--cyber-borders.dw-steps--cards .dw-steps__step::before {
      animation: none;
      opacity: 1;
      transform: none;
    }
    
    .dw-steps--gradient-text .dw-steps__heading {
      -webkit-text-fill-color: var(--steps-text, #ffffff);
      background: none;
    }
  }
</style>

<script>
  (function() {
    const section = document.querySelector('[data-section-type="dw-how-it-works"].dw-steps--scroll-reveal');
    if (!section) return;
    
    const items = section.querySelectorAll('.dw-steps__animate-item');
    if (!items.length) return;
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    });
    
    items.forEach(item => observer.observe(item));
  })();
</script>

{% schema %}
{
  "name": "DW How It Works",
  "tag": "section",
  "class": "dw-steps-section",
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "How to use"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How to use"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "select",
      "id": "header_alignment",
      "label": "Header alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
