{%- comment -%}
  Editorial blog index for Seoul Glow Lab — magazine masthead + card grid.
  First post = large featured card; the rest in a responsive uniform grid.
  On brand: Periwinkle #B0C3FA, Blood Red #5E0A02, Mindaro #F2FFA0, Antique White.
{%- endcomment -%}

{%- liquid
  assign s = section.settings
  assign posts = blog.articles
-%}

<div class="section-background color-{{ s.color_scheme }}"></div>
<div class="sgl-blog color-{{ s.color_scheme }}" style="{% render 'spacing-style', settings: s %}">
  <div class="sgl-blog__inner">

    <header class="sgl-blog__masthead">
      <p class="sgl-blog__kicker">Seoul Glow Lab Journal</p>
      <h1 class="sgl-blog__title">{{ blog.title }}</h1>
      {%- if s.tagline != blank -%}
        <p class="sgl-blog__tagline">{{ s.tagline }}</p>
      {%- endif -%}
      <div class="sgl-blog__rule">
        <span>{{ blog.articles_count }} {% if blog.articles_count == 1 %}story{% else %}stories{% endif %}</span>
      </div>
    </header>

    {%- if posts.size == 0 -%}
      <p class="sgl-blog__empty">No stories yet — check back soon.</p>
    {%- else -%}
      <div class="sgl-blog__grid">
        {%- for article in posts -%}
          {%- assign featured = false -%}
          {%- if forloop.first and posts.size > 2 -%}{%- assign featured = true -%}{%- endif -%}

          <a href="{{ article.url }}" class="sgl-card{% if featured %} sgl-card--featured{% endif %}">
            <span class="sgl-card__media">
              {%- if article.image -%}
                {%- if featured -%}
                {{ article.image | image_url: width: 1200 | image_tag:
                  loading: 'eager',
                  widths: '400, 700, 1000, 1200',
                  sizes: '(min-width: 750px) 55vw, 100vw',
                  alt: article.image.alt | default: article.title
                }}
              {%- else -%}
                {{ article.image | image_url: width: 900 | image_tag:
                  loading: 'lazy',
                  widths: '300, 500, 700, 900',
                  sizes: '(min-width: 750px) 33vw, 100vw',
                  alt: article.image.alt | default: article.title
                }}
              {%- endif -%}
              {%- else -%}
                <span class="sgl-card__media-fallback">{{ article.title | slice: 0 }}</span>
              {%- endif -%}
            </span>
            <span class="sgl-card__body">
              <span class="sgl-card__meta">
                {{ article.published_at | date: '%b %-d, %Y' }}
                {%- if article.tags.size > 0 -%}
                  {%- for tag in article.tags limit: 1 -%}
                    {%- unless tag contains 'rejected' -%}<span class="sgl-card__tag">{{ tag }}</span>{%- endunless -%}
                  {%- endfor -%}
                {%- endif -%}
              </span>
              <span class="sgl-card__title">{{ article.title }}</span>
              <span class="sgl-card__excerpt">
                {%- if article.excerpt != blank -%}
                  {{ article.excerpt | strip_html | truncate: 140 }}
                {%- else -%}
                  {{ article.content | strip_html | truncate: 140 }}
                {%- endif -%}
              </span>
              <span class="sgl-card__more">Read story &rarr;</span>
            </span>
          </a>
        {%- endfor -%}
      </div>

    {%- endif -%}

  </div>
</div>

{% stylesheet %}
  .sgl-blog {
    --sgl-periwinkle: #B0C3FA;
    --sgl-bloodred: #5E0A02;
    --sgl-mindaro: #F2FFA0;
    --sgl-cream: #F8EBDA;
    width: 100%;
  }

  .sgl-blog__inner {
    max-width: 1400px;
    margin-inline: auto;
    padding-inline: var(--page-margin, 2rem);
    padding-block: clamp(2rem, 5vw, 4rem);
  }

  /* ── Masthead ── */
  .sgl-blog__masthead { text-align: center; margin-bottom: clamp(2rem, 5vw, 3.5rem); }
  .sgl-blog__kicker {
    font-family: var(--font-primary--family);
    text-transform: uppercase; letter-spacing: 0.22em;
    font-size: 0.8rem; color: var(--sgl-bloodred);
    margin: 0 0 0.75rem;
  }
  .sgl-blog__title {
    font-family: var(--font-primary--family);
    font-weight: 800; line-height: 1; letter-spacing: -0.01em;
    font-size: clamp(2.8rem, 7vw, 5rem);
    margin: 0; color: var(--color-foreground);
  }
  .sgl-blog__tagline {
    max-width: 38rem; margin: 1rem auto 0;
    font-size: 1.05rem; line-height: 1.6;
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text, 0.7));
  }
  .sgl-blog__rule {
    display: flex; align-items: center; justify-content: center;
    margin-top: 1.5rem;
  }
  .sgl-blog__rule::before, .sgl-blog__rule::after {
    content: ""; height: 2px; flex: 1; max-width: 120px; background: var(--sgl-periwinkle);
  }
  .sgl-blog__rule span {
    font-family: var(--font-primary--family);
    text-transform: uppercase; letter-spacing: 0.12em; font-size: 0.78rem;
    padding: 0 1rem; color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text, 0.7));
  }

  /* ── Grid ── */
  .sgl-blog__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }

  .sgl-card {
    display: flex; flex-direction: column;
    text-decoration: none; color: var(--color-foreground);
    border-radius: 12px; overflow: hidden;
    background: var(--color-background, #fff);
    transition: transform 0.18s ease;
  }
  .sgl-card:hover { transform: translateY(-4px); }

  .sgl-card__media {
    display: block; aspect-ratio: 3 / 2; overflow: hidden;
    background: var(--sgl-periwinkle); border-radius: 12px;
  }
  .sgl-card__media img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.4s ease; }
  .sgl-card:hover .sgl-card__media img { transform: scale(1.04); }
  .sgl-card__media-fallback {
    display: flex; align-items: center; justify-content: center; height: 100%;
    font-family: var(--font-primary--family); font-weight: 800; font-size: 3rem; color: var(--sgl-bloodred);
  }

  .sgl-card__body { display: flex; flex-direction: column; gap: 0.5rem; padding: 1rem 0.25rem 0; }
  .sgl-card__meta {
    display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap;
    font-family: var(--font-primary--family);
    text-transform: uppercase; letter-spacing: 0.08em; font-size: 0.72rem;
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text, 0.65));
  }
  .sgl-card__tag {
    background: var(--sgl-mindaro); color: var(--sgl-bloodred);
    padding: 0.2rem 0.55rem; border-radius: 999px; letter-spacing: 0.05em;
  }
  .sgl-card__title {
    font-family: var(--font-primary--family); font-weight: 700; line-height: 1.15;
    font-size: 1.35rem;
  }
  .sgl-card:hover .sgl-card__title { color: var(--sgl-bloodred); }
  .sgl-card__excerpt {
    font-size: 0.95rem; line-height: 1.55;
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text, 0.75));
  }
  .sgl-card__more {
    font-family: var(--font-primary--family); font-weight: 600; font-size: 0.85rem;
    color: var(--sgl-bloodred); margin-top: 0.25rem;
  }

  /* Featured (first) card spans full width, image left / text right */
  .sgl-card--featured { grid-column: 1 / -1; }
  @media (min-width: 750px) {
    .sgl-card--featured {
      flex-direction: row; align-items: stretch; gap: 2rem;
      background: var(--sgl-cream); padding: 1.5rem; border-radius: 16px;
    }
    .sgl-card--featured .sgl-card__media { flex: 0 0 55%; aspect-ratio: 16 / 10; }
    .sgl-card--featured .sgl-card__body { justify-content: center; padding: 0 1rem 0 0; gap: 0.75rem; }
    .sgl-card--featured .sgl-card__title { font-size: clamp(1.8rem, 3vw, 2.6rem); }
    .sgl-card--featured .sgl-card__excerpt { font-size: 1.05rem; }
  }

  .sgl-blog__empty { text-align: center; padding: 3rem 0; font-size: 1.1rem; opacity: 0.7; }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.blog_posts",
  "blocks": [{ "type": "@app" }],
  "disabled_on": { "groups": ["header"] },
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "K-beauty rituals, ingredient deep-dives, and your guide to the glow."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0
    }
  ]
}
{% endschema %}
