{%- comment -%} ── Sticky Header + Height CSS Variables ── {%- endcomment -%}
<script>
  (function() {
    var header = document.querySelector('.casa-header');
    if (!header) return;

    // Find the header group container (Shopify wraps header sections in a group)
    // Try multiple selector patterns for compatibility
    var headerGroup = header.closest('[id*="header-group"]') ||
                      header.closest('[id*="section-group"]') ||
                      header.closest('.header-group') ||
                      header.closest('.shopify-section-group-header') ||
                      document.querySelector('#shopify-section-group-header');

    // Fallback: find the outermost shopify-section wrapper
    var sectionWrapper = header.closest('.shopify-section');

    // Set CSS variables for header height (on both body and :root for maximum compatibility)
    function updateHeaderHeight() {
      var targetEl = headerGroup || sectionWrapper || header;
      var headerH = header.offsetHeight;
      var groupH = targetEl.offsetHeight;

      // Set on body
      document.body.style.setProperty('--header-height', headerH + 'px');
      document.body.style.setProperty('--header-group-height', groupH + 'px');

      // Also set on :root for mega menu access
      document.documentElement.style.setProperty('--header-height', headerH + 'px');
      document.documentElement.style.setProperty('--header-group-height', groupH + 'px');
    }

    // Run immediately
    updateHeaderHeight();

    // Run again after a frame to ensure CSS has been applied
    requestAnimationFrame(function() {
      updateHeaderHeight();
    });

    // Run on window load to ensure all styles are applied
    window.addEventListener('load', updateHeaderHeight);

    // Use ResizeObserver to detect header size changes (e.g., from theme editor)
    if (typeof ResizeObserver !== 'undefined') {
      var resizeObserver = new ResizeObserver(function() {
        updateHeaderHeight();
      });
      resizeObserver.observe(header);
      if (headerGroup && headerGroup !== header) {
        resizeObserver.observe(headerGroup);
      }
    }

    // Make the header group sticky if enabled
    if (header.classList.contains('casa-header--sticky')) {
      // Apply sticky to the header group if found
      if (headerGroup) {
        headerGroup.style.position = 'sticky';
        headerGroup.style.top = '0';
        headerGroup.style.zIndex = '1000';
      }
      // Also apply to section wrapper for single-section setups
      if (sectionWrapper && sectionWrapper !== headerGroup) {
        sectionWrapper.style.position = 'sticky';
        sectionWrapper.style.top = '0';
        sectionWrapper.style.zIndex = '1000';
      }
      // Ultimate fallback: apply directly to header
      if (!headerGroup && !sectionWrapper) {
        header.style.position = 'sticky';
        header.style.top = '0';
        header.style.zIndex = '1000';
      }

      // Recalculate on scroll (throttled)
      var scrollTimeout;
      window.addEventListener('scroll', function() {
        if (!scrollTimeout) {
          scrollTimeout = setTimeout(function() {
            updateHeaderHeight();
            scrollTimeout = null;
          }, 100);
        }
      }, { passive: true });

      // Recalculate on resize
      window.addEventListener('resize', updateHeaderHeight, { passive: true });
    }
  })();

  // ── Desktop Mega Menu: Click-toggle with click-outside-to-close ──
  (function() {
    var navItems = document.querySelectorAll('.casa-nav-item');
    if (!navItems.length) return;

    function closeAll() {
      navItems.forEach(function(item) {
        item.classList.remove('is-open');
        var link = item.querySelector('.casa-header__nav-link');
        if (link) link.setAttribute('aria-expanded', 'false');
      });
    }

    navItems.forEach(function(item) {
      var link = item.querySelector('.casa-header__nav-link');
      if (!link) return;

      // Prevent navigation — only toggle the mega menu
      link.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        var wasOpen = item.classList.contains('is-open');
        closeAll();
        if (!wasOpen) {
          item.classList.add('is-open');
          link.setAttribute('aria-expanded', 'true');
        }
      });
    });

    // Click outside closes any open mega menu
    document.addEventListener('click', function(e) {
      var openItem = document.querySelector('.casa-nav-item.is-open');
      if (!openItem) return;
      // If click is outside the open nav-item (link + mega menu), close it
      if (!openItem.contains(e.target)) {
        closeAll();
      }
    });

    // Escape key closes
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeAll();
    });
  })();

  // Upsell Add to Cart / Quick-Buy Handler
  (function() {
    function directAddToCart(btn, variantId) {
      btn.classList.add('is-loading');
      btn.disabled = true;

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ items: [{ id: parseInt(variantId), quantity: 1 }] })
      })
      .then(function(response) {
        if (!response.ok) throw new Error('Add to cart failed');
        return response.json();
      })
      .then(function() {
        btn.classList.remove('is-loading');
        btn.classList.add('is-success');
        var cartDrawer = document.querySelector('cart-drawer-component');
        if (cartDrawer && typeof cartDrawer.refresh === 'function') {
          cartDrawer.refresh();
        } else {
          fetch(window.location.pathname + '?sections=casa-header')
            .then(function(r) { return r.json(); })
            .then(function(sections) {
              var html = sections['casa-header'];
              if (html) {
                var parser = new DOMParser();
                var doc = parser.parseFromString(html, 'text/html');
                var newCartInner = doc.querySelector('.cart-drawer__inner');
                var currentCartInner = document.querySelector('.cart-drawer__inner');
                if (newCartInner && currentCartInner) {
                  currentCartInner.innerHTML = newCartInner.innerHTML;
                }
              }
            }).catch(function() { window.location.reload(); });
        }
        setTimeout(function() { btn.classList.remove('is-success'); btn.disabled = false; }, 1200);
      })
      .catch(function(err) {
        console.error('Upsell add error:', err);
        btn.classList.remove('is-loading');
        btn.disabled = false;
      });
    }

    function getOrCreateQuickAdd() {
      // Try to find an existing quick-add-component first
      var qa = document.querySelector('quick-add-component');
      if (qa && typeof qa.fetchProductPage === 'function') return qa;

      // None found or not upgraded — create a temporary hidden one
      // so the browser upgrades it and we can use its methods
      qa = document.createElement('quick-add-component');
      qa.style.display = 'none';
      document.body.appendChild(qa);

      // Wait a tick for custom element upgrade
      return new Promise(function(resolve) {
        requestAnimationFrame(function() {
          if (typeof qa.fetchProductPage === 'function') {
            resolve(qa);
          } else {
            // Custom element not registered — give up
            qa.remove();
            resolve(null);
          }
        });
      });
    }

    function closeCartDrawer() {
      var cartDrawer = document.querySelector('cart-drawer-component');
      if (cartDrawer && typeof cartDrawer.close === 'function') {
        cartDrawer.close();
      }
    }

    function initVariantCarousel() {
      var dialog = document.getElementById('quick-add-dialog');
      if (!dialog) return;
      dialog.querySelectorAll('.variant-option--buttons').forEach(function(fieldset) {
        // Skip if already initialized
        if (fieldset.querySelector('.qa-variant-nav')) return;

        // Create nav wrapper
        var nav = document.createElement('div');
        nav.className = 'qa-variant-nav';
        nav.innerHTML =
          '<button type="button" class="qa-variant-arrow qa-variant-arrow--prev" aria-label="Previous" disabled>' +
            '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"></polyline></svg>' +
          '</button>' +
          '<button type="button" class="qa-variant-arrow qa-variant-arrow--next" aria-label="Next">' +
            '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 6 15 12 9 18"></polyline></svg>' +
          '</button>';

        // Insert nav into legend (next to the option name)
        var legend = fieldset.querySelector('legend');
        if (legend) {
          legend.style.display = 'flex';
          legend.style.justifyContent = 'space-between';
          legend.style.alignItems = 'center';
          legend.appendChild(nav);
        } else {
          fieldset.insertBefore(nav, fieldset.firstChild);
        }

        var prevBtn = nav.querySelector('.qa-variant-arrow--prev');
        var nextBtn = nav.querySelector('.qa-variant-arrow--next');

        function updateArrows() {
          prevBtn.disabled = fieldset.scrollLeft <= 2;
          nextBtn.disabled = fieldset.scrollLeft + fieldset.offsetWidth >= fieldset.scrollWidth - 2;
        }

        prevBtn.addEventListener('click', function(e) {
          e.preventDefault();
          var card = fieldset.querySelector('.variant-option__button-label');
          if (card) fieldset.scrollBy({ left: -(card.offsetWidth + 8), behavior: 'smooth' });
        });

        nextBtn.addEventListener('click', function(e) {
          e.preventDefault();
          var card = fieldset.querySelector('.variant-option__button-label');
          if (card) fieldset.scrollBy({ left: card.offsetWidth + 8, behavior: 'smooth' });
        });

        fieldset.addEventListener('scroll', updateArrows, { passive: true });
        // Delay initial check to let flex layout settle
        setTimeout(updateArrows, 100);
      });
    }

    function openQuickBuy(btn, productUrl) {
      btn.classList.add('is-loading');
      btn.disabled = true;

      // Close cart drawer first so modal is visible (especially on mobile)
      closeCartDrawer();

      Promise.resolve(getOrCreateQuickAdd()).then(function(qa) {
        if (!qa || typeof qa.fetchProductPage !== 'function') {
          // Quick-add custom element not available — fetch + inject manually
          return manualQuickBuy(btn, productUrl);
        }

        return qa.fetchProductPage(productUrl).then(function(doc) {
          if (!doc) { btn.classList.remove('is-loading'); btn.disabled = false; return; }
          var gridElement = doc.querySelector('[data-product-grid-content]');
          if (!gridElement) { return manualQuickBuy(btn, productUrl); }

          var freshContent = gridElement.cloneNode(true);
          return qa.updateQuickAddModal(freshContent).then(function() {
            var dialogComponent = document.getElementById('quick-add-dialog');
            if (dialogComponent && typeof dialogComponent.showDialog === 'function') {
              dialogComponent.showDialog();
            }
            setTimeout(initVariantCarousel, 200);
            btn.classList.remove('is-loading');
            btn.disabled = false;
          });
        });
      }).catch(function(err) {
        console.error('Quick-buy error:', err);
        manualQuickBuy(btn, productUrl);
      });
    }

    function manualQuickBuy(btn, productUrl) {
      // Fallback: fetch product page HTML and inject into modal manually
      return fetch(productUrl)
        .then(function(r) { return r.text(); })
        .then(function(html) {
          var parser = new DOMParser();
          var doc = parser.parseFromString(html, 'text/html');
          var productGrid = doc.querySelector('[data-product-grid-content]');

          if (!productGrid) {
            window.location.href = productUrl;
            return;
          }

          var modalContent = document.getElementById('quick-add-modal-content');
          if (modalContent) {
            modalContent.innerHTML = productGrid.outerHTML;

            // Fix slideshow: set first slide visible
            modalContent.querySelectorAll('slideshow-slide').forEach(function(slide, i) {
              slide.setAttribute('aria-hidden', i === 0 ? 'false' : 'true');
            });
            // Force images to load
            modalContent.querySelectorAll('img').forEach(function(img) {
              img.loading = 'eager';
            });
            // Upgrade custom elements
            if (customElements.upgrade) customElements.upgrade(modalContent);
          }

          var dialogComponent = document.getElementById('quick-add-dialog');
          if (dialogComponent && typeof dialogComponent.showDialog === 'function') {
            dialogComponent.showDialog();
          } else {
            var dialog = dialogComponent ? dialogComponent.querySelector('dialog') : null;
            if (dialog && !dialog.open) dialog.showModal();
          }

          setTimeout(initVariantCarousel, 200);
          btn.classList.remove('is-loading');
          btn.disabled = false;
        })
        .catch(function() {
          window.location.href = productUrl;
        });
    }

    document.addEventListener('click', function(e) {
      var btn = e.target.closest('[data-upsell-add]');
      if (!btn) return;

      e.preventDefault();
      e.stopPropagation();

      var hasOnlyDefault = btn.dataset.hasVariants === 'true'; // data-has-variants stores has_only_default_variant
      var productUrl = btn.dataset.productUrl;
      var variantId = btn.dataset.variantId;

      if (hasOnlyDefault || !productUrl) {
        // Single-variant product: add directly to cart
        if (!variantId) return;
        directAddToCart(btn, variantId);
      } else {
        // Multi-variant product: open quick-buy modal
        openQuickBuy(btn, productUrl);
      }
    });
  })();

  // Upsell Carousel Navigation
  (function() {
    function initUpsellCarousel() {
      document.querySelectorAll('.cart-upsell--carousel').forEach(function(upsell) {
        var track = upsell.querySelector('.cart-upsell__track');
        var prev = upsell.querySelector('.cart-upsell__arrow--prev');
        var next = upsell.querySelector('.cart-upsell__arrow--next');
        if (!track || !prev || !next) return;

        function updateArrows() {
          prev.disabled = track.scrollLeft <= 2;
          next.disabled = track.scrollLeft + track.offsetWidth >= track.scrollWidth - 2;
        }

        prev.addEventListener('click', function() {
          var item = track.querySelector('.cart-upsell__item');
          if (item) track.scrollBy({ left: -(item.offsetWidth + 10), behavior: 'smooth' });
        });

        next.addEventListener('click', function() {
          var item = track.querySelector('.cart-upsell__item');
          if (item) track.scrollBy({ left: item.offsetWidth + 10, behavior: 'smooth' });
        });

        track.addEventListener('scroll', updateArrows, { passive: true });
        updateArrows();
      });
    }

    // Init now and after cart refreshes
    if (document.readyState !== 'loading') initUpsellCarousel();
    else document.addEventListener('DOMContentLoaded', initUpsellCarousel);

    // Re-init when cart content is updated (observer on cart-drawer__inner)
    var observer = new MutationObserver(function() { setTimeout(initUpsellCarousel, 100); });
    var cartInner = document.querySelector('.cart-drawer__inner');
    if (cartInner) observer.observe(cartInner, { childList: true, subtree: true });
  })();
</script>

{%- comment -%} ── CSS Custom Properties from Settings ── {%- endcomment -%}
{%- liquid
  assign header_bg = section.settings.header_bg_color | default: '#0a0a0f'
  assign header_bg_opacity = section.settings.header_bg_opacity | default: 80 | divided_by: 100.0
  assign header_border = section.settings.header_border_color | default: '#ffffff'
  assign header_border_opacity = section.settings.header_border_opacity | default: 8 | divided_by: 100.0
  assign header_text = section.settings.header_text_color | default: '#ffffff'
  assign header_text_opacity = section.settings.header_text_opacity | default: 85 | divided_by: 100.0
  assign mega_bg = section.settings.mega_bg_color | default: '#0f0f14'
  assign mega_bg_opacity = section.settings.mega_bg_opacity | default: 95 | divided_by: 100.0
  assign mega_border = section.settings.mega_border_color | default: '#ffffff'
  assign glow_primary = section.settings.glow_accent_primary | default: '#9333ea'
  assign glow_secondary = section.settings.glow_accent_secondary | default: '#ec4899'
  assign lifestyle_primary = section.settings.lifestyle_accent_primary | default: '#f59e0b'
  assign lifestyle_secondary = section.settings.lifestyle_accent_secondary | default: '#d97706'
  assign support_primary = section.settings.support_accent_primary | default: '#06b6d4'
  assign support_secondary = section.settings.support_accent_secondary | default: '#0891b2'
  assign drawer_bg = section.settings.drawer_bg_color | default: '#0a0a0f'
  assign drawer_accent = section.settings.drawer_accent_color | default: '#9333ea'

  comment
    Glassmorphic drawer controls
  endcomment
  assign glass_tint = section.settings.drawer_glass_tint | default: '#ffffff'
  assign glass_opacity = section.settings.drawer_glass_opacity | default: 45
  assign glass_blur = section.settings.drawer_glass_blur | default: 60
  assign glass_text = section.settings.drawer_glass_text | default: '#000000'
  assign glass_text_muted = section.settings.drawer_glass_text_muted | default: '#555555'
  assign glass_icon_bg = section.settings.drawer_glass_icon_bg | default: '#e5e5e5'
  assign glass_icon_active = section.settings.drawer_glass_icon_active | default: '#1a1a1a'
  assign glass_border = section.settings.drawer_glass_border | default: '#d4d4d4'
  assign glass_card_bg = section.settings.drawer_glass_card_bg | default: '#ffffff'
  assign glass_btn_bg = section.settings.drawer_glass_btn_bg | default: '#1a1a1a'
  assign glass_btn_text = section.settings.drawer_glass_btn_text | default: '#ffffff'

  comment
    Convert glass_opacity from 0-100 to 0-1 for CSS
  endcomment
  assign glass_opacity_decimal = glass_opacity | divided_by: 100.0

  assign logo_weight = section.settings.logo_font_weight | default: '300'
  assign logo_spacing = section.settings.logo_letter_spacing | default: 4
  assign nav_weight = section.settings.nav_font_weight | default: '500'
  assign nav_size = section.settings.nav_font_size | default: 14
  assign header_height = section.settings.header_height | default: 80
  assign logo_height = section.settings.logo_height | default: 36
-%}
<style>
  /* Global sizing variables - accessible to mega menu & drawer */
  :root {
    --casa-header-height: {{ header_height }}px;
    --casa-logo-height: {{ logo_height }}px;

    /* Glassmorphic Drawer Controls (on :root so drawer/submenu can inherit) */
    --casa-glass-tint: {{ glass_tint }};
    --casa-glass-tint-rgb: {{ glass_tint | color_extract: 'red' }}, {{ glass_tint | color_extract: 'green' }}, {{ glass_tint | color_extract: 'blue' }};
    --casa-glass-opacity: {{ glass_opacity_decimal }};
    --casa-glass-blur: {{ glass_blur }}px;
    --casa-glass-text: {{ glass_text }};
    --casa-glass-text-rgb: {{ glass_text | color_extract: 'red' }}, {{ glass_text | color_extract: 'green' }}, {{ glass_text | color_extract: 'blue' }};
    --casa-glass-text-muted: {{ glass_text_muted }};
    --casa-glass-text-muted-rgb: {{ glass_text_muted | color_extract: 'red' }}, {{ glass_text_muted | color_extract: 'green' }}, {{ glass_text_muted | color_extract: 'blue' }};
    --casa-glass-icon-bg: {{ glass_icon_bg }};
    --casa-glass-icon-bg-rgb: {{ glass_icon_bg | color_extract: 'red' }}, {{ glass_icon_bg | color_extract: 'green' }}, {{ glass_icon_bg | color_extract: 'blue' }};
    --casa-glass-icon-active: {{ glass_icon_active }};
    --casa-glass-icon-active-rgb: {{ glass_icon_active | color_extract: 'red' }}, {{ glass_icon_active | color_extract: 'green' }}, {{ glass_icon_active | color_extract: 'blue' }};
    --casa-glass-border: {{ glass_border }};
    --casa-glass-border-rgb: {{ glass_border | color_extract: 'red' }}, {{ glass_border | color_extract: 'green' }}, {{ glass_border | color_extract: 'blue' }};
    --casa-glass-card-bg: {{ glass_card_bg }};
    --casa-glass-card-bg-rgb: {{ glass_card_bg | color_extract: 'red' }}, {{ glass_card_bg | color_extract: 'green' }}, {{ glass_card_bg | color_extract: 'blue' }};
    --casa-glass-btn-bg: {{ glass_btn_bg }};
    --casa-glass-btn-text: {{ glass_btn_text }};
  }

  .casa-header {
    /* Typography */
    --casa-logo-weight: {{ logo_weight }};
    --casa-logo-spacing: {{ logo_spacing }}px;
    --casa-nav-weight: {{ nav_weight }};
    --casa-nav-size: {{ nav_size }}px;

    /* Header Colors */
    --casa-header-bg: {{ header_bg | color_modify: 'alpha', header_bg_opacity }};
    --casa-header-border: {{ header_border | color_modify: 'alpha', header_border_opacity }};
    --casa-header-text: {{ header_text }};
    --casa-header-text-muted: {{ header_text | color_modify: 'alpha', header_text_opacity }};

    /* Mega Menu Colors */
    --casa-mega-bg: {{ mega_bg | color_modify: 'alpha', mega_bg_opacity }};
    --casa-mega-border: {{ mega_border | color_modify: 'alpha', 0.1 }};

    /* Glow Variant Accents */
    --casa-glow-primary: {{ glow_primary }};
    --casa-glow-secondary: {{ glow_secondary }};
    --casa-glow-primary-rgb: {{ glow_primary | color_extract: 'red' }}, {{ glow_primary | color_extract: 'green' }}, {{ glow_primary | color_extract: 'blue' }};
    --casa-glow-secondary-rgb: {{ glow_secondary | color_extract: 'red' }}, {{ glow_secondary | color_extract: 'green' }}, {{ glow_secondary | color_extract: 'blue' }};

    /* Lifestyle Variant Accents */
    --casa-lifestyle-primary: {{ lifestyle_primary }};
    --casa-lifestyle-secondary: {{ lifestyle_secondary }};
    --casa-lifestyle-primary-rgb: {{ lifestyle_primary | color_extract: 'red' }}, {{ lifestyle_primary | color_extract: 'green' }}, {{ lifestyle_primary | color_extract: 'blue' }};
    --casa-lifestyle-secondary-rgb: {{ lifestyle_secondary | color_extract: 'red' }}, {{ lifestyle_secondary | color_extract: 'green' }}, {{ lifestyle_secondary | color_extract: 'blue' }};

    /* Support Variant Accents */
    --casa-support-primary: {{ support_primary }};
    --casa-support-secondary: {{ support_secondary }};
    --casa-support-primary-rgb: {{ support_primary | color_extract: 'red' }}, {{ support_primary | color_extract: 'green' }}, {{ support_primary | color_extract: 'blue' }};
    --casa-support-secondary-rgb: {{ support_secondary | color_extract: 'red' }}, {{ support_secondary | color_extract: 'green' }}, {{ support_secondary | color_extract: 'blue' }};

    /* Drawer Colors */
    --casa-drawer-bg: {{ drawer_bg }};
    --casa-drawer-accent: {{ drawer_accent }};
    --casa-drawer-accent-rgb: {{ drawer_accent | color_extract: 'red' }}, {{ drawer_accent | color_extract: 'green' }}, {{ drawer_accent | color_extract: 'blue' }};

    /* Primary accent (used for cart badge, etc) */
    --casa-accent-primary: {{ glow_primary }};
  }

  /* ── Cart Drawer CSS Variables (must be in <style> for Liquid processing) ── */
  {%- liquid
    assign cart_accent = section.settings.cart_accent_primary | default: '#9333ea'
    assign cart_accent_secondary = section.settings.cart_accent_secondary | default: '#a855f7'
    assign cart_bg = section.settings.cart_bg_color | default: '#ffffff'
    assign cart_text = section.settings.cart_text_color | default: '#1f2937'
    assign cart_border = section.settings.cart_border_color | default: '#e5e7eb'
    assign cart_accent_rgb = cart_accent | color_to_rgb | remove: 'rgb(' | remove: ')'
  -%}
  :root {
    --cart-drawer-accent: {{ cart_accent }};
    --cart-drawer-accent-secondary: {{ cart_accent_secondary }};
    --cart-drawer-accent-rgb: {{ cart_accent_rgb }};
    --cart-drawer-bg: {{ cart_bg }};
    --cart-drawer-border: {{ cart_border }};
    --cart-drawer-text: {{ cart_text }};
  }
</style>

{% stylesheet %}
  /* ── Section Group & Wrapper ── */
  /* Sticky is applied via JavaScript when enable_sticky is true */
  .casa-header-section {
    position: relative;
    z-index: 1000;
  }

  /* ── Header Container ── */
  .casa-header {
    padding: 0 clamp(20px, 4vw, 60px);
    height: var(--casa-header-height, 80px);
    display: flex;
    align-items: center;
    z-index: 1000;
    position: relative;
  }

  /* Border - static */
  .casa-header--border-static {
    border-bottom: 1px solid var(--casa-header-border, rgba(255, 255, 255, 0.08));
  }

  /* Border - animated gradient */
  .casa-header--border-animated::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg,
      var(--casa-glow-primary, #9333ea),
      var(--casa-glow-secondary, #ec4899),
      var(--casa-support-primary, #06b6d4),
      var(--casa-glow-secondary, #ec4899),
      var(--casa-glow-primary, #9333ea));
    background-size: 300% 100%;
    animation: casa-border-shimmer 4s linear infinite;
  }

  @keyframes casa-border-shimmer {
    0% { background-position: 100% 0; }
    100% { background-position: -100% 0; }
  }

  /* Glassmorphism via ::before to avoid creating a containing block
     for position:fixed mega menu (backdrop-filter creates one) */
  .casa-header::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--casa-header-bg, rgba(10, 10, 15, 0.8));
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    z-index: -1;
  }
  .casa-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: 1600px;
    margin: 0 auto;
  }

  /* Widescreen layout - full width, no max-width constraint */
  .casa-header--widescreen .casa-header__inner {
    max-width: none;
  }

  /* Uppercase nav links */
  .casa-header--nav-uppercase .casa-header__nav-link {
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  /* ── Left: Logo + Nav ── */
  .casa-header__left {
    display: flex;
    align-items: center;
    align-self: stretch;
    gap: clamp(12px, 2vw, 60px);
    min-width: 0;
  }

  .casa-header__logo {
    font-size: 22px;
    font-weight: var(--casa-logo-weight, 300);
    letter-spacing: var(--casa-logo-spacing, 4px);
    text-decoration: none;
    color: var(--casa-header-text, white);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .casa-header__logo-img {
    height: var(--casa-logo-height, 36px);
    width: auto;
    min-height: 24px;
    flex-shrink: 0;
  }

  /* ── Desktop Navigation ── */
  .casa-header__nav {
    display: flex;
    gap: clamp(6px, 1.5vw, 40px);
    align-items: center;
    align-self: stretch;
    white-space: nowrap;
  }

  .casa-nav-item {
    /* position:relative for the hover bridge — mega menu uses position:fixed so unaffected */
    position: relative;
    display: flex;
    align-items: center;
    align-self: stretch;
  }
  /* Invisible bridge below the nav item — keeps hover alive as mouse
     moves from nav link down to the mega menu panel.
     Extended to provide generous buffer zone. */
  .casa-nav-item::after {
    content: '';
    position: absolute;
    left: -50px;
    right: -50px;
    top: 100%;
    height: 80px;
    pointer-events: none;
  }
  .casa-nav-item.is-open::after {
    pointer-events: auto;
  }

  .casa-header__nav-link {
    text-decoration: none;
    color: var(--casa-header-text-muted, rgba(255, 255, 255, 0.85));
    font-size: clamp(11px, 1vw, var(--casa-nav-size, 14px));
    font-weight: var(--casa-nav-weight, 500);
    transition: color 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 8px 0;
    white-space: nowrap;
  }
  .casa-header__nav-link:hover {
    color: var(--casa-header-text, white);
  }
  .casa-header__nav-link svg {
    opacity: 0.5;
    transition: transform 0.2s;
  }
  .casa-nav-item.is-open .casa-header__nav-link {
    color: var(--casa-header-text, white);
  }
  .casa-nav-item.is-open .casa-header__nav-link svg {
    transform: rotate(180deg);
    opacity: 1;
  }

  /* ── Right: Actions ── */
  .casa-header__actions {
    display: flex;
    gap: clamp(4px, 1vw, 20px);
    align-items: center;
    flex-shrink: 0;
    margin-left: clamp(8px, 1.5vw, 24px);
  }

  .casa-header__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: var(--casa-header-text-muted, rgba(255, 255, 255, 0.7));
    cursor: pointer;
    transition: color 0.2s;
    padding: 4px;
    position: relative;
    min-width: 28px;
    min-height: 28px;
    flex-shrink: 0;
  }
  .casa-header__btn svg {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }
  .casa-header__btn:hover {
    color: var(--casa-header-text, white);
  }

  /* Cart count badge */
  .casa-header__cart-count {
    position: absolute;
    top: -4px;
    right: -8px;
    min-width: 18px;
    height: 18px;
    background: var(--casa-accent-primary, #9333ea);
    color: white;
    font-size: 10px;
    font-weight: 600;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 4px;
  }
  .casa-header__cart-count:empty,
  .casa-header__cart-count[data-cart-count="0"] {
    display: none;
  }

  /* Account avatar (logged-in user initial) */
  .casa-header__account-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--casa-glow-primary, #9333ea), var(--casa-glow-secondary, #ec4899));
    color: white;
    font-size: 12px;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    text-transform: uppercase;
  }
  .casa-header__account-btn:hover .casa-header__account-avatar {
    box-shadow: 0 0 12px rgba(var(--casa-glow-primary-rgb, 147, 51, 234), 0.5);
  }

  /* Locale/Currency selector button */
  .casa-header__locale-btn {
    gap: 4px;
    padding: 5px 10px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    font-size: 11px;
    font-weight: 500;
    transition: all 0.2s;
  }
  .casa-header__locale-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
  }
  .casa-header__locale-text {
    letter-spacing: 0.5px;
  }

  /* ── Responsive Utilities ── */
  .casa-desktop-only { display: flex; }
  .casa-mobile-only { display: none; }

  /* ── Mobile/Tablet: Switch to hamburger menu under 1000px ── */
  @media (max-width: 999px) {
    .casa-header {
      padding: 0 20px;
      height: calc(var(--casa-header-height, 80px) * 0.85);
    }

    .casa-header__inner {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: flex-end;
    }

    /* Hamburger pinned to the left edge */
    .casa-menu-toggle {
      position: absolute;
      left: 0;
      top: 50%;
      transform: translateY(-50%);
    }

    /* Logo centered — constrained so it can't overlap side elements */
    .casa-header__left {
      position: absolute;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
      justify-content: center;
      gap: 0;
      max-width: calc(100% - 180px);
    }

    .casa-header__logo {
      font-size: 18px;
      letter-spacing: calc(var(--casa-logo-spacing, 4px) * 0.85);
    }
    .casa-header__logo-img {
      height: calc(var(--casa-logo-height, 36px) * 0.89);
      min-height: 28px;
    }

    /* Action icons pushed to the right */
    .casa-header__actions {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .casa-desktop-only { display: none !important; }
    .casa-mobile-only { display: flex !important; }
  }

  /* ── Small mobile (under 480px) ── */
  @media (max-width: 479px) {
    .casa-header {
      padding: 0 14px;
      height: calc(var(--casa-header-height, 80px) * 0.75);
    }

    .casa-header__left {
      max-width: calc(100% - 140px);
    }

    .casa-header__logo {
      font-size: 16px;
      letter-spacing: calc(var(--casa-logo-spacing, 4px) * 0.75);
    }
    .casa-header__logo-img {
      height: calc(var(--casa-logo-height, 36px) * 0.78);
      min-height: 24px;
    }

    .casa-header__actions { gap: 10px; }

    .casa-header__btn svg {
      width: 20px;
      height: 20px;
    }
  }

  /* ── Tight Desktop (1000–1399px) — hide locale, compact logo ── */
  @media (min-width: 1000px) and (max-width: 1399px) {
    .casa-header__locale-btn {
      display: none !important;
    }

    .casa-header__logo {
      font-size: 18px;
      letter-spacing: calc(var(--casa-logo-spacing, 4px) * 0.75);
    }
    .casa-header__logo-img {
      height: calc(var(--casa-logo-height, 36px) * 0.85);
    }
  }

  /* ── Mid Desktop (1200px+) — restore icon sizing ── */
  @media (min-width: 1200px) {
    .casa-header__btn svg {
      width: 22px;
      height: 22px;
    }
  }

  /* ── Large Desktop (1600px+) — generous spacing ── */
  @media (min-width: 1600px) {
    .casa-header {
      padding: 0 80px;
    }

    .casa-header__nav {
      gap: 48px;
    }

    .casa-header__actions {
      gap: 20px;
    }

    .casa-header__locale-btn {
      font-size: 12px;
      padding: 6px 12px;
      gap: 6px;
    }
  }

  /* ══════════════════════════════════════════════════════════════════════════
     CART DRAWER STYLES - SUPERCHARGED CASA EDITION
     Premium glassmorphism drawer with enhanced UX features
     ══════════════════════════════════════════════════════════════════════════ */
  .cart-drawer {
    --cart-drawer-padding: 20px 24px;
    --cart-drawer-padding-desktop: 24px 32px;
    --cart-drawer-text-secondary: #6b7280;
    --cart-drawer-text-muted: #9ca3af;
    --cart-drawer-success: #10b981;
  }

  /* ── Main Dialog Container ── */
  .cart-drawer__dialog {
    position: fixed;
    overflow: hidden;
    border-radius: 20px 0 0 20px;
    width: var(--sidebar-width, 440px);
    max-width: 95vw;
    height: 100%;
    margin: 0 0 0 auto;
    padding: 0;
    border: none;
    border-left: 1px solid rgba(var(--cart-drawer-accent-rgb), 0.15);
    box-shadow:
      -12px 0 40px rgba(0, 0, 0, 0.15),
      -4px 0 20px rgba(var(--cart-drawer-accent-rgb), 0.08);
    background: var(--cart-drawer-bg);
  }

  .cart-drawer__dialog::backdrop {
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .cart-drawer__dialog:modal {
    max-height: 100dvh;
    overflow-y: hidden;
  }

  /* Premium accent line at top */
  .cart-drawer__dialog::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--cart-drawer-accent), var(--cart-drawer-accent-secondary), var(--cart-drawer-accent));
    background-size: 200% 100%;
    animation: cart-shimmer 3s ease-in-out infinite;
    z-index: 10;
  }

  @keyframes cart-shimmer {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .cart-drawer__inner {
    height: 100%;
    overflow: hidden;
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
  }

  /* ═══ COMPACT CART ITEMS (Drawer-specific) ═══ */
  /* ── 3-col drawer grid: image | details (with inline qty) | price ── */
  .cart-drawer .cart-items__table-row {
    grid-template-columns: 56px minmax(0, 1fr) auto;
    grid-template-areas: 'media details price';
    column-gap: 10px;
    padding-bottom: 12px;
    margin-bottom: 12px;
  }

  .cart-drawer .cart-items__media-container {
    width: 56px;
  }

  .cart-drawer .cart-items__title {
    font-size: 13px;
    font-weight: 700;
    line-height: 1.3;
  }

  .cart-drawer .cart-items__inline-price {
    display: none;
  }

  /* Stack price + compare-at vertically in drawer */
  .cart-drawer .cart-items__price {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2px;
    font-size: 12px;
    font-weight: 600;
  }

  .cart-drawer .cart-items__compare-price {
    font-size: 10px;
    color: var(--compare-price-color, #6b7280);
  }

  .cart-drawer .cart-items__details > * + * {
    margin-block-start: 2px;
  }

  .cart-drawer .cart-items__details * {
    font-size: 11px;
  }

  .cart-drawer .cart-items__variant,
  .cart-drawer .cart-items__variants {
    font-size: 11px;
    color: #6b7280;
  }

  /* Hide original quantity row — use compact inline qty in details instead */
  .cart-drawer .cart-items__quantity { display: none; }

  /* Show inline qty controls inside details cell */
  .cart-drawer .cart-items__inline-qty {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-top: 6px;
  }

  .cart-drawer .cart-items__quantity-controls {
    gap: 4px;
  }

  .cart-drawer .quantity-selector {
    height: 24px;
    min-width: auto;
    border-radius: 6px;
  }

  .cart-drawer .quantity-selector__button {
    width: 24px;
    height: 24px;
    padding: 0;
  }

  .cart-drawer .quantity-selector__input {
    width: 24px;
    height: 24px;
    font-size: 11px;
    padding: 0;
  }

  .cart-drawer .cart-items__remove {
    width: 24px;
    height: 24px;
  }

  .cart-drawer .cart-items__remove svg {
    width: 14px;
    height: 14px;
  }

  /* ═══ Quick-Buy Modal — Variant List (vertical compact layout) ═══ */

  /* ═══ UPSELLS - Horizontal Carousel ═══ */
  .cart-upsell {
    padding: 12px 16px;
    border-top: 1px solid var(--cart-drawer-border);
  }

  .cart-upsell__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
  }

  .cart-upsell__title {
    font-size: 11px;
    font-weight: 600;
    color: var(--cart-drawer-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin: 0;
  }

  .cart-upsell__nav {
    display: flex;
    gap: 4px;
  }

  .cart-upsell__arrow {
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.04);
    border: 1px solid var(--cart-drawer-border);
    border-radius: 50%;
    cursor: pointer;
    color: var(--cart-drawer-text-secondary);
    transition: all 0.15s ease;
    padding: 0;
  }

  .cart-upsell__arrow:hover:not(:disabled) {
    background: rgba(var(--cart-drawer-accent-rgb), 0.1);
    border-color: rgba(var(--cart-drawer-accent-rgb), 0.3);
    color: var(--cart-drawer-accent);
  }

  .cart-upsell__arrow:disabled {
    opacity: 0.3;
    cursor: default;
  }

  .cart-upsell__track {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    scroll-behavior: smooth;
  }

  .cart-upsell__track::-webkit-scrollbar {
    display: none;
  }

  .cart-upsell__item {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 10px;
    padding: 10px;
    background: rgba(0, 0, 0, 0.02);
    border: 1px solid var(--cart-drawer-border);
    border-radius: 8px;
    flex: 0 0 85%;
    scroll-snap-align: start;
    min-width: 0;
  }

  .cart-upsell__image {
    width: 52px;
    height: 52px;
    border-radius: 6px;
    overflow: hidden;
    flex-shrink: 0;
    background: #f5f5f5;
  }

  .cart-upsell__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cart-upsell__info {
    flex: 1;
    min-width: 0;
  }

  .cart-upsell__name {
    display: block;
    font-size: 12px;
    font-weight: 500;
    color: var(--cart-drawer-text);
    text-decoration: none;
    line-height: 1.3;
    margin-bottom: 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .cart-upsell__name:hover {
    text-decoration: underline;
  }

  .cart-upsell__price {
    font-size: 12px;
    font-weight: 600;
    color: var(--cart-drawer-text);
  }

  button.cart-upsell__add,
  .cart-upsell__add {
    padding: 7px 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--cart-drawer-accent, #9333ea);
    background-color: var(--cart-drawer-accent, #9333ea);
    color: #fff;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-size: 11px;
    font-weight: 600;
    transition: all 0.15s ease;
    flex-shrink: 0;
    white-space: nowrap;
    -webkit-appearance: none;
    appearance: none;
  }

  .cart-upsell__add:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .cart-upsell__add:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .cart-upsell__add.is-loading {
    pointer-events: none;
  }

  .cart-upsell__add.is-success {
    background: #10b981;
  }

  /* ═══ Trust Line - Minimal ═══ */
  .cart-cro__trust {
    font-size: 10px;
    color: #9ca3af;
    text-align: center;
    padding: 8px 16px;
    margin: 0;
    border-top: 1px solid var(--cart-drawer-border);
  }

  /* ── Compact Header ── */
  .cart-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 14px 20px;
    border-bottom: none;
    position: sticky;
    top: 0;
    z-index: 2;
    background: var(--cart-drawer-bg, #ffffff);
  }

  .cart-drawer__header-left {
    display: flex;
    align-items: center;
    gap: 12px;
    flex: 1;
    min-width: 0;
  }

  .cart-drawer__heading {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-bottom: 0;
    font-size: 16px;
    font-weight: 700;
    color: var(--cart-drawer-text);
    white-space: nowrap;
  }

  .cart-drawer__heading .cart-bubble {
    display: none;
  }

  .cart-drawer__count {
    font-weight: 400;
    color: var(--cart-drawer-text-secondary);
    font-size: 15px;
  }

  .cart-drawer__shipping-inline {
    display: flex;
    align-items: center;
  }

  .cart-drawer__shipping-inline .cart-drawer__shipping-text {
    font-size: 11px;
    color: var(--cart-drawer-text-muted);
    margin: 0;
    white-space: nowrap;
  }
  .cart-drawer__shipping-inline .cart-drawer__shipping-text strong {
    color: var(--cart-drawer-text);
    font-weight: 600;
  }
  .cart-drawer__shipping-inline .cart-drawer__shipping-text--success {
    color: #10b981;
    font-weight: 600;
  }

  .cart-drawer__close-button {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid var(--cart-drawer-border);
    border-radius: 50%;
    cursor: pointer;
    color: var(--cart-drawer-text-secondary);
    transition: all 0.2s;
    flex-shrink: 0;
  }
  .cart-drawer__close-button:hover {
    background: #f3f4f6;
    color: var(--cart-drawer-text);
    border-color: #d1d5db;
  }
  .cart-drawer__close-button svg {
    width: 14px;
    height: 14px;
  }

  /* ── Shipping Progress Bar (thin line below header) ── */
  .cart-drawer__shipping-bar {
    padding: 0 20px 0;
    background: transparent;
  }

  .cart-drawer__shipping-text {
    font-size: 11px;
    color: var(--cart-drawer-text-muted);
    margin: 0;
  }
  .cart-drawer__shipping-text strong {
    color: var(--cart-drawer-text);
    font-weight: 600;
  }
  .cart-drawer__shipping-text--success {
    color: #10b981;
  }

  .cart-drawer__shipping-track {
    height: 3px;
    background: #e5e7eb;
    border-radius: 2px;
    overflow: hidden;
  }

  .cart-drawer__shipping-progress {
    height: 100%;
    width: var(--progress, 0%);
    background: linear-gradient(90deg, var(--cart-drawer-accent), var(--cart-drawer-success));
    border-radius: 3px;
    transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
  }
  .cart-drawer__shipping-progress::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
    animation: shimmer 2s infinite;
  }

  @keyframes shimmer {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }

  /* ── Content Area ── */
  .cart-drawer__content {
    display: flex;
    flex-direction: column;
    padding: 0;
    background: transparent;
    flex: 1;
    min-height: 0;
    overflow-y: auto;
  }

  .cart-drawer__items {
    display: flex;
    flex-direction: column;
    padding: var(--cart-drawer-padding);
  }

  @media screen and (min-width: 750px) {
    .cart-drawer__items {
      padding: var(--cart-drawer-padding-desktop);
    }
  }

  /* ── Product Cards in Drawer ── */
  .cart-drawer__items .cart-items__table-row {
    padding: 16px;
    margin-bottom: 16px;
    background: #ffffff;
    border: 1px solid var(--cart-drawer-border);
    border-radius: 12px;
    transition: all 0.2s;
  }
  .cart-drawer__items .cart-items__table-row:hover {
    border-color: #d1d5db;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  .cart-drawer__items .cart-items__table-row:has(+ .cart-items__nested-line) {
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
    margin-bottom: 0;
    border-bottom: none;
  }

  .cart-drawer__items .cart-items__table-row:last-child {
    margin-bottom: 0;
  }

  .cart-drawer__items .cart-items__media-container {
    border-radius: 8px;
    overflow: hidden;
    background: #f9fafb;
  }

  .cart-drawer__items .cart-items__title {
    color: var(--cart-drawer-text);
    font-weight: 700;
    font-size: 13px;
  }
  .cart-drawer__items .cart-items__title:hover {
    color: var(--cart-drawer-accent);
  }

  .cart-drawer__items .cart-items__details {
    color: var(--cart-drawer-text-secondary);
    font-size: 12px;
  }

  .cart-drawer__items .cart-items__inline-current {
    color: var(--cart-drawer-text);
    font-size: 13px;
  }
  .cart-drawer__items .cart-items__inline-current--sale {
    color: #dc2626;
  }
  .cart-drawer__items .cart-items__inline-compare {
    color: var(--cart-drawer-text-muted);
  }

  /* Quantity selector styling */
  .cart-drawer__items .quantity-selector {
    background: #f9fafb;
    border: 1px solid var(--cart-drawer-border);
    border-radius: 6px;
  }

  .cart-drawer__items .cart-items__remove {
    color: var(--cart-drawer-text-muted);
    transition: color 0.2s;
    min-width: 28px;
    min-height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0.6;
  }
  .cart-drawer__items .cart-items__remove:hover {
    color: #ef4444;
    opacity: 1;
  }

  /* ── Summary Section ── */
  .cart-drawer__summary {
    --cart-drawer-summary-padding: 24px;
    position: sticky;
    bottom: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 20px;
    padding: var(--cart-drawer-summary-padding);
    background: #ffffff;
    border-top: 1px solid var(--cart-drawer-border);
  }

  @media screen and (min-width: 750px) {
    .cart-drawer__summary {
      --cart-drawer-summary-padding: 32px;
    }
  }

  /* Force summary always sticky — never let theme JS override */
  .cart-drawer__dialog[cart-summary-sticky='false'] .cart-drawer__summary {
    position: sticky;
    bottom: 0;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.95) 0%, #ffffff 20%);
    border-top: 1px solid var(--cart-drawer-border);
  }

  /* Summary totals */
  .cart-drawer__summary .cart__summary-totals {
    gap: 12px;
  }

  .cart-drawer__summary .cart__total {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    width: 100%;
  }

  .cart-drawer__summary .cart__total-label {
    color: var(--cart-drawer-text-secondary);
    font-size: 14px;
  }

  .cart-drawer__summary .cart__total-prices {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }

  .cart-drawer__summary .cart__total-value {
    color: var(--cart-drawer-text);
    font-size: 18px;
    font-weight: 700;
  }

  .cart-drawer__summary .cart__total-compare {
    font-size: 13px;
  }

  .cart-drawer__summary .cart__total-compare {
    color: var(--compare-price-color, #6b7280);
    font-size: 14px;
    font-weight: 400;
    text-decoration: line-through;
  }

  /* Checkout button - premium gradient CTA */
  .cart-drawer__summary .cart__checkout-button,
  .cart-drawer .cart__checkout-button,
  .cart-drawer-component .cart__checkout-button,
  .cart__checkout-button.button {
    background: linear-gradient(135deg, var(--cart-drawer-accent, #9333ea), var(--cart-drawer-accent-secondary, #a855f7)) !important;
    border: none !important;
    border-radius: 14px;
    color: white !important;
    font-weight: 700;
    font-size: 15px;
    letter-spacing: 0.3px;
    padding: 18px 28px;
    cursor: pointer;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
    box-shadow:
      0 4px 14px rgba(var(--cart-drawer-accent-rgb), 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.2);
  }
  .cart-drawer__summary .cart__checkout-button::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.2), transparent 60%);
    opacity: 1;
  }
  .cart-drawer__summary .cart__checkout-button::after {
    content: '';
    position: absolute;
    inset: -50%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.15),
      transparent
    );
    transform: translateX(-100%) rotate(25deg);
    transition: transform 0.6s ease;
  }
  .cart-drawer__summary .cart__checkout-button:hover::after {
    transform: translateX(100%) rotate(25deg);
  }
  .cart-drawer__summary .cart__checkout-button:hover {
    transform: translateY(-3px);
    box-shadow:
      0 12px 28px rgba(var(--cart-drawer-accent-rgb), 0.45),
      0 4px 10px rgba(var(--cart-drawer-accent-rgb), 0.25),
      inset 0 1px 0 rgba(255, 255, 255, 0.25);
  }
  .cart-drawer__summary .cart__checkout-button:active {
    transform: translateY(-1px);
    box-shadow:
      0 6px 16px rgba(var(--cart-drawer-accent-rgb), 0.35),
      inset 0 1px 0 rgba(255, 255, 255, 0.2);
  }
  .cart-drawer__summary .cart__checkout-button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }

  /* Discount input styling */
  .cart-drawer__summary .cart-discount__input {
    background: #f9fafb;
    border: 1px solid var(--cart-drawer-border);
    border-radius: 8px;
    color: var(--cart-drawer-text);
  }
  .cart-drawer__summary .cart-discount__input:focus {
    border-color: var(--cart-drawer-accent);
    outline: none;
    box-shadow: 0 0 0 3px rgba(var(--cart-drawer-accent-rgb), 0.1);
  }

  .cart-drawer__summary .cart-discount__button {
    background: var(--cart-drawer-accent);
    border: none;
    border-radius: 8px;
    color: white;
    font-weight: 500;
    transition: all 0.2s;
  }
  .cart-drawer__summary .cart-discount__button:hover {
    background: var(--cart-drawer-accent-secondary);
  }

  /* Note accordion */
  .cart-drawer__summary .cart-note__summary,
  .cart-drawer__summary .cart-discount__summary {
    color: var(--cart-drawer-text-secondary);
  }
  .cart-drawer__summary .cart-note__summary:hover,
  .cart-drawer__summary .cart-discount__summary:hover {
    color: var(--cart-drawer-text);
  }

  .cart-drawer__summary .cart-note__instructions {
    background: #f9fafb;
    border: 1px solid var(--cart-drawer-border);
    border-radius: 8px;
    color: var(--cart-drawer-text);
  }
  .cart-drawer__summary .cart-note__instructions:focus {
    border-color: var(--cart-drawer-accent);
    outline: none;
    box-shadow: 0 0 0 3px rgba(var(--cart-drawer-accent-rgb), 0.1);
  }

  /* ── Empty Cart State ── */
  .cart-drawer--empty .cart-drawer__header {
    justify-content: flex-end;
    border-bottom: none;
    background: transparent;
  }

  .cart-drawer--empty .cart-drawer__content {
    text-align: center;
    min-height: auto;
  }

  .cart-drawer--empty .cart-drawer__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100dvh;
    margin-top: 0;
  }

  .cart-drawer--empty .cart-drawer__heading {
    margin-bottom: 24px;
    font-size: 22px;
    color: var(--cart-drawer-text-secondary);
  }

  .cart-drawer__heading--empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .cart-drawer__heading--empty::before {
    content: '';
    width: 80px;
    height: 80px;
    background: linear-gradient(135deg, rgba(var(--cart-drawer-accent-rgb), 0.1), rgba(var(--cart-drawer-accent-rgb), 0.05));
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cart-drawer:not(:has(.cart-form)) .cart-drawer__content {
    justify-content: center;
  }

  .cart-drawer:not(:has(.cart-form)) .cart-items__empty-button {
    background: linear-gradient(135deg, var(--cart-drawer-accent), var(--cart-drawer-accent-secondary));
    border: none;
    border-radius: 12px;
    color: white;
    font-weight: 600;
    padding: 14px 32px;
    transition: all 0.2s;
  }
  .cart-drawer:not(:has(.cart-form)) .cart-items__empty-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(var(--cart-drawer-accent-rgb), 0.35);
  }

  /* ── Scrollbar Styling ── */
  .cart-drawer__items::-webkit-scrollbar,
  .cart-drawer__content::-webkit-scrollbar {
    width: 6px;
  }
  .cart-drawer__items::-webkit-scrollbar-track,
  .cart-drawer__content::-webkit-scrollbar-track {
    background: transparent;
  }
  .cart-drawer__items::-webkit-scrollbar-thumb,
  .cart-drawer__content::-webkit-scrollbar-thumb {
    background: #d1d5db;
    border-radius: 3px;
  }
  .cart-drawer__items::-webkit-scrollbar-thumb:hover,
  .cart-drawer__content::-webkit-scrollbar-thumb:hover {
    background: #9ca3af;
  }

  /* ══════════════════════════════════════════════════════════════════════════
     LOCALIZATION DRAWER STYLES
     Country/language selector modal matching Casa dark theme
     ══════════════════════════════════════════════════════════════════════════ */
  .casa-locale-drawer {
    position: fixed;
    border: none;
    border-radius: 16px;
    background: linear-gradient(145deg, rgba(15, 15, 20, 0.98), rgba(10, 10, 15, 0.99));
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.08),
      0 20px 60px rgba(0, 0, 0, 0.5),
      0 0 80px rgba(var(--casa-glow-primary-rgb, 147, 51, 234), 0.1);
    color: white;
    max-width: 420px;
    width: 90vw;
    max-height: 80vh;
    padding: 0;
    overflow: hidden;
  }

  .casa-locale-drawer::backdrop {
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .casa-locale-drawer__inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    max-height: 80vh;
  }

  .casa-locale-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 24px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    flex-shrink: 0;
  }

  .casa-locale-drawer__title {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 16px;
    font-weight: 500;
    margin: 0;
    color: white;
  }
  .casa-locale-drawer__title svg {
    opacity: 0.7;
  }

  .casa-locale-drawer__close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    color: rgba(255, 255, 255, 0.7);
    cursor: pointer;
    transition: all 0.2s;
  }
  .casa-locale-drawer__close:hover {
    background: rgba(255, 255, 255, 0.1);
    color: white;
  }

  .casa-locale-drawer__content {
    padding: 0;
    overflow-y: auto;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  /* Custom Locale Form */
  .casa-locale-form {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  /* Search Input */
  .casa-locale-search {
    padding: 16px 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    position: relative;
    flex-shrink: 0;
  }
  .casa-locale-search__icon {
    position: absolute;
    left: 32px;
    top: 50%;
    transform: translateY(-50%);
    color: rgba(255, 255, 255, 0.4);
    pointer-events: none;
  }
  .casa-locale-drawer .casa-locale-search__input,
  .casa-locale-drawer input.casa-locale-search__input {
    width: 100%;
    padding: 12px 16px 12px 40px;
    background-color: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    color: white;
    font-size: 14px;
    transition: all 0.2s;
  }
  .casa-locale-drawer .casa-locale-search__input::placeholder,
  .casa-locale-drawer input.casa-locale-search__input::placeholder {
    color: rgba(255, 255, 255, 0.4);
  }
  .casa-locale-drawer .casa-locale-search__input:focus,
  .casa-locale-drawer input.casa-locale-search__input:focus {
    outline: none;
    border-color: var(--casa-glow-primary, #9333ea);
    background-color: rgba(255, 255, 255, 0.08);
    color: white;
  }

  /* Country List */
  .casa-locale-countries {
    flex: 1;
    overflow-y: auto;
    padding: 12px 20px;
    min-height: 200px;
    max-height: 340px;
  }
  .casa-locale-countries::-webkit-scrollbar {
    width: 6px;
  }
  .casa-locale-countries::-webkit-scrollbar-track {
    background: transparent;
  }
  .casa-locale-countries::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 3px;
  }

  /* Section Labels */
  .casa-locale-section {
    margin-bottom: 12px;
  }
  .casa-locale-section__label {
    display: block;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: rgba(255, 255, 255, 0.4);
    margin-bottom: 10px;
    padding-left: 4px;
  }

  /* Country Grid */
  .casa-locale-grid {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  /* Individual Country Button */
  .casa-locale-country {
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
    padding: 12px 14px;
    background: transparent;
    border: 1px solid transparent;
    border-radius: 10px;
    color: rgba(255, 255, 255, 0.8);
    font-size: 14px;
    text-align: left;
    cursor: pointer;
    transition: all 0.15s;
  }
  .casa-locale-country:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.08);
  }
  .casa-locale-country.is-selected {
    background: rgba(var(--casa-glow-primary-rgb, 147, 51, 234), 0.15);
    border-color: rgba(var(--casa-glow-primary-rgb, 147, 51, 234), 0.3);
    color: white;
  }
  .casa-locale-country__check {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: transparent;
    transition: all 0.15s;
  }
  .casa-locale-country.is-selected .casa-locale-country__check {
    background: var(--casa-glow-primary, #9333ea);
    border-color: var(--casa-glow-primary, #9333ea);
    color: white;
  }
  .casa-locale-country__name {
    flex: 1;
    font-weight: 500;
  }
  .casa-locale-country__currency {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.5);
    font-weight: 400;
  }
  .casa-locale-country.is-selected .casa-locale-country__currency {
    color: rgba(255, 255, 255, 0.7);
  }

  /* No Results */
  .casa-locale-no-results {
    text-align: center;
    color: rgba(255, 255, 255, 0.4);
    font-size: 14px;
    padding: 24px;
  }

  /* Language Selector */
  .casa-locale-language {
    padding: 16px 20px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-shrink: 0;
  }
  .casa-locale-language__label {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.6);
    font-weight: 500;
  }
  .casa-locale-language__select-wrapper {
    position: relative;
    flex: 1;
    max-width: 200px;
  }
  .casa-locale-language__select {
    width: 100%;
    padding: 10px 36px 10px 14px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    color: white;
    font-size: 13px;
    cursor: pointer;
    appearance: none;
    transition: all 0.2s;
  }
  .casa-locale-language__select:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.15);
  }
  .casa-locale-language__select:focus {
    outline: none;
    border-color: var(--casa-glow-primary, #9333ea);
  }
  .casa-locale-language__select option {
    background: #1a1a20;
    color: white;
  }
  .casa-locale-language__caret {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    color: rgba(255, 255, 255, 0.4);
    pointer-events: none;
  }

  /* Submit Button */
  .casa-locale-submit {
    margin: 16px 20px 20px;
    padding: 14px 24px;
    background: linear-gradient(135deg, var(--casa-glow-primary, #9333ea), var(--casa-glow-secondary, #ec4899));
    border: none;
    border-radius: 10px;
    color: white;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    flex-shrink: 0;
  }
  .casa-locale-submit:hover {
    opacity: 0.9;
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(var(--casa-glow-primary-rgb, 147, 51, 234), 0.4);
  }

  /* Noscript fallback selects */
  .casa-locale-drawer noscript select {
    margin-bottom: 12px;
  }

  /* ═══════════════════════════════════════════════════════
     RESPONSIVE: VERY SMALL MOBILE (375px and below)
     Optimized for iPhone SE and similar small devices
     ═══════════════════════════════════════════════════════ */
  @media (max-width: 375px) {
    .casa-header {
      padding: 0 12px;
      height: calc(var(--casa-header-height, 80px) * 0.7);
    }

    .casa-header__logo {
      font-size: 14px;
      letter-spacing: calc(var(--casa-logo-spacing, 4px) * 0.6);
    }
    .casa-header__logo-img {
      height: calc(var(--casa-logo-height, 36px) * 0.7);
    }

    .casa-header__actions {
      gap: 12px;
    }

    .casa-header__btn {
      padding: 2px;
    }

    .casa-header__btn svg {
      width: 20px;
      height: 20px;
    }

    .casa-menu-toggle svg {
      width: 20px;
      height: 20px;
    }
  }

  /* ═══════════════════════════════════════════════════════
     RESPONSIVE: EXTRA LARGE DESKTOP (1920px+)
     More breathing room for larger monitors
     ═══════════════════════════════════════════════════════ */
  @media (min-width: 1920px) {
    .casa-header {
      padding: 0 100px;
    }

    .casa-header__inner {
      max-width: 1800px;
    }

    .casa-header--widescreen .casa-header__inner {
      max-width: none;
    }

    .casa-header__left {
      gap: 80px;
    }

    .casa-header__nav {
      gap: 56px;
    }

    .casa-header__logo {
      font-size: 24px;
    }
    .casa-header__logo-img {
      height: calc(var(--casa-logo-height, 36px) * 1.15);
    }

    .casa-header__nav-link {
      font-size: calc(var(--casa-nav-size, 14px) + 1px);
    }
  }

  /* ═══════════════════════════════════════════════════════
     RESPONSIVE: ULTRAWIDE (2560px+ / QHD & 4K)
     ═══════════════════════════════════════════════════════ */
  @media (min-width: 2560px) {
    .casa-header {
      padding: 0 140px;
      height: calc(var(--casa-header-height, 80px) * 1.1);
    }

    .casa-header__inner {
      max-width: 2200px;
    }

    .casa-header--widescreen .casa-header__inner {
      max-width: none;
    }

    .casa-header__left {
      gap: 100px;
    }

    .casa-header__nav {
      gap: 64px;
    }

    .casa-header__logo {
      font-size: 28px;
      letter-spacing: calc(var(--casa-logo-spacing, 4px) * 1.2);
    }
    .casa-header__logo-img {
      height: calc(var(--casa-logo-height, 36px) * 1.3);
    }

    .casa-header__nav-link {
      font-size: calc(var(--casa-nav-size, 14px) + 2px);
    }

    .casa-header__btn svg {
      width: 26px;
      height: 26px;
    }

    .casa-header__actions {
      gap: 28px;
    }
  }

  /* ═══════════════════════════════════════════════════════
     RESPONSIVE: SUPER ULTRAWIDE (3440px+ / 34" Ultrawide)
     ═══════════════════════════════════════════════════════ */
  @media (min-width: 3440px) {
    .casa-header {
      padding: 0 200px;
      height: calc(var(--casa-header-height, 80px) * 1.2);
    }

    .casa-header__inner {
      max-width: 2800px;
    }

    .casa-header__left {
      gap: 120px;
    }

    .casa-header__nav {
      gap: 72px;
    }

    .casa-header__logo {
      font-size: 32px;
    }
    .casa-header__logo-img {
      height: calc(var(--casa-logo-height, 36px) * 1.5);
    }

    .casa-header__nav-link {
      font-size: calc(var(--casa-nav-size, 14px) + 3px);
    }

    .casa-header__btn svg {
      width: 30px;
      height: 30px;
    }

    .casa-header__actions {
      gap: 36px;
    }
  }
{% endstylesheet %}

