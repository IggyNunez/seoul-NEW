{%- comment -%}
  Seoul Glow Lab - Main Header Section
  Sticky dark glassmorphism header with desktop mega menu and mobile drawer.
{%- endcomment -%}

{%- comment -%} ── Pre-render quick link blocks BEFORE header (render isolates scope) ── {%- endcomment -%}
{%- capture glow_quick_links_html -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'quick_link' and block.settings.variant == 'glow' -%}
      <a href="{{ block.settings.url }}" class="casa-mega-quick-link" {{ block.shopify_attributes }}>
        {%- render 'casa-icon', icon: block.settings.icon, size: 16 -%} {{ block.settings.text }}
      </a>
    {%- endif -%}
  {%- endfor -%}
{%- endcapture -%}

{%- capture lifestyle_quick_links_html -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'quick_link' and block.settings.variant == 'lifestyle' -%}
      <a href="{{ block.settings.url }}" class="casa-mega-quick-link" {{ block.shopify_attributes }}>
        {%- render 'casa-icon', icon: block.settings.icon, size: 16 -%} {{ block.settings.text }}
      </a>
    {%- endif -%}
  {%- endfor -%}
{%- endcapture -%}

{%- capture support_quick_links_html -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'quick_link' and block.settings.variant == 'support' -%}
      <a href="{{ block.settings.url }}" class="casa-mega-quick-link" {{ block.shopify_attributes }}>
        {%- render 'casa-icon', icon: block.settings.icon, size: 16 -%} {{ block.settings.text }}
      </a>
    {%- endif -%}
  {%- endfor -%}
{%- endcapture -%}

{%- capture mobile_quick_links_html -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'quick_link' and block.settings.variant == 'mobile' -%}
      <a href="{{ block.settings.url }}" class="casa-drawer__secondary-link" {{ block.shopify_attributes }}>
        {%- render 'casa-icon', icon: block.settings.icon, size: 14 -%} {{ block.settings.text }}
      </a>
    {%- endif -%}
  {%- endfor -%}
{%- endcapture -%}

<header class="casa-header{% if section.settings.enable_sticky %} casa-header--sticky{% endif %}{% if section.settings.header_border_style == 'static' %} casa-header--border-static{% elsif section.settings.header_border_style == 'animated' %} casa-header--border-animated{% endif %}{% if section.settings.header_layout == 'widescreen' %} casa-header--widescreen{% endif %}{% if section.settings.nav_uppercase %} casa-header--nav-uppercase{% endif %}" {{ section.shopify_attributes }}>
  <div class="casa-header__inner">

    {%- comment -%} ── Left: Logo + Desktop Nav ── {%- endcomment -%}
    <div class="casa-header__left">
      <a href="{{ routes.root_url }}" class="casa-header__logo" aria-label="{{ shop.name }}">
        {%- if section.settings.logo_image != blank -%}
          {{ section.settings.logo_image | image_url: width: 200 | image_tag: class: 'casa-header__logo-img', alt: section.settings.logo_text | default: shop.name }}
        {%- else -%}
          {{ section.settings.logo_text | default: 'SEOUL GLOW LAB' }}
        {%- endif -%}
      </a>

      <nav class="casa-header__nav casa-desktop-only" aria-label="Main navigation">
        {%- for link in linklists[section.settings.menu].links -%}
          {%- if link.links.size > 0 -%}
            {%- comment -%} Nav item with mega menu {%- endcomment -%}
            {%- liquid
              assign _link_handle = link.title | downcase | handle
              assign custom_accent_primary = nil
              assign custom_accent_secondary = nil
              assign custom_accent_tertiary = nil
              assign custom_menu_theme = nil
              assign custom_collection = nil
              assign custom_product_limit = nil
              for block in section.blocks
                if block.type == 'menu_color' and block.settings.menu_handle == _link_handle
                  assign custom_accent_primary = block.settings.accent_primary
                  assign custom_accent_secondary = block.settings.accent_secondary
                  assign custom_accent_tertiary = block.settings.accent_tertiary
                endif
                if block.type == 'menu_theme' and block.settings.menu_handle == _link_handle
                  assign custom_menu_theme = block.settings.theme
                endif
                if block.type == 'menu_collection'
                  assign _block_handle = block.settings.menu_handle | downcase | handle
                  if _block_handle == _link_handle or _block_handle == link.handle
                    assign custom_collection = block.settings.collection
                    assign custom_product_limit = block.settings.product_limit
                    assign custom_products_title = block.settings.products_title
                  endif
                endif
              endfor
            -%}
            <div class="casa-nav-item">
              <a href="{{ link.url }}" class="casa-header__nav-link">
                {{ link.title }}
                {%- render 'casa-icon', icon: 'chevron-down', size: 14 -%}
              </a>
              {%- render 'casa-mega-menu',
                link: link,
                collection_glow: section.settings.collection_glow,
                collection_lifestyle: section.settings.collection_lifestyle,
                video_url: section.settings.video_url,
                promo_title: section.settings.promo_title,
                promo_subtitle: section.settings.promo_subtitle,
                promo_link: section.settings.promo_link,
                promo_image: section.settings.promo_image,
                promo_btn_primary: section.settings.promo_btn_primary,
                promo_btn_secondary: section.settings.promo_btn_secondary,
                promo_btn_secondary_link: section.settings.promo_btn_secondary_link,
                featured_label_glow: section.settings.featured_label_glow,
                featured_label_lifestyle: section.settings.featured_label_lifestyle,
                featured_label_support: section.settings.featured_label_support,
                lifestyle_title: section.settings.lifestyle_title,
                lifestyle_subtitle: section.settings.lifestyle_subtitle,
                lifestyle_link: section.settings.lifestyle_link,
                lifestyle_image: section.settings.lifestyle_image,
                lifestyle_video_url: section.settings.lifestyle_video_url,
                lifestyle_btn_primary: section.settings.lifestyle_btn_primary,
                lifestyle_btn_secondary: section.settings.lifestyle_btn_secondary,
                lifestyle_btn_secondary_link: section.settings.lifestyle_btn_secondary_link,
                support_email: section.settings.support_email,
                support_phone: section.settings.support_phone,
                support_title: section.settings.support_title,
                support_description: section.settings.support_description,
                support_chat_label: section.settings.support_chat_label,
                support_chat_link: section.settings.support_chat_link,
                support_btn_text: section.settings.support_btn_text,
                support_btn_link: section.settings.support_btn_link,
                support_fallback_description: section.settings.support_fallback_description,
                categories_title_glow: section.settings.categories_title_glow,
                categories_title_lifestyle: section.settings.categories_title_lifestyle,
                categories_title_support: section.settings.categories_title_support,
                products_title_glow: section.settings.products_title_glow,
                products_title_lifestyle: section.settings.products_title_lifestyle,
                quick_help_title: section.settings.quick_help_title,
                product_limit_glow: section.settings.product_limit_glow,
                product_limit_lifestyle: section.settings.product_limit_lifestyle,
                products_per_row: section.settings.products_per_row,
                glow_quick_links_html: glow_quick_links_html,
                lifestyle_quick_links_html: lifestyle_quick_links_html,
                support_quick_links_html: support_quick_links_html,
                custom_accent_primary: custom_accent_primary,
                custom_accent_secondary: custom_accent_secondary,
                custom_accent_tertiary: custom_accent_tertiary,
                custom_menu_theme: custom_menu_theme,
                custom_collection: custom_collection,
                custom_product_limit: custom_product_limit,
                custom_products_title: custom_products_title,
                show_category_icons: section.settings.show_category_icons
              -%}
            </div>
          {%- else -%}
            <a href="{{ link.url }}" class="casa-header__nav-link">{{ link.title }}</a>
          {%- endif -%}
        {%- endfor -%}
      </nav>
    </div>

    {%- comment -%} ── Right: Actions ── {%- endcomment -%}
    <div class="casa-header__actions">
      {%- comment -%} Country/Currency Selector (desktop) {%- endcomment -%}
      {%- if localization.available_countries.size > 1 or localization.available_languages.size > 1 -%}
        <button class="casa-header__btn casa-header__locale-btn casa-desktop-only" aria-label="Country and language">
          {%- render 'casa-icon', icon: 'globe', size: 18 -%}
          <span class="casa-header__locale-text">{{ localization.country.currency.iso_code }}</span>
        </button>
      {%- endif -%}

      {%- comment -%} Search (desktop) — triggers Horizon's search modal {%- endcomment -%}
      <button class="casa-header__btn casa-header__search-btn casa-desktop-only" aria-label="Search" onclick="document.querySelector('#search-modal')?.showDialog?.()">
        {%- render 'casa-icon', icon: 'search', size: 22 -%}
      </button>

      {%- comment -%} Search (mobile) {%- endcomment -%}
      <button class="casa-header__btn casa-header__search-btn casa-mobile-only" aria-label="Search" onclick="document.querySelector('#search-modal')?.showDialog?.()">
        {%- render 'casa-icon', icon: 'search', size: 22 -%}
      </button>

      {%- comment -%} Account (desktop) — links to account page or login {%- endcomment -%}
      {%- if shop.customer_accounts_enabled -%}
        <a href="{{ routes.account_url }}" class="casa-header__btn casa-header__account-btn casa-desktop-only" aria-label="{{ 'accessibility.account' | t }}">
          {%- if customer -%}
            {%- comment -%} Logged in: show initial or avatar {%- endcomment -%}
            <span class="casa-header__account-avatar">
              {%- assign _initial = customer.email | slice: 0 -%}
              {%- if customer.first_name != blank -%}
                {%- assign _initial = customer.first_name | slice: 0 -%}
              {%- endif -%}
              {{ _initial | upcase }}
            </span>
          {%- else -%}
            {%- comment -%} Guest: show user icon {%- endcomment -%}
            {%- render 'casa-icon', icon: 'user', size: 22 -%}
          {%- endif -%}
        </a>
      {%- endif -%}

      {%- comment -%} Cart — integrates with Horizon's cart drawer setting {%- endcomment -%}
      {%- if settings.cart_type == 'drawer' and template.name != 'cart' -%}
        <button class="casa-header__btn casa-header__cart-btn" aria-label="{{ 'accessibility.cart' | t }}" onclick="document.querySelector('cart-drawer-component')?.open?.()">
          {%- render 'casa-icon', icon: 'cart', size: 22 -%}
          {%- render 'cart-bubble', limit: 100 -%}
        </button>
      {%- else -%}
        <a href="{{ routes.cart_url }}" class="casa-header__btn casa-header__cart-btn" aria-label="{{ 'accessibility.cart' | t }}">
          {%- render 'casa-icon', icon: 'cart', size: 22 -%}
          {%- render 'cart-bubble', limit: 100 -%}
        </a>
      {%- endif -%}

      {%- comment -%} Mobile menu toggle {%- endcomment -%}
      <button class="casa-header__btn casa-menu-toggle casa-mobile-only" data-casa-drawer-toggle aria-label="Open menu" aria-expanded="false">
        {%- render 'casa-icon', icon: 'menu', size: 22 -%}
      </button>
    </div>

  </div>
</header>

{%- comment -%} ── Mobile Drawer (rendered outside header for z-index stacking) ── {%- endcomment -%}
{%- render 'casa-mobile-drawer',
  menu: section.settings.menu,
  logo_text: section.settings.logo_text,
  logo_image: section.settings.logo_image,
  drawer_logo_image: section.settings.drawer_logo_image,
  drawer_logo_height: section.settings.drawer_logo_height,
  promo_title: section.settings.promo_title,
  promo_subtitle: section.settings.promo_subtitle,
  promo_link: section.settings.promo_link,
  promo_image: section.settings.promo_image,
  video_url: section.settings.video_url,
  mobile_promo_btn_text: section.settings.mobile_promo_btn_text,
  mobile_quick_links_title: section.settings.mobile_quick_links_title,
  submenu_product_limit: section.settings.submenu_product_limit,
  mobile_quick_links_html: mobile_quick_links_html,
  drawer_glassmorphic: section.settings.drawer_glassmorphic
-%}

{%- comment -%} ── Cart Drawer (Horizon's cart-drawer-component for settings.cart_type == 'drawer') ── {%- endcomment -%}
{%- if settings.cart_type == 'drawer' and template.name != 'cart' -%}
  <script src="{{ 'cart-drawer.js' | asset_url }}" type="module" fetchpriority="low"></script>

  {% capture empty_cart_drawer_content %}
    <div class="cart-drawer__header">
      <button
        ref="closeButton"
        on:click="cart-drawer-component/close"
        class="button close-button cart-drawer__close-button button-unstyled"
        aria-label="{{ 'actions.close_dialog' | t }}"
      >
        <span class="svg-wrapper">
          {{- 'icon-close.svg' | inline_asset_content -}}
        </span>
      </button>
    </div>

    <div class="cart-drawer__content" aria-label="{{ 'accessibility.cart' | t }}">
      <h2 class="cart-drawer__heading h4 cart-drawer__heading--empty" id="cart-drawer-heading-empty">
        {{ 'content.your_cart_is_empty' | t }}
      </h2>

      <div class="cart-drawer__items">
        {% render 'cart-products', force_empty: true %}
      </div>
    </div>
  {% endcapture %}

  <cart-drawer-component
    class="cart-drawer"
    {% if settings.auto_open_cart_drawer %}auto-open{% endif %}
  >
    <template id="empty-cart-template">
      {{ empty_cart_drawer_content }}
    </template>

    <dialog
      ref="dialog"
      class="cart-drawer__dialog dialog-modal dialog-drawer color-{{ settings.drawer_color_scheme }}{% if cart.empty? %} cart-drawer--empty{% endif %}"
      aria-labelledby="{% if cart.empty? %}cart-drawer-heading-empty{% else %}cart-drawer-heading{% endif %}"
      scroll-lock
      cart-summary-sticky="true"
    >
      <div class="cart-drawer__inner" data-hydration-key="cart-drawer-inner">
        {%- comment -%} ═══ Prepare upsell data ═══ {%- endcomment -%}
        {%- assign show_upsells = false -%}
        {%- assign upsell_position = settings.cart_upsell_position | default: 'inside' -%}
        {%- if settings.cart_show_upsell and settings.cart_upsell_collection != blank -%}
          {%- assign upsell_collection = collections[settings.cart_upsell_collection] -%}
          {%- assign upsell_limit = settings.cart_upsell_limit | default: 3 -%}
          {%- if upsell_collection and upsell_collection.products.size > 0 -%}
            {%- assign show_upsells = true -%}
          {%- endif -%}
        {%- endif -%}

        {%- comment -%} ═══ Upsell markup capture (reused in either position) ═══ {%- endcomment -%}
        {%- if show_upsells -%}
          {%- capture upsell_html -%}
            <div class="cart-upsell cart-upsell--carousel">
              <div class="cart-upsell__header">
                <p class="cart-upsell__title">{{ settings.cart_upsell_title | default: 'You may also like' }}</p>
                <div class="cart-upsell__nav">
                  <button type="button" class="cart-upsell__arrow cart-upsell__arrow--prev" aria-label="Previous" disabled>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
                  </button>
                  <button type="button" class="cart-upsell__arrow cart-upsell__arrow--next" aria-label="Next">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
                  </button>
                </div>
              </div>
              <div class="cart-upsell__track">
                {%- assign cart_product_ids = cart.items | map: 'product_id' -%}
                {%- assign shown = 0 -%}
                {%- for product in upsell_collection.products -%}
                  {%- if cart_product_ids contains product.id -%}{%- continue -%}{%- endif -%}
                  {%- if shown >= upsell_limit -%}{%- break -%}{%- endif -%}
                  <div class="cart-upsell__item">
                    <a href="{{ product.url }}" class="cart-upsell__image">
                      {%- if product.featured_image != blank -%}
                        <img src="{{ product.featured_image | image_url: width: 120 }}" alt="{{ product.title | escape }}" loading="lazy" width="60" height="60">
                      {%- endif -%}
                    </a>
                    <div class="cart-upsell__info">
                      <a href="{{ product.url }}" class="cart-upsell__name">{{ product.title | truncate: 28 }}</a>
                      <span class="cart-upsell__price">{{ product.price | money }}</span>
                    </div>
                    <button
                      type="button"
                      class="cart-upsell__add"
                      aria-label="Add {{ product.title | escape }} to cart"
                      data-upsell-add
                      data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                      data-product-url="{{ product.url }}"
                      data-has-variants="{{ product.has_only_default_variant | json }}"
                    >
                      Add
                    </button>
                  </div>
                  {%- assign shown = shown | plus: 1 -%}
                {%- endfor -%}
              </div>
            </div>
          {%- endcapture -%}
        {%- endif -%}

        <cart-items-component class="cart-items-component" data-drawer data-section-id="{{ section.id }}">
          {%- if cart.empty? -%}
            {{ empty_cart_drawer_content }}
          {%- else -%}
            {%- liquid
              assign free_shipping_threshold = settings.free_shipping_threshold | default: 100
              assign cart_total_cents = cart.total_price
              assign threshold_cents = free_shipping_threshold | times: 100
              assign remaining_cents = threshold_cents | minus: cart_total_cents
              assign progress_percent = cart_total_cents | times: 100 | divided_by: threshold_cents
              if progress_percent > 100
                assign progress_percent = 100
              endif
              assign remaining_amount = remaining_cents | money_without_trailing_zeros
            -%}
            <div class="cart-drawer__header" id="cart-drawer-header">
              <div class="cart-drawer__header-left">
                <h2 class="cart-drawer__heading h4" id="cart-drawer-heading">
                  {{ 'content.cart_title' | t }}
                  <span class="cart-drawer__count">({{ cart.item_count }})</span>
                </h2>
                {%- if free_shipping_threshold > 0 -%}
                  <div class="cart-drawer__shipping-inline">
                    {%- if remaining_cents > 0 -%}
                      <span class="cart-drawer__shipping-text">
                        <strong>{{ remaining_amount }}</strong> to free shipping
                      </span>
                    {%- else -%}
                      <span class="cart-drawer__shipping-text cart-drawer__shipping-text--success">
                        ✓ Free shipping
                      </span>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              </div>
              <button
                ref="closeButton"
                on:click="cart-drawer-component/close"
                class="button close-button cart-drawer__close-button button-unstyled"
                aria-label="{{ 'actions.close_dialog' | t }}"
              >
                <span class="svg-wrapper">
                  {{- 'icon-close.svg' | inline_asset_content -}}
                </span>
              </button>
            </div>
            {%- if free_shipping_threshold > 0 -%}
              <div class="cart-drawer__shipping-bar">
                <div class="cart-drawer__shipping-track">
                  <div class="cart-drawer__shipping-progress" style="--progress: {{ progress_percent }}%;"></div>
                </div>
              </div>
            {%- endif -%}

            <scroll-hint class="cart-drawer__content" aria-label="{{ 'accessibility.cart' | t }}" style="--header-height: 60px;">
              <div class="cart-drawer__items">
                {% render 'cart-products', drawer_context: 'drawer' %}

                {%- comment -%} ═══ Upsells - Inside items (when position = inside) ═══ {%- endcomment -%}
                {%- if show_upsells and upsell_position == 'inside' -%}
                  {{ upsell_html }}
                {%- endif -%}
              </div>

              {%- comment -%} ═══ Upsells - Below items (when position = below) ═══ {%- endcomment -%}
              {%- if show_upsells and upsell_position == 'below' -%}
                {{ upsell_html }}
              {%- endif -%}

              {%- comment -%} ═══ Minimal Trust Line ═══ {%- endcomment -%}
              {%- if settings.cart_show_trust_badges -%}
                <p class="cart-cro__trust">
                  {%- if settings.cart_trust_badge_1 != blank -%}{{ settings.cart_trust_badge_1 }}{%- endif -%}
                  {%- if settings.cart_trust_badge_2 != blank -%} · {{ settings.cart_trust_badge_2 }}{%- endif -%}
                  {%- if settings.cart_trust_badge_3 != blank -%} · {{ settings.cart_trust_badge_3 }}{%- endif -%}
                </p>
              {%- endif -%}

              <div class="cart-drawer__summary">
                {% render 'cart-summary', section_id: section.id %}
              </div>
            </scroll-hint>
          {%- endif -%}
        </cart-items-component>
      </div>
    </dialog>
  </cart-drawer-component>
{%- endif -%}

{%- comment -%} ── Localization Drawer (Country/Language selector) ── {%- endcomment -%}
{%- if localization.available_countries.size > 1 or localization.available_languages.size > 1 -%}
  {%- liquid
    assign popular_countries = localization.available_countries | where: 'popular?' | sort: 'name'
    assign show_popular = false
    if popular_countries.size > 1 and localization.available_countries.size > 10
      assign show_popular = true
    endif
  -%}
  <dialog id="casa-localization-drawer" class="casa-locale-drawer">
    <div class="casa-locale-drawer__inner">
      <div class="casa-locale-drawer__header">
        <h2 class="casa-locale-drawer__title">
          {%- render 'casa-icon', icon: 'globe', size: 20 -%}
          Select Your Region
        </h2>
        <button class="casa-locale-drawer__close" type="button" onclick="document.getElementById('casa-localization-drawer').close()" aria-label="Close">
          {%- render 'casa-icon', icon: 'close', size: 20 -%}
        </button>
      </div>

      <div class="casa-locale-drawer__content">
        {%- form 'localization', id: 'CasaLocalizationForm', class: 'casa-locale-form', return_to: request.path -%}
          {%- comment -%} Search input for many countries {%- endcomment -%}
          {%- if localization.available_countries.size > 10 -%}
            <div class="casa-locale-search">
              <span class="casa-locale-search__icon">{%- render 'casa-icon', icon: 'search', size: 16 -%}</span>
              <input
                type="text"
                class="casa-locale-search__input"
                placeholder="Search countries..."
                id="casa-country-search"
                autocomplete="off"
              >
            </div>
          {%- endif -%}

          {%- comment -%} Country List {%- endcomment -%}
          <div class="casa-locale-countries" id="casa-country-list">
            {%- if show_popular -%}
              <div class="casa-locale-section">
                <span class="casa-locale-section__label">Popular</span>
                <div class="casa-locale-grid">
                  {%- for country in popular_countries -%}
                    <button
                      type="button"
                      class="casa-locale-country{% if country.iso_code == localization.country.iso_code %} is-selected{% endif %}"
                      data-country-code="{{ country.iso_code }}"
                      data-country-name="{{ country.name | downcase }}"
                    >
                      <span class="casa-locale-country__check">
                        {%- render 'casa-icon', icon: 'check', size: 14 -%}
                      </span>
                      <span class="casa-locale-country__name">{{ country.name }}</span>
                      <span class="casa-locale-country__currency">{{ country.currency.iso_code }} {{ country.currency.symbol }}</span>
                    </button>
                  {%- endfor -%}
                </div>
              </div>
              <div class="casa-locale-section">
                <span class="casa-locale-section__label">All Countries</span>
              </div>
            {%- endif -%}

            <div class="casa-locale-grid" id="casa-all-countries">
              {%- for country in localization.available_countries -%}
                <button
                  type="button"
                  class="casa-locale-country{% if country.iso_code == localization.country.iso_code %} is-selected{% endif %}"
                  data-country-code="{{ country.iso_code }}"
                  data-country-name="{{ country.name | downcase }}"
                >
                  <span class="casa-locale-country__check">
                    {%- render 'casa-icon', icon: 'check', size: 14 -%}
                  </span>
                  <span class="casa-locale-country__name">{{ country.name }}</span>
                  <span class="casa-locale-country__currency">{{ country.currency.iso_code }} {{ country.currency.symbol }}</span>
                </button>
              {%- endfor -%}
            </div>

            <p class="casa-locale-no-results" id="casa-no-results" hidden>No countries found</p>
          </div>

          <input type="hidden" name="country_code" id="casa-country-input" value="{{ localization.country.iso_code }}">

          {%- comment -%} Language Selector {%- endcomment -%}
          {%- if localization.available_languages.size > 1 -%}
            <div class="casa-locale-language">
              <label class="casa-locale-language__label" for="casa-language-select">Language</label>
              <div class="casa-locale-language__select-wrapper">
                <select name="language_code" id="casa-language-select" class="casa-locale-language__select">
                  {%- for language in localization.available_languages -%}
                    <option value="{{ language.iso_code }}"{% if language.iso_code == localization.language.iso_code %} selected{% endif %}>
                      {{ language.endonym_name | capitalize }}
                    </option>
                  {%- endfor -%}
                </select>
                <span class="casa-locale-language__caret">{%- render 'casa-icon', icon: 'chevron-down', size: 16 -%}</span>
              </div>
            </div>
          {%- endif -%}

          {%- comment -%} Submit Button {%- endcomment -%}
          <button type="submit" class="casa-locale-submit">
            Update Region
          </button>
        {%- endform -%}
      </div>
    </div>
  </dialog>
  <script>
    (function() {
      const dialog = document.getElementById('casa-localization-drawer');
      const form = document.getElementById('CasaLocalizationForm');
      const countryInput = document.getElementById('casa-country-input');
      const searchInput = document.getElementById('casa-country-search');
      const allCountries = document.getElementById('casa-all-countries');
      const noResults = document.getElementById('casa-no-results');
      const submitBtn = dialog?.querySelector('.casa-locale-submit');

      // Wire up the locale buttons to open the drawer
      document.querySelectorAll('[aria-label="Country and language"]').forEach(btn => {
        btn.addEventListener('click', function(e) {
          e.preventDefault();
          const mobileDrawer = document.querySelector('.casa-drawer');
          const overlay = document.querySelector('.casa-drawer-overlay');
          if (mobileDrawer && mobileDrawer.classList.contains('active')) {
            mobileDrawer.classList.remove('active');
            overlay?.classList.remove('active');
            document.body.style.overflow = '';
            setTimeout(() => dialog?.showModal(), 350);
          } else {
            dialog?.showModal();
          }
        });
      });

      // Close on backdrop click
      dialog?.addEventListener('click', function(e) {
        if (e.target === this) this.close();
      });

      // Country selection - auto-submit on click
      dialog?.querySelectorAll('.casa-locale-country').forEach(btn => {
        btn.addEventListener('click', function() {
          const code = this.dataset.countryCode;
          // Update hidden input
          if (countryInput) countryInput.value = code;
          // Update visual selection
          dialog.querySelectorAll('.casa-locale-country').forEach(b => b.classList.remove('is-selected'));
          this.classList.add('is-selected');
          // Show loading state
          if (submitBtn) {
            submitBtn.textContent = 'Updating...';
            submitBtn.disabled = true;
          }
          // Submit the form after brief delay for visual feedback
          setTimeout(() => {
            if (form) form.submit();
          }, 300);
        });
      });

      // Search filtering
      if (searchInput && allCountries) {
        searchInput.addEventListener('input', function() {
          const query = this.value.toLowerCase().trim();
          const buttons = allCountries.querySelectorAll('.casa-locale-country');
          let visibleCount = 0;

          buttons.forEach(btn => {
            const name = btn.dataset.countryName || '';
            const matches = !query || name.includes(query);
            btn.style.display = matches ? '' : 'none';
            if (matches) visibleCount++;
          });

          if (noResults) {
            noResults.hidden = visibleCount > 0;
          }
        });
      }
    })();
  </script>
{%- endif -%}

