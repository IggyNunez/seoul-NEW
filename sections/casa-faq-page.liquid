{%- comment -%}
  Seoul Glow Lab - FAQ Page Section
  Full-page FAQ with category tabs, accordion, and contact CTA
  Dark glassmorphic aesthetic with gradient accents
{%- endcomment -%}

{%- liquid
  assign badge_text    = section.settings.badge_text | default: 'Support'
  assign title         = section.settings.title | default: 'Frequently Asked Questions'
  assign subtitle      = section.settings.subtitle | default: 'Everything you need to know about our products, orders, and shipping.'

  assign accent_1      = section.settings.accent_primary | default: '#9333ea'
  assign accent_2      = section.settings.accent_secondary | default: '#ec4899'
  assign bg_color      = section.settings.bg_color | default: '#09090b'
  assign text_color    = section.settings.text_color | default: '#fafafa'
  assign muted_color   = section.settings.muted_color | default: '#a1a1aa'
  assign card_bg       = section.settings.card_bg | default: 'rgba(255,255,255,0.04)'
  assign card_border   = section.settings.card_border | default: 'rgba(255,255,255,0.08)'

  assign show_contact  = section.settings.show_contact
  assign contact_title = section.settings.contact_title | default: 'Still have questions?'
  assign contact_text  = section.settings.contact_text | default: 'Our support team is here to help. Reach out and we will get back to you within 24 hours.'
  assign contact_btn   = section.settings.contact_btn_text | default: 'Contact Us'
  assign contact_url   = section.settings.contact_url | default: '/pages/contact'

  assign padding_top          = section.settings.padding_top | default: 100
  assign padding_bottom       = section.settings.padding_bottom | default: 100
  assign padding_mobile_top   = section.settings.padding_mobile_top | default: 60
  assign padding_mobile_bottom = section.settings.padding_mobile_bottom | default: 60

  # Collect categories and questions from blocks
  assign categories = ''
  assign cat_count  = 0
  for block in section.blocks
    if block.type == 'category'
      if cat_count > 0
        assign categories = categories | append: '|||'
      endif
      assign categories = categories | append: block.id | append: '::' | append: block.settings.title | append: '::' | append: block.settings.icon
      assign cat_count = cat_count | plus: 1
    endif
  endfor
  assign category_list = categories | split: '|||'
-%}

<section
  class="casa-faqp"
  id="casa-faqp-{{ section.id }}"
  style="
    --faqp-bg: {{ bg_color }};
    --faqp-text: {{ text_color }};
    --faqp-muted: {{ muted_color }};
    --faqp-accent: {{ accent_1 }};
    --faqp-accent-2: {{ accent_2 }};
    --faqp-card-bg: {{ card_bg }};
    --faqp-card-border: {{ card_border }};
    --faqp-pt: {{ padding_top }}px;
    --faqp-pb: {{ padding_bottom }}px;
    --faqp-pt-m: {{ padding_mobile_top }}px;
    --faqp-pb-m: {{ padding_mobile_bottom }}px;
  "
>
  <div class="casa-faqp__wrap">

    {%- comment -%} ---- Hero ---- {%- endcomment -%}
    <div class="casa-faqp__hero">
      {%- if badge_text != blank -%}
        <span class="casa-faqp__badge">{{ badge_text }}</span>
      {%- endif -%}
      {%- if title != blank -%}
        <h1 class="casa-faqp__title">{{ title }}</h1>
      {%- endif -%}
      {%- if subtitle != blank -%}
        <p class="casa-faqp__subtitle">{{ subtitle }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} ---- Category Tabs ---- {%- endcomment -%}
    {%- if cat_count > 1 -%}
      <div class="casa-faqp__tabs" role="tablist">
        <button class="casa-faqp__tab casa-faqp__tab--active" data-faqp-tab="all" role="tab" aria-selected="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          All
        </button>
        {%- for cat_str in category_list -%}
          {%- assign cat_parts = cat_str | split: '::' -%}
          {%- assign cat_id    = cat_parts[0] -%}
          {%- assign cat_title = cat_parts[1] -%}
          {%- assign cat_icon  = cat_parts[2] -%}
          <button class="casa-faqp__tab" data-faqp-tab="{{ cat_id }}" role="tab" aria-selected="false">
            {%- case cat_icon -%}
              {%- when 'package' -%}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="16.5" y1="9.4" x2="7.5" y2="4.21"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
              {%- when 'truck' -%}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              {%- when 'zap' -%}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
              {%- when 'search' -%}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
              {%- when 'help-circle' -%}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              {%- else -%}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            {%- endcase -%}
            {{ cat_title }}
          </button>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} ---- FAQ Groups ---- {%- endcomment -%}
    <div class="casa-faqp__groups">
      {%- assign current_cat_id = '' -%}
      {%- assign group_open = false -%}

      {%- for block in section.blocks -%}
        {%- if block.type == 'category' -%}
          {%- if group_open -%}
              </div>{%- comment -%} close items {%- endcomment -%}
            </div>{%- comment -%} close group {%- endcomment -%}
          {%- endif -%}

          {%- assign current_cat_id = block.id -%}
          <div class="casa-faqp__group" data-faqp-group="{{ block.id }}" {{ block.shopify_attributes }}>
            <h2 class="casa-faqp__group-title">{{ block.settings.title }}</h2>
            <div class="casa-faqp__items">
          {%- assign group_open = true -%}

        {%- elsif block.type == 'question' -%}
          <details class="casa-faqp__item" {{ block.shopify_attributes }}>
            <summary class="casa-faqp__question">
              <span class="casa-faqp__question-text">{{ block.settings.question }}</span>
              <span class="casa-faqp__chevron">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </span>
            </summary>
            <div class="casa-faqp__answer">
              <div class="casa-faqp__answer-inner">{{ block.settings.answer }}</div>
            </div>
          </details>

        {%- elsif block.type == 'text_block' -%}
          {%- if group_open -%}
              </div>
            </div>
            {%- assign group_open = false -%}
          {%- endif -%}
          <div
            class="casa-faqp__text-block"
            style="text-align: {{ block.settings.alignment | default: 'center' }}; font-size: {{ block.settings.font_size | default: 16 }}px; padding: {{ block.settings.padding_top | default: 24 }}px 0 {{ block.settings.padding_bottom | default: 24 }}px;"
            {{ block.shopify_attributes }}
          >
            {{ block.settings.content }}
          </div>
        {%- endif -%}
      {%- endfor -%}

      {%- if group_open -%}
          </div>{%- comment -%} close items {%- endcomment -%}
        </div>{%- comment -%} close group {%- endcomment -%}
      {%- endif -%}
    </div>

    {%- comment -%} ---- Contact CTA ---- {%- endcomment -%}
    {%- if show_contact -%}
      <div class="casa-faqp__cta">
        <div class="casa-faqp__cta-inner">
          <div class="casa-faqp__cta-glow"></div>
          {%- if contact_title != blank -%}
            <h3 class="casa-faqp__cta-title">{{ contact_title }}</h3>
          {%- endif -%}
          {%- if contact_text != blank -%}
            <p class="casa-faqp__cta-text">{{ contact_text }}</p>
          {%- endif -%}
          <a href="{{ contact_url }}" class="casa-faqp__cta-btn">
            {{ contact_btn }}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>
    {%- endif -%}

  </div>

  {%- comment -%} App blocks {%- endcomment -%}
  {%- for block in section.blocks -%}
    {%- if block.type == '@app' -%}
      <div class="casa-app-block" {{ block.shopify_attributes }}>
        {% render block %}
      </div>
    {%- endif -%}
  {%- endfor -%}
</section>

{%- comment -%} ---- JavaScript ---- {%- endcomment -%}
<script>
(function() {
  const section = document.getElementById('casa-faqp-{{ section.id }}');
  if (!section) return;

  /* --- Tab filtering --- */
  const tabs   = section.querySelectorAll('.casa-faqp__tab');
  const groups = section.querySelectorAll('.casa-faqp__group');

  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      const target = this.getAttribute('data-faqp-tab');

      tabs.forEach(function(t) {
        t.classList.remove('casa-faqp__tab--active');
        t.setAttribute('aria-selected', 'false');
      });
      this.classList.add('casa-faqp__tab--active');
      this.setAttribute('aria-selected', 'true');

      groups.forEach(function(g) {
        if (target === 'all' || g.getAttribute('data-faqp-group') === target) {
          g.style.display = '';
        } else {
          g.style.display = 'none';
        }
      });
    });
  });

  /* --- Accordion (close siblings on open) --- */
  const details = section.querySelectorAll('.casa-faqp__item');
  details.forEach(function(d) {
    d.addEventListener('toggle', function() {
      if (this.open) {
        var parent = this.closest('.casa-faqp__items');
        if (parent) {
          parent.querySelectorAll('.casa-faqp__item').forEach(function(sib) {
            if (sib !== d && sib.open) sib.removeAttribute('open');
          });
        }
      }
    });
  });
})();
</script>

{%- comment -%} ---- Styles ---- {%- endcomment -%}
<style>
/* === Casa FAQ Page === */
.casa-faqp {
  background: var(--faqp-bg);
  color: var(--faqp-text);
  padding: var(--faqp-pt) 0 var(--faqp-pb);
  position: relative;
  overflow: hidden;
}
@media (max-width: 749px) {
  .casa-faqp {
    padding: var(--faqp-pt-m) 0 var(--faqp-pb-m);
  }
}

.casa-faqp__wrap {
  max-width: 800px;
  margin: 0 auto;
  padding: 0 24px;
}

/* Hero */
.casa-faqp__hero {
  text-align: center;
  margin-bottom: 48px;
}
.casa-faqp__badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 6px 16px;
  border-radius: 9999px;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  background: linear-gradient(135deg, var(--faqp-accent), var(--faqp-accent-2));
  color: #fff;
  margin-bottom: 20px;
}
.casa-faqp__title {
  font-size: clamp(28px, 5vw, 44px);
  font-weight: 700;
  line-height: 1.15;
  letter-spacing: -0.02em;
  margin: 0 0 16px;
  color: var(--faqp-text);
}
.casa-faqp__subtitle {
  font-size: clamp(15px, 2vw, 18px);
  line-height: 1.6;
  color: var(--faqp-muted);
  max-width: 560px;
  margin: 0 auto;
}

/* Tabs */
.casa-faqp__tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  justify-content: center;
  margin-bottom: 40px;
}
.casa-faqp__tab {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 8px 18px;
  border-radius: 9999px;
  border: 1px solid var(--faqp-card-border);
  background: var(--faqp-card-bg);
  color: var(--faqp-muted);
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.25s ease;
  -webkit-backdrop-filter: blur(12px);
  backdrop-filter: blur(12px);
}
.casa-faqp__tab:hover {
  border-color: rgba(255,255,255,0.16);
  color: var(--faqp-text);
}
.casa-faqp__tab--active {
  background: linear-gradient(135deg, var(--faqp-accent), var(--faqp-accent-2));
  border-color: transparent;
  color: #fff;
}
.casa-faqp__tab svg {
  flex-shrink: 0;
  opacity: 0.8;
}
.casa-faqp__tab--active svg {
  opacity: 1;
}

/* Groups */
.casa-faqp__group {
  margin-bottom: 40px;
}
.casa-faqp__group:last-child {
  margin-bottom: 0;
}
.casa-faqp__group-title {
  font-size: 14px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--faqp-muted);
  margin: 0 0 16px;
  padding-left: 4px;
}

/* Accordion items */
.casa-faqp__item {
  border: 1px solid var(--faqp-card-border);
  border-radius: 14px;
  background: var(--faqp-card-bg);
  -webkit-backdrop-filter: blur(16px);
  backdrop-filter: blur(16px);
  margin-bottom: 10px;
  transition: border-color 0.25s ease, box-shadow 0.25s ease;
  overflow: hidden;
}
.casa-faqp__item:hover {
  border-color: rgba(255,255,255,0.12);
}
.casa-faqp__item[open] {
  border-color: rgba(147,51,234,0.3);
  box-shadow: 0 0 24px rgba(147,51,234,0.06);
}

.casa-faqp__question {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: 18px 22px;
  cursor: pointer;
  list-style: none;
  font-size: 15px;
  font-weight: 500;
  line-height: 1.5;
  color: var(--faqp-text);
  transition: color 0.2s ease;
}
.casa-faqp__question::-webkit-details-marker { display: none; }
.casa-faqp__question::marker { display: none; content: ''; }

.casa-faqp__chevron {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: rgba(255,255,255,0.06);
  transition: transform 0.3s ease, background 0.3s ease;
}
.casa-faqp__chevron svg {
  color: var(--faqp-muted);
  transition: color 0.3s ease;
}
.casa-faqp__item[open] .casa-faqp__chevron {
  transform: rotate(180deg);
  background: linear-gradient(135deg, var(--faqp-accent), var(--faqp-accent-2));
}
.casa-faqp__item[open] .casa-faqp__chevron svg {
  color: #fff;
}

.casa-faqp__answer {
  padding: 0 22px 20px;
}
.casa-faqp__answer-inner {
  font-size: 14px;
  line-height: 1.7;
  color: var(--faqp-muted);
}
.casa-faqp__answer-inner p { margin: 0 0 10px; }
.casa-faqp__answer-inner p:last-child { margin-bottom: 0; }
.casa-faqp__answer-inner a {
  color: var(--faqp-accent);
  text-decoration: underline;
  text-underline-offset: 2px;
}
.casa-faqp__answer-inner a:hover {
  color: var(--faqp-accent-2);
}
.casa-faqp__answer-inner ul,
.casa-faqp__answer-inner ol {
  padding-left: 20px;
  margin: 8px 0;
}
.casa-faqp__answer-inner li {
  margin-bottom: 4px;
}

/* Text / Links block */
.casa-faqp__text-block {
  color: var(--faqp-muted, #9ca3af);
  line-height: 1.6;
  max-width: 700px;
  margin: 0 auto;
}
.casa-faqp__text-block a {
  color: var(--faqp-text, #ffffff);
  text-decoration: underline;
  text-underline-offset: 3px;
  text-decoration-color: var(--faqp-accent, #9333ea);
  transition: color 0.2s, text-decoration-color 0.2s;
}
.casa-faqp__text-block a:hover {
  color: var(--faqp-accent, #9333ea);
}
.casa-faqp__text-block p { margin: 0 0 8px; }
.casa-faqp__text-block p:last-child { margin: 0; }

/* Contact CTA */
.casa-faqp__cta {
  margin-top: 56px;
}
.casa-faqp__cta-inner {
  position: relative;
  text-align: center;
  padding: 48px 32px;
  border-radius: 20px;
  border: 1px solid var(--faqp-card-border);
  background: var(--faqp-card-bg);
  -webkit-backdrop-filter: blur(20px);
  backdrop-filter: blur(20px);
  overflow: hidden;
}
.casa-faqp__cta-glow {
  position: absolute;
  top: -60%;
  left: 50%;
  transform: translateX(-50%);
  width: 320px;
  height: 320px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(147,51,234,0.12) 0%, transparent 70%);
  pointer-events: none;
}
.casa-faqp__cta-title {
  font-size: clamp(20px, 3vw, 26px);
  font-weight: 700;
  margin: 0 0 12px;
  position: relative;
  color: var(--faqp-text);
}
.casa-faqp__cta-text {
  font-size: 15px;
  line-height: 1.6;
  color: var(--faqp-muted);
  max-width: 440px;
  margin: 0 auto 24px;
  position: relative;
}
.casa-faqp__cta-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 12px 28px;
  border-radius: 9999px;
  background: linear-gradient(135deg, var(--faqp-accent), var(--faqp-accent-2));
  color: #fff;
  font-size: 14px;
  font-weight: 600;
  text-decoration: none;
  transition: transform 0.25s ease, box-shadow 0.25s ease;
  position: relative;
}
.casa-faqp__cta-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(147,51,234,0.3);
}

/* Mobile tweaks */
@media (max-width: 749px) {
  .casa-faqp__wrap { padding: 0 16px; }
  .casa-faqp__hero { margin-bottom: 32px; }
  .casa-faqp__tabs { margin-bottom: 28px; gap: 6px; }
  .casa-faqp__tab { padding: 7px 14px; font-size: 12px; }
  .casa-faqp__question { padding: 16px 18px; font-size: 14px; }
  .casa-faqp__answer { padding: 0 18px 16px; }
  .casa-faqp__answer-inner { font-size: 13px; }
  .casa-faqp__cta-inner { padding: 36px 20px; }
  .casa-faqp__group { margin-bottom: 28px; }
}
</style>

{% schema %}
{
  "name": "FAQ Page",
  "tag": "section",
  "class": "casa-faqp-section",
  "templates": ["page"],
  "settings": [
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Support"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Everything you need to know about our products, orders, and shipping."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "accent_primary",
      "label": "Accent primary",
      "default": "#9333ea"
    },
    {
      "type": "color",
      "id": "accent_secondary",
      "label": "Accent secondary",
      "default": "#ec4899"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#09090b"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#fafafa"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Muted text",
      "default": "#a1a1aa"
    },
    {
      "type": "text",
      "id": "card_bg",
      "label": "Card background (rgba)",
      "default": "rgba(255,255,255,0.04)"
    },
    {
      "type": "text",
      "id": "card_border",
      "label": "Card border (rgba)",
      "default": "rgba(255,255,255,0.08)"
    },
    {
      "type": "header",
      "content": "Contact CTA"
    },
    {
      "type": "checkbox",
      "id": "show_contact",
      "label": "Show contact CTA",
      "default": true
    },
    {
      "type": "text",
      "id": "contact_title",
      "label": "CTA title",
      "default": "Still have questions?"
    },
    {
      "type": "textarea",
      "id": "contact_text",
      "label": "CTA description",
      "default": "Our support team is here to help. Reach out and we will get back to you within 24 hours."
    },
    {
      "type": "text",
      "id": "contact_btn_text",
      "label": "CTA button text",
      "default": "Contact Us"
    },
    {
      "type": "url",
      "id": "contact_url",
      "label": "CTA button link"
