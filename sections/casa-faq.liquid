{%- comment -%}
  Seoul Glow Lab - FAQ Section
  "Common Questions" accordion section for PDP
{%- endcomment -%}

{%- liquid
  assign tag_text = section.settings.tag_text | default: 'FAQ'
  assign title = section.settings.title | default: 'Common Questions'

  # Accent colors
  assign accent_primary = section.settings.accent_primary | default: '#9333ea'
  assign accent_secondary = section.settings.accent_secondary | default: '#ec4899'

  # Background
  assign bg_style = section.settings.background_style | default: 'light'

  # Behavior
  assign open_first = section.settings.open_first
  assign allow_multiple = section.settings.allow_multiple

  # Padding
  assign padding_top = section.settings.padding_top | default: 100
  assign padding_bottom = section.settings.padding_bottom | default: 100
  assign padding_mobile_top = section.settings.padding_mobile_top | default: 60
  assign padding_mobile_bottom = section.settings.padding_mobile_bottom | default: 60
-%}

<section
  class="casa-faq casa-faq--bg-{{ bg_style }}"
  id="casa-faq-{{ section.id }}"
  style="
    --cfaq-accent-primary: {{ accent_primary }};
    --cfaq-accent-secondary: {{ accent_secondary }};
    --cfaq-padding-top: {{ padding_top }}px;
    --cfaq-padding-bottom: {{ padding_bottom }}px;
    --cfaq-padding-mobile-top: {{ padding_mobile_top }}px;
    --cfaq-padding-mobile-bottom: {{ padding_mobile_bottom }}px;
  "
  data-allow-multiple="{{ allow_multiple }}"
>
  <div class="casa-faq__container">
    {%- comment -%} Header {%- endcomment -%}
    <div class="casa-faq__header">
      {%- if tag_text != blank -%}
        <span class="casa-faq__tag">{{ tag_text }}</span>
      {%- endif -%}

      {%- if title != blank -%}
        <h2 class="casa-faq__title">{{ title }}</h2>
      {%- endif -%}
    </div>

    {%- comment -%} FAQ Accordion {%- endcomment -%}
    <div class="casa-faq__list">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'question' -%}
            <div
              class="casa-faq__item{% if open_first and forloop.first %} casa-faq__item--open{% endif %}"
              data-faq-item
              {{ block.shopify_attributes }}
            >
              <button class="casa-faq__question" data-faq-trigger aria-expanded="{% if open_first and forloop.first %}true{% else %}false{% endif %}">
                <span class="casa-faq__question-text">{{ block.settings.question }}</span>
                <span class="casa-faq__icon">
                  <svg class="casa-faq__icon-plus" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="12" y1="5" x2="12" y2="19"/>
                    <line x1="5" y1="12" x2="19" y2="12"/>
                  </svg>
                  <svg class="casa-faq__icon-minus" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"/>
                  </svg>
                </span>
              </button>
              <div class="casa-faq__answer" data-faq-answer>
                <div class="casa-faq__answer-inner">
                  {{ block.settings.answer }}
                </div>
              </div>
            </div>
          {%- when '@app' -%}
            <div {{ block.shopify_attributes }}>
              {%- render block -%}
            </div>
          {%- when 'custom-liquid' -%}
            <div {{ block.shopify_attributes }}>
              {{ block.settings.custom_liquid }}
            </div>
        {%- endcase -%}
      {%- endfor -%}

      {%- comment -%} Default FAQs if no blocks {%- endcomment -%}
      {%- if section.blocks.size == 0 -%}
        <div class="casa-faq__item casa-faq__item--open" data-faq-item>
          <button class="casa-faq__question" data-faq-trigger aria-expanded="true">
            <span class="casa-faq__question-text">How difficult is installation?</span>
            <span class="casa-faq__icon">
              <svg class="casa-faq__icon-plus" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="5" x2="12" y2="19"/>
                <line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
              <svg class="casa-faq__icon-minus" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
            </span>
          </button>
          <div class="casa-faq__answer" data-faq-answer>
            <div class="casa-faq__answer-inner">
              Very easy! Most customers complete installation in under 15 minutes. No special tools or electrician required — just mount, plug in, and connect via the app.
            </div>
          </div>
        </div>
        <div class="casa-faq__item" data-faq-item>
          <button class="casa-faq__question" data-faq-trigger aria-expanded="false">
            <span class="casa-faq__question-text">Does it work as a real mirror?</span>
            <span class="casa-faq__icon">
              <svg class="casa-faq__icon-plus" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="5" x2="12" y2="19"/>
                <line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
              <svg class="casa-faq__icon-minus" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
            </span>
          </button>
          <div class="casa-faq__answer" data-faq-answer>
            <div class="casa-faq__answer-inner">
              Yes! When the LEDs are off, it functions as a beautiful, high-quality mirror perfect for any room.
            </div>
          </div>
        </div>
        <div class="casa-faq__item" data-faq-item>
          <button class="casa-faq__question" data-faq-trigger aria-expanded="false">
            <span class="casa-faq__question-text">What smart systems does it work with?</span>
            <span class="casa-faq__icon">
              <svg class="casa-faq__icon-plus" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="5" x2="12" y2="19"/>
                <line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
              <svg class="casa-faq__icon-minus" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
            </span>
          </button>
          <div class="casa-faq__answer" data-faq-answer>
            <div class="casa-faq__answer-inner">
              Our mirrors work with Alexa, Google Home, and Apple HomeKit for seamless voice control integration.
            </div>
          </div>
        </div>
        <div class="casa-faq__item" data-faq-item>
          <button class="casa-faq__question" data-faq-trigger aria-expanded="false">
            <span class="casa-faq__question-text">Will it work with my voltage?</span>
            <span class="casa-faq__icon">
              <svg class="casa-faq__icon-plus" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="5" x2="12" y2="19"/>
                <line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
              <svg class="casa-faq__icon-minus" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
            </span>
          </button>
          <div class="casa-faq__answer" data-faq-answer>
            <div class="casa-faq__answer-inner">
              Absolutely! Our mirrors work with 100V-240V and ship with plug adapters for US, EU, UK, and AU outlets.
            </div>
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{%- comment -%} FAQ Schema.org structured data for SEO {%- endcomment -%}
{%- assign faq_blocks = section.blocks | where: 'type', 'question' -%}
{%- if faq_blocks.size > 0 -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {%- for block in faq_blocks -%}
          {
            "@type": "Question",
            "name": {{ block.settings.question | json }},
            "acceptedAnswer": {
              "@type": "Answer",
              "text": {{ block.settings.answer | strip_html | json }}
            }
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ]
    }
  </script>
{%- endif -%}

<script>
  (function() {
    const section = document.getElementById('casa-faq-{{ section.id }}');
    if (!section) return;

    const allowMultiple = section.dataset.allowMultiple === 'true';
    const items = section.querySelectorAll('[data-faq-item]');

    items.forEach(item => {
      const trigger = item.querySelector('[data-faq-trigger]');
      const answer = item.querySelector('[data-faq-answer]');

      if (!trigger || !answer) return;

      trigger.addEventListener('click', function() {
        const isOpen = item.classList.contains('casa-faq__item--open');

        // Close other items if not allowing multiple
        if (!allowMultiple && !isOpen) {
          items.forEach(otherItem => {
            if (otherItem !== item) {
              otherItem.classList.remove('casa-faq__item--open');
              otherItem.querySelector('[data-faq-trigger]')?.setAttribute('aria-expanded', 'false');
            }
          });
        }

        // Toggle current item
        item.classList.toggle('casa-faq__item--open');
        trigger.setAttribute('aria-expanded', !isOpen);
      });
    });
  })();
</script>

