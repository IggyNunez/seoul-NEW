{% stylesheet %}
/* ══════════════════════════════════════════════════════════════════════════
   CASA FAQ SECTION
   "Common Questions" accordion for PDP
   ══════════════════════════════════════════════════════════════════════════ */

.casa-faq {
  --cfaq-accent-primary: #9333ea;
  --cfaq-accent-secondary: #ec4899;
  --cfaq-padding-top: 100px;
  --cfaq-padding-bottom: 100px;
  --cfaq-padding-mobile-top: 60px;
  --cfaq-padding-mobile-bottom: 60px;

  padding: var(--cfaq-padding-top) 0 var(--cfaq-padding-bottom);
  position: relative;
}

/* ── Background Variants ── */
.casa-faq--bg-light {
  background: #f8f8fa;
}

.casa-faq--bg-white {
  background: #ffffff;
}

.casa-faq--bg-dark {
  background: #0a0a0f;
}

/* ── Container ── */
.casa-faq__container {
  max-width: 800px;
  margin: 0 auto;
  padding: 0 24px;
}

/* ── Header ── */
.casa-faq__header {
  text-align: center;
  margin-bottom: 32px;
}

.casa-faq__tag {
  display: inline-block;
  font-size: 12px;
  font-weight: 600;
  color: var(--cfaq-accent-primary);
  text-transform: uppercase;
  letter-spacing: 2px;
  margin-bottom: 16px;
}

.casa-faq__title {
  font-size: clamp(28px, 5vw, 42px);
  font-weight: 300;
  color: #0a0a0a;
  margin: 0;
  letter-spacing: -0.5px;
  line-height: 1.2;
}

.casa-faq--bg-dark .casa-faq__title {
  color: #ffffff;
}

/* ══════════════════════════════════════════════════════════════════════════
   FAQ LIST & ITEMS
   ══════════════════════════════════════════════════════════════════════════ */

.casa-faq__list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.casa-faq__item {
  background: #ffffff;
  border: 1px solid #e5e5e5;
  border-radius: 12px;
  overflow: hidden;
  transition: all 0.3s ease;
}

.casa-faq--bg-dark .casa-faq__item {
  background: rgba(255, 255, 255, 0.03);
  border-color: rgba(255, 255, 255, 0.08);
}

.casa-faq__item:hover {
  border-color: #d5d5d5;
}

.casa-faq--bg-dark .casa-faq__item:hover {
  border-color: rgba(255, 255, 255, 0.12);
}

/* ── Question Button ── */
.casa-faq__question {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: 20px 24px;
  background: none;
  border: none;
  cursor: pointer;
  text-align: left;
  transition: all 0.2s ease;
}

.casa-faq__question:hover {
  background: rgba(0, 0, 0, 0.02);
}

.casa-faq--bg-dark .casa-faq__question:hover {
  background: rgba(255, 255, 255, 0.02);
}

.casa-faq__question-text {
  font-size: 16px;
  font-weight: 500;
  color: #0a0a0a;
  line-height: 1.4;
}

.casa-faq--bg-dark .casa-faq__question-text {
  color: #ffffff;
}

/* ── Icon ── */
.casa-faq__icon {
  flex-shrink: 0;
  width: 20px;
  height: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6b7280;
  position: relative;
  transition: all 0.3s ease;
}

.casa-faq--bg-dark .casa-faq__icon {
  color: rgba(255, 255, 255, 0.5);
}

.casa-faq__icon-plus {
  transition: transform 0.3s ease;
}

.casa-faq__icon-minus {
  display: none;
}

/* Open state icon — rotates + to × */
.casa-faq__item--open .casa-faq__icon {
  color: var(--cfaq-accent-primary);
}

.casa-faq__item--open .casa-faq__icon-plus {
  transform: rotate(45deg);
}

/* ── Answer ── */
.casa-faq__answer {
  display: grid;
  grid-template-rows: 0fr;
  transition: grid-template-rows 0.3s ease;
}

.casa-faq__item--open .casa-faq__answer {
  grid-template-rows: 1fr;
}

.casa-faq__answer-inner {
  overflow: hidden;
  padding: 0 24px;
  transition: padding 0.3s ease;
}

.casa-faq__item--open .casa-faq__answer-inner {
  padding: 0 24px 20px;
}

.casa-faq__answer-inner,
.casa-faq__answer-inner p {
  font-size: 14px;
  color: #757575;
  line-height: 1.7;
  margin: 0;
}

.casa-faq--bg-dark .casa-faq__answer-inner,
.casa-faq--bg-dark .casa-faq__answer-inner p {
  color: rgba(255, 255, 255, 0.6);
}

/* ══════════════════════════════════════════════════════════════════════════
   RESPONSIVE
   ══════════════════════════════════════════════════════════════════════════ */

@media (max-width: 768px) {
  .casa-faq {
    padding: var(--cfaq-padding-mobile-top) 0 var(--cfaq-padding-mobile-bottom);
  }

  .casa-faq__container {
    padding: 0 16px;
  }

  .casa-faq__header {
    margin-bottom: 32px;
  }

  .casa-faq__tag {
    font-size: 11px;
    margin-bottom: 12px;
  }

  .casa-faq__list {
    gap: 10px;
  }

  .casa-faq__question {
    padding: 16px 18px;
    gap: 12px;
  }

  .casa-faq__question-text {
    font-size: 15px;
  }

  .casa-faq__answer-inner {
    padding: 0 18px;
  }

  .casa-faq__item--open .casa-faq__answer-inner {
    padding: 0 18px 16px;
  }

  .casa-faq__answer-inner,
  .casa-faq__answer-inner p {
    font-size: 13px;
    line-height: 1.6;
  }
}

@media (max-width: 480px) {
  .casa-faq__list {
    gap: 8px;
  }

  .casa-faq__question {
    padding: 14px 14px;
  }

  .casa-faq__question-text {
    font-size: 14px;
  }

  .casa-faq__answer-inner {
    padding: 0 14px;
  }

  .casa-faq__item--open .casa-faq__answer-inner {
    padding: 0 14px 14px;
  }

  .casa-faq__answer-inner,
  .casa-faq__answer-inner p {
    font-size: 13px;
  }
}
{% endstylesheet %}
