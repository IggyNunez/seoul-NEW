{% comment %}
  Seoul Glow Lab — Lookbook Gallery (Masonry/Bento)
  Bento grid with lightbox, hover captions, responsive layout.
{% endcomment %}

{{ 'section-casa-lookbook-gallery.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign gap = section.settings.gap | default: 16
  assign radius = section.settings.border_radius | default: 8
  assign bg = section.settings.bg_color | default: '#0a0a0a'
  assign pt = section.settings.padding_top | default: 60
  assign pb = section.settings.padding_bottom | default: 60
  assign lightbox = section.settings.enable_lightbox
-%}

<style>
  /* ── Casa Lookbook Gallery ── */
  .casa-lb-gal {
    background: {{ bg }};
    padding-top: {{ pt }}px;
    padding-bottom: {{ pb }}px;
  }

  .casa-lb-gal__inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Header */
  .casa-lb-gal__header {
    text-align: center;
    margin-bottom: 48px;
  }

  .casa-lb-gal__title {
    font-family: var(--font-heading-family, 'Times New Roman', serif);
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 300;
    letter-spacing: 0.04em;
    color: #ffffff;
    margin: 0 0 16px;
    line-height: 1.15;
  }

  .casa-lb-gal__desc {
    font-size: 1.05rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.55);
    max-width: 640px;
    margin: 0 auto;
  }

  /* Grid */
  .casa-lb-gal__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ gap }}px;
    grid-auto-flow: dense;
  }

  /* Size variants */
  .casa-lb-gal__item--full {
    grid-column: 1 / -1;
  }

  .casa-lb-gal__item--large {
    grid-column: span 2;
    grid-row: span 2;
  }

  .casa-lb-gal__item--medium {
    grid-column: span 1;
    grid-row: span 2;
  }

  .casa-lb-gal__item--small {
    grid-column: span 1;
    grid-row: span 1;
  }

  /* Item */
  .casa-lb-gal__item {
    position: relative;
    overflow: hidden;
    border-radius: {{ radius }}px;
    background: #111;
    cursor: pointer;
  }

  .casa-lb-gal__item--full {
    aspect-ratio: 21 / 9;
  }

  .casa-lb-gal__item--large {
    aspect-ratio: auto;
    min-height: 420px;
  }

  .casa-lb-gal__item--medium {
    aspect-ratio: auto;
    min-height: 380px;
  }

  .casa-lb-gal__item--small {
    aspect-ratio: 1 / 1;
  }

  .casa-lb-gal__item a {
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  /* Image */
  .casa-lb-gal__img-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .casa-lb-gal__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.65s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform;
  }

  .casa-lb-gal__item:hover .casa-lb-gal__img {
    transform: scale(1.06);
  }

  /* Caption overlay */
  .casa-lb-gal__caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 32px 20px 20px;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.72) 0%, transparent 100%);
    transform: translateY(100%);
    transition: transform 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                opacity 0.45s ease;
    opacity: 0;
    z-index: 2;
  }

  .casa-lb-gal__item:hover .casa-lb-gal__caption {
    transform: translateY(0);
    opacity: 1;
  }

  .casa-lb-gal__caption-text {
    font-size: 0.9rem;
    font-weight: 400;
    letter-spacing: 0.03em;
    color: rgba(255, 255, 255, 0.9);
    margin: 0;
  }

  /* Lightbox icon hint */
  .casa-lb-gal__zoom-icon {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.45);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.35s ease;
    z-index: 3;
    pointer-events: none;
  }

  .casa-lb-gal__zoom-icon svg {
    width: 16px;
    height: 16px;
    stroke: #fff;
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .casa-lb-gal__item:hover .casa-lb-gal__zoom-icon {
    opacity: 1;
  }

  /* ── Lightbox ── */
  .casa-lb-gal__lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.35s ease, visibility 0.35s ease;
  }

  .casa-lb-gal__lightbox.is-active {
    opacity: 1;
    visibility: visible;
  }

  .casa-lb-gal__lightbox-img {
    max-width: 90vw;
    max-height: 85vh;
    object-fit: contain;
    border-radius: 4px;
    opacity: 0;
    transform: scale(0.95);
    transition: opacity 0.35s ease, transform 0.35s ease;
  }

  .casa-lb-gal__lightbox.is-active .casa-lb-gal__lightbox-img {
    opacity: 1;
    transform: scale(1);
  }

  .casa-lb-gal__lightbox-caption {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.7);
    text-align: center;
    max-width: 600px;
    padding: 0 24px;
  }

  .casa-lb-gal__lightbox-close {
    position: absolute;
    top: 24px;
    right: 24px;
    width: 44px;
    height: 44px;
    border: none;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.25s ease;
    z-index: 2;
  }

  .casa-lb-gal__lightbox-close:hover {
    background: rgba(255, 255, 255, 0.16);
  }

  .casa-lb-gal__lightbox-close svg {
    width: 20px;
    height: 20px;
    stroke: #fff;
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
  }

  .casa-lb-gal__lightbox-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 48px;
    height: 48px;
    border: none;
    background: rgba(255, 255, 255, 0.06);
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.25s ease;
    z-index: 2;
  }

  .casa-lb-gal__lightbox-nav:hover {
    background: rgba(255, 255, 255, 0.14);
  }

  .casa-lb-gal__lightbox-nav svg {
    width: 20px;
    height: 20px;
    stroke: #fff;
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .casa-lb-gal__lightbox-prev { left: 24px; }
  .casa-lb-gal__lightbox-next { right: 24px; }

  .casa-lb-gal__lightbox-counter {
    position: absolute;
    top: 32px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.4);
  }

  /* ── Responsive ── */
  @media (max-width: 999px) {
    .casa-lb-gal__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .casa-lb-gal__item--full {
      grid-column: 1 / -1;
      aspect-ratio: 16 / 9;
    }

    .casa-lb-gal__item--large {
      grid-column: span 2;
      grid-row: span 1;
      min-height: 300px;
    }

    .casa-lb-gal__item--medium {
      grid-column: span 1;
      grid-row: span 1;
      min-height: 260px;
    }

    .casa-lb-gal__item--small {
      grid-column: span 1;
    }

    /* Always show captions on touch */
    .casa-lb-gal__caption {
      transform: translateY(0);
      opacity: 1;
    }
  }

  @media (max-width: 599px) {
    .casa-lb-gal__grid {
      grid-template-columns: 1fr;
    }

    .casa-lb-gal__item--full,
    .casa-lb-gal__item--large,
    .casa-lb-gal__item--medium {
      grid-column: span 1;
      grid-row: span 1;
      min-height: 260px;
    }

    .casa-lb-gal__item--full {
      aspect-ratio: 4 / 3;
    }

    .casa-lb-gal__item--small {
      aspect-ratio: 4 / 3;
    }

    .casa-lb-gal__lightbox-nav { display: none; }

    .casa-lb-gal__inner {
      padding: 0 16px;
    }

    .casa-lb-gal__header {
      margin-bottom: 32px;
    }
  }

  /* Placeholder for editor */
  .casa-lb-gal__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    min-height: 200px;
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    color: rgba(255, 255, 255, 0.25);
    font-size: 0.85rem;
    letter-spacing: 0.05em;
  }
</style>

<section
  class="casa-lb-gal"
  data-section-id="{{ section.id }}"
  data-lightbox="{{ lightbox }}"
>
  <div class="casa-lb-gal__inner">
    {%- if section.settings.title != blank or section.settings.description != blank -%}
      <div class="casa-lb-gal__header">
        {%- if section.settings.title != blank -%}
          <h2 class="casa-lb-gal__title">{{ section.settings.title | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p class="casa-lb-gal__desc">{{ section.settings.description | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="casa-lb-gal__grid" role="list">
      {%- for block in section.blocks -%}
        {%- liquid
          assign size = block.settings.size | default: 'small'
          assign has_link = false
          if block.settings.link != blank
            assign has_link = true
          endif
        -%}

        <div
          class="casa-lb-gal__item casa-lb-gal__item--{{ size }}"
          role="listitem"
          data-index="{{ forloop.index0 }}"
          {{ block.shopify_attributes }}
        >
          {%- if has_link and lightbox == false -%}
            <a href="{{ block.settings.link }}" aria-label="{{ block.settings.caption | default: 'Gallery image' | escape }}">
          {%- endif -%}

          <div class="casa-lb-gal__img-wrap">
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 1400
                | image_tag:
                  class: 'casa-lb-gal__img',
                  loading: 'lazy',
                  widths: '375, 550, 750, 1000, 1400',
                  sizes: '(max-width: 599px) 100vw, (max-width: 999px) 50vw, 25vw',
                  alt: block.settings.caption | default: block.settings.image.alt | escape
              }}
            {%- else -%}
              <div class="casa-lb-gal__placeholder">{{ 'lifestyle-' | append: forloop.index | placeholder_svg_tag }}</div>
            {%- endif -%}
          </div>

          {%- if block.settings.caption != blank -%}
            <div class="casa-lb-gal__caption">
              <p class="casa-lb-gal__caption-text">{{ block.settings.caption | escape }}</p>
            </div>
          {%- endif -%}

          {%- if lightbox and block.settings.image != blank -%}
            <div class="casa-lb-gal__zoom-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
            </div>
          {%- endif -%}

          {%- if has_link and lightbox == false -%}
            </a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>

  {%- if lightbox -%}
    <div class="casa-lb-gal__lightbox" id="casaLbGalLightbox-{{ section.id }}" role="dialog" aria-modal="true" aria-label="Image lightbox">
      <button class="casa-lb-gal__lightbox-close" aria-label="Close lightbox">
        <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>

      <button class="casa-lb-gal__lightbox-nav casa-lb-gal__lightbox-prev" aria-label="Previous image">
        <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
      </button>

      <img class="casa-lb-gal__lightbox-img" src="" alt="" />

      <button class="casa-lb-gal__lightbox-nav casa-lb-gal__lightbox-next" aria-label="Next image">
        <svg viewBox="0 0 24 24"><polyline points="9 6 15 12 9 18"/></svg>
      </button>

      <div class="casa-lb-gal__lightbox-caption"></div>
      <div class="casa-lb-gal__lightbox-counter"></div>
    </div>
  {%- endif -%}
</section>

{%- if lightbox -%}
<script>
  (function () {
    'use strict';

    const sectionId = '{{ section.id }}';
    const lightboxEl = document.getElementById('casaLbGalLightbox-' + sectionId);
    if (!lightboxEl) return;

    const section = document.querySelector('[data-section-id="' + sectionId + '"]');
    if (!section) return;

    const imgEl = lightboxEl.querySelector('.casa-lb-gal__lightbox-img');
    const captionEl = lightboxEl.querySelector('.casa-lb-gal__lightbox-caption');
    const counterEl = lightboxEl.querySelector('.casa-lb-gal__lightbox-counter');
    const closeBtn = lightboxEl.querySelector('.casa-lb-gal__lightbox-close');
    const prevBtn = lightboxEl.querySelector('.casa-lb-gal__lightbox-prev');
    const nextBtn = lightboxEl.querySelector('.casa-lb-gal__lightbox-next');

    let images = [];
    let current = 0;

    function buildImageList() {
      images = [];
      section.querySelectorAll('.casa-lb-gal__item').forEach(function (item) {
        const img = item.querySelector('.casa-lb-gal__img');
        if (!img) return;
        const captionNode = item.querySelector('.casa-lb-gal__caption-text');
        images.push({
          src: img.currentSrc || img.src,
          srcset: img.srcset || '',
          alt: img.alt || '',
          caption: captionNode ? captionNode.textContent : ''
        });
      });
    }

    function show(index) {
      if (images.length === 0) return;
      current = (index + images.length) % images.length;
      const data = images[current];

      imgEl.src = data.src;
      if (data.srcset) {
        imgEl.srcset = data.srcset;
        imgEl.sizes = '90vw';
      } else {
        imgEl.removeAttribute('srcset');
        imgEl.removeAttribute('sizes');
      }
      imgEl.alt = data.alt;
      captionEl.textContent = data.caption;
      captionEl.style.display = data.caption ? '' : 'none';
      counterEl.textContent = (current + 1) + ' / ' + images.length;

      prevBtn.style.display = images.length > 1 ? '' : 'none';
      nextBtn.style.display = images.length > 1 ? '' : 'none';
    }

    function open(index) {
      buildImageList();
      show(index);
      lightboxEl.classList.add('is-active');
      document.body.style.overflow = 'hidden';
      lightboxEl.focus();
    }

    function close() {
      lightboxEl.classList.remove('is-active');
      document.body.style.overflow = '';
    }

    /* Item click */
    section.querySelectorAll('.casa-lb-gal__item').forEach(function (item) {
      item.addEventListener('click', function (e) {
        const img = item.querySelector('.casa-lb-gal__img');
        if (!img) return;
        /* Don't intercept if a link wrapper is present and lightbox is off */
        if (item.querySelector('a')) return;
        e.preventDefault();
        const idx = parseInt(item.getAttribute('data-index'), 10);
        open(idx);
      });
    });

    /* Controls */
    closeBtn.addEventListener('click', close);
    prevBtn.addEventListener('click', function () { show(current - 1); });
    nextBtn.addEventListener('click', function () { show(current + 1); });

    /* Backdrop click */
    lightboxEl.addEventListener('click', function (e) {
      if (e.target === lightboxEl) close();
    });

    /* Keyboard */
    document.addEventListener('keydown', function (e) {
      if (!lightboxEl.classList.contains('is-active')) return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowLeft') show(current - 1);
      if (e.key === 'ArrowRight') show(current + 1);
    });

    /* Swipe support for mobile */
    let touchStartX = 0;
    let touchEndX = 0;

    lightboxEl.addEventListener('touchstart', function (e) {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });

    lightboxEl.addEventListener('touchend', function (e) {
      touchEndX = e.changedTouches[0].screenX;
      const diff = touchStartX - touchEndX;
      if (Math.abs(diff) > 50) {
        if (diff > 0) show(current + 1);
        else show(current - 1);
      }
    }, { passive: true });
  })();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Lookbook Gallery",
  "tag": "section",
  "class": "casa-lb-gal-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "The Collection"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "A curated selection of our finest lighting, captured in their intended settings."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#0a0a0a"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Grid gap",
      "min": 8,
      "max": 32,
      "step": 4,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "default": 8,
      "unit": "px"
    },
    {
      "type": "checkbox",
      "id": "enable_lightbox",
      "label": "Enable lightbox on click",
      "default": true
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "gallery_image",
      "name": "Gallery Image",
      "limit": 12,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "size",
          "label": "Size",
          "options": [
            { "value": "full", "label": "Full width" },
            { "value": "large", "label": "Large (2-col)" },
            { "value": "medium", "label": "Medium (tall)" },
            { "value": "small", "label": "Small (square)" }
          ],
          "default": "small"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption (optional)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lookbook Gallery",
      "blocks": [
        { "type": "gallery_image", "settings": { "size": "large", "caption": "Illuminated Elegance" } },
        { "type": "gallery_image", "settings": { "size": "medium", "caption": "Sculptural Light" } },
        { "type": "gallery_image", "settings": { "size": "small", "caption": "Evening Glow" } },
        { "type": "gallery_image", "settings": { "size": "small", "caption": "Ambient Warmth" } },
        { "type": "gallery_image", "settings": { "size": "full", "caption": "The Grand Chandelier" } }
      ]
    }
  ],
  "templates": ["page"]
}
{% endschema %}
