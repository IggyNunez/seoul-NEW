{% comment %}
  DoingWell Scrolling Testimonials Section
  - Unlimited testimonial cards via blocks
  - Auto-scrolling marquee effect
  - Pause on hover
  - Star ratings
  - Footer with review count
{% endcomment %}

<section 
  class="dw-testimonials"
  style="
    --testimonials-bg: {{ section.settings.background_color }};
    --testimonials-text: {{ section.settings.text_color }};
    --testimonials-accent: {{ section.settings.accent_color }};
    --testimonials-card-bg: {{ section.settings.card_bg_color }};
    --testimonials-card-text: {{ section.settings.card_text_color }};
    --testimonials-star: {{ section.settings.star_color }};
    --testimonials-padding-desktop: {{ section.settings.padding_desktop }}px;
    --testimonials-padding-mobile: {{ section.settings.padding_mobile }}px;
    --testimonials-speed: {{ section.settings.scroll_speed }}s;
  "
>
  <div class="dw-testimonials__header">
    {%- if section.settings.heading != blank -%}
      <h2 class="dw-testimonials__heading{% if section.settings.heading_italic %} dw-testimonials__heading--italic{% endif %}">{{ section.settings.heading }}</h2>
    {%- endif -%}
    
    {%- if section.settings.subheading != blank -%}
      <p class="dw-testimonials__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>

  <div class="dw-testimonials__carousel" data-testimonials-carousel>
    <div class="dw-testimonials__track" data-testimonials-track>
      {%- for block in section.blocks -%}
        <div class="dw-testimonials__card" {{ block.shopify_attributes }}>
          <div class="dw-testimonials__stars">
            {%- for i in (1..5) -%}
              {%- if i <= block.settings.rating -%}
                <svg class="dw-testimonials__star dw-testimonials__star--filled" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M10 15.27L16.18 19l-1.64-7.03L20 7.24l-7.19-.61L10 0 7.19 6.63 0 7.24l5.46 4.73L3.82 19z"/>
                </svg>
              {%- else -%}
                <svg class="dw-testimonials__star" viewBox="0 0 20 20" fill="currentColor" opacity="0.3">
                  <path d="M10 15.27L16.18 19l-1.64-7.03L20 7.24l-7.19-.61L10 0 7.19 6.63 0 7.24l5.46 4.73L3.82 19z"/>
                </svg>
              {%- endif -%}
            {%- endfor -%}
          </div>
          
          <blockquote class="dw-testimonials__quote">
            "{{ block.settings.quote }}"
          </blockquote>
          
          <cite class="dw-testimonials__author">
            — {{ block.settings.author }}{% if block.settings.verified %}, <span class="dw-testimonials__verified">Verified Customer</span>{% endif %}
          </cite>
        </div>
      {%- endfor -%}
      
      {%- comment -%} Duplicate cards for seamless loop {%- endcomment -%}
      {%- for block in section.blocks -%}
        <div class="dw-testimonials__card" aria-hidden="true">
          <div class="dw-testimonials__stars">
            {%- for i in (1..5) -%}
              {%- if i <= block.settings.rating -%}
                <svg class="dw-testimonials__star dw-testimonials__star--filled" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M10 15.27L16.18 19l-1.64-7.03L20 7.24l-7.19-.61L10 0 7.19 6.63 0 7.24l5.46 4.73L3.82 19z"/>
                </svg>
              {%- else -%}
                <svg class="dw-testimonials__star" viewBox="0 0 20 20" fill="currentColor" opacity="0.3">
                  <path d="M10 15.27L16.18 19l-1.64-7.03L20 7.24l-7.19-.61L10 0 7.19 6.63 0 7.24l5.46 4.73L3.82 19z"/>
                </svg>
              {%- endif -%}
            {%- endfor -%}
          </div>
          
          <blockquote class="dw-testimonials__quote">
            "{{ block.settings.quote }}"
          </blockquote>
          
          <cite class="dw-testimonials__author">
            — {{ block.settings.author }}{% if block.settings.verified %}, <span class="dw-testimonials__verified">Verified Customer</span>{% endif %}
          </cite>
        </div>
      {%- endfor -%}
    </div>
  </div>

  {%- if section.settings.show_footer -%}
    <div class="dw-testimonials__footer">
      <span class="dw-testimonials__count">{{ section.settings.review_count }}</span>
      <span class="dw-testimonials__divider">|</span>
      <span class="dw-testimonials__average">Average Rating: {{ section.settings.average_rating }}</span>
    </div>
  {%- endif -%}
</section>

<style>
  .dw-testimonials {
    background: var(--testimonials-bg);
    color: var(--testimonials-text);
    padding: var(--testimonials-padding-mobile) 0;
    overflow: hidden;
    font-family: 'Poppins', sans-serif;
  }

  @media (min-width: 750px) {
    .dw-testimonials {
      padding: var(--testimonials-padding-desktop) 0;
    }
  }

  /* Header */
  .dw-testimonials__header {
    text-align: center;
    padding: 0 20px;
    margin-bottom: 32px;
  }

  @media (min-width: 750px) {
    .dw-testimonials__header {
      margin-bottom: 48px;
    }
  }

  .dw-testimonials__heading {
    font-size: 28px;
    font-weight: 600;
    font-family: 'Poppins', sans-serif;
    margin: 0 0 12px 0;
    line-height: 1.2;
  }

  .dw-testimonials__heading--italic {
    font-style: italic;
  }

  @media (min-width: 750px) {
    .dw-testimonials__heading {
      font-size: 42px;
      margin-bottom: 16px;
    }
  }

  .dw-testimonials__subheading {
    font-size: 14px;
    color: var(--testimonials-text);
    opacity: 0.8;
    margin: 0;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }

  @media (min-width: 750px) {
    .dw-testimonials__subheading {
      font-size: 15px;
    }
  }

  /* Carousel */
  .dw-testimonials__carousel {
    position: relative;
    width: 100%;
  }

  .dw-testimonials__track {
    display: flex;
    gap: 16px;
    animation: testimonials-scroll var(--testimonials-speed, 40s) linear infinite;
    width: max-content;
  }

  @media (min-width: 750px) {
    .dw-testimonials__track {
      gap: 24px;
    }
  }

  .dw-testimonials__carousel:hover .dw-testimonials__track {
    animation-play-state: paused;
  }

  @keyframes testimonials-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  /* Cards */
  .dw-testimonials__card {
    flex-shrink: 0;
    width: 280px;
    background: var(--testimonials-card-bg);
    border-radius: 12px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  @media (min-width: 750px) {
    .dw-testimonials__card {
      width: 340px;
      padding: 28px;
    }
  }

  /* Stars */
  .dw-testimonials__stars {
    display: flex;
    gap: 2px;
  }

  .dw-testimonials__star {
    width: 16px;
    height: 16px;
    color: var(--testimonials-star);
  }

  @media (min-width: 750px) {
    .dw-testimonials__star {
      width: 18px;
      height: 18px;
    }
  }

  /* Quote */
  .dw-testimonials__quote {
    font-size: 14px;
    line-height: 1.6;
    color: var(--testimonials-card-text);
    margin: 0;
    flex: 1;
  }

  @media (min-width: 750px) {
    .dw-testimonials__quote {
      font-size: 15px;
    }
  }

  /* Author */
  .dw-testimonials__author {
    font-size: 13px;
    font-weight: 600;
    color: var(--testimonials-card-text);
    font-style: normal;
  }

  .dw-testimonials__verified {
    font-weight: 600;
    color: var(--testimonials-accent);
  }

  /* Footer */
  .dw-testimonials__footer {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-top: 32px;
    padding: 0 20px;
    font-size: 14px;
  }

  @media (min-width: 750px) {
    .dw-testimonials__footer {
      margin-top: 48px;
      font-size: 15px;
    }
  }

  .dw-testimonials__count {
    font-weight: 700;
    color: var(--testimonials-text);
  }

  .dw-testimonials__divider {
    color: var(--testimonials-text);
    opacity: 0.4;
  }

  .dw-testimonials__average {
    color: var(--testimonials-text);
    opacity: 0.8;
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .dw-testimonials__track {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
      width: 100%;
      padding: 0 20px;
    }
    
    .dw-testimonials__card[aria-hidden="true"] {
      display: none;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Adjust animation duration based on number of cards
    const carousel = document.querySelector('[data-testimonials-carousel]');
    const track = document.querySelector('[data-testimonials-track]');
    
    if (carousel && track) {
      const cards = track.querySelectorAll('.dw-testimonials__card');
      const uniqueCards = cards.length / 2; // Half are duplicates
      
      // Adjust speed based on content (more cards = longer duration)
      if (uniqueCards > 0) {
        const baseSpeed = {{ section.settings.scroll_speed }};
        const adjustedSpeed = baseSpeed * (uniqueCards / 5); // 5 cards = base speed
        track.style.setProperty('--testimonials-speed', Math.max(adjustedSpeed, 20) + 's');
      }
    }
  });
</script>

