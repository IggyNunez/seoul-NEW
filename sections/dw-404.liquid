{% comment %}
  DoingWell 404 Page
  - Cyber-themed error page
  - Animated glitch effects
  - Glow orbs background
  - On-brand messaging
{% endcomment %}

<section 
  class="dw-404"
  style="
    --404-bg: {{ section.settings.background_color }};
    --404-text: {{ section.settings.text_color }};
    --404-accent: {{ section.settings.accent_color }};
    --404-glow-1: {{ section.settings.glow_color_1 }};
    --404-glow-2: {{ section.settings.glow_color_2 }};
    --404-glow-3: {{ section.settings.glow_color_3 }};
  "
>
  {%- if section.settings.enable_glow -%}
    <div class="dw-404__glow">
      <div class="dw-404__glow-orb dw-404__glow-orb--1"></div>
      <div class="dw-404__glow-orb dw-404__glow-orb--2"></div>
      <div class="dw-404__glow-orb dw-404__glow-orb--3"></div>
    </div>
  {%- endif -%}

  <div class="dw-404__container">
    <div class="dw-404__content">
      
      {%- if section.settings.enable_glitch -%}
        <div class="dw-404__code dw-404__code--glitch" data-text="{{ section.settings.error_code }}">
          {{ section.settings.error_code }}
        </div>
      {%- else -%}
        <div class="dw-404__code">
          {{ section.settings.error_code }}
        </div>
      {%- endif -%}

      <h1 class="dw-404__heading">{{ section.settings.heading }}</h1>
      
      <p class="dw-404__text">{{ section.settings.text }}</p>

      <div class="dw-404__actions">
        <a href="{{ section.settings.button_1_link }}" class="dw-btn dw-btn--{{ section.settings.button_1_style }}{% if section.settings.button_1_style == 'gradient' or section.settings.button_1_style == 'gradient-glow' %} dw-btn--gradient-animate{% endif %}">
          <span>{{ section.settings.button_1_text }}</span>
        </a>
        
        {%- if section.settings.button_2_text != blank -%}
          <a href="{{ section.settings.button_2_link }}" class="dw-btn dw-btn--{{ section.settings.button_2_style }}{% if section.settings.button_2_style == 'gradient' or section.settings.button_2_style == 'gradient-glow' %} dw-btn--gradient-animate{% endif %}">
            <span>{{ section.settings.button_2_text }}</span>
          </a>
        {%- endif -%}
      </div>

      {%- if section.settings.show_search -%}
        <div class="dw-404__search">
          <p class="dw-404__search-label">{{ section.settings.search_label }}</p>
          <form action="{{ routes.search_url }}" method="get" class="dw-404__search-form">
            <input 
              type="search" 
              name="q" 
              placeholder="{{ section.settings.search_placeholder }}"
              class="dw-404__search-input"
              aria-label="Search"
            >
            <button type="submit" class="dw-404__search-btn">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"></circle>
                <path d="m21 21-4.35-4.35"></path>
              </svg>
            </button>
          </form>
        </div>
      {%- endif -%}

    </div>

    {%- if section.settings.show_popular_links -%}
      <div class="dw-404__links">
        <p class="dw-404__links-heading">{{ section.settings.popular_heading }}</p>
        <div class="dw-404__links-grid">
          {%- for block in section.blocks -%}
            <a href="{{ block.settings.link }}" class="dw-404__link-card" {{ block.shopify_attributes }}>
              {%- if block.settings.icon != 'none' -%}
                <span class="dw-404__link-icon">
                  {%- case block.settings.icon -%}
                    {%- when 'home' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
                    {%- when 'shop' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
                    {%- when 'box' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
                    {%- when 'help' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                    {%- when 'user' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                    {%- when 'mail' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                  {%- endcase -%}
                </span>
              {%- endif -%}
              <span class="dw-404__link-text">{{ block.settings.text }}</span>
              <span class="dw-404__link-arrow">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </span>
            </a>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

  </div>
</section>

<style>
  /* ==========================================
     404 BASE
     ========================================== */
  
  .dw-404 {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--404-bg);
    color: var(--404-text);
    padding: 80px 20px;
    overflow: hidden;
  }

  @media (min-width: 750px) {
    .dw-404 {
      padding: 100px 50px;
    }
  }

  .dw-404__container {
    position: relative;
    z-index: 2;
    max-width: 800px;
    width: 100%;
    text-align: center;
  }

  /* ==========================================
     GLOW BACKGROUND
     ========================================== */
  
  .dw-404__glow {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0;
  }

  .dw-404__glow-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.4;
    animation: glow-404-float 10s ease-in-out infinite;
  }

  .dw-404__glow-orb--1 {
    width: 400px;
    height: 400px;
    background: var(--404-glow-1);
    top: -100px;
    left: -100px;
  }

  .dw-404__glow-orb--2 {
    width: 350px;
    height: 350px;
    background: var(--404-glow-2);
    bottom: -50px;
    right: -50px;
    animation-delay: -3s;
  }

  .dw-404__glow-orb--3 {
    width: 250px;
    height: 250px;
    background: var(--404-glow-3);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    animation-delay: -6s;
  }

  @keyframes glow-404-float {
    0%, 100% {
      transform: translate(0, 0) scale(1);
      opacity: 0.4;
    }
    33% {
      transform: translate(30px, -30px) scale(1.1);
      opacity: 0.3;
    }
    66% {
      transform: translate(-20px, 20px) scale(0.9);
      opacity: 0.5;
    }
  }

  /* ==========================================
     ERROR CODE
     ========================================== */
  
  .dw-404__code {
    font-size: 120px;
    font-weight: 800;
    line-height: 1;
    color: var(--404-accent);
    margin-bottom: 20px;
    letter-spacing: -0.02em;
  }

  @media (min-width: 750px) {
    .dw-404__code {
      font-size: 180px;
      margin-bottom: 30px;
    }
  }

  /* Glitch Effect */
  .dw-404__code--glitch {
    position: relative;
    animation: glitch-skew 4s infinite linear alternate-reverse;
  }

  .dw-404__code--glitch::before,
  .dw-404__code--glitch::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .dw-404__code--glitch::before {
    color: var(--404-glow-1);
    animation: glitch-anim-1 2s infinite linear alternate-reverse;
    clip-path: polygon(0 0, 100% 0, 100% 35%, 0 35%);
  }

  .dw-404__code--glitch::after {
    color: var(--404-glow-2);
    animation: glitch-anim-2 3s infinite linear alternate-reverse;
    clip-path: polygon(0 65%, 100% 65%, 100% 100%, 0 100%);
  }

  @keyframes glitch-anim-1 {
    0%, 100% { transform: translate(0); }
    20% { transform: translate(-3px, 3px); }
    40% { transform: translate(-3px, -3px); }
    60% { transform: translate(3px, 3px); }
    80% { transform: translate(3px, -3px); }
  }

  @keyframes glitch-anim-2 {
    0%, 100% { transform: translate(0); }
    20% { transform: translate(3px, -3px); }
    40% { transform: translate(3px, 3px); }
    60% { transform: translate(-3px, -3px); }
    80% { transform: translate(-3px, 3px); }
  }

  @keyframes glitch-skew {
    0%, 100% { transform: skew(0deg); }
    20% { transform: skew(-0.5deg); }
    40% { transform: skew(0.5deg); }
    60% { transform: skew(0deg); }
    80% { transform: skew(-0.3deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .dw-404__code--glitch,
    .dw-404__code--glitch::before,
    .dw-404__code--glitch::after,
    .dw-404__glow-orb {
      animation: none;
    }
  }

  /* ==========================================
     CONTENT
     ========================================== */
  
  .dw-404__content {
    margin-bottom: 60px;
  }

  .dw-404__heading {
    font-size: 28px;
    font-weight: 700;
    margin: 0 0 16px;
    line-height: 1.2;
  }

  @media (min-width: 750px) {
    .dw-404__heading {
      font-size: 40px;
    }
  }

  .dw-404__text {
    font-size: 16px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.7);
    margin: 0 0 32px;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  @media (min-width: 750px) {
    .dw-404__text {
      font-size: 18px;
    }
  }

  /* ==========================================
     ACTIONS
     ========================================== */
  
  .dw-404__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    justify-content: center;
    margin-bottom: 40px;
  }

  /* Buttons */
  .dw-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 32px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    border-radius: 6px;
    transition: all 0.2s ease;
    cursor: pointer;
    border: 2px solid transparent;
    position: relative;
  }

  .dw-btn--primary {
    background: var(--404-accent);
    color: #0a0a0a;
    border-color: var(--404-accent);
  }

  .dw-btn--primary:hover {
    filter: brightness(0.9);
    transform: translateY(-2px);
  }

  .dw-btn--secondary {
    background: transparent;
    color: var(--404-text);
    border-color: rgba(255, 255, 255, 0.3);
  }

  .dw-btn--secondary:hover {
    border-color: var(--404-accent);
    background: rgba(196, 214, 0, 0.1);
  }

  .dw-btn--gradient {
    background: transparent;
    color: #fff;
    border: none;
    position: relative;
    z-index: 1;
    overflow: hidden;
  }

  .dw-btn--gradient::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 6px;
    padding: 2px;
    background: linear-gradient(90deg, var(--404-glow-1), var(--404-glow-2), var(--404-glow-1), var(--404-glow-2));
    background-size: 300% 100%;
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    z-index: -1;
  }

  .dw-btn--gradient-animate::before {
    animation: gradient-shift 3s linear infinite;
  }

  .dw-btn--gradient::after {
    content: '';
    position: absolute;
    inset: 2px;
    border-radius: 4px;
    background: var(--404-bg);
    z-index: -1;
  }

  .dw-btn--gradient span {
    position: relative;
    z-index: 2;
  }

  .dw-btn--gradient-glow {
    background: transparent;
    color: #fff;
    border: none;
    position: relative;
    z-index: 1;
    overflow: visible;
  }

  .dw-btn--gradient-glow::before {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 8px;
    background: linear-gradient(90deg, var(--404-glow-1), var(--404-glow-2), var(--404-glow-1), var(--404-glow-2));
    background-size: 300% 100%;
    z-index: -2;
    animation: gradient-shift 3s linear infinite;
    filter: blur(10px);
    opacity: 0.7;
  }

  .dw-btn--gradient-glow::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 6px;
    background: var(--404-bg);
    z-index: -1;
  }

  .dw-btn--gradient-glow:hover::before {
    filter: blur(15px);
    opacity: 1;
  }

  .dw-btn--gradient-glow span {
    position: relative;
    z-index: 2;
  }

  @keyframes gradient-shift {
    0% { background-position: 0% 50%; }
    100% { background-position: 300% 50%; }
  }

  /* ==========================================
     SEARCH
     ========================================== */
  
  .dw-404__search {
    max-width: 400px;
    margin: 0 auto;
  }

  .dw-404__search-label {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.5);
    margin: 0 0 12px;
  }

  .dw-404__search-form {
    display: flex;
    gap: 0;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.2s ease;
  }

  .dw-404__search-form:focus-within {
    border-color: var(--404-accent);
  }

  .dw-404__search-input {
    flex: 1;
    background: transparent;
    border: none;
    padding: 14px 16px;
    color: var(--404-text);
    font-size: 15px;
    outline: none;
  }

  .dw-404__search-input::placeholder {
    color: rgba(255, 255, 255, 0.4);
  }

  .dw-404__search-btn {
    background: transparent;
    border: none;
    padding: 14px 16px;
    color: rgba(255, 255, 255, 0.6);
    cursor: pointer;
    transition: color 0.2s ease;
  }

  .dw-404__search-btn:hover {
    color: var(--404-accent);
  }

  /* ==========================================
     POPULAR LINKS
     ========================================== */
  
  .dw-404__links {
    padding-top: 40px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .dw-404__links-heading {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.5);
    margin: 0 0 20px;
  }

  .dw-404__links-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }

  @media (min-width: 550px) {
    .dw-404__links-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 750px) {
    .dw-404__links-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .dw-404__link-card {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 20px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    text-decoration: none;
    color: var(--404-text);
    transition: all 0.2s ease;
  }

  .dw-404__link-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: var(--404-accent);
    transform: translateY(-2px);
  }

  .dw-404__link-icon {
    color: var(--404-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .dw-404__link-text {
    flex: 1;
    font-size: 14px;
    font-weight: 500;
  }

  .dw-404__link-arrow {
    color: rgba(255, 255, 255, 0.3);
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
  }

  .dw-404__link-card:hover .dw-404__link-arrow {
    color: var(--404-accent);
    transform: translateX(4px);
  }
</style>

{% schema %}
{
  "name": "DW 404 Page",
  "tag": "section",
  "class": "dw-404-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "error_code",
      "label": "Error code",
      "default": "404"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Page not found"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Looks like you've wandered off the path. The page you're looking for doesn't exist or has been moved."
    },
    {
      "type": "header",
      "content": "Primary Button"
    },
    {
      "type": "text",
      "id": "button_1_text",
      "label": "Button text",
      "default": "Back to Home"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Button link",
      "default": "/"
    },
    {
      "type": "select",
      "id": "button_1_style",
      "label": "Button style",
      "options": [
        { "value": "primary", "label": "Primary (lime)" },
        { "value": "secondary", "label": "Secondary (outline)" },
        { "value": "gradient", "label": "Cyber Gradient" },
        { "value": "gradient-glow", "label": "Cyber Glow ✨" }
      ],
      "default": "primary"
    },
    {
      "type": "header",
      "content": "Secondary Button"
    },
    {
      "type": "text",
      "id": "button_2_text",
      "label": "Button text",
      "info": "Leave blank to hide"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_2_style",
      "label": "Button style",
      "options": [
        { "value": "primary", "label": "Primary (lime)" },
        { "value": "secondary", "label": "Secondary (outline)" },
        { "value": "gradient", "label": "Cyber Gradient" },
        { "value": "gradient-glow", "label": "Cyber Glow ✨" }
      ],
      "default": "secondary"
    },
    {
      "type": "header",
      "content": "Search"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show search",
      "default": true
    },
    {
      "type": "text",
      "id": "search_label",
      "label": "Search label",
      "default": "Or try searching:"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search placeholder",
      "default": "Search products..."
    },
    {
      "type": "header",
      "content": "Popular Links"
    },
    {
      "type": "checkbox",
      "id": "show_popular_links",
      "label": "Show popular links",
      "default": true
    },
    {
      "type": "text",
      "id": "popular_heading",
      "label": "Section heading",
      "default": "Popular Pages"
    },
    {
      "type": "header",
      "content": "Effects"
    },
    {
      "type": "checkbox",
      "id": "enable_glitch",
      "label": "Enable glitch effect on 404",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_glow",
      "label": "Enable background glow",
      "default": true
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#0a0a0a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#c4d600"
    },
    {
      "type": "color",
      "id": "glow_color_1",
      "label": "Glow color 1",
      "default": "#c4d600"
    },
    {
      "type": "color",
      "id": "glow_color_2",
      "label": "Glow color 2",
      "default": "#ff00ff"
    },
    {
      "type": "color",
      "id": "glow_color_3",
      "label": "Glow color 3",
      "default": "#00d4ff"
    }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Link",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "home", "label": "Home" },
            { "value": "shop", "label": "Shop/Cart" },
