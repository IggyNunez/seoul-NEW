{
  "type": "footer",
  "name": "Footer",
  "sections": {
    "footer_main": {
      "type": "footer",
      "blocks": {
        "col_logo": {
          "type": "group",
          "settings": {
            "content_direction": "column",
            "vertical_on_mobile": true,
            "horizontal_alignment": "flex-start",
            "vertical_alignment": "flex-start",
            "gap": 16,
            "width": "fill",
            "inherit_color_scheme": true
          },
          "blocks": {
            "logo_img": {
              "type": "logo",
              "settings": {
                "logo": "shopify://shop_images/Primary Logo.png",
                "logo_width": 160
              }
            },
            "tagline_text": {
              "type": "text",
              "settings": {
                "text": "Seoul you need for that glow.",
                "width": "100%",
                "alignment": "left",
                "type_preset": "body"
              }
            },
            "social_icons": {
              "type": "social-links",
              "settings": {
                "style": "icon"
              }
            }
          },
          "block_order": ["logo_img", "tagline_text", "social_icons"]
        },
        "col_shop": {
          "type": "group",
          "settings": {
            "content_direction": "column",
            "vertical_on_mobile": true,
            "horizontal_alignment": "flex-start",
            "vertical_alignment": "flex-start",
            "gap": 12,
            "width": "fill",
            "inherit_color_scheme": true
          },
          "blocks": {
            "shop_heading": {
              "type": "text",
              "settings": {
                "text": "Shop",
                "width": "100%",
                "alignment": "left",
                "type_preset": "h4"
              }
            },
            "shop_menu": {
              "type": "menu",
              "settings": {
                "menu": "main-menu",
                "layout": "list"
              }
            }
          },
          "block_order": ["shop_heading", "shop_menu"]
        },
        "col_newsletter": {
          "type": "group",
          "settings": {
            "content_direction": "column",
            "vertical_on_mobile": true,
            "horizontal_alignment": "flex-start",
            "vertical_alignment": "flex-start",
            "gap": 12,
            "width": "fill",
            "inherit_color_scheme": true
          },
          "blocks": {
            "newsletter_heading": {
              "type": "text",
              "settings": {
                "text": "Be the first to hear from us",
                "width": "100%",
                "alignment": "left",
                "type_preset": "h4"
              }
            },
            "newsletter_sub": {
              "type": "text",
              "settings": {
                "text": "Sign up for new drops, skincare tips & exclusive offers.",
                "width": "100%",
                "alignment": "left",
                "type_preset": "body"
              }
            },
            "newsletter_form": {
              "type": "email-signup",
              "settings": {
                "width": "fill"
              }
            }
          },
          "block_order": ["newsletter_heading", "newsletter_sub", "newsletter_form"]
        }
      },
      "block_order": ["col_logo", "col_shop", "col_newsletter"],
      "settings": {
        "section_width": "page-width",
        "gap": 48,
        "color_scheme": "scheme-6",
        "padding-block-start": 80,
        "padding-block-end": 48
      }
    },
    "footer_utilities": {
      "type": "footer-utilities",
      "blocks": {
        "copyright": {
          "type": "footer-copyright",
          "settings": {}
        },
        "policy_list": {
          "type": "footer-policy-list",
          "settings": {}
        }
      },
      "block_order": ["copyright", "policy_list"],
      "settings": {
        "section_width": "page-width",
        "gap": 24,
        "divider_thickness": 1,
        "color_scheme": "scheme-6",
        "padding-block-start": 20,
        "padding-block-end": 20
      }
    }
  },
  "order": ["footer_main", "footer_utilities"]
}
