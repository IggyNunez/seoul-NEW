{%- comment -%}
  Seoul Glow Lab - UGC Gallery Section
  "Join 5,000+ Happy Customers" with stats and photo grid
{%- endcomment -%}

{%- liquid
  assign title = section.settings.title | default: 'Join 5,000+ Happy Customers'
  assign stat_1_value = section.settings.stat_1_value | default: '5K+'
  assign stat_1_label = section.settings.stat_1_label | default: 'Happy Customers'
  assign stat_2_value = section.settings.stat_2_value | default: '4.9'
  assign stat_2_label = section.settings.stat_2_label | default: 'Average Rating'
  assign stat_3_value = section.settings.stat_3_value | default: '87'
  assign stat_3_label = section.settings.stat_3_label | default: 'Countries'

  assign padding_top = section.settings.padding_top | default: 100
  assign padding_bottom = section.settings.padding_bottom | default: 100
  assign padding_mobile_top = section.settings.padding_mobile_top | default: 60
  assign padding_mobile_bottom = section.settings.padding_mobile_bottom | default: 60

  assign _ugc_bg = section.settings.bg_color | default: '#0a0a0f'
  assign _ugc_text = section.settings.text_color | default: '#ffffff'
  assign _ugc_accent = section.settings.accent_color | default: '#9333ea'
  assign _ugc_accent2 = section.settings.accent_secondary | default: '#ec4899'
-%}

<section
  class="casa-ugc"
  id="casa-ugc-{{ section.id }}"
  style="
    --cugc-padding-top: {{ padding_top }}px;
    --cugc-padding-bottom: {{ padding_bottom }}px;
    --cugc-padding-mobile-top: {{ padding_mobile_top }}px;
    --cugc-padding-mobile-bottom: {{ padding_mobile_bottom }}px;
    --cugc-bg: {{ _ugc_bg }};
    --cugc-text: {{ _ugc_text }};
    --cugc-accent: {{ _ugc_accent }};
    --cugc-accent2: {{ _ugc_accent2 }};
  "
>
  <div class="casa-ugc__container">
    {%- if title != blank -%}
      <h2 class="casa-ugc__title">{{ title }}</h2>
    {%- endif -%}

    {%- comment -%} Stats Row {%- endcomment -%}
    <div class="casa-ugc__stats">
      <div class="casa-ugc__stat">
        <span class="casa-ugc__stat-value">{{ stat_1_value }}</span>
        <span class="casa-ugc__stat-label">{{ stat_1_label }}</span>
      </div>
      <div class="casa-ugc__stat">
        <span class="casa-ugc__stat-value">{{ stat_2_value }}</span>
        <span class="casa-ugc__stat-label">{{ stat_2_label }}</span>
      </div>
      <div class="casa-ugc__stat">
        <span class="casa-ugc__stat-value">{{ stat_3_value }}</span>
        <span class="casa-ugc__stat-label">{{ stat_3_label }}</span>
      </div>
    </div>

  </div>

  {%- comment -%} Photo Grid: wrapper is display:flex justify-content:center with overflow-x:auto; inner grid is inline-flex {%- endcomment -%}
  <div class="casa-ugc__grid-wrap">
  <div class="casa-ugc__grid">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'photo' -%}
            <div class="casa-ugc__item" {{ block.shopify_attributes }}>
              {%- if block.settings.video != blank -%}
                <video class="casa-ugc__item-video" autoplay loop muted playsinline
                  {%- if block.settings.image != blank %} poster="{{ block.settings.image | image_url: width: 600 }}"{% endif %}>
                  {%- for source in block.settings.video.sources -%}
                    <source src="{{ source.url }}" type="{{ source.mime_type }}">
                  {%- endfor -%}
                </video>
              {%- elsif block.settings.video_url != blank -%}
                <video class="casa-ugc__item-video" src="{{ block.settings.video_url }}" autoplay loop muted playsinline
                  {%- if block.settings.image != blank %} poster="{{ block.settings.image | image_url: width: 600 }}"{% endif %}></video>
              {%- endif -%}
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 600 }}"
                  alt="{{ block.settings.alt | default: 'Customer photo' | escape }}"
                  class="casa-ugc__item-img{% if block.settings.video != blank or block.settings.video_url != blank %} casa-ugc__item-img--poster{% endif %}"
                  loading="lazy"
                >
              {%- endif -%}
            </div>
          {%- when '@app' -%}
            <div class="casa-ugc__item-app" {{ block.shopify_attributes }}>
              {%- render block -%}
            </div>
          {%- when 'custom-liquid' -%}
            <div class="casa-ugc__item-app" {{ block.shopify_attributes }}>
              {{ block.settings.custom_liquid }}
            </div>
        {%- endcase -%}
      {%- endfor -%}

      {%- if section.blocks.size == 0 -%}
        <div class="casa-ugc__item"></div>
        <div class="casa-ugc__item"></div>
        <div class="casa-ugc__item"></div>
        <div class="casa-ugc__item"></div>
        <div class="casa-ugc__item"></div>
        <div class="casa-ugc__item"></div>
      {%- endif -%}
  </div>
  </div>
</section>

<script>
(function() {
  var root = document.getElementById('casa-ugc-{{ section.id }}');
  if (!root) return;

  /* ── Video poster fade-out on play ── */
  root.querySelectorAll('.casa-ugc__item').forEach(function(item) {
    var video = item.querySelector('.casa-ugc__item-video');
    var poster = item.querySelector('.casa-ugc__item-img--poster');
    if (video && poster) {
      video.addEventListener('playing', function() { poster.style.opacity = '0'; }, { once: true });
    }
  });

  /* ── Intersection observer for lazy play/pause ── */
  if ('IntersectionObserver' in window) {
    var obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) e.target.play().catch(function(){});
        else e.target.pause();
      });
    }, { rootMargin: '100px' });
    root.querySelectorAll('.casa-ugc__item-video').forEach(function(v) { obs.observe(v); });
  }

  /* ── Lightbox: navigate ALL items (photo blocks + app blocks + custom-liquid) ── */
  /* Select every direct child of the grid regardless of type */
  var grid = root.querySelector('.casa-ugc__grid');
  var allItems = grid
    ? Array.prototype.slice.call(grid.children)
    : [];
  if (allItems.length === 0) return;

  var modal = null;
  var modalContent = null;
  var prevBtn = null;
  var nextBtn = null;
  var currentIndex = -1;

  function buildModal() {
    modal = document.createElement('div');
    modal.className = 'casa-ugc-modal';

    var closeBtn = document.createElement('button');
    closeBtn.className = 'casa-ugc-modal__close';
    closeBtn.setAttribute('aria-label', 'Close');
    closeBtn.innerHTML = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';
    closeBtn.addEventListener('click', closeModal);

    /* Arrows: position:fixed so they show regardless of any parent CSS */
    prevBtn = document.createElement('button');
    prevBtn.className = 'casa-ugc-modal__arrow casa-ugc-modal__arrow--prev';
    prevBtn.setAttribute('aria-label', 'Previous');
    prevBtn.innerHTML = '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>';
    prevBtn.addEventListener('click', function(e) { e.stopPropagation(); navigateTo(currentIndex - 1); });

    nextBtn = document.createElement('button');
    nextBtn.className = 'casa-ugc-modal__arrow casa-ugc-modal__arrow--next';
    nextBtn.setAttribute('aria-label', 'Next');
    nextBtn.innerHTML = '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>';
    nextBtn.addEventListener('click', function(e) { e.stopPropagation(); navigateTo(currentIndex + 1); });

    modalContent = document.createElement('div');
    modalContent.className = 'casa-ugc-modal__content';

    modal.appendChild(closeBtn);
    modal.appendChild(prevBtn);
    modal.appendChild(modalContent);
    modal.appendChild(nextBtn);

    modal.addEventListener('click', function(e) {
      if (e.target === modal) closeModal();
    });

    document.body.appendChild(modal);
  }

  function updateArrows() {
    var atStart = currentIndex <= 0;
    var atEnd   = currentIndex >= allItems.length - 1;
    prevBtn.style.opacity       = atStart ? '0.35' : '1';
    prevBtn.style.pointerEvents = atStart ? 'none' : '';
    nextBtn.style.opacity       = atEnd   ? '0.35' : '1';
    nextBtn.style.pointerEvents = atEnd   ? 'none' : '';
  }

  function openModal(index) {
    if (!modal) buildModal();
    currentIndex = index;
    var item = allItems[index];

    var oldVid = modalContent.querySelector('video');
    if (oldVid) oldVid.pause();
    modalContent.innerHTML = '';

    /* Only use OUR video (.casa-ugc__item-video) — app block videos are
       streaming/blob URLs that cannot be cloned into a new video element */
    var ownVideo = item.querySelector('.casa-ugc__item-video');
    var ownImg   = item.querySelector('.casa-ugc__item-img');

    if (ownVideo) {
      var vid = document.createElement('video');
      vid.className = 'casa-ugc-modal__video';
      vid.setAttribute('controls', '');
      vid.setAttribute('playsinline', '');
      vid.setAttribute('autoplay', '');
      vid.setAttribute('muted', '');  /* required for autoplay in most browsers */

      if (ownVideo.getAttribute('src')) {
        vid.setAttribute('src', ownVideo.getAttribute('src'));
      } else {
        ownVideo.querySelectorAll('source').forEach(function(s) {
          var ns = document.createElement('source');
          ns.setAttribute('src', s.getAttribute('src'));
          ns.setAttribute('type', s.getAttribute('type') || '');
          vid.appendChild(ns);
        });
      }
      if (ownImg) vid.setAttribute('poster', ownImg.getAttribute('src'));
      else if (ownVideo.getAttribute('poster')) vid.setAttribute('poster', ownVideo.getAttribute('poster'));

      modalContent.appendChild(vid);
      vid.load();
      vid.play().catch(function(){});

    } else if (ownImg) {
      var img = document.createElement('img');
      img.className = 'casa-ugc-modal__image';
      img.src = ownImg.getAttribute('src');
      img.alt = ownImg.getAttribute('alt') || '';
      modalContent.appendChild(img);

    } else {
      /* App block or empty — try any visible img as thumbnail */
      var anyImg = item.querySelector('img');
      if (anyImg && anyImg.getAttribute('src')) {
        var img2 = document.createElement('img');
        img2.className = 'casa-ugc-modal__image';
        img2.src = anyImg.getAttribute('src');
        modalContent.appendChild(img2);
      }
      /* If still nothing, modal opens with empty content — arrows still work */
    }

    updateArrows();
    modal.classList.add('casa-ugc-modal--open');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    if (!modal) return;
    var vid = modalContent && modalContent.querySelector('video');
    if (vid) vid.pause();
    modalContent.innerHTML = '';
    modal.classList.remove('casa-ugc-modal--open');
    document.body.style.overflow = '';
    currentIndex = -1;
  }

  function navigateTo(index) {
    if (index < 0 || index >= allItems.length) return;
    openModal(index);
  }

  /* Keyboard — guard prevents duplicate listeners on theme re-renders */
  if (!window._casaUgcKbAdded) {
    window._casaUgcKbAdded = true;
    document.addEventListener('keydown', function(e) {
      if (currentIndex < 0) return;
      if (e.key === 'Escape') closeModal();
      else if (e.key === 'ArrowLeft') navigateTo(currentIndex - 1);
      else if (e.key === 'ArrowRight') navigateTo(currentIndex + 1);
    });
  }

  /* Click handlers — overlay catches clicks even inside iframes */
  allItems.forEach(function(item, i) {
    item.style.position = 'relative';
    item.style.cursor = 'pointer';
    var overlay = document.createElement('div');
    overlay.style.cssText = 'position:absolute;top:0;left:0;right:0;bottom:0;z-index:10;cursor:pointer;';
    item.appendChild(overlay);
    overlay.addEventListener('click', function(e) {
      e.stopPropagation();
      openModal(i);
    });
  });
})();
</script>

