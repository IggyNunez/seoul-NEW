{% stylesheet %}
/* ══════════════════════════════════════════════════════════════════════════
   CASA UGC GALLERY
   "Join 5,000+ Happy Customers" — dark section with stats + photo grid
   ══════════════════════════════════════════════════════════════════════════ */

.casa-ugc {
  --cugc-padding-top: 100px;
  --cugc-padding-bottom: 100px;
  --cugc-padding-mobile-top: 60px;
  --cugc-padding-mobile-bottom: 60px;

  background: var(--cugc-bg, #0a0a0f);
  padding: var(--cugc-padding-top) 0 var(--cugc-padding-bottom);
}

.casa-ugc__container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 24px;
}

/* ── Title ── */
.casa-ugc__title {
  font-size: clamp(24px, 4vw, 36px);
  font-weight: 300;
  color: var(--cugc-text, #ffffff);
  text-align: center;
  margin: 0 0 32px 0;
  letter-spacing: -0.5px;
  line-height: 1.3;
}

/* ── Stats ── */
.casa-ugc__stats {
  display: flex;
  justify-content: center;
  gap: 48px;
  margin-bottom: 40px;
}

.casa-ugc__stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.casa-ugc__stat-value {
  font-size: clamp(32px, 5vw, 48px);
  font-weight: 300;
  background: linear-gradient(90deg, var(--cugc-accent, #9333ea), var(--cugc-accent2, #ec4899));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1.3;
}

.casa-ugc__stat-label {
  font-size: 13px;
  color: color-mix(in srgb, var(--cugc-text, #ffffff) 50%, transparent);
  margin-top: 2px;
}

/* ── Photo Grid ── */
/*
  Centering via margin-inline:auto on the grid — works in every browser.
  The wrap is a plain scroll container. The grid sets its own width to
  max-content (exactly as wide as its items), then auto margins center it
  when there's room. On overflow, margins collapse to 0 and it scrolls
  from the left edge. No justify-content needed, no safe/unsafe issues.
*/
.casa-ugc__grid-wrap {
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}
.casa-ugc__grid-wrap::-webkit-scrollbar {
  display: none;
}
.casa-ugc__grid {
  display: flex;
  gap: 16px;
  flex-wrap: nowrap;
  padding: 0 24px;
  box-sizing: border-box;
  width: max-content;
  margin-inline: auto;
}

.casa-ugc__item {
  aspect-ratio: 9 / 16;
  width: clamp(120px, 12vw, 160px);
  border-radius: 12px;
  overflow: hidden;
  position: relative;
  flex-shrink: 0;
}

/* App blocks — explicit width prevents the app injecting width:100%
   which would expand the grid wider than the wrap and break centering */
.casa-ugc__item-app {
  width: clamp(120px, 12vw, 160px);
  aspect-ratio: 9 / 16;
  flex-shrink: 0;
  overflow: hidden;
  border-radius: 12px;
  cursor: pointer;
  position: relative;
}

.casa-ugc__item-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.casa-ugc__item-video {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 1;
}

.casa-ugc__item-img--poster {
  position: relative;
  z-index: 0;
  transition: opacity 0.6s ease;
}

/* Fallback gradient backgrounds (shown only when item has no media loaded).
   opacity intentionally removed — it was making real photo/video content
   semi-transparent. The gradient is safely hidden behind media via object-fit. */
.casa-ugc__item:nth-child(1) { background: linear-gradient(135deg, #9333ea 0%, #ec4899 100%); }
.casa-ugc__item:nth-child(2) { background: linear-gradient(135deg, #06b6d4 0%, #3b82f6 100%); }
.casa-ugc__item:nth-child(3) { background: linear-gradient(135deg, #ec4899 0%, #f97316 100%); }
.casa-ugc__item:nth-child(4) { background: linear-gradient(135deg, #22c55e 0%, #10b981 100%); }
.casa-ugc__item:nth-child(5) { background: linear-gradient(135deg, #f59e0b 0%, #ea580c 100%); }
.casa-ugc__item:nth-child(6) { background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%); }

/* ══════════════════════════════════════════════════════════════════════════
   RESPONSIVE
   ══════════════════════════════════════════════════════════════════════════ */

@media (max-width: 768px) {
  .casa-ugc {
    padding: var(--cugc-padding-mobile-top) 0 var(--cugc-padding-mobile-bottom);
  }

  .casa-ugc__container {
    padding: 0 16px;
  }

  .casa-ugc__stats {
    gap: 32px;
    margin-bottom: 32px;
  }

  .casa-ugc__stat-label {
    font-size: 11px;
  }

  .casa-ugc__grid {
    gap: 12px;
    padding: 0 16px;
  }
}

@media (max-width: 480px) {
  .casa-ugc__stats {
    gap: 24px;
  }

  .casa-ugc__grid {
    gap: 8px;
    padding: 0 12px;
  }

  .casa-ugc__item {
    border-radius: 10px;
  }
}

/* ══════════════════════════════════════════════════════════════════════════
   LIGHTBOX MODAL
   ══════════════════════════════════════════════════════════════════════════ */

.casa-ugc-modal {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.92);
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.25s ease, visibility 0.25s ease;
}

.casa-ugc-modal--open {
  opacity: 1;
  visibility: visible;
}

/* Close button */
.casa-ugc-modal__close {
  position: fixed;
  top: 16px;
  right: 16px;
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
  color: #000;
  cursor: pointer;
  z-index: 10001;
  box-shadow: 0 2px 8px rgba(0,0,0,0.4);
}
.casa-ugc-modal__close:hover { background: #fff; }

.casa-ugc-modal__content {
  display: flex;
  align-items: center;
  justify-content: center;
}

.casa-ugc-modal__video {
  width: min(72vw, 380px);
  max-height: 80vh;
  border-radius: 12px;
  background: #000;
  outline: none;
  display: block;
}

.casa-ugc-modal__image {
  width: min(72vw, 380px);
  max-height: 80vh;
  border-radius: 12px;
  object-fit: contain;
  display: block;
}

/* Arrows — position:fixed, white background, impossible to miss */
.casa-ugc-modal__arrow {
  position: fixed;
  top: 50%;
