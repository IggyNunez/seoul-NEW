{%- comment -%}
  Seoul Glow Lab Products Grid Section
  Premium product grid with animations, multiple layouts, CRO features, and full customization
{%- endcomment -%}

{%- liquid
  # Layout settings
  assign layout = section.settings.layout | default: 'grid'
  assign columns = section.settings.columns | default: 4
  assign gap = section.settings.gap | default: 32
  assign product_limit = section.settings.product_limit | default: 4

  # Style settings
  assign bg_style = section.settings.background_style | default: 'light'
  assign accent_primary = section.settings.accent_primary | default: '#9333ea'
  assign accent_secondary = section.settings.accent_secondary | default: '#ec4899'
  assign card_style = section.settings.card_style | default: 'default'

  # Animation settings
  assign animation = section.settings.animation | default: 'fade-up'
  assign stagger_delay = section.settings.stagger_delay | default: 100

  # Padding
  assign padding_top = section.settings.padding_top | default: 120
  assign padding_bottom = section.settings.padding_bottom | default: 120
  assign padding_mobile_top = section.settings.padding_mobile_top | default: 60
  assign padding_mobile_bottom = section.settings.padding_mobile_bottom | default: 60

  # Header settings
  assign header_alignment = section.settings.header_alignment | default: 'center'
  assign title_size = section.settings.title_size | default: 'large'
  assign show_divider = section.settings.show_divider

  # CRO Feature settings
  assign show_quick_add = section.settings.show_quick_add
  assign show_variant_swatches = section.settings.show_variant_swatches
  assign show_wishlist = section.settings.show_wishlist
  assign show_stock_urgency = section.settings.show_stock_urgency
  assign stock_threshold = section.settings.stock_threshold | default: 5
  assign show_installment = section.settings.show_installment
  assign installment_count = section.settings.installment_count | default: 4
  assign show_quick_view = section.settings.show_quick_view
  assign show_hover_video = section.settings.show_hover_video
  assign show_savings_highlight = section.settings.show_savings_highlight
  assign show_social_proof = section.settings.show_social_proof

  # Text colors based on background
  if bg_style == 'dark' or bg_style == 'gradient-dark'
    assign text_primary = '#ffffff'
    assign text_secondary = 'rgba(255, 255, 255, 0.7)'
    assign tag_color = accent_primary
  else
    assign text_primary = '#0a0a0a'
    assign text_secondary = '#6b7280'
    assign tag_color = accent_primary
  endif

  # Title sizes
  case title_size
    when 'small'
      assign title_font_size = '32px'
      assign title_font_size_mobile = '24px'
    when 'medium'
      assign title_font_size = '40px'
      assign title_font_size_mobile = '28px'
    when 'large'
      assign title_font_size = '48px'
      assign title_font_size_mobile = '32px'
    when 'xlarge'
      assign title_font_size = '56px'
      assign title_font_size_mobile = '36px'
  endcase

  # Get collection
  assign collection = collections[section.settings.collection]
-%}

<section
  id="casa-pg-{{ section.id }}"
  class="casa-products-grid casa-products-grid--{{ layout }} casa-products-grid--bg-{{ bg_style }} casa-products-grid--cards-{{ card_style }}"
  style="
    --pg-padding-top: {{ padding_top }}px;
    --pg-padding-bottom: {{ padding_bottom }}px;
    --pg-padding-mobile-top: {{ padding_mobile_top }}px;
    --pg-padding-mobile-bottom: {{ padding_mobile_bottom }}px;
    --pg-columns: {{ columns }};
    --pg-gap: {{ gap }}px;
    --pg-accent-primary: {{ accent_primary }};
    --pg-accent-secondary: {{ accent_secondary }};
    --pg-text-primary: {{ text_primary }};
    --pg-text-secondary: {{ text_secondary }};
    --pg-tag-color: {{ tag_color }};
    --pg-title-size: {{ title_font_size }};
    --pg-title-size-mobile: {{ title_font_size_mobile }};
    --card-title-size: {{ section.settings.card_title_size | default: 16 }}px;
    --card-info-gap: {{ section.settings.card_info_gap | default: 8 }}px;
    {%- if section.settings.atc_bg_1 != blank and section.settings.atc_bg_2 != blank -%}--card-atc-bg: linear-gradient(135deg, {{ section.settings.atc_bg_1 }}, {{ section.settings.atc_bg_2 }});{%- endif -%}
    {%- if section.settings.atc_text != blank -%}--card-atc-text: {{ section.settings.atc_text }};{%- endif -%}
    {%- if section.settings.options_bg_1 != blank and section.settings.options_bg_2 != blank -%}--card-options-bg: linear-gradient(135deg, {{ section.settings.options_bg_1 }}, {{ section.settings.options_bg_2 }});{%- endif -%}
    {%- if section.settings.options_text != blank -%}--card-options-text: {{ section.settings.options_text }};{%- endif -%}
    --pg-max-w: {% case section.settings.section_width %}{% when 'full' %}100%{% when 'wide' %}1600px{% when 'narrow' %}1200px{% else %}1400px{% endcase %};
  "
  data-animation="{{ animation }}"
>
  {%- comment -%} Ambient glow effects for dark backgrounds {%- endcomment -%}
  {%- if bg_style == 'dark' or bg_style == 'gradient-dark' -%}
    <div class="casa-products-grid__ambient-glow casa-products-grid__ambient-glow--left"></div>
    <div class="casa-products-grid__ambient-glow casa-products-grid__ambient-glow--right"></div>
  {%- endif -%}

  <div class="casa-products-grid__container">
    {%- comment -%} Header {%- endcomment -%}
    <div class="casa-products-grid__header casa-products-grid__header--{{ header_alignment }}">
      {%- if section.settings.tag != blank -%}
        <span class="casa-products-grid__tag">{{ section.settings.tag }}</span>
      {%- endif -%}

      {%- if section.settings.title != blank -%}
        <h2 class="casa-products-grid__title">{{ section.settings.title }}</h2>
      {%- endif -%}

      {%- if show_divider -%}
        <div class="casa-products-grid__divider"></div>
      {%- endif -%}

      {%- if section.settings.subtitle != blank -%}
        <p class="casa-products-grid__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} Products Grid {%- endcomment -%}
    <div class="casa-products-grid__grid" role="list">
      {%- if collection != blank and collection.products.size > 0 -%}
        {%- for product in collection.products limit: product_limit -%}
          <div
            class="casa-products-grid__item"
            style="--item-delay: {{ forloop.index0 | times: stagger_delay }}ms;"
            role="listitem"
          >
            {%- render 'casa-product-card',
              product: product,
              variant: card_style,
              index: forloop.index0,
              show_quick_add: show_quick_add,
              show_variant_swatches: show_variant_swatches,
              show_wishlist: show_wishlist,
              show_stock_urgency: show_stock_urgency,
              stock_threshold: stock_threshold,
              show_installment: show_installment,
              installment_count: installment_count,
              show_quick_view: show_quick_view,
              show_hover_video: show_hover_video,
              show_social_proof: show_social_proof
            -%}
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- comment -%} Placeholder cards when no collection selected {%- endcomment -%}
        {%- for i in (1..product_limit) -%}
          <div class="casa-products-grid__item casa-products-grid__placeholder" style="--item-delay: {{ forloop.index0 | times: stagger_delay }}ms;">
            <div class="casa-products-grid__placeholder-image">
              <div class="casa-products-grid__placeholder-shape"></div>
            </div>
            <div class="casa-products-grid__placeholder-info">
              <div class="casa-products-grid__placeholder-title"></div>
              <div class="casa-products-grid__placeholder-price"></div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- comment -%} View All Button {%- endcomment -%}
    {%- if section.settings.view_all_text != blank and collection != blank -%}
      <div class="casa-products-grid__footer">
        <a href="{{ collection.url }}" class="casa-products-grid__view-all">
          <span>{{ section.settings.view_all_text }}</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

<script>
  (function() {
    function initProductsGrid() {
      var section = document.getElementById('casa-pg-{{ section.id }}');
      if (!section || section.dataset.initialized) return;
      section.dataset.initialized = 'true';

      var animation = section.dataset.animation;
      var items = section.querySelectorAll('.casa-products-grid__item');

      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        items.forEach(function(item) {
          item.classList.add('casa-products-grid__item--visible');
          item.style.animation = 'none';
        });
        return;
      }

      if (animation && animation !== 'none') {
        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('casa-products-grid__item--visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

        items.forEach(function(item) { observer.observe(item); });
      } else {
        items.forEach(function(item) { item.classList.add('casa-products-grid__item--visible'); });
      }
    }

    // Run now if DOM is ready, otherwise wait
    if (document.readyState !== 'loading') {
      initProductsGrid();
    } else {
      document.addEventListener('DOMContentLoaded', initProductsGrid);
    }

    // Re-init on Shopify section events (customizer add/reorder/select)
    document.addEventListener('shopify:section:load', function(e) {
      if (e.target.querySelector('#casa-pg-{{ section.id }}')) initProductsGrid();
    });
  })();
</script>

