{% stylesheet %}
/* ==========================================================================
   BASE STYLES
   ========================================================================== */

.casa-products-grid {
  position: relative;
  padding: var(--pg-padding-top) 80px var(--pg-padding-bottom);
  overflow: hidden;
}

.casa-products-grid__container {
  max-width: var(--pg-max-w, 1400px);
  margin: 0 auto;
  position: relative;
  z-index: 1;
}

/* ==========================================================================
   BACKGROUNDS
   ========================================================================== */

.casa-products-grid--bg-light {
  background: #ffffff;
}

.casa-products-grid--bg-subtle {
  background: #fafafa;
}

.casa-products-grid--bg-dark {
  background: #0a0a0f;
}

.casa-products-grid--bg-gradient-dark {
  background: linear-gradient(180deg, #0a0a0f 0%, #12121a 50%, #0a0a0f 100%);
}

/* Ambient glow */
.casa-products-grid__ambient-glow {
  position: absolute;
  width: 500px;
  height: 500px;
  border-radius: 50%;
  filter: blur(120px);
  opacity: 0.3;
  pointer-events: none;
}

.casa-products-grid__ambient-glow--left {
  top: 20%;
  left: -10%;
  background: var(--pg-accent-primary);
}

.casa-products-grid__ambient-glow--right {
  bottom: 20%;
  right: -10%;
  background: var(--pg-accent-secondary);
}

/* ==========================================================================
   HEADER
   ========================================================================== */

.casa-products-grid__header {
  margin-bottom: 60px;
}

.casa-products-grid__header--left {
  text-align: left;
}

.casa-products-grid__header--center {
  text-align: center;
}

.casa-products-grid__header--right {
  text-align: right;
}

.casa-products-grid__tag {
  display: inline-block;
  font-size: 12px;
  font-weight: 600;
  color: var(--pg-tag-color);
  text-transform: uppercase;
  letter-spacing: 2px;
  margin-bottom: 12px;
}

.casa-products-grid__title {
  font-size: var(--pg-title-size, 48px);
  font-weight: 300;
  margin: 0 0 16px 0;
  letter-spacing: -1px;
  color: var(--pg-text-primary);
  line-height: 1.1;
}

.casa-products-grid__divider {
  width: 80px;
  height: 3px;
  background: linear-gradient(90deg, var(--pg-accent-primary), var(--pg-accent-secondary));
  border-radius: 2px;
  margin: 20px 0;
}

.casa-products-grid__header--center .casa-products-grid__divider {
  margin-left: auto;
  margin-right: auto;
}

.casa-products-grid__header--right .casa-products-grid__divider {
  margin-left: auto;
}

.casa-products-grid__subtitle {
  font-size: 18px;
  color: var(--pg-text-secondary);
  max-width: 600px;
  margin: 0;
  line-height: 1.6;
}

.casa-products-grid__header--center .casa-products-grid__subtitle {
  margin-left: auto;
  margin-right: auto;
}

.casa-products-grid__header--right .casa-products-grid__subtitle {
  margin-left: auto;
}

/* ==========================================================================
   GRID LAYOUTS
   ========================================================================== */

.casa-products-grid__grid {
  display: grid;
  grid-template-columns: repeat(var(--pg-columns), 1fr);
  gap: var(--pg-gap);
}

/* Featured layout - first item larger */
.casa-products-grid--featured .casa-products-grid__grid {
  grid-template-columns: repeat(var(--pg-columns), 1fr);
}

.casa-products-grid--featured .casa-products-grid__item:first-child {
  grid-column: span 2;
  grid-row: span 2;
}

/* Carousel layout */
.casa-products-grid--carousel .casa-products-grid__grid {
  display: flex;
  gap: var(--pg-gap);
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  padding-bottom: 20px;
}

.casa-products-grid--carousel .casa-products-grid__grid::-webkit-scrollbar {
  display: none;
}

.casa-products-grid--carousel .casa-products-grid__item {
  flex: 0 0 calc((100% - var(--pg-gap) * 3) / 4);
  scroll-snap-align: start;
}

/* ==========================================================================
   ITEMS & ANIMATIONS
   ========================================================================== */

.casa-products-grid__item {
  opacity: 0;
  transform: translateY(30px);
  transition: opacity 0.6s cubic-bezier(0.4, 0, 0.2, 1),
              transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  transition-delay: var(--item-delay, 0ms);
}

.casa-products-grid__item--visible {
  opacity: 1;
  transform: translateY(0);
}

/* Animation variants */
.casa-products-grid[data-animation="fade-in"] .casa-products-grid__item {
  transform: none;
}

.casa-products-grid[data-animation="scale-up"] .casa-products-grid__item {
  transform: scale(0.9);
}

.casa-products-grid[data-animation="scale-up"] .casa-products-grid__item--visible {
  transform: scale(1);
}

.casa-products-grid[data-animation="slide-in"] .casa-products-grid__item {
  transform: translateX(-30px);
}

.casa-products-grid[data-animation="slide-in"] .casa-products-grid__item--visible {
  transform: translateX(0);
}

.casa-products-grid[data-animation="none"] .casa-products-grid__item {
  opacity: 1;
  transform: none;
}

/* ==========================================================================
   FOOTER / VIEW ALL
   ========================================================================== */

.casa-products-grid__footer {
  text-align: center;
  margin-top: 48px;
}

.casa-products-grid__view-all {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 16px 32px;
  background: linear-gradient(135deg, var(--pg-accent-primary), var(--pg-accent-secondary));
  color: white;
  text-decoration: none;
  font-size: 14px;
  font-weight: 600;
  border-radius: 50px;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.casa-products-grid__view-all:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 30px rgba(147, 51, 234, 0.3);
}

.casa-products-grid__view-all svg {
  transition: transform 0.3s ease;
}

.casa-products-grid__view-all:hover svg {
  transform: translateX(4px);
}

/* Dark background view-all styling */
.casa-products-grid--bg-dark .casa-products-grid__view-all,
.casa-products-grid--bg-gradient-dark .casa-products-grid__view-all {
  box-shadow: 0 0 30px rgba(147, 51, 234, 0.2);
}

/* ==========================================================================
   PLACEHOLDERS
   ========================================================================== */

.casa-products-grid__placeholder {
  background: #ffffff;
  border-radius: 20px;
  overflow: hidden;
}

.casa-products-grid--bg-dark .casa-products-grid__placeholder,
.casa-products-grid--bg-gradient-dark .casa-products-grid__placeholder {
  background: rgba(255, 255, 255, 0.05);
}

.casa-products-grid__placeholder-image {
  aspect-ratio: 1;
  background: linear-gradient(135deg, #f5f5f7, #e5e5ea);
  display: flex;
  align-items: center;
  justify-content: center;
}

.casa-products-grid--bg-dark .casa-products-grid__placeholder-image,
.casa-products-grid--bg-gradient-dark .casa-products-grid__placeholder-image {
  background: linear-gradient(135deg, rgba(255,255,255,0.1), rgba(255,255,255,0.05));
}

.casa-products-grid__placeholder-shape {
  width: 50%;
  height: 50%;
  background: linear-gradient(135deg, var(--pg-accent-primary), var(--pg-accent-secondary));
  clip-path: polygon(30% 0%, 70% 0%, 100% 30%, 100% 70%, 70% 100%, 30% 100%, 0% 70%, 0% 30%);
  opacity: 0.5;
  animation: pgPlaceholderPulse 2s ease-in-out infinite;
}

@keyframes pgPlaceholderPulse {
  0%, 100% { opacity: 0.3; transform: scale(0.95); }
  50% { opacity: 0.6; transform: scale(1); }
}

.casa-products-grid__placeholder-info {
  padding: 24px;
}

.casa-products-grid__placeholder-title {
  height: 20px;
  background: #e5e5e5;
  border-radius: 4px;
  margin-bottom: 12px;
}

.casa-products-grid--bg-dark .casa-products-grid__placeholder-title,
.casa-products-grid--bg-gradient-dark .casa-products-grid__placeholder-title {
  background: rgba(255, 255, 255, 0.1);
}

.casa-products-grid__placeholder-price {
  height: 16px;
  width: 60%;
  background: #e5e5e5;
  border-radius: 4px;
}

.casa-products-grid--bg-dark .casa-products-grid__placeholder-price,
.casa-products-grid--bg-gradient-dark .casa-products-grid__placeholder-price {
  background: rgba(255, 255, 255, 0.1);
}

/* ==========================================================================
   RESPONSIVE
   ========================================================================== */

@media (max-width: 1200px) {
  .casa-products-grid {
    padding: var(--pg-padding-top) 40px var(--pg-padding-bottom);
  }

  .casa-products-grid__grid {
    --pg-columns: 3;
  }

  .casa-products-grid--carousel .casa-products-grid__item {
    flex: 0 0 calc((100% - var(--pg-gap) * 2) / 3);
  }
}

@media (max-width: 900px) {
  .casa-products-grid__grid {
    --pg-columns: 2;
    gap: 24px;
  }

  .casa-products-grid__title {
    font-size: var(--pg-title-size-mobile, 32px);
  }

  .casa-products-grid__header {
    margin-bottom: 40px;
  }

  .casa-products-grid--featured .casa-products-grid__item:first-child {
    grid-column: span 2;
    grid-row: span 1;
  }

  .casa-products-grid--carousel .casa-products-grid__item {
    flex: 0 0 calc((100% - var(--pg-gap)) / 2);
  }

  .casa-products-grid__ambient-glow {
    width: 300px;
    height: 300px;
  }
}

@media (max-width: 600px) {
  .casa-products-grid {
    padding: var(--pg-padding-mobile-top) 20px var(--pg-padding-mobile-bottom);
  }

  .casa-products-grid__grid {
    gap: 16px;
  }

  .casa-products-grid__title {
    font-size: var(--pg-title-size-mobile, 28px);
  }

  .casa-products-grid__subtitle {
    font-size: 16px;
  }

  .casa-products-grid--featured .casa-products-grid__item:first-child {
    grid-column: span 1;
  }

  .casa-products-grid--carousel .casa-products-grid__item {
    flex: 0 0 280px;
  }

  .casa-products-grid__view-all {
    padding: 14px 24px;
    font-size: 13px;
  }

  .casa-products-grid__footer {
    margin-top: 32px;
  }
}

/* ==========================================================================
   REDUCED MOTION
   ========================================================================== */

@media (prefers-reduced-motion: reduce) {
  .casa-products-grid__item {
    opacity: 1;
    transform: none;
    transition: none;
  }

  .casa-products-grid__view-all {
    transition: none;
  }

  .casa-products-grid__placeholder-shape {
    animation: none;
  }
}
{% endstylesheet %}
