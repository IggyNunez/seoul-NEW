  .dw-details__list-text {
    flex: 1;
    line-height: 1.5;
  }
  
  /* Card highlight */
  .dw-details__card-highlight {
    display: inline-block;
    margin-top: 16px;
    padding: 8px 14px;
    background: rgba(var(--details-accent-rgb), 0.12);
