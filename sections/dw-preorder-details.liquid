      font-size: 20px;
    }
  }
  
  .dw-details__card-body {
    font-size: 14px;
    line-height: 1.6;
    color: var(--details-text-muted);
  }
  
  .dw-details__card-body p {
    margin: 0 0 10px;
  }
  
  .dw-details__card-body p:last-child {
    margin-bottom: 0;
  }
  
  .dw-details__card-body strong {
    color: var(--details-text);
    font-weight: 600;
  }

  /* Card list */
  .dw-details__card-list {
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: 14px;
  }
  
  .dw-details__card-list li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 10px;
    color: var(--details-text-muted);
  }
  
  .dw-details__card-list li:last-child {
    margin-bottom: 0;
  }
  
  .dw-details__list-check {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(var(--details-accent-rgb), 0.15);
    border-radius: 50%;
    color: var(--details-lime);
    margin-top: 2px;
