{% comment %}
  DoingWell Preorder Details
  - Brand-compliant styling with 3 color schemes
  - Countdown timer (clean design)
  - Inventory bar with urgency
  - Info cards with icons
  - Stat cards
  - Clean editorial aesthetic
  - No cyber glow effects
{% endcomment %}

{%- liquid
  assign color_scheme = section.settings.color_scheme
  assign accent_choice = section.settings.accent_color
  
  case accent_choice
    when 'lime'
      assign accent_color = '#C6D76B'
      assign accent_rgb = '198, 215, 107'
    when 'raspberry'
      assign accent_color = '#E08FBC'
      assign accent_rgb = '224, 143, 188'
  endcase
  
  case color_scheme
    when 'dark'
      assign bg_color = '#171717'
      assign text_color = '#ffffff'
      assign text_muted = 'rgba(255,255,255,0.6)'
      assign card_bg = 'rgba(255,255,255,0.04)'
      assign card_border = 'rgba(255,255,255,0.08)'
      assign countdown_bg = 'rgba(255,255,255,0.03)'
    when 'light'
      assign bg_color = '#F8F0E3'
      assign text_color = '#171717'
      assign text_muted = 'rgba(23,23,23,0.6)'
      assign card_bg = '#ffffff'
      assign card_border = 'rgba(23,23,23,0.08)'
      assign countdown_bg = '#ffffff'
    when 'white'
      assign bg_color = '#ffffff'
      assign text_color = '#171717'
      assign text_muted = 'rgba(23,23,23,0.6)'
      assign card_bg = '#F8F0E3'
      assign card_border = 'rgba(23,23,23,0.06)'
      assign countdown_bg = '#F8F0E3'
  endcase
-%}

<section 
  class="dw-details{% if section.settings.enable_animations %} dw-details--animate{% endif %}"
  data-section-type="dw-preorder-details"
  data-section-id="{{ section.id }}"
  style="
    --details-padding-top-desktop: {{ section.settings.padding_top_desktop }}px;
    --details-padding-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;
    --details-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --details-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --details-bg: {{ bg_color }};
    --details-text: {{ text_color }};
    --details-text-muted: {{ text_muted }};
    --details-accent: {{ accent_color }};
    --details-accent-rgb: {{ accent_rgb }};
    --details-lime: var(--details-accent);
    --details-raspberry: #E08FBC;
    --details-card-bg: {{ card_bg }};
    --details-card-border: {{ card_border }};
    --details-countdown-bg: {{ countdown_bg }};
    --details-inventory-bg: {{ inventory_bg }};
    --details-inventory-border: {{ inventory_border }};
    --details-max-width: {{ section.settings.max_width }}px;
    --details-card-gap: {{ section.settings.card_gap }}px;
  "
>
  <div class="dw-details__container">
    <!-- Header -->
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="dw-details__header dw-details__header--{{ section.settings.header_alignment }}">
        {%- if section.settings.eyebrow != blank -%}
          <span class="dw-details__eyebrow dw-details__animate-item" data-index="1">
            {{ section.settings.eyebrow }}
          </span>
        {%- endif -%}
        
        {%- if section.settings.heading != blank -%}
          <h2 class="dw-details__heading dw-details__animate-item" data-index="2">
            {{ section.settings.heading | newline_to_br }}
          </h2>
        {%- endif -%}
        
        {%- if section.settings.subheading != blank -%}
          <p class="dw-details__subheading dw-details__animate-item" data-index="3">
            {{ section.settings.subheading }}
          </p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <!-- Countdown Timer -->
    {%- if section.settings.show_countdown and section.settings.countdown_date != blank -%}
      <div class="dw-details__countdown dw-details__animate-item" data-index="4" data-countdown="{{ section.settings.countdown_date }}">
        <span class="dw-details__countdown-label">
          <span class="dw-details__countdown-dot"></span>
          {{ section.settings.countdown_label }}
        </span>
        <div class="dw-details__countdown-timer">
          <div class="dw-details__countdown-unit">
            <span class="dw-details__countdown-value" data-days>00</span>
            <span class="dw-details__countdown-text">Days</span>
          </div>
          <span class="dw-details__countdown-sep">:</span>
          <div class="dw-details__countdown-unit">
            <span class="dw-details__countdown-value" data-hours>00</span>
            <span class="dw-details__countdown-text">Hours</span>
          </div>
          <span class="dw-details__countdown-sep">:</span>
          <div class="dw-details__countdown-unit">
            <span class="dw-details__countdown-value" data-minutes>00</span>
            <span class="dw-details__countdown-text">Min</span>
          </div>
          <span class="dw-details__countdown-sep">:</span>
          <div class="dw-details__countdown-unit">
            <span class="dw-details__countdown-value" data-seconds>00</span>
            <span class="dw-details__countdown-text">Sec</span>
          </div>
        </div>
      </div>
    {%- endif -%}

    <!-- Inventory Bar -->
    {%- if section.settings.show_inventory_bar -%}
      <div class="dw-details__inventory dw-details__animate-item" data-index="5">
        <div class="dw-details__inventory-header">
          <span class="dw-details__inventory-label">
            <span class="dw-details__inventory-dot"></span>
            {{ section.settings.inventory_label }}
          </span>
          {%- if section.settings.show_inventory_count -%}
            <span class="dw-details__inventory-count">
              <strong>{{ section.settings.inventory_remaining }}</strong>
              {%- if section.settings.show_inventory_total -%}
                of {{ section.settings.inventory_total }}
              {%- endif -%}
              remaining
            </span>
          {%- endif -%}
        </div>
        <div class="dw-details__inventory-bar">
          <div class="dw-details__inventory-fill" style="--fill-percent: {{ section.settings.inventory_remaining | times: 100.0 | divided_by: section.settings.inventory_total }}%;"></div>
        </div>
        {%- if section.settings.inventory_message != blank -%}
          <p class="dw-details__inventory-message">{{ section.settings.inventory_message }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <!-- Cards Grid -->
    <div class="dw-details__grid dw-details__grid--{{ section.settings.columns_desktop }} dw-details__grid--mobile-{{ section.settings.columns_mobile }}">
      {%- assign card_index = 5 -%}
      {%- for block in section.blocks -%}
        {%- assign card_index = card_index | plus: 1 -%}
        
        {%- case block.type -%}
          {%- when 'card' -%}
            <div 
              class="dw-details__card dw-details__animate-item{% if block.settings.featured %} dw-details__card--featured{% endif %}"
              data-index="{{ card_index }}"
              {{ block.shopify_attributes }}
            >
              <!-- Card number -->
              <span class="dw-details__card-number">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
              
              {%- if block.settings.badge != blank -%}
                <span class="dw-details__card-badge">{{ block.settings.badge }}</span>
              {%- endif -%}
              
              {%- if block.settings.icon != 'none' or block.settings.custom_icon != blank -%}
                <div class="dw-details__card-icon">
                  {%- if block.settings.custom_icon != blank -%}
                    <img src="{{ block.settings.custom_icon | image_url: width: 96 }}" alt="" width="28" height="28" loading="lazy">
                  {%- else -%}
                    {%- case block.settings.icon -%}
                      {%- when 'box' -%}
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
                      {%- when 'calendar' -%}
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                      {%- when 'tag' -%}
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
                      {%- when 'shield' -%}
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
                      {%- when 'truck' -%}
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                      {%- when 'zap' -%}
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                      {%- when 'gift' -%}
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
                      {%- when 'crown' -%}
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="m2 4 3 12h14l3-12-6 7-4-7-4 7-6-7zm3 16h14"/></svg>
                      {%- when 'star' -%}
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                      {%- when 'refresh' -%}
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
                      {%- when 'mail' -%}
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                      {%- when 'users' -%}
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                      {%- when 'check-circle' -%}
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    {%- endcase -%}
                  {%- endif -%}
                </div>
              {%- endif -%}
              
              <div class="dw-details__card-content">
                {%- if block.settings.title != blank -%}
                  <h3 class="dw-details__card-title">{{ block.settings.title }}</h3>
                {%- endif -%}
                
                {%- if block.settings.content != blank -%}
                  <div class="dw-details__card-body">{{ block.settings.content }}</div>
                {%- endif -%}
                
                {%- if block.settings.items != blank -%}
                  {%- assign items = block.settings.items | newline_to_br | split: '<br />' -%}
                  <ul class="dw-details__card-list">
                    {%- for item in items -%}
                      {%- assign item_text = item | strip -%}
                      {%- if item_text != blank -%}
                        <li>
                          <span class="dw-details__list-check">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                          </span>
                          <span class="dw-details__list-text">{{ item_text }}</span>
                        </li>
                      {%- endif -%}
                    {%- endfor -%}
                  </ul>
                {%- endif -%}
                
                {%- if block.settings.highlight != blank -%}
                  <span class="dw-details__card-highlight">{{ block.settings.highlight }}</span>
                {%- endif -%}
              </div>
            </div>

          {%- when 'stat_card' -%}
            <div class="dw-details__stat dw-details__animate-item" data-index="{{ card_index }}" {{ block.shopify_attributes }}>
              <span class="dw-details__stat-label">{{ block.settings.label }}</span>
              <span class="dw-details__stat-value">
                {%- if block.settings.value contains '$' -%}<span class="dw-details__stat-prefix">$</span>{%- endif -%}
                <span class="dw-details__stat-number">{{ block.settings.value | remove: '$' | remove: '/mo' }}</span>
                {%- if block.settings.value contains '/mo' -%}<span class="dw-details__stat-suffix">/mo</span>{%- endif -%}
              </span>
              {%- if block.settings.note != blank -%}
                <span class="dw-details__stat-note">{{ block.settings.note }}</span>
              {%- endif -%}
            </div>

        {%- endcase -%}
      {%- endfor -%}
    </div>

    <!-- Footer -->
    {%- if section.settings.footer_text != blank -%}
      <div class="dw-details__footer dw-details__animate-item" data-index="{{ card_index | plus: 1 }}">
        <div class="dw-details__footer-content">{{ section.settings.footer_text }}</div>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  /* ==========================================
     BASE
     ========================================== */
  .dw-details {
    position: relative;
    padding: var(--details-padding-top-mobile) 20px var(--details-padding-bottom-mobile);
    background: var(--details-bg);
    color: var(--details-text);
    font-family: 'Poppins', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }
  
  @media (min-width: 750px) {
    .dw-details {
      padding: var(--details-padding-top-desktop) 50px var(--details-padding-bottom-desktop);
    }
  }

  /* Container */
  .dw-details__container {
    max-width: var(--details-max-width, 1200px);
    margin: 0 auto;
  }

  /* ==========================================
     HEADER
     ========================================== */
  .dw-details__header {
    margin-bottom: 40px;
  }
  
  .dw-details__header--left { text-align: left; }
  .dw-details__header--center { text-align: center; }
  
  @media (min-width: 750px) {
    .dw-details__header {
      margin-bottom: 50px;
    }
  }
  
  .dw-details__eyebrow {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--details-lime);
    margin-bottom: 16px;
  }
  
  .dw-details__heading {
    font-size: 32px;
    font-weight: 700;
    line-height: 1.15;
    margin: 0 0 16px;
    letter-spacing: -0.02em;
  }
  
  @media (min-width: 750px) {
    .dw-details__heading {
      font-size: 44px;
    }
  }
  
  .dw-details__subheading {
    font-size: 16px;
    line-height: 1.6;
    color: var(--details-text-muted);
    margin: 0 auto;
    max-width: 550px;
  }
  
  .dw-details__header--left .dw-details__subheading {
    margin-left: 0;
  }
  
  @media (min-width: 750px) {
    .dw-details__subheading {
      font-size: 18px;
    }
  }

  /* ==========================================
     COUNTDOWN TIMER
     ========================================== */
  .dw-details__countdown {
    text-align: center;
    margin-bottom: 40px;
    padding: 24px;
    background: var(--details-countdown-bg);
    border: 1px solid var(--details-card-border);
    border-radius: 16px;
  }
  
  @media (min-width: 750px) {
    .dw-details__countdown {
      padding: 32px 40px;
      margin-bottom: 50px;
    }
  }
  
  .dw-details__countdown-label {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--details-lime);
    margin-bottom: 20px;
  }
  
  .dw-details__countdown-dot {
    width: 8px;
    height: 8px;
    background: var(--details-lime);
    border-radius: 50%;
    animation: countdown-pulse 2s ease-in-out infinite;
  }
  
  @keyframes countdown-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  
  .dw-details__countdown-timer {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  
  @media (min-width: 750px) {
    .dw-details__countdown-timer {
      gap: 16px;
    }
  }
  
  .dw-details__countdown-unit {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 60px;
    padding: 12px 8px;
    background: var(--details-card-bg);
    border: 1px solid var(--details-card-border);
    border-radius: 12px;
  }
  
  @media (min-width: 750px) {
    .dw-details__countdown-unit {
      min-width: 80px;
      padding: 16px 12px;
    }
  }
  
  .dw-details__countdown-value {
    font-size: 28px;
    font-weight: 700;
    line-height: 1;
    font-variant-numeric: tabular-nums;
    color: var(--details-text);
  }
  
  @media (min-width: 750px) {
    .dw-details__countdown-value {
      font-size: 40px;
    }
  }
  
  .dw-details__countdown-text {
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--details-text-muted);
    margin-top: 6px;
  }
  
  .dw-details__countdown-sep {
    font-size: 24px;
    font-weight: 300;
    color: var(--details-text-muted);
    margin-bottom: 18px;
  }
  
  @media (min-width: 750px) {
    .dw-details__countdown-sep {
      font-size: 32px;
    }
  }

  /* ==========================================
     INVENTORY BAR
     ========================================== */
  .dw-details__inventory {
    margin-bottom: 40px;
    padding: 20px;
    background: var(--details-inventory-bg);
    border: 1px solid var(--details-inventory-border);
    border-radius: 12px;
  }
  
  @media (min-width: 750px) {
    .dw-details__inventory {
      padding: 24px 28px;
      margin-bottom: 50px;
    }
  }
  
  .dw-details__inventory-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 14px;
    flex-wrap: wrap;
    gap: 8px;
  }
  
  .dw-details__inventory-label {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--details-lime);
  }
  
  .dw-details__inventory-dot {
    width: 8px;
    height: 8px;
    background: var(--details-lime);
    border-radius: 50%;
    animation: countdown-pulse 2s ease-in-out infinite;
  }
  
  .dw-details__inventory-count {
    font-size: 14px;
    color: var(--details-text-muted);
  }
  
  .dw-details__inventory-count strong {
    color: var(--details-text);
    font-weight: 600;
  }
  
  .dw-details__inventory-bar {
    position: relative;
    height: 8px;
    background: var(--details-card-border);
    border-radius: 4px;
    overflow: hidden;
  }
  
  .dw-details__inventory-fill {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: var(--fill-percent, 70%);
    background: var(--details-accent);
    border-radius: 4px;
    transition: width 1s ease-out;
  }
  
  .dw-details__inventory-message {
    margin: 12px 0 0;
    font-size: 13px;
    color: var(--details-text-muted);
    text-align: center;
  }

  /* ==========================================
     GRID
     ========================================== */
  .dw-details__grid {
    display: grid;
    gap: var(--details-card-gap, 20px);
  }
  
  .dw-details__grid--mobile-1 { grid-template-columns: 1fr; }
  .dw-details__grid--mobile-2 { grid-template-columns: repeat(2, 1fr); }
  
  @media (min-width: 750px) {
    .dw-details__grid--2 { grid-template-columns: repeat(2, 1fr); }
    .dw-details__grid--3 { grid-template-columns: repeat(3, 1fr); }
    .dw-details__grid--4 { grid-template-columns: repeat(4, 1fr); }
  }

  /* ==========================================
     INFO CARD
     ========================================== */
  .dw-details__card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 28px 24px;
    background: var(--details-card-bg);
    border: 1px solid var(--details-card-border);
    border-radius: 16px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  
  @media (min-width: 750px) {
    .dw-details__card {
      padding: 32px 28px;
    }
  }
  
  .dw-details__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.12);
  }
  
  /* Card number */
  .dw-details__card-number {
    position: absolute;
    top: 16px;
    right: 16px;
    font-size: 40px;
    font-weight: 800;
    line-height: 1;
    color: var(--details-text);
    opacity: 0.04;
    pointer-events: none;
  }
  
  /* Card badge */
  .dw-details__card-badge {
    position: absolute;
    top: 0;
    left: 20px;
    padding: 6px 12px;
    background: var(--details-lime);
    color: #171717;
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-radius: 0 0 6px 6px;
  }
  
  /* Featured card */
  .dw-details__card--featured {
    border-color: var(--details-lime);
    border-width: 2px;
  }
  
  .dw-details__card--featured::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--details-lime);
    border-radius: 16px 16px 0 0;
  }

  /* Card icon */
  .dw-details__card-icon {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(var(--details-accent-rgb), 0.12);
    border-radius: 12px;
    color: var(--details-lime);
    margin-bottom: 20px;
    transition: background 0.3s ease;
  }
  
  .dw-details__card:hover .dw-details__card-icon {
    background: rgba(var(--details-accent-rgb), 0.18);
  }
  
  .dw-details__card-icon img {
    width: 28px;
    height: 28px;
    object-fit: contain;
  }

  /* Card content */
  .dw-details__card-content {
    flex: 1;
  }
  
  .dw-details__card-title {
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 12px;
    color: var(--details-text);
    letter-spacing: -0.01em;
  }
  
  @media (min-width: 750px) {
