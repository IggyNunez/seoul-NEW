{%- comment -%}
  Seoul Glow Lab Brand Story Section
  2-column layout with image and text content
{%- endcomment -%}

{%- liquid
  assign img_ratio = section.settings.image_ratio | default: 'auto'
  assign img_fit = section.settings.image_fit | default: 'cover'
  assign img_height = section.settings.image_height | default: 500
  assign img_pos = section.settings.image_position | default: 'left'
-%}
<section
  class="casa-brand-story{% if img_pos == 'right' %} casa-brand-story--img-right{% endif %}"
  style="
    --cbs-ratio: {{ img_ratio }};
    --cbs-fit: {{ img_fit }};
    --cbs-height: {{ img_height }}px;
    --cbs-bg: {{ section.settings.bg_color | default: '#ffffff' }};
    --cbs-tag: {{ section.settings.tag_color | default: '#9333ea' }};
    --cbs-title: {{ section.settings.title_color | default: '#0a0a0a' }};
    --cbs-text: {{ section.settings.text_color | default: '#6b7280' }};
    --cbs-btn-bg: {{ section.settings.button_bg | default: '#9333ea' }};
    --cbs-btn-bg2: {{ section.settings.button_bg_2 | default: '#ec4899' }};
    --cbs-btn-text: {{ section.settings.button_text_color | default: '#ffffff' }};
    --cbs-grad1: {{ section.settings.image_gradient_1 | default: '#9333ea' }};
    --cbs-grad2: {{ section.settings.image_gradient_2 | default: '#ec4899' }};
    --cbs-gap: {{ section.settings.gap | default: 80 }}px;
    --cbs-img-radius: {{ section.settings.image_radius | default: 24 }}px;
    --cbs-pt: {{ section.settings.padding_top | default: 120 }}px;
    --cbs-pb: {{ section.settings.padding_bottom | default: 120 }}px;
    --cbs-max-w: {% case section.settings.section_width %}{% when 'full' %}100%{% when 'wide' %}1600px{% when 'narrow' %}1200px{% else %}1400px{% endcase %};
  "
>
  <div class="casa-brand-story__inner">
    <div class="casa-brand-story__visual"
      style="{% if img_ratio != 'auto' %}aspect-ratio: {{ img_ratio }};{% else %}height: var(--cbs-height);{% endif %}"
    >
      {%- if section.settings.video != blank -%}
        <video class="casa-brand-story__video" autoplay loop muted playsinline
          {%- if section.settings.image != blank %} poster="{{ section.settings.image | image_url: width: 1200 }}"{% endif %}>
          {%- for source in section.settings.video.sources -%}
            <source src="{{ source.url }}" type="{{ source.mime_type }}">
          {%- endfor -%}
        </video>
      {%- elsif section.settings.video_url != blank -%}
        <video class="casa-brand-story__video" src="{{ section.settings.video_url }}" autoplay loop muted playsinline
          {%- if section.settings.image != blank %} poster="{{ section.settings.image | image_url: width: 1200 }}"{% endif %}></video>
      {%- endif -%}
      {%- if section.settings.image != blank -%}
        <img
          src="{{ section.settings.image | image_url: width: 1200 }}"
          alt="{{ section.settings.title | escape }}"
          class="{% if section.settings.video != blank or section.settings.video_url != blank %}casa-brand-story__poster{% endif %}"
          loading="lazy"
        >
      {%- endif -%}
    </div>

    <div class="casa-brand-story__content">
      {%- if section.settings.tag != blank -%}
        <span class="casa-brand-story__tag">{{ section.settings.tag }}</span>
      {%- endif -%}

      {%- if section.settings.title != blank -%}
        <h2 class="casa-brand-story__title">{{ section.settings.title }}</h2>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="casa-brand-story__text">{{ section.settings.text }}</div>
      {%- endif -%}

      {%- if section.settings.button_text != blank -%}
        <a href="{{ section.settings.button_link }}" class="casa-brand-story__btn">
          {{ section.settings.button_text }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

<script>
(function() {
  var visual = document.querySelector('.casa-brand-story__visual');
  if (!visual) return;
  var video = visual.querySelector('.casa-brand-story__video');
  var poster = visual.querySelector('.casa-brand-story__poster');
  if (video && poster) {
    video.addEventListener('playing', function() { poster.style.opacity = '0'; }, { once: true });
  }
  if (video && 'IntersectionObserver' in window) {
    new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) e.target.play().catch(function(){});
        else e.target.pause();
      });
    }, { rootMargin: '100px' }).observe(video);
  }
})();
</script>

{% schema %}
{
  "name": "Casa Brand Story",
  "tag": "section",
  "class": "casa-brand-story-section",
  "settings": [
    {
      "type": "header",
      "content": "Visual"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Also used as poster frame when a video is set"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video (Shopify-hosted)",
      "info": "Loops silently as background — overrides image"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL (fallback)",
      "info": "Direct .mp4 URL — only used if no Shopify video above"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "default": "auto",
      "options": [
        { "value": "auto", "label": "Auto (fixed height)" },
        { "value": "1 / 1", "label": "1:1 Square" },
        { "value": "4 / 3", "label": "4:3" },
        { "value": "3 / 4", "label": "3:4 Portrait" },
        { "value": "16 / 9", "label": "16:9 Wide" },
        { "value": "9 / 16", "label": "9:16 Tall" },
        { "value": "3 / 2", "label": "3:2" },
        { "value": "2 / 3", "label": "2:3 Portrait" }
      ]
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Image fit",
      "info": "Cover crops to fill, Contain shows entire image",
      "default": "cover",
      "options": [
        { "value": "cover", "label": "Cover (fill & crop)" },
        { "value": "contain", "label": "Contain (show all)" }
      ]
    },
    {
      "type": "range",
      "id": "image_height",
      "label": "Image height (when ratio is Auto)",
      "min": 200,
      "max": 700,
      "step": 20,
      "default": 500,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "tag",
      "label": "Tag",
      "default": "Our Story"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "We Dream, Envision & Innovate"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Content",
      "default": "<p>Seoul Glow Lab — House of Light. We're on a mission to revolutionize the world of home décor through high-quality, beautiful, and functional pieces that inspire customers to create personalized living spaces like never seen before.</p><p>For the world travelers and the storytellers, for the embracers of unique culture, and for the lovers of expression through design.</p>"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "full", "label": "Full width" },
        { "value": "wide", "label": "Wide (1600px)" },
        { "value": "contained", "label": "Contained (1400px)" },
        { "value": "narrow", "label": "Narrow (1200px)" }
      ],
      "default": "full"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between image and text",
      "min": 20,
      "max": 120,
      "step": 4,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "tag_color",
      "label": "Tag text color",
      "default": "#9333ea"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#0a0a0a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body text color",
      "default": "#6b7280"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background",
      "default": "#9333ea"
    },
    {
      "type": "color",
      "id": "button_bg_2",
      "label": "Button gradient end",
      "info": "Set same as button background for solid color",
      "default": "#ec4899"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "image_gradient_1",
      "label": "Image placeholder gradient start",
      "default": "#9333ea"
    },
    {
      "type": "color",
      "id": "image_gradient_2",
      "label": "Image placeholder gradient end",
      "default": "#ec4899"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 120,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 120,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Casa Brand Story"
    }
  ]
}
{% endschema %}

{% stylesheet %}
.casa-brand-story {
  background: var(--cbs-bg, #ffffff);
  padding: var(--cbs-pt, 120px) 80px var(--cbs-pb, 120px);
}

.casa-brand-story__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--cbs-gap, 80px);
  align-items: center;
  max-width: var(--cbs-max-w, 100%);
  margin: 0 auto;
}

.casa-brand-story--img-right .casa-brand-story__visual { order: 2; }
.casa-brand-story--img-right .casa-brand-story__content { order: 1; }

.casa-brand-story__visual {
  position: relative;
  border-radius: var(--cbs-img-radius, 24px);
  overflow: hidden;
  background: linear-gradient(135deg, var(--cbs-grad1, #9333ea), var(--cbs-grad2, #ec4899));
}

.casa-brand-story__visual img,
.casa-brand-story__video {
  width: 100%;
  height: 100%;
  object-fit: var(--cbs-fit, cover);
}

.casa-brand-story__video {
  position: absolute;
  inset: 0;
  z-index: 1;
}

.casa-brand-story__poster {
  position: relative;
  z-index: 0;
  transition: opacity 0.6s ease;
}

.casa-brand-story__tag {
  display: inline-block;
  font-size: 12px;
  font-weight: 600;
  color: var(--cbs-tag, #9333ea);
  text-transform: uppercase;
  letter-spacing: 2px;
  margin-bottom: 12px;
}

.casa-brand-story__title {
  font-size: 42px;
  font-weight: 300;
  margin: 0 0 24px 0;
  line-height: 1.2;
  color: var(--cbs-title, #0a0a0a);
}

.casa-brand-story__text {
  font-size: 18px;
  color: var(--cbs-text, #6b7280);
  line-height: 1.8;
  margin-bottom: 32px;
}

.casa-brand-story__text p {
  margin: 0 0 16px 0;
}

.casa-brand-story__text p:last-child {
  margin-bottom: 0;
}

.casa-brand-story__btn {
  display: inline-block;
  padding: 18px 40px;
  border-radius: 12px;
  font-size: 16px;
  font-weight: 600;
  text-decoration: none;
  background: linear-gradient(135deg, var(--cbs-btn-bg, #9333ea), var(--cbs-btn-bg2, #ec4899));
  color: var(--cbs-btn-text, #ffffff);
  transition: all 0.3s ease;
}

.casa-brand-story__btn:hover {
  transform: translateY(-2px);
  filter: brightness(1.1);
  box-shadow: 0 20px 40px -10px rgba(147, 51, 234, 0.5);
}

@media (max-width: 1200px) {
  .casa-brand-story {
    padding: 80px 40px;
  }

  .casa-brand-story__inner {
    gap: 48px;
  }
}

@media (max-width: 900px) {
  .casa-brand-story__inner {
    grid-template-columns: 1fr;
    gap: 40px;
  }

  .casa-brand-story__visual[style*="height"] {
    height: 350px !important;
  }

  .casa-brand-story__title {
    font-size: 32px;
  }
}

@media (max-width: 600px) {
  .casa-brand-story {
    padding: 60px 20px;
  }

  .casa-brand-story__visual[style*="height"] {
    height: 280px !important;
  }

  .casa-brand-story__title {
    font-size: 28px;
  }

  .casa-brand-story__text {
    font-size: 16px;
  }

  .casa-brand-story__btn {
    width: 100%;
    text-align: center;
  }
}
{% endstylesheet %}
