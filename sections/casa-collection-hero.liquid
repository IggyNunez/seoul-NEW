{%- liquid
  assign show_breadcrumbs = section.settings.show_breadcrumbs
  assign show_description = section.settings.show_description
  assign show_stats = section.settings.show_stats
  assign accent_word = section.settings.accent_word | default: ''
  assign padding_top = section.settings.padding_top | default: 80
  assign padding_bottom = section.settings.padding_bottom | default: 60

  # Layout
  assign layout_style = section.settings.layout_style | default: 'minimal'
  assign content_align = section.settings.content_align | default: 'left'
  assign content_width = section.settings.content_width | default: 680
  assign title_size = section.settings.title_size | default: 'large'

  # Colors
  assign bg_color = section.settings.bg_color | default: '#0a0a0f'
  assign text_primary = section.settings.text_primary | default: '#ffffff'
  assign text_secondary = section.settings.text_secondary | default: '#a0a0a0'
  assign accent_primary = section.settings.accent_primary | default: '#9333ea'
  assign accent_secondary = section.settings.accent_secondary | default: '#ec4899'

  # Image / Video
  assign bg_image = section.settings.bg_image
  assign use_collection_image = section.settings.use_collection_image
  assign overlay_opacity = section.settings.overlay_opacity | default: 60
  assign bg_position = section.settings.bg_position | default: 'center'
  assign enable_parallax = section.settings.enable_parallax
  assign bg_video_url = section.settings.bg_video_url | default: ''
  assign min_height = section.settings.min_height | default: 0

  # Determine which image to use
  assign hero_image = bg_image
  if use_collection_image and collection.image and hero_image == blank
    assign hero_image = collection.image
  endif

  assign has_bg_media = false
  if hero_image != blank or bg_video_url != blank
    assign has_bg_media = true
  endif

  # Badge / subtitle
  assign hero_badge = section.settings.hero_badge | default: ''
  assign custom_subtitle = section.settings.custom_subtitle | default: ''

  # CTA
  assign cta_text = section.settings.cta_text | default: ''
  assign cta_link = section.settings.cta_link | default: ''
  assign cta_style = section.settings.cta_style | default: 'gradient'
  assign cta_text_2 = section.settings.cta_text_2 | default: ''
  assign cta_link_2 = section.settings.cta_link_2 | default: ''

  # Title
  assign collection_title = collection.title | default: 'Collection'
  assign display_title = collection_title
  if accent_word != blank
    assign accent_html = '<span class="casa-col-hero__accent">' | append: accent_word | append: '</span>'
    assign display_title = collection_title | replace: accent_word, accent_html
  endif

  # Title size class
  case title_size
    when 'small'
      assign title_class = 'casa-col-hero__title--sm'
    when 'medium'
      assign title_class = 'casa-col-hero__title--md'
    when 'large'
      assign title_class = 'casa-col-hero__title--lg'
    when 'extra-large'
      assign title_class = 'casa-col-hero__title--xl'
    else
      assign title_class = 'casa-col-hero__title--lg'
  endcase
-%}

<section
  class="casa-col-hero casa-col-hero--{{ layout_style }}{% if has_bg_media %} casa-col-hero--has-bg{% endif %}{% if content_align == 'center' %} casa-col-hero--centered{% endif %}"
  style="
    --cch-pt: {{ padding_top }}px;
    --cch-pb: {{ padding_bottom }}px;
    --cch-bg: {{ bg_color }};
    --cch-text: {{ text_primary }};
    --cch-text-muted: {{ text_secondary }};
    --cch-accent-1: {{ accent_primary }};
    --cch-accent-2: {{ accent_secondary }};
    --cch-content-w: {{ content_width }}px;
    --cch-overlay-opacity: {{ overlay_opacity | divided_by: 100.0 }};
    {%- if min_height > 0 -%}--cch-min-h: {{ min_height }}px;{%- endif -%}
  "
>
  {%- comment -%} Background media {%- endcomment -%}
  {%- if has_bg_media -%}
    <div class="casa-col-hero__media">
      {%- if bg_video_url != blank -%}
        <video class="casa-col-hero__video" autoplay loop muted playsinline>
          <source src="{{ bg_video_url }}" type="video/mp4">
        </video>
      {%- elsif hero_image -%}
        <img
          src="{{ hero_image | image_url: width: 1920 }}"
          srcset="{{ hero_image | image_url: width: 960 }} 960w, {{ hero_image | image_url: width: 1440 }} 1440w, {{ hero_image | image_url: width: 1920 }} 1920w"
          sizes="100vw"
          alt="{{ collection_title | escape }}"
          loading="eager"
          class="casa-col-hero__bg-img{% if enable_parallax %} casa-col-hero__bg-img--parallax{% endif %}"
          style="object-position: {{ bg_position }};"
        >
      {%- endif -%}
      <div class="casa-col-hero__overlay"></div>
    </div>
  {%- else -%}
    {%- comment -%} Decorative gradient glows (no image mode) {%- endcomment -%}
    <div class="casa-col-hero__glow casa-col-hero__glow--1"></div>
    <div class="casa-col-hero__glow casa-col-hero__glow--2"></div>
  {%- endif -%}

  <div class="casa-col-hero__container">
    {%- if show_breadcrumbs -%}
      <nav class="casa-col-hero__breadcrumbs" aria-label="Breadcrumbs">
        <a href="/" class="casa-col-hero__breadcrumb-link">Home</a>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        <a href="/collections" class="casa-col-hero__breadcrumb-link">Collections</a>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        <span class="casa-col-hero__breadcrumb-current">{{ collection_title }}</span>
      </nav>
    {%- endif -%}

    <div class="casa-col-hero__content">
      {%- if hero_badge != blank -%}
        <div class="casa-col-hero__badge">
          <span class="casa-col-hero__badge-dot"></span>
          {{ hero_badge }}
        </div>
      {%- endif -%}

      <h1 class="casa-col-hero__title {{ title_class }}">{{ display_title }}</h1>

      {%- if custom_subtitle != blank -%}
        <div class="casa-col-hero__description">{{ custom_subtitle }}</div>
      {%- elsif show_description and collection.description != blank -%}
        <div class="casa-col-hero__description">{{ collection.description }}</div>
      {%- endif -%}

      {%- if cta_text != blank -%}
        <div class="casa-col-hero__cta-row">
          <a href="{{ cta_link | default: collection.url }}" class="casa-col-hero__cta casa-col-hero__cta--{{ cta_style }}">
            {{ cta_text }}
          </a>
          {%- if cta_text_2 != blank -%}
            <a href="{{ cta_link_2 | default: collection.url }}" class="casa-col-hero__cta casa-col-hero__cta--outline">
              {{ cta_text_2 }}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if show_stats -%}
        <div class="casa-col-hero__stats">
          {%- for block in section.blocks -%}
            {%- if block.type == 'stat' -%}
              <div class="casa-col-hero__stat" {{ block.shopify_attributes }}>
                {%- case block.settings.stat_icon -%}
                  {%- when 'products' -%}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
                  {%- when 'star' -%}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="casa-col-hero__stat-star"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01z"/></svg>
                  {%- when 'shipping' -%}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
                  {%- when 'shield' -%}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><polyline points="9 12 11 14 15 10"></polyline></svg>
                  {%- when 'heart' -%}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                  {%- when 'clock' -%}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                  {%- when 'tag' -%}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path><line x1="7" y1="7" x2="7.01" y2="7"></line></svg>
                  {%- when 'gift' -%}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"></polyline><rect x="2" y="7" width="20" height="5"></rect><line x1="12" y1="22" x2="12" y2="7"></line><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"></path><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"></path></svg>
                  {%- when 'zap' -%}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
                {%- endcase -%}
                <span>
                  {%- if block.settings.stat_use_count and block.settings.stat_icon == 'products' -%}
                    {{ collection.products_count }} {{ block.settings.stat_text | default: 'Products' }}
                  {%- else -%}
                    {{ block.settings.stat_text }}
                  {%- endif -%}
                </span>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Split image for split layout {%- endcomment -%}
    {%- if layout_style == 'split' and hero_image -%}
      <div class="casa-col-hero__split-image">
        <img
          src="{{ hero_image | image_url: width: 800 }}"
          alt="{{ collection_title | escape }}"
          loading="eager"
          class="casa-col-hero__split-img"
        >
      </div>
    {%- endif -%}
  </div>
</section>

{%- if enable_parallax and has_bg_media -%}
  <script>
    (function() {
      var img = document.querySelector('.casa-col-hero__bg-img--parallax');
      if (!img) return;
      var hero = img.closest('.casa-col-hero');
      function onScroll() {
        var rect = hero.getBoundingClientRect();
        var y = -(rect.top * 0.3);
        img.style.transform = 'translateY(' + y + 'px) scale(1.1)';
      }
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    })();
  </script>
{%- endif -%}

