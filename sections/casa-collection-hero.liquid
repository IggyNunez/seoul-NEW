{% stylesheet %}
/* ═══════════════════════════════════════════════════════
   COLLECTION HERO — BASE
   ═══════════════════════════════════════════════════════ */
.casa-col-hero {
  position: relative;
  background: var(--cch-bg);
  padding: var(--cch-pt) 60px var(--cch-pb);
  overflow: hidden;
  min-height: var(--cch-min-h, auto);
  max-width: 100vw;
  box-sizing: border-box;
}

.casa-col-hero--has-bg {
  display: flex;
  align-items: flex-end;
}

.casa-col-hero--centered .casa-col-hero__content {
  text-align: center;
  margin-left: auto;
  margin-right: auto;
}

.casa-col-hero--centered .casa-col-hero__breadcrumbs {
  justify-content: center;
}

.casa-col-hero--centered .casa-col-hero__stats {
  justify-content: center;
}

.casa-col-hero--centered .casa-col-hero__cta-row {
  justify-content: center;
}

.casa-col-hero--centered .casa-col-hero__badge {
  margin-left: auto;
  margin-right: auto;
}

/* ── Background media ── */
.casa-col-hero__media {
  position: absolute;
  inset: 0;
  z-index: 0;
}

.casa-col-hero__bg-img,
.casa-col-hero__video {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.casa-col-hero__bg-img--parallax {
  transform: scale(1.1);
  will-change: transform;
}

.casa-col-hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    180deg,
    rgba(0, 0, 0, calc(var(--cch-overlay-opacity) * 0.7)) 0%,
    rgba(0, 0, 0, var(--cch-overlay-opacity)) 100%
  );
}

/* ── Decorative glows (no-image mode) ── */
.casa-col-hero__glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(120px);
  opacity: 0.3;
  pointer-events: none;
}

.casa-col-hero__glow--1 {
  width: 600px;
  height: 600px;
  background: var(--cch-accent-1);
  top: -200px;
  left: 20%;
}

.casa-col-hero__glow--2 {
  width: 500px;
  height: 500px;
  background: var(--cch-accent-2);
  top: -150px;
  right: 5%;
}

/* ── Container ── */
.casa-col-hero__container {
  position: relative;
  z-index: 1;
  max-width: 1800px;
  margin: 0 auto;
  width: 100%;
}

.casa-col-hero--split .casa-col-hero__container {
  display: flex;
  align-items: center;
  gap: 60px;
}

/* ── Breadcrumbs ── */
.casa-col-hero__breadcrumbs {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 20px;
  font-size: 13px;
}

.casa-col-hero__breadcrumb-link {
  color: var(--cch-text-muted);
  text-decoration: none;
  transition: color 0.2s ease;
}

.casa-col-hero__breadcrumb-link:hover {
  color: var(--cch-text);
}

.casa-col-hero__breadcrumbs svg {
  color: var(--cch-text-muted);
  flex-shrink: 0;
}

.casa-col-hero__breadcrumb-current {
  color: var(--cch-text);
}

/* ── Badge ── */
.casa-col-hero__badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 5px 14px;
  border-radius: 100px;
  background: linear-gradient(135deg, rgba(147, 51, 234, 0.15), rgba(236, 72, 153, 0.1));
  border: 1px solid rgba(255, 255, 255, 0.1);
  color: var(--cch-text);
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.8px;
  margin-bottom: 16px;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.casa-col-hero__badge-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--cch-accent-1);
  animation: casaHeroPulse 2s ease-in-out infinite;
}

@keyframes casaHeroPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.6; transform: scale(0.8); }
}

/* ── Content ── */
.casa-col-hero__content {
  max-width: var(--cch-content-w, 680px);
  flex: 1;
}

/* Title sizes */
.casa-col-hero__title {
  font-weight: 300;
  color: var(--cch-text);
  margin: 0 0 16px 0;
  letter-spacing: -1px;
  line-height: 1.1;
}

.casa-col-hero__title--sm { font-size: 32px; }
.casa-col-hero__title--md { font-size: 40px; }
.casa-col-hero__title--lg { font-size: 48px; }
.casa-col-hero__title--xl { font-size: 64px; }

.casa-col-hero__accent {
  background: linear-gradient(135deg, var(--cch-accent-1), var(--cch-accent-2));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: 400;
}

.casa-col-hero__description {
  font-size: 16px;
  line-height: 1.6;
  color: var(--cch-text-muted);
  max-width: 560px;
  margin-bottom: 20px;
}

.casa-col-hero--centered .casa-col-hero__description {
  margin-left: auto;
  margin-right: auto;
}

.casa-col-hero__description p {
  margin: 0;
}

/* ── CTA buttons ── */
.casa-col-hero__cta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-bottom: 24px;
}

.casa-col-hero__cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12px 28px;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 600;
  text-decoration: none;
  transition: all 0.3s ease;
  cursor: pointer;
}

.casa-col-hero__cta--gradient {
  background: linear-gradient(135deg, var(--cch-accent-1), var(--cch-accent-2));
  color: #ffffff;
  border: none;
}

.casa-col-hero__cta--gradient:hover {
  filter: brightness(1.15);
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(147, 51, 234, 0.4);
}

.casa-col-hero__cta--solid {
  background: var(--cch-accent-1);
  color: #ffffff;
  border: none;
}

.casa-col-hero__cta--solid:hover {
  filter: brightness(1.15);
  transform: translateY(-2px);
}

.casa-col-hero__cta--outline {
  background: transparent;
  color: var(--cch-text);
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.casa-col-hero__cta--outline:hover {
  border-color: rgba(255, 255, 255, 0.4);
  background: rgba(255, 255, 255, 0.05);
}

/* ── Stats row ── */
.casa-col-hero__stats {
  display: flex;
  flex-wrap: wrap;
  gap: 24px;
  padding-top: 8px;
}

.casa-col-hero__stat {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  color: var(--cch-text-muted);
}

.casa-col-hero__stat svg {
  color: var(--cch-text-muted);
  flex-shrink: 0;
}

.casa-col-hero__stat-star {
  color: #fbbf24 !important;
}

/* ── Split layout image ── */
.casa-col-hero__split-image {
  flex: 0 0 400px;
  max-width: 400px;
  border-radius: 16px;
  overflow: hidden;
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.casa-col-hero__split-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* ═══════════════════════════════════════════════════════
   RESPONSIVE
   ═══════════════════════════════════════════════════════ */
@media (max-width: 900px) {
  .casa-col-hero {
    padding-left: 24px;
    padding-right: 24px;
  }

  .casa-col-hero__title--sm { font-size: 26px; }
  .casa-col-hero__title--md { font-size: 32px; }
  .casa-col-hero__title--lg { font-size: 36px; }
  .casa-col-hero__title--xl { font-size: 48px; }

  .casa-col-hero__glow--1 {
    width: 300px;
    height: 300px;
    top: -100px;
  }

  .casa-col-hero__glow--2 {
    width: 250px;
    height: 250px;
    top: -80px;
  }

  .casa-col-hero--split .casa-col-hero__container {
    flex-direction: column;
    gap: 32px;
  }

  .casa-col-hero__split-image {
    flex: none;
    max-width: 100%;
    width: 100%;
    max-height: 280px;
  }
}

@media (max-width: 480px) {
  .casa-col-hero {
    padding-left: 16px;
    padding-right: 16px;
  }

  .casa-col-hero__title--sm { font-size: 22px; }
  .casa-col-hero__title--md { font-size: 26px; }
  .casa-col-hero__title--lg { font-size: 28px; }
  .casa-col-hero__title--xl { font-size: 36px; }

  .casa-col-hero__description {
    font-size: 14px;
  }

  .casa-col-hero__stats {
    gap: 16px;
  }

  .casa-col-hero__stat {
    font-size: 12px;
  }

  .casa-col-hero__cta {
    width: 100%;
    padding: 14px 24px;
  }
}
{% endstylesheet %}
