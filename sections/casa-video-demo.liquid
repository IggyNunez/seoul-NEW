{%- comment -%}
  Seoul Glow Lab - Video Testimonials Section
  Full-width section version of the video testimonials block.
  Horizontal scroll row of portrait video thumbnail cards with play buttons.
  Clicking opens a sticky modal with the video (YouTube, Vimeo, or direct URL).
  Modal stays fixed on scroll until X / backdrop / Escape closes it.
  Optional product link per card shown in modal.
  Video sources (priority): Shopify-hosted video > video_url picker > manual URL text.
{%- endcomment -%}

{%- liquid
  assign s = section.settings

  assign tag_text = s.tag_text
  assign title = s.title
  assign subtitle = s.subtitle
  assign accent_word = s.accent_word
  assign accent_style = s.accent_style | default: 'gradient'
  assign accent_color = s.accent_color | default: '#9333ea'
  assign accent_color_2 = s.accent_color_2 | default: '#ec4899'

  assign padding_top = s.padding_top | default: 100
  assign padding_bottom = s.padding_bottom | default: 100
  assign padding_mobile_top = s.padding_mobile_top | default: 60
  assign padding_mobile_bottom = s.padding_mobile_bottom | default: 60

  assign bg_color = s.bg_color | default: '#0a0a0f'
  assign text_color = s.text_color | default: '#ffffff'

  assign layout_width = s.layout_width | default: 'page'
  assign card_width = s.card_width | default: 220

  assign video_ids = "1,2,3,4,5,6,7,8" | split: ","

  # Build title with accent word
  assign display_title = title
  if accent_word != blank and title != blank
    assign accent_html = '<span class="casa-vtm-section__accent casa-vtm-section__accent--' | append: accent_style | append: '">' | append: accent_word | append: '</span>'
    assign display_title = title | replace: accent_word, accent_html
  endif
-%}

<section
  class="casa-vtm-section"
  id="casa-vtm-section-{{ section.id }}"
  style="
    --cvts-bg: {{ bg_color }};
    --cvts-text: {{ text_color }};
    --cvts-padding-top: {{ padding_top }}px;
    --cvts-padding-bottom: {{ padding_bottom }}px;
    --cvts-padding-mobile-top: {{ padding_mobile_top }}px;
    --cvts-padding-mobile-bottom: {{ padding_mobile_bottom }}px;
    --cvts-card-width: {{ card_width }}px;
    --cvts-accent-1: {{ accent_color }};
    --cvts-accent-2: {{ accent_color_2 }};
  "
>
  <div class="casa-vtm-section__container{% if layout_width == 'full' %} casa-vtm-section__container--full{% endif %}">
    {%- comment -%} Header — hidden when all fields empty {%- endcomment -%}
    {%- if tag_text != blank or title != blank or subtitle != blank -%}
    <div class="casa-vtm-section__header" style="text-align: {{ s.content_align | default: 'center' }}; align-items: {% if s.content_align == 'left' %}flex-start{% elsif s.content_align == 'right' %}flex-end{% else %}center{% endif %};">
      {%- if tag_text != blank -%}
        {%- if s.tag_link != blank -%}
          <a href="{{ s.tag_link }}" class="casa-vtm-section__tag casa-vtm-section__tag--link">{{ tag_text }}</a>
        {%- else -%}
          <span class="casa-vtm-section__tag">{{ tag_text }}</span>
        {%- endif -%}
      {%- endif -%}

      {%- if title != blank -%}
        {%- if s.title_link != blank -%}
          <a href="{{ s.title_link }}" class="casa-vtm-section__title-link"><h2 class="casa-vtm-section__title">{{ display_title }}</h2></a>
        {%- else -%}
          <h2 class="casa-vtm-section__title">{{ display_title }}</h2>
        {%- endif -%}
      {%- endif -%}

      {%- if subtitle != blank -%}
        <p class="casa-vtm-section__subtitle">{{ subtitle }}</p>
      {%- endif -%}
    </div>
    {%- endif -%}

    {%- comment -%} Video cards carousel {%- endcomment -%}
    <div class="casa-vtm-section__carousel">
      <button type="button" class="casa-vtm-section__arrow casa-vtm-section__arrow--prev" aria-label="Scroll left" style="display:none;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
      </button>
      <div class="casa-vtm-section__row">
      {%- for vid in video_ids -%}
        {%- assign thumb_key   = "thumbnail_"   | append: vid -%}
        {%- assign hosted_key  = "video_hosted_" | append: vid -%}
        {%- assign picker_key  = "video_picker_" | append: vid -%}
        {%- assign url_key     = "video_url_"    | append: vid -%}
        {%- assign name_key    = "author_"       | append: vid -%}
        {%- assign prod_url_key   = "product_url_"   | append: vid -%}
        {%- assign prod_title_key = "product_title_" | append: vid -%}
        {%- assign caption_key    = "caption_"       | append: vid -%}

        {%- assign thumb  = s[thumb_key] -%}
        {%- assign hosted = s[hosted_key] -%}
        {%- assign picker = s[picker_key] -%}
        {%- assign vurl   = s[url_key] -%}
        {%- assign name   = s[name_key] -%}
        {%- assign prod_url   = s[prod_url_key] -%}
        {%- assign prod_title = s[prod_title_key] -%}
        {%- assign caption    = s[caption_key] -%}

        {%- comment -%} Resolve the best video source {%- endcomment -%}
        {%- assign resolved_url = "" -%}
        {%- assign resolved_type = "" -%}

        {%- if hosted != blank and hosted.sources.size > 0 -%}
          {%- assign resolved_url = "" -%}
          {%- for src in hosted.sources -%}
            {%- if src.mime_type == "video/mp4" and resolved_url == "" -%}
              {%- assign resolved_url = src.url -%}
            {%- endif -%}
          {%- endfor -%}
          {%- if resolved_url == "" -%}
            {%- assign resolved_url = hosted.sources[0].url -%}
          {%- endif -%}
          {%- assign resolved_type = "hosted" -%}
        {%- elsif picker != blank -%}
          {%- assign resolved_url = picker | external_video_url -%}
          {%- assign resolved_type = "external" -%}
        {%- elsif vurl != blank -%}
          {%- assign resolved_url = vurl -%}
          {%- assign resolved_type = "manual" -%}
        {%- endif -%}

        {%- comment -%} Auto-thumbnail from YouTube if no image uploaded {%- endcomment -%}
        {%- assign auto_thumb = "" -%}
        {%- if thumb == blank and resolved_url != blank -%}
          {%- if resolved_url contains "youtube.com" or resolved_url contains "youtu.be" -%}
            {%- assign yt_parts = resolved_url | split: "v=" -%}
            {%- if yt_parts.size > 1 -%}
              {%- assign yt_id = yt_parts[1] | split: "&" | first -%}
            {%- else -%}
              {%- assign yt_id = resolved_url | split: "youtu.be/" | last | split: "?" | first -%}
            {%- endif -%}
            {%- if yt_id != blank -%}
              {%- assign auto_thumb = "https://img.youtube.com/vi/" | append: yt_id | append: "/hqdefault.jpg" -%}
            {%- endif -%}
          {%- endif -%}
        {%- endif -%}

        {%- if thumb != blank or resolved_url != blank -%}
          <button
            type="button"
            class="casa-vtm-section__card"
            data-vtms-url="{{ resolved_url }}"
            data-vtms-type="{{ resolved_type }}"
            {%- if hosted != blank and hosted.sources.size > 0 -%}
              data-vtms-hosted-sources="[{%- for source in hosted.sources -%}{&quot;url&quot;:&quot;{{ source.url }}&quot;,&quot;mime&quot;:&quot;{{ source.mime_type }}&quot;}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}]"
            {%- endif -%}
            {%- if prod_url != blank and prod_title != blank -%}
              data-vtms-product-url="{{ prod_url | escape }}"
              data-vtms-product-title="{{ prod_title | escape }}"
            {%- endif -%}
            aria-label="Play video{% if name != blank %} from {{ name | escape }}{% endif %}"
          >
            {%- if thumb != blank -%}
              <img
                src="{{ thumb | image_url: width: 400 }}"
                alt="{{ name | default: 'Video testimonial' | escape }}"
                class="casa-vtm-section__thumb"
                loading="lazy"
                width="180"
                height="320"
              >
            {%- elsif auto_thumb != blank -%}
              <img
                src="{{ auto_thumb }}"
                alt="{{ name | default: 'Video testimonial' | escape }}"
                class="casa-vtm-section__thumb"
                loading="lazy"
                width="180"
                height="320"
              >
            {%- elsif hosted != blank and hosted.preview_image -%}
              <img
                src="{{ hosted.preview_image | image_url: width: 400 }}"
                alt="{{ name | default: 'Video testimonial' | escape }}"
                class="casa-vtm-section__thumb"
                loading="lazy"
                width="180"
                height="320"
              >
            {%- else -%}
              <div class="casa-vtm-section__thumb casa-vtm-section__thumb--placeholder"></div>
            {%- endif -%}

            <span class="casa-vtm-section__play" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M8 5.14v14l11-7-11-7z"/>
              </svg>
            </span>

            {%- if name != blank -%}
              <span class="casa-vtm-section__name">{{ name }}</span>
            {%- endif -%}

            {%- if caption != blank -%}
              <span class="casa-vtm-section__caption">{{ caption }}</span>
            {%- endif -%}

            {%- if prod_url != blank and prod_title != blank -%}
              <span class="casa-vtm-section__product-badge" aria-hidden="true">
                {{ prod_title | truncate: 20 }}
              </span>
            {%- endif -%}
          </button>
        {%- endif -%}
      {%- endfor -%}
      </div>
      <button type="button" class="casa-vtm-section__arrow casa-vtm-section__arrow--next" aria-label="Scroll right" style="display:none;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </button>
    </div>
  </div>

  {%- comment -%} App / custom-liquid blocks {%- endcomment -%}
  {%- for block in section.blocks -%}
    {%- case block.type -%}
      {%- when '@app' -%}
        <div {{ block.shopify_attributes }}>
          {%- render block -%}
        </div>
      {%- when 'custom-liquid' -%}
        <div {{ block.shopify_attributes }}>
          {{ block.settings.custom_liquid }}
        </div>
    {%- endcase -%}
  {%- endfor -%}
</section>

{%- comment -%} Modal — rendered once, populated by JS {%- endcomment -%}
<div class="casa-vtm-section__modal" id="casa-vtm-section-modal-{{ section.id }}" aria-hidden="true">
  <div class="casa-vtm-section__backdrop"></div>
  <div class="casa-vtm-section__player">
    <button type="button" class="casa-vtm-section__close" aria-label="Close video">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
    <button type="button" class="casa-vtm-section__modal-prev" aria-label="Previous video">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <button type="button" class="casa-vtm-section__modal-next" aria-label="Next video">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
    <div class="casa-vtm-section__video-wrap"></div>
    <button type="button" class="casa-vtm-section__mute" aria-label="Toggle mute" style="display:none;">
      <svg class="casa-vtm-section__mute-on" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/>
      </svg>
      <svg class="casa-vtm-section__mute-off" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
        <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/>
      </svg>
    </button>
    <a class="casa-vtm-section__modal-product" href="#" style="display:none;">
      <span class="casa-vtm-section__modal-product-title"></span>
      <span class="casa-vtm-section__modal-product-cta">Shop &rarr;</span>
    </a>
  </div>
</div>

<script>
(function() {
  var root = document.getElementById('casa-vtm-section-{{ section.id }}');
  var modal = document.getElementById('casa-vtm-section-modal-{{ section.id }}');
  if (!root || !modal) return;

  /* ── Carousel arrows ── */
  var row = root.querySelector('.casa-vtm-section__row');
  var prevBtn = root.querySelector('.casa-vtm-section__arrow--prev');
  var nextBtn = root.querySelector('.casa-vtm-section__arrow--next');

  function updateArrows() {
    if (!row || !prevBtn || !nextBtn) return;
    var scrollable = row.scrollWidth > row.clientWidth + 4;
    if (!scrollable) {
      prevBtn.style.display = 'none';
      nextBtn.style.display = 'none';
      return;
    }
    prevBtn.style.display = row.scrollLeft > 10 ? 'flex' : 'none';
    nextBtn.style.display = row.scrollLeft < row.scrollWidth - row.clientWidth - 10 ? 'flex' : 'none';
  }

  if (row && prevBtn && nextBtn) {
    row.addEventListener('scroll', updateArrows, { passive: true });
    window.addEventListener('resize', updateArrows);
    updateArrows();

    prevBtn.addEventListener('click', function() {
      row.scrollBy({ left: -row.clientWidth * 0.6, behavior: 'smooth' });
    });
    nextBtn.addEventListener('click', function() {
      row.scrollBy({ left: row.clientWidth * 0.6, behavior: 'smooth' });
    });
  }

  var backdrop = modal.querySelector('.casa-vtm-section__backdrop');
  var closeBtn = modal.querySelector('.casa-vtm-section__close');
  var wrap = modal.querySelector('.casa-vtm-section__video-wrap');
  var muteBtn = modal.querySelector('.casa-vtm-section__mute');
  var muteOn = muteBtn.querySelector('.casa-vtm-section__mute-on');
  var muteOff = muteBtn.querySelector('.casa-vtm-section__mute-off');
  var productBar = modal.querySelector('.casa-vtm-section__modal-product');
  var productTitle = modal.querySelector('.casa-vtm-section__modal-product-title');
  var modalPrev = modal.querySelector('.casa-vtm-section__modal-prev');
  var modalNext = modal.querySelector('.casa-vtm-section__modal-next');
  var allCards = root.querySelectorAll('.casa-vtm-section__card');
  var currentVideo = null;
  var currentCardIndex = 0;

  function updateModalNav() {
    if (modalPrev) modalPrev.disabled = currentCardIndex <= 0;
    if (modalNext) modalNext.disabled = currentCardIndex >= allCards.length - 1;
  }

  function openCardByIndex(idx) {
    if (idx < 0 || idx >= allCards.length) return;
    currentCardIndex = idx;
    var card = allCards[idx];
    if (card) card.click();
  }

  if (modalPrev) {
    modalPrev.addEventListener('click', function(e) {
      e.stopPropagation();
      openCardByIndex(currentCardIndex - 1);
    });
  }
  if (modalNext) {
    modalNext.addEventListener('click', function(e) {
      e.stopPropagation();
      openCardByIndex(currentCardIndex + 1);
    });
  }

  /* ── Detect URL type ── */
  function parseUrl(url) {
    var yt = url.match(/(?:youtube\.com\/(?:watch\?v=|embed\/|shorts\/)|youtu\.be\/)([\w-]{11})/);
    if (yt) return { type: 'youtube', id: yt[1] };
    var vm = url.match(/vimeo\.com\/(\d+)/);
    if (vm) return { type: 'vimeo', id: vm[1] };
    return { type: 'direct', id: url };
  }

  /* ── Open modal ── */
  function open(url) {
    var info = parseUrl(url);
    wrap.innerHTML = '';
    muteBtn.style.display = 'none';

    if (info.type === 'youtube') {
      var iframe = document.createElement('iframe');
      iframe.src = 'https://www.youtube.com/embed/' + info.id + '?autoplay=1&rel=0&modestbranding=1&playsinline=1';
      iframe.allow = 'autoplay; encrypted-media; picture-in-picture';
      iframe.allowFullscreen = true;
      iframe.className = 'casa-vtm-section__video';
      wrap.appendChild(iframe);
    } else if (info.type === 'vimeo') {
      var iframe2 = document.createElement('iframe');
      iframe2.src = 'https://player.vimeo.com/video/' + info.id + '?autoplay=1&title=0&byline=0&portrait=0';
      iframe2.allow = 'autoplay; fullscreen; picture-in-picture';
      iframe2.allowFullscreen = true;
      iframe2.className = 'casa-vtm-section__video';
      wrap.appendChild(iframe2);
    } else {
      var vid = document.createElement('video');
      vid.src = info.id;
      vid.autoplay = true;
      vid.playsInline = true;
      vid.loop = true;
      vid.muted = true;
      vid.className = 'casa-vtm-section__video';
      wrap.appendChild(vid);
      currentVideo = vid;
      muteBtn.style.display = 'flex';
      updateMuteIcon(true);
    }

    modal.classList.add('casa-vtm-section__modal--open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  /* ── Open modal with Shopify-hosted video ── */
  function openHosted(sourcesJson) {
    wrap.innerHTML = '';
    muteBtn.style.display = 'flex';
    var vid = document.createElement('video');
    vid.autoplay = true;
    vid.playsInline = true;
    vid.loop = true;
    vid.muted = true;
    vid.className = 'casa-vtm-section__video';
    try {
      var sources = JSON.parse(sourcesJson);
      /* Prefer MP4 sources over HLS (.m3u8) for cross-browser compat */
      var mp4Sources = sources.filter(function(s) { return s.mime === 'video/mp4'; });
      var otherSources = sources.filter(function(s) { return s.mime !== 'video/mp4'; });
      var ordered = mp4Sources.concat(otherSources);
      ordered.forEach(function(src) {
        /* Skip HLS streams — not supported by <video> in most browsers */
        if (src.url.indexOf('.m3u8') !== -1) return;
        var el = document.createElement('source');
        el.src = src.url;
        el.type = src.mime;
        vid.appendChild(el);
      });
      /* If no sources added (all were HLS), use the direct URL fallback */
      if (!vid.querySelectorAll('source').length && mp4Sources.length === 0) {
        var fallbackUrl = sources[0] ? sources[0].url : '';
        if (fallbackUrl) vid.src = fallbackUrl;
      }
    } catch(e) { /* fallback: won't play */ }
    wrap.appendChild(vid);
    currentVideo = vid;
    updateMuteIcon(true);
    modal.classList.add('casa-vtm-section__modal--open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  /* ── Close modal ── */
  function close() {
    modal.classList.remove('casa-vtm-section__modal--open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    wrap.innerHTML = '';
    currentVideo = null;
    muteBtn.style.display = 'none';
    productBar.style.display = 'none';
  }

  /* ── Mute toggle ── */
  function updateMuteIcon(muted) {
    muteOn.style.display = muted ? 'block' : 'none';
    muteOff.style.display = muted ? 'none' : 'block';
  }

  muteBtn.addEventListener('click', function(e) {
    e.stopPropagation();
    if (!currentVideo) return;
    currentVideo.muted = !currentVideo.muted;
    updateMuteIcon(currentVideo.muted);
  });

  /* ── Show/hide product link in modal ── */
  function showProductBar(card) {
    var pUrl = card.getAttribute('data-vtms-product-url');
    var pTitle = card.getAttribute('data-vtms-product-title');
    if (pUrl && pTitle) {
      productBar.href = pUrl;
      productTitle.textContent = pTitle;
      productBar.style.display = 'flex';
    } else {
      productBar.style.display = 'none';
    }
  }

  /* ── Event listeners ── */
  root.querySelectorAll('.casa-vtm-section__card').forEach(function(card, idx) {
    card.addEventListener('click', function() {
      currentCardIndex = idx;
      var url = card.getAttribute('data-vtms-url');
      var type = card.getAttribute('data-vtms-type');
      var hostedSrc = card.getAttribute('data-vtms-hosted-sources');
      if (type === 'hosted' && hostedSrc) {
        openHosted(hostedSrc);
      } else if (url) {
        open(url);
      }
      showProductBar(card);
      updateModalNav();
    });
  });

  backdrop.addEventListener('click', close);
  closeBtn.addEventListener('click', close);

  document.addEventListener('keydown', function(e) {
    if (!modal.classList.contains('casa-vtm-section__modal--open')) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowLeft') openCardByIndex(currentCardIndex - 1);
    if (e.key === 'ArrowRight') openCardByIndex(currentCardIndex + 1);
  });
})();
</script>

{% schema %}
{
  "name": "Casa Video Testimonials",
  "tag": "section",
  "class": "casa-vtm-section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "tag_text",
      "label": "Tag text"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "url",
      "id": "title_link",
      "label": "Title link",
      "info": "Makes the title clickable"
    },
    {
      "type": "text",
      "id": "accent_word",
      "label": "Accent word in title",
      "info": "This word will be highlighted with the chosen accent style"
    },
    {
      "type": "select",
      "id": "accent_style",
      "label": "Accent style",
      "options": [
        { "value": "gradient", "label": "Gradient text" },
        { "value": "solid", "label": "Solid color" },
        { "value": "underline", "label": "Underline" },
        { "value": "glow", "label": "Neon glow" },
        { "value": "shimmer", "label": "Shimmer animation" }
      ],
      "default": "gradient"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color 1",
      "default": "#9333ea"
    },
    {
      "type": "color",
      "id": "accent_color_2",
      "label": "Accent color 2",
      "info": "Used for gradient/shimmer end color",
      "default": "#ec4899"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle"
    },
    {
      "type": "select",
      "id": "content_align",
      "label": "Content alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "url",
      "id": "tag_link",
      "label": "Tag link",
      "info": "Makes the tag text clickable"
    },
    {
      "type": "header",
      "content": "Colors"
    },
