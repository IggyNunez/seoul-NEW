{% stylesheet %}
/* ══════════════════════════════════════════════════════════════════════════
   CASA VIDEO TESTIMONIALS SECTION
   Horizontal scroll row of portrait video cards + sticky modal
   ══════════════════════════════════════════════════════════════════════════ */

.casa-vtm-section {
  background: var(--cvts-bg, #0a0a0f);
  color: var(--cvts-text, #ffffff);
  padding: var(--cvts-padding-top) 0 var(--cvts-padding-bottom);
  position: relative;
  overflow: hidden;
}

/* ── Container ── */
.casa-vtm-section__container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 24px;
}
.casa-vtm-section__container--full {
  max-width: none;
  padding: 0 40px;
}

/* ── Header ── */
.casa-vtm-section__header {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  margin-bottom: 48px;
}

.casa-vtm-section__tag {
  display: inline-block;
  font-size: 12px;
  font-weight: 600;
  color: #9333ea;
  text-transform: uppercase;
  letter-spacing: 2px;
  margin-bottom: 16px;
}

.casa-vtm-section__title {
  font-size: clamp(28px, 5vw, 42px);
  font-weight: 300;
  color: var(--cvts-text, #ffffff);
  margin: 0 0 16px 0;
  letter-spacing: -0.5px;
  line-height: 1.2;
}

/* Accent word styles */
.casa-vtm-section__accent--gradient {
  background: linear-gradient(135deg, var(--cvts-accent-1, #9333ea), var(--cvts-accent-2, #ec4899));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.casa-vtm-section__accent--solid {
  color: var(--cvts-accent-1, #9333ea);
}
.casa-vtm-section__accent--underline {
  text-decoration: underline;
  text-decoration-color: var(--cvts-accent-1, #9333ea);
  text-underline-offset: 6px;
  text-decoration-thickness: 3px;
}
.casa-vtm-section__accent--glow {
  color: var(--cvts-accent-1, #9333ea);
  text-shadow: 0 0 20px var(--cvts-accent-1, #9333ea), 0 0 40px rgba(147, 51, 234, 0.3);
}
.casa-vtm-section__accent--shimmer {
  background: linear-gradient(90deg, var(--cvts-accent-1, #9333ea) 0%, var(--cvts-accent-2, #ec4899) 50%, var(--cvts-accent-1, #9333ea) 100%);
  background-size: 200% 100%;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: vtm-shimmer 3s ease-in-out infinite;
}
@keyframes vtm-shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.casa-vtm-section__subtitle {
  font-size: 16px;
  color: rgba(255, 255, 255, 0.6);
  margin: 0 auto;
  max-width: 600px;
  line-height: 1.6;
}

/* ══════════════════════════════════════════════════════════════════════════
   VIDEO CARDS ROW
   ══════════════════════════════════════════════════════════════════════════ */

.casa-vtm-section__carousel {
  position: relative;
}

.casa-vtm-section__row {
  display: flex;
  justify-content: center;
  gap: 16px;
  overflow-x: auto;
  overflow-y: hidden;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  padding-bottom: 4px;
  scrollbar-width: none;
}
.casa-vtm-section__row::-webkit-scrollbar {
  display: none;
}

/* ── Carousel arrows ── */
.casa-vtm-section__arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 3;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: none;
  background: rgba(255,255,255,0.12);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: background 0.2s ease, opacity 0.2s ease;
}
.casa-vtm-section__arrow:hover {
  background: rgba(255,255,255,0.25);
}
.casa-vtm-section__arrow--prev {
  left: -8px;
}
.casa-vtm-section__arrow--next {
  right: -8px;
}

/* Full-width mode — arrows further out */
.casa-vtm-section__container--full .casa-vtm-section__arrow--prev {
  left: 4px;
}
.casa-vtm-section__container--full .casa-vtm-section__arrow--next {
  right: 4px;
}

/* ── Card ── */
.casa-vtm-section__card {
  position: relative;
  flex-shrink: 0;
  width: var(--cvts-card-width, 220px);
  aspect-ratio: 9 / 16;
  border-radius: 14px;
  overflow: hidden;
  cursor: pointer;
  border: none;
  padding: 0;
  background: #1a1a2e;
  scroll-snap-align: start;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.casa-vtm-section__card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 32px rgba(0,0,0,0.3);
}

/* ── Thumbnail ── */
.casa-vtm-section__thumb {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.casa-vtm-section__thumb--placeholder {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
}

/* ── Play button ── */
.casa-vtm-section__play {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: rgba(255,255,255,0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0a0a0a;
  box-shadow: 0 2px 8px rgba(0,0,0,0.15);
  transition: transform 0.2s ease, background 0.2s ease;
  pointer-events: none;
}
.casa-vtm-section__play svg {
  margin-left: 2px; /* optical center for play triangle */
}
.casa-vtm-section__card:hover .casa-vtm-section__play {
  transform: translate(-50%, -50%) scale(1.1);
  background: #fff;
}

/* ── Author name ── */
.casa-vtm-section__name {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 28px 10px 10px;
  background: linear-gradient(transparent, rgba(0,0,0,0.65));
  color: #fff;
  font-size: 12px;
  font-weight: 600;
  text-align: left;
  pointer-events: none;
  line-height: 1.3;
}
.casa-vtm-section__caption {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 4px 10px 8px;
  color: rgba(255,255,255,0.7);
  font-size: 10px;
  font-weight: 400;
  text-align: left;
  pointer-events: none;
  line-height: 1.3;
}
.casa-vtm-section__card:has(.casa-vtm-section__caption) .casa-vtm-section__name {
  padding-bottom: 22px;
}
.casa-vtm-section__title-link {
  text-decoration: none;
  color: inherit;
}
.casa-vtm-section__title-link:hover .casa-vtm-section__title {
  opacity: 0.8;
}
.casa-vtm-section__tag--link {
  text-decoration: none;
  transition: opacity 0.2s;
}
.casa-vtm-section__tag--link:hover {
  opacity: 0.7;
}

/* ── Product badge on card ── */
.casa-vtm-section__product-badge {
  position: absolute;
  top: 8px;
  left: 8px;
  right: 8px;
  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  color: #fff;
  font-size: 9px;
  font-weight: 600;
  padding: 3px 6px;
  border-radius: 6px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  pointer-events: none;
  line-height: 1.3;
  opacity: 0;
  transition: opacity 0.2s ease;
}
.casa-vtm-section__card:hover .casa-vtm-section__product-badge {
  opacity: 1;
}

/* ══════════════════════════════════════════════════════════════════════════
   MODAL
   ══════════════════════════════════════════════════════════════════════════ */

.casa-vtm-section__modal {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}
.casa-vtm-section__modal--open {
  opacity: 1;
  pointer-events: auto;
}

/* ── Backdrop ── */
.casa-vtm-section__backdrop {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

/* ── Player card ── */
.casa-vtm-section__player {
  position: relative;
  width: 90vw;
  max-width: 400px;
  aspect-ratio: 9 / 16;
  border-radius: 20px;
  overflow: hidden;
  background: #000;
  box-shadow: 0 24px 64px rgba(0,0,0,0.4);
  z-index: 1;
  transform: scale(0.92);
  transition: transform 0.3s ease;
}
.casa-vtm-section__modal--open .casa-vtm-section__player {
  transform: scale(1);
}

/* ── Video element ── */
.casa-vtm-section__video-wrap {
  width: 100%;
  height: 100%;
}
.casa-vtm-section__video {
  width: 100%;
  height: 100%;
  border: none;
  object-fit: cover;
  display: block;
}

/* ── Close button ── */
.casa-vtm-section__close {
  position: absolute;
  top: 12px;
  right: 12px;
  z-index: 2;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  border: none;
  background: rgba(255,255,255,0.15);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: background 0.2s ease;
}

/* Modal nav arrows */
.casa-vtm-section__modal-prev,
.casa-vtm-section__modal-next {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 3;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  border: none;
  background: rgba(255,255,255,0.12);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: background 0.2s ease, transform 0.2s ease;
}
.casa-vtm-section__modal-prev { left: 12px; }
.casa-vtm-section__modal-next { right: 12px; }
.casa-vtm-section__modal-prev:hover,
.casa-vtm-section__modal-next:hover {
  background: rgba(255,255,255,0.25);
}
.casa-vtm-section__modal-prev:disabled,
.casa-vtm-section__modal-next:disabled {
  opacity: 0.3;
  cursor: default;
}
@media (max-width: 749px) {
  .casa-vtm-section__modal-prev,
  .casa-vtm-section__modal-next {
    width: 36px;
    height: 36px;
  }
  .casa-vtm-section__modal-prev { left: 8px; }
  .casa-vtm-section__modal-next { right: 8px; }
}
.casa-vtm-section__close:hover {
  background: rgba(255,255,255,0.3);
}

/* ── Mute button ── */
.casa-vtm-section__mute {
  position: absolute;
  bottom: 12px;
  right: 12px;
  z-index: 4;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  border: none;
  background: rgba(255,255,255,0.15);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: background 0.2s ease;
}
.casa-vtm-section__mute:hover {
  background: rgba(255,255,255,0.3);
}

/* ── Product link in modal ── */
.casa-vtm-section__modal-product {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 3;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 56px 12px 16px; /* right padding clears the mute button */
  background: linear-gradient(transparent, rgba(0,0,0,0.7));
  color: #fff;
  text-decoration: none;
  font-size: 13px;
  transition: opacity 0.2s ease;
}
.casa-vtm-section__modal-product:hover {
  opacity: 0.85;
}
.casa-vtm-section__modal-product-title {
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex: 1;
  min-width: 0;
}
.casa-vtm-section__modal-product-cta {
  font-weight: 500;
  flex-shrink: 0;
  margin-left: 12px;
  text-decoration: underline;
  text-underline-offset: 2px;
}

/* ══════════════════════════════════════════════════════════════════════════
   RESPONSIVE
   ══════════════════════════════════════════════════════════════════════════ */

@media (max-width: 768px) {
  .casa-vtm-section {
    padding: var(--cvts-padding-mobile-top) 0 var(--cvts-padding-mobile-bottom);
  }

  .casa-vtm-section__container,
  .casa-vtm-section__container--full {
    padding: 0 16px;
  }

  .casa-vtm-section__header {
    margin-bottom: 32px;
  }

  .casa-vtm-section__tag {
    font-size: 11px;
    margin-bottom: 12px;
  }

  .casa-vtm-section__subtitle {
    font-size: 14px;
  }

  .casa-vtm-section__row {
    gap: 12px;
  }

  .casa-vtm-section__card {
    width: 140px;
    border-radius: 12px;
  }

  /* Hide carousel arrows on tablet and below — use swipe */
  .casa-vtm-section__arrow {
    display: none !important;
  }

  .casa-vtm-section__play {
    width: 38px;
    height: 38px;
  }
  .casa-vtm-section__play svg {
    width: 16px;
    height: 16px;
  }

  .casa-vtm-section__player {
    width: 92vw;
    max-width: 360px;
    border-radius: 16px;
  }
}

@media (max-width: 480px) {
  .casa-vtm-section__card {
    width: 125px;
    border-radius: 10px;
  }

  .casa-vtm-section__name {
    font-size: 10px;
    padding: 20px 8px 8px;
  }

  .casa-vtm-section__player {
    width: 95vw;
    border-radius: 14px;
  }
}
