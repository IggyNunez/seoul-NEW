{% doc %}
  Casa Cart Section

  Premium dark-themed cart page section that replaces main-cart.
  Maintains full JS compatibility with cart-items-component for AJAX updates.
  Uses Casa design system tokens for consistent brand styling.
{% enddoc %}

<cart-items-component
  class="cart-items-component"
  data-section-id="{{ section.id }}"
>
  {%- comment -%} ═══ Empty Cart Template (for JS morphing when cart empties) ═══ {%- endcomment -%}
  <template id="empty-cart-template">
    <div class="casa-cart">
      <div class="casa-cart__bg-orbs">
        <div class="casa-cart__orb casa-cart__orb--1"></div>
        <div class="casa-cart__orb casa-cart__orb--2"></div>
      </div>
      <div class="casa-cart__container">
        {%- render 'casa-cart-items', force_empty: true -%}
      </div>
    </div>
  </template>

  {%- comment -%} ═══ Color Settings ═══ {%- endcomment -%}
  {%- liquid
    assign bg_color = section.settings.bg_color | default: '#ffffff'
    assign bg_secondary = section.settings.bg_secondary | default: '#f9fafb'
    assign text_primary = section.settings.text_primary | default: '#0a0a0a'
    assign text_secondary = section.settings.text_secondary | default: '#6b7280'
    assign accent_primary = section.settings.accent_primary | default: '#9333ea'
    assign accent_secondary = section.settings.accent_secondary | default: '#ec4899'
    assign price_color = section.settings.price_color | default: '#0a0a0a'
    assign compare_price_color = section.settings.compare_price_color | default: '#9ca3af'
    assign sale_price_color = section.settings.sale_price_color | default: '#ec4899'
    assign savings_color = section.settings.savings_color | default: '#22c55e'
    assign checkout_btn_bg = section.settings.checkout_btn_bg | default: '#9333ea'
    assign checkout_btn_text = section.settings.checkout_btn_text | default: '#ffffff'
    assign quantity_btn_bg = section.settings.quantity_btn_bg | default: '#9333ea'
    assign quantity_btn_text = section.settings.quantity_btn_text | default: '#ffffff'
    assign title_size = section.settings.title_size | default: 16
    assign body_size = section.settings.body_size | default: 13
  -%}

  {%- comment -%} ═══ Main Cart Content ═══ {%- endcomment -%}
  <div class="casa-cart" style="
    --cart-bg: {{ bg_color }};
    --cart-bg-secondary: {{ bg_secondary }};
    --cart-text: {{ text_primary }};
    --cart-text-muted: {{ text_secondary }};
    --cart-accent-1: {{ accent_primary }};
    --cart-accent-2: {{ accent_secondary }};
    --cart-price-color: {{ price_color }};
    --cart-compare-price-color: {{ compare_price_color }};
    --cart-sale-price-color: {{ sale_price_color }};
    --cart-savings-color: {{ savings_color }};
    --cart-checkout-btn-bg: {{ checkout_btn_bg }};
    --cart-checkout-btn-text: {{ checkout_btn_text }};
    --cart-quantity-btn-bg: {{ quantity_btn_bg }};
    --cart-quantity-btn-text: {{ quantity_btn_text }};
    --cart-title-size: {{ title_size }}px;
    --cart-body-size: {{ body_size }}px;
    {%- if section.settings.border_color != blank %}--cart-border: {{ section.settings.border_color }};{% endif -%}
    {%- if section.settings.shipping_bar_bg != blank %}--cart-ship-bar-bg: {{ section.settings.shipping_bar_bg }};{% endif -%}
    {%- if section.settings.shipping_bar_fill != blank %}--cart-ship-bar-fill: {{ section.settings.shipping_bar_fill }};{% endif -%}
    {%- if section.settings.shipping_bar_text != blank %}--cart-ship-bar-text: {{ section.settings.shipping_bar_text }};{% endif -%}
    {%- if section.settings.checkout_btn_bg_2 != blank %}--cart-checkout-btn-bg-2: {{ section.settings.checkout_btn_bg_2 }};{% endif -%}
    {%- if section.settings.continue_btn_bg != blank %}--cart-continue-btn-bg: {{ section.settings.continue_btn_bg }};{% endif -%}
    {%- if section.settings.continue_btn_text != blank %}--cart-continue-btn-text: {{ section.settings.continue_btn_text }};{% endif -%}
    {%- if section.settings.remove_btn_color != blank %}--cart-remove-btn: {{ section.settings.remove_btn_color }};{% endif -%}
    {%- if section.settings.summary_bg != blank %}--cart-summary-bg: {{ section.settings.summary_bg }};{% endif -%}
    {%- if section.settings.summary_border != blank %}--cart-summary-border: {{ section.settings.summary_border }};{% endif -%}
    {%- if section.settings.summary_text != blank %}--cart-summary-text: {{ section.settings.summary_text }};{% endif -%}
    {%- if section.settings.subtotal_color != blank %}--cart-subtotal: {{ section.settings.subtotal_color }};{% endif -%}
    {%- if section.settings.upsell_bg != blank %}--cart-upsell-bg: {{ section.settings.upsell_bg }};{% endif -%}
    {%- if section.settings.upsell_title_color != blank %}--cart-upsell-title: {{ section.settings.upsell_title_color }};{% endif -%}
    {%- if section.settings.upsell_card_bg != blank %}--cart-upsell-card-bg: {{ section.settings.upsell_card_bg }};{% endif -%}
  ">
    {%- comment -%} Subtle ambient accent — single soft glow, off by default {%- endcomment -%}
    {%- if section.settings.show_orbs -%}
    <div class="casa-cart__bg-orbs" aria-hidden="true">
      <div class="casa-cart__orb casa-cart__orb--1"></div>
    </div>
    {%- endif -%}

    <div class="casa-cart__container">

      {%- if cart.empty? -%}
        {%- render 'casa-cart-items', force_empty: true -%}
      {%- else -%}
        {%- comment -%} ═══ Cart Header ═══ {%- endcomment -%}
        {%- if section.settings.show_header != false -%}
        <div class="casa-cart__header">
          <h1 class="casa-cart__header-title">
            {{ section.settings.header_title | default: 'Shopping Bag' }}
            <span class="casa-cart__header-count">{{ cart.item_count }}</span>
          </h1>
        </div>
        {%- endif -%}

        {%- comment -%} ═══ Free Shipping Progress Bar ═══ {%- endcomment -%}
        {%- if section.settings.show_shipping_bar != false -%}
          {%- render 'casa-cart-progress-bar' -%}
        {%- endif -%}

        {%- comment -%} ═══ Grid: Items + Summary ═══ {%- endcomment -%}
        <div class="casa-cart__grid">
          <div class="casa-cart__main">
            {%- render 'casa-cart-items' -%}
          </div>

          <div class="casa-cart__sidebar">
            {%- render 'casa-cart-summary', section_id: section.id -%}
          </div>
        </div>

        {%- comment -%} ═══ Upsell Section ═══ {%- endcomment -%}
        {%- if settings.cart_show_upsell and section.settings.show_upsell != false -%}
          {%- liquid
            assign upsell_collection = collections[settings.cart_upsell_collection]
            assign upsell_limit = settings.cart_upsell_limit | default: 4
            assign upsell_title = settings.cart_upsell_title | default: 'You may also like'
          -%}
          {%- if upsell_collection != blank and upsell_collection.products.size > 0 -%}
            <div class="casa-cart__upsell">
              <div class="casa-cart__upsell-header">
                <h2 class="casa-cart__upsell-title">{{ upsell_title }}</h2>
                <div class="casa-cart__upsell-nav">
                  <button type="button" class="casa-cart__upsell-arrow casa-cart__upsell-arrow--prev" aria-label="Previous" disabled>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="15 18 9 12 15 6"></polyline></svg>
                  </button>
                  <button type="button" class="casa-cart__upsell-arrow casa-cart__upsell-arrow--next" aria-label="Next">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="9 18 15 12 9 6"></polyline></svg>
                  </button>
                </div>
              </div>
              <div class="casa-cart__upsell-track">
                {%- assign cart_product_ids = cart.items | map: 'product_id' -%}
                {%- assign shown = 0 -%}
                {%- for product in upsell_collection.products -%}
                  {%- if cart_product_ids contains product.id -%}{%- continue -%}{%- endif -%}
                  {%- if shown >= upsell_limit -%}{%- break -%}{%- endif -%}
                  <div class="casa-cart__upsell-card">
                    {%- render 'casa-product-card',
                      product: product,
                      index: shown,
                      show_quick_add: true,
                      show_variant_swatches: false,
                      show_wishlist: false,
                      show_stock_urgency: false,
                      show_installment: false,
                      show_quick_view: false,
                      show_hover_video: false,
                      card_variant: 'minimal'
                    -%}
                  </div>
                  {%- assign shown = shown | plus: 1 -%}
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}
        {%- endif -%}

        {%- comment -%} ═══ Gift Wrap ═══ {%- endcomment -%}
        {%- if settings.cart_show_gift_options and section.settings.show_gift_wrap != false -%}
          <div class="casa-cart__gift-wrap">
            <label class="casa-cart__gift-label">
              <input type="checkbox" class="casa-cart__gift-checkbox" name="attributes[gift_wrap]" value="true"
                {% if cart.attributes.gift_wrap == 'true' %}checked{% endif %}
              >
              <span class="casa-cart__gift-icon">{%- render 'casa-icon', icon: 'gift', size: 14 -%}</span>
              <span class="casa-cart__gift-text">
                {{ settings.cart_gift_wrap_text | default: 'Add gift wrapping' }}
                {%- assign _gift_price = settings.cart_gift_wrap_price | plus: 0 -%}
                {%- if _gift_price > 0 -%}
                  <span class="casa-cart__gift-price">+{{ settings.cart_gift_wrap_price | money }}</span>
                {%- endif -%}
              </span>
            </label>
          </div>
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>
</cart-items-component>

<script>
  (function() {
    function initCartUpsellCarousel() {
      var upsell = document.querySelector('.casa-cart__upsell');
      if (!upsell) return;
      var track = upsell.querySelector('.casa-cart__upsell-track');
      var prev = upsell.querySelector('.casa-cart__upsell-arrow--prev');
      var next = upsell.querySelector('.casa-cart__upsell-arrow--next');
      if (!track || !prev || !next) return;

      function updateArrows() {
        prev.disabled = track.scrollLeft <= 2;
        next.disabled = track.scrollLeft + track.offsetWidth >= track.scrollWidth - 2;
      }

      prev.addEventListener('click', function() {
        var card = track.querySelector('.casa-cart__upsell-card');
        if (card) track.scrollBy({ left: -(card.offsetWidth + 16), behavior: 'smooth' });
      });

      next.addEventListener('click', function() {
        var card = track.querySelector('.casa-cart__upsell-card');
        if (card) track.scrollBy({ left: card.offsetWidth + 16, behavior: 'smooth' });
      });

      track.addEventListener('scroll', updateArrows, { passive: true });
      updateArrows();
    }

    if (document.readyState !== 'loading') initCartUpsellCarousel();
    else document.addEventListener('DOMContentLoaded', initCartUpsellCarousel);
  })();
</script>

{% stylesheet %}
  /* ══════════════════════════════════════════════
     Casa Cart — Minimal / Elegant
     ══════════════════════════════════════════════ */

  .casa-cart {
    background: var(--cart-bg, var(--casa-bg-dark));
    min-height: 100vh;
    position: relative;
    overflow: hidden;
    color: var(--cart-text, var(--casa-text-primary));
  }

  .casa-cart__container {
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
    padding: var(--casa-space-12, 56px) var(--casa-section-px);
    position: relative;
    z-index: 1;
  }

  @media (max-width: 749px) {
    .casa-cart__container {
      padding: var(--casa-space-8, 32px) var(--casa-section-px-mobile);
    }
  }

  /* ── Subtle ambient accent (opt-in) ── */
  .casa-cart__bg-orbs {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }

  .casa-cart__orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
  }

  .casa-cart__orb--1 {
    width: 520px;
    height: 520px;
    background: var(--cart-accent-1, var(--casa-purple));
    opacity: 0.04;
    top: -120px;
    right: -120px;
  }

  /* ── Cart Header ── */
  .casa-cart__header {
    margin-bottom: var(--casa-space-8, 32px);
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding-bottom: var(--casa-space-5, 20px);
    border-bottom: 1px solid var(--cart-border, rgba(255, 255, 255, 0.08));
  }

  .casa-cart__header-title {
    font-size: 28px;
    font-weight: 400;
    color: var(--cart-text, var(--casa-text-primary));
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.01em;
    display: flex;
    align-items: baseline;
    gap: 10px;
  }

  @media (max-width: 749px) {
    .casa-cart__header-title {
      font-size: 22px;
    }
    .casa-cart__header {
      margin-bottom: var(--casa-space-6, 24px);
      padding-bottom: var(--casa-space-4, 16px);
    }
  }

  .casa-cart__header-count {
    font-size: 14px;
    font-weight: 400;
    color: var(--cart-text-muted, var(--casa-text-secondary));
    letter-spacing: 0;
  }
  .casa-cart__header-count::before { content: '/ '; opacity: 0.4; }

  /* ── Grid Layout ── */
  .casa-cart__grid {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: var(--casa-space-10, 48px);
    align-items: start;
  }

  @media (max-width: 1199px) and (min-width: 1000px) {
    .casa-cart__grid {
      grid-template-columns: 1fr 320px;
      gap: var(--casa-space-6, 24px);
    }
  }

  @media (max-width: 999px) {
    .casa-cart__grid {
      grid-template-columns: 1fr;
      gap: var(--casa-space-6, 24px);
    }
  }

  .casa-cart__main,
  .casa-cart__sidebar { min-width: 0; }

  /* ── Upsell Section ── */
  .casa-cart__upsell {
    margin-top: var(--casa-space-12, 56px);
    padding-top: var(--casa-space-8, 32px);
    border-top: 1px solid var(--cart-border, rgba(255, 255, 255, 0.08));
  }

  .casa-cart__upsell-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--casa-space-6, 24px);
  }

  .casa-cart__upsell-title {
    font-size: 18px;
    font-weight: 500;
    color: var(--cart-upsell-title, var(--cart-text, var(--casa-text-primary)));
    margin: 0;
    letter-spacing: -0.005em;
  }

  .casa-cart__upsell-nav {
    display: flex;
    gap: 6px;
  }

  .casa-cart__upsell-arrow {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid var(--cart-border, rgba(255, 255, 255, 0.12));
    border-radius: 50%;
    cursor: pointer;
    color: var(--cart-text-muted, var(--casa-text-secondary));
    transition: color 0.2s ease, border-color 0.2s ease;
    padding: 0;
  }

  .casa-cart__upsell-arrow:hover:not(:disabled) {
    border-color: var(--cart-text, var(--casa-text-primary));
    color: var(--cart-text, var(--casa-text-primary));
  }

  .casa-cart__upsell-arrow:disabled {
    opacity: 0.25;
    cursor: default;
  }

  .casa-cart__upsell-track {
    display: flex;
    gap: var(--casa-space-4, 16px);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    scroll-behavior: smooth;
  }

  .casa-cart__upsell-track::-webkit-scrollbar { display: none; }

  .casa-cart__upsell-card {
    flex: 0 0 calc(25% - var(--casa-space-4, 16px) * 3 / 4);
    scroll-snap-align: start;
    min-width: 0;
  }

  @media (max-width: 1199px) {
    .casa-cart__upsell-card {
      flex: 0 0 calc(33.33% - var(--casa-space-4, 16px) * 2 / 3);
    }
  }

  @media (max-width: 749px) {
    .casa-cart__upsell-card {
      flex: 0 0 200px;
    }
  }

  /* ── Gift Wrap ── */
  .casa-cart__gift-wrap {
    margin-top: var(--casa-space-6, 24px);
    padding: 14px 18px;
    border: 1px solid var(--cart-border, rgba(255, 255, 255, 0.08));
    border-radius: 10px;
  }

  .casa-cart__gift-label {
    display: flex;
    align-items: center;
    gap: 12px;
    cursor: pointer;
    font-size: 13px;
    color: var(--cart-text, var(--casa-text-primary));
  }

  .casa-cart__gift-checkbox {
    accent-color: var(--cart-accent-1, var(--casa-purple));
    width: 16px;
    height: 16px;
    cursor: pointer;
  }

  .casa-cart__gift-icon {
    display: flex;
    align-items: center;
    color: var(--cart-text-muted, var(--casa-text-muted));
  }

  .casa-cart__gift-text { flex: 1; }

  .casa-cart__gift-price {
    color: var(--cart-text-muted, var(--casa-text-muted));
    font-size: 12px;
    margin-left: 4px;
  }

  /* ── View Transition (empty cart) ── */
  html:active-view-transition-type(empty-cart-page) {
    .cart-items-component {
      view-transition-name: cart-page-content;
    }
  }

  ::view-transition-old(cart-page-content) {
    animation: casa-cart-fade-out 0.3s ease forwards;
  }

  @keyframes casa-cart-fade-out {
    from { opacity: 1; }
    to { opacity: 0; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Casa Cart",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Visibility toggles"
    },
    {
      "type": "checkbox",
      "id": "show_header",
      "label": "Show cart header",
      "info": "Shopping Bag title + item count",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_shipping_bar",
      "label": "Show free shipping progress bar",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_upsell",
