{% comment %}
  Seoul Glow Lab — Custom Hero Section
  Full-bleed, GSAP-animated, mobile-first
  Designed to replace the Horizon hero on the homepage
{% endcomment %}

<section
  id="sgl-hero-{{ section.id }}"
  class="sgl-hero"
  data-section-id="{{ section.id }}"
  data-section-type="sgl-hero"
>
  {%- comment -%} Background media {%- endcomment -%}
  <div class="sgl-hero__media">
    {%- if section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | image_url: width: 2000 }}"
        srcset="
          {{ section.settings.image | image_url: width: 800 }} 800w,
          {{ section.settings.image | image_url: width: 1200 }} 1200w,
          {{ section.settings.image | image_url: width: 1600 }} 1600w,
          {{ section.settings.image | image_url: width: 2000 }} 2000w
        "
        sizes="100vw"
        alt="{{ section.settings.image.alt | default: 'Seoul Glow Lab hero' }}"
        class="sgl-hero__image sgl-hero__image--desktop"
        loading="eager"
        fetchpriority="high"
        width="{{ section.settings.image.width }}"
        height="{{ section.settings.image.height }}"
      >
    {%- else -%}
      <div class="sgl-hero__image-placeholder"></div>
    {%- endif -%}

    {%- if section.settings.image_mobile != blank -%}
      <img
        src="{{ section.settings.image_mobile | image_url: width: 800 }}"
        srcset="
          {{ section.settings.image_mobile | image_url: width: 400 }} 400w,
          {{ section.settings.image_mobile | image_url: width: 600 }} 600w,
          {{ section.settings.image_mobile | image_url: width: 800 }} 800w
        "
        sizes="100vw"
        alt="{{ section.settings.image_mobile.alt | default: 'Seoul Glow Lab hero mobile' }}"
        class="sgl-hero__image sgl-hero__image--mobile"
        loading="eager"
        fetchpriority="high"
        width="{{ section.settings.image_mobile.width }}"
        height="{{ section.settings.image_mobile.height }}"
      >
    {%- endif -%}

    <div class="sgl-hero__overlay"></div>
  </div>

  {%- comment -%} Content {%- endcomment -%}
  <div class="sgl-hero__inner page-width">
    <div class="sgl-hero__content">

      {%- if section.settings.eyebrow != blank -%}
        <p class="sgl-hero__eyebrow" data-anim="eyebrow">
          {{ section.settings.eyebrow }}
        </p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="sgl-hero__heading" data-anim="heading">
          {{ section.settings.heading | newline_to_br }}
        </h1>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="sgl-hero__subheading" data-anim="subheading">
          {{ section.settings.subheading }}
        </p>
      {%- endif -%}

      <div class="sgl-hero__ctas" data-anim="ctas">
        {%- if section.settings.cta_primary_label != blank -%}
          <a
            href="{{ section.settings.cta_primary_link | default: '/collections/all' }}"
            class="sgl-hero__btn sgl-hero__btn--primary"
          >
            {{ section.settings.cta_primary_label }}
          </a>
        {%- endif -%}

        {%- if section.settings.cta_secondary_label != blank -%}
          <a
            href="{{ section.settings.cta_secondary_link | default: '/pages/about-us' }}"
            class="sgl-hero__btn sgl-hero__btn--secondary"
          >
            {{ section.settings.cta_secondary_label }}
          </a>
        {%- endif -%}
      </div>

    </div>

    {%- comment -%} Scroll indicator {%- endcomment -%}
    <div class="sgl-hero__scroll-indicator" data-anim="scroll">
      <span class="sgl-hero__scroll-line"></span>
      <span class="sgl-hero__scroll-label">Scroll</span>
    </div>
  </div>

  {%- comment -%} Decorative pill badges {%- endcomment -%}
  <div class="sgl-hero__badges" aria-hidden="true" data-anim="badges">
    <span class="sgl-hero__badge">✦ Clean Beauty</span>
    <span class="sgl-hero__badge">✦ K-Beauty Science</span>
    <span class="sgl-hero__badge">✦ Glass Skin</span>
  </div>
</section>

<style>
  /* =============================================
     SGL HERO — BASE STYLES
  ============================================= */
  .sgl-hero {
    position: relative;
    width: 100%;
    height: 100svh;
    min-height: 600px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    background-color: #5E0A02;
  }

  /* Media */
  .sgl-hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .sgl-hero__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    will-change: transform;
  }

  .sgl-hero__image--mobile {
    display: none;
  }

  .sgl-hero__image-placeholder {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #5E0A02 0%, #3a0601 40%, #1a0300 100%);
  }

  /* Overlay — gradient from bottom so text is always readable */
  .sgl-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(94, 10, 2, 0.92) 0%,
      rgba(94, 10, 2, 0.55) 40%,
      rgba(94, 10, 2, 0.2) 70%,
      rgba(0, 0, 0, 0.05) 100%
    );
    z-index: 1;
  }

  /* Inner layout */
  .sgl-hero__inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-start;
    height: 100%;
    padding-block: clamp(40px, 8vw, 120px);
    gap: 0;
  }

  /* Content block */
  .sgl-hero__content {
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 700px;
    padding-bottom: 48px;
  }

  /* Eyebrow */
  .sgl-hero__eyebrow {
    margin: 0;
    font-family: var(--font-body--family);
    font-size: clamp(0.65rem, 1.2vw, 0.8rem);
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #F2FFA0;
    opacity: 0;
    transform: translateY(12px);
  }

  /* Heading */
  .sgl-hero__heading {
    margin: 0;
    font-family: var(--font-heading--family);
    font-size: clamp(3rem, 8vw, 7.5rem);
    font-weight: 800;
    line-height: 0.93;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: #F8EBDA;
    opacity: 0;
    transform: translateY(24px);
  }

  /* Subheading */
  .sgl-hero__subheading {
    margin: 0;
    font-family: var(--font-body--family);
    font-size: clamp(0.9rem, 1.6vw, 1.05rem);
    line-height: 1.6;
    color: rgba(248, 235, 218, 0.8);
    max-width: 520px;
    opacity: 0;
    transform: translateY(16px);
  }

  /* CTAs */
  .sgl-hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 8px;
    opacity: 0;
    transform: translateY(16px);
  }

  .sgl-hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 32px;
    font-family: var(--font-body--family);
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 2px;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease, transform 0.15s ease;
    cursor: pointer;
    white-space: nowrap;
  }

  .sgl-hero__btn--primary {
    background: #F2FFA0;
    color: #1B4900;
    border: 2px solid #F2FFA0;
  }

  .sgl-hero__btn--primary:hover {
    background: #ffffff;
    border-color: #ffffff;
    color: #5E0A02;
    transform: translateY(-1px);
  }

  .sgl-hero__btn--secondary {
    background: transparent;
    color: #F8EBDA;
    border: 2px solid rgba(248, 235, 218, 0.5);
  }

  .sgl-hero__btn--secondary:hover {
    border-color: #F8EBDA;
    background: rgba(248, 235, 218, 0.08);
    transform: translateY(-1px);
  }

  /* Scroll indicator */
  .sgl-hero__scroll-indicator {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    opacity: 0;
    position: absolute;
    bottom: clamp(20px, 4vw, 40px);
    right: clamp(20px, 4vw, 48px);
  }

  .sgl-hero__scroll-line {
    display: block;
    width: 1px;
    height: 48px;
    background: rgba(248, 235, 218, 0.4);
    transform-origin: top center;
    transform: scaleY(0);
  }

  .sgl-hero__scroll-label {
    font-family: var(--font-body--family);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(248, 235, 218, 0.5);
    writing-mode: vertical-rl;
    transform: rotate(180deg);
  }

  /* Floating badges */
  .sgl-hero__badges {
    position: absolute;
    top: clamp(20px, 4vw, 40px);
    right: clamp(16px, 3vw, 40px);
    z-index: 3;
    display: flex;
    flex-direction: column;
    gap: 8px;
    opacity: 0;
  }

  .sgl-hero__badge {
    display: inline-block;
    padding: 6px 14px;
    background: rgba(248, 235, 218, 0.08);
    border: 1px solid rgba(248, 235, 218, 0.2);
    border-radius: 100px;
    font-family: var(--font-body--family);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(248, 235, 218, 0.7);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  /* =============================================
     MOBILE
  ============================================= */
  @media (max-width: 749px) {
    .sgl-hero {
      height: 100svh;
      min-height: 580px;
    }

    .sgl-hero__image--desktop {
      display: none;
    }

    /* Show mobile image if set, else show desktop */
    .sgl-hero__image--mobile {
      display: block;
    }

    /* If no mobile image, re-show desktop */
    .sgl-hero__image--desktop:not([srcset]) {
      display: block;
    }

    .sgl-hero__inner {
      justify-content: flex-end;
      padding-bottom: 80px;
    }

    .sgl-hero__content {
      gap: 16px;
      max-width: 100%;
      padding-bottom: 32px;
    }

    .sgl-hero__heading {
      font-size: clamp(2.6rem, 11vw, 4rem);
      line-height: 0.95;
    }

    .sgl-hero__subheading {
      font-size: 0.9rem;
    }

    .sgl-hero__ctas {
      flex-direction: column;
      gap: 10px;
    }

    .sgl-hero__btn {
      width: 100%;
      justify-content: center;
      padding: 14px 24px;
    }

    .sgl-hero__badges {
      flex-direction: row;
      flex-wrap: wrap;
      top: auto;
      right: auto;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%);
      justify-content: center;
      display: none; /* hide on small screens, too busy */
    }

    .sgl-hero__scroll-indicator {
      display: none;
    }

    .sgl-hero__overlay {
      background: linear-gradient(
        to top,
        rgba(94, 10, 2, 0.95) 0%,
        rgba(94, 10, 2, 0.65) 45%,
        rgba(94, 10, 2, 0.2) 75%,
        rgba(0, 0, 0, 0.0) 100%
      );
    }
  }

  /* No-image fallback visible even without JS */
  @media (prefers-reduced-motion: reduce) {
    .sgl-hero__eyebrow,
    .sgl-hero__heading,
    .sgl-hero__subheading,
    .sgl-hero__ctas,
    .sgl-hero__scroll-indicator,
    .sgl-hero__badges {
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>

<script>
  (function() {
    'use strict';

    const GSAP_CDN = 'https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js';
    const ST_CDN   = 'https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js';

    function loadScript(src, cb) {
      if (document.querySelector('script[src="' + src + '"]')) { cb(); return; }
      const s = document.createElement('script');
      s.src = src;
      s.async = true;
      s.onload = cb;
      document.head.appendChild(s);
    }

    function initHero() {
      const section  = document.getElementById('sgl-hero-{{ section.id }}');
      if (!section) return;

      const gsap = window.gsap;
      if (!gsap) return;

      const eyebrow  = section.querySelector('[data-anim="eyebrow"]');
      const heading  = section.querySelector('[data-anim="heading"]');
      const sub      = section.querySelector('[data-anim="subheading"]');
      const ctas     = section.querySelector('[data-anim="ctas"]');
      const scroll   = section.querySelector('[data-anim="scroll"]');
      const badges   = section.querySelector('[data-anim="badges"]');
      const image    = section.querySelector('.sgl-hero__image');
      const line     = section.querySelector('.sgl-hero__scroll-line');

      /* ── Entrance timeline ── */
      const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

      /* Image subtle Ken-Burns on load */
      if (image) {
        gsap.set(image, { scale: 1.06 });
        tl.to(image, { scale: 1, duration: 2.2, ease: 'power2.out' }, 0);
      }

      /* Staggered text reveal */
      if (eyebrow) {
        tl.to(eyebrow, { opacity: 1, y: 0, duration: 0.7 }, 0.3);
      }
      if (heading) {
        /* Split heading words for stagger if possible */
        const words = heading.querySelectorAll('.sgl-word') ;
        if (words.length) {
          tl.to(words, { opacity: 1, y: 0, duration: 0.8, stagger: 0.08 }, 0.45);
        } else {
          tl.to(heading, { opacity: 1, y: 0, duration: 0.85 }, 0.45);
        }
      }
      if (sub) {
        tl.to(sub, { opacity: 1, y: 0, duration: 0.75 }, 0.7);
      }
      if (ctas) {
        tl.to(ctas, { opacity: 1, y: 0, duration: 0.7 }, 0.9);
      }
      if (badges) {
        tl.to(badges, { opacity: 1, duration: 0.8 }, 1.1);
      }
      if (scroll) {
        tl.to(scroll, { opacity: 1, duration: 0.6 }, 1.2);
      }
      if (line) {
        tl.to(line, { scaleY: 1, duration: 0.9, ease: 'power2.inOut' }, 1.4);

        /* Animate line up and down on repeat */
        gsap.to(line, {
          scaleY: 0,
          transformOrigin: 'bottom center',
          duration: 0.6,
          ease: 'power2.in',
          delay: 2.5,
          repeat: -1,
          repeatDelay: 1.2,
          yoyo: false,
          onRepeat: function() {
            gsap.set(line, { scaleY: 0, transformOrigin: 'top center' });
            gsap.to(line, { scaleY: 1, duration: 0.5, ease: 'power2.out' });
          }
        });
      }

      /* ── Parallax on scroll (desktop only) ── */
      if (window.ScrollTrigger && image && window.matchMedia('(min-width: 750px)').matches) {
        gsap.registerPlugin(window.ScrollTrigger);
        gsap.to(image, {
          yPercent: 18,
          ease: 'none',
          scrollTrigger: {
            trigger: section,
            start: 'top top',
            end: 'bottom top',
            scrub: true
          }
        });
      }

      /* ── Floating badge drift ── */
      const badgeEls = section.querySelectorAll('.sgl-hero__badge');
      badgeEls.forEach(function(badge, i) {
        gsap.to(badge, {
          y: -6 + (i * 3),
          duration: 2.5 + (i * 0.4),
          ease: 'sine.inOut',
          yoyo: true,
          repeat: -1,
          delay: i * 0.3
        });
      });
    }

    /* Load GSAP → ScrollTrigger → init */
    loadScript(GSAP_CDN, function() {
      loadScript(ST_CDN, function() {
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initHero);
        } else {
          initHero();
        }
      });
    });

  })();
</script>

{% schema %}
{
  "name": "SGL Hero",
  "tag": "section",
  "class": "sgl-hero-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "K-Beauty Elevated"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Seoul You Need\nFor That Glow"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "The art and science of Korean skincare — clean formulas and rituals designed to help every skin tone glow with intention."
    },
    {
      "type": "header",
      "content": "Primary CTA"
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Label",
      "default": "Shop the Collection"
    },
    {
      "type": "url",
      "id": "cta_primary_link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Secondary CTA"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "Label",
      "default": "Our Story"
    },
    {
      "type": "url",
      "id": "cta_secondary_link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop Image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile Image (optional — uses desktop if blank)"
    }
  ],
  "presets": [
    {
      "name": "SGL Hero",
      "settings": {
        "eyebrow": "K-Beauty Elevated",
        "heading": "Seoul You Need\nFor That Glow",
        "subheading": "The art and science of Korean skincare — clean formulas and rituals designed to help every skin tone glow with intention.",
        "cta_primary_label": "Shop the Collection",
        "cta_secondary_label": "Our Story"
      }
    }
  ]
}
{% endschema %}
