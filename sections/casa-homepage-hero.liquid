{%- liquid
  # ══════════════════════════════════════════════════════
  # Casa Homepage Hero — 6 Layouts, Fully Self-Contained
  # ══════════════════════════════════════════════════════

  # ── Layout & Structure ──
  assign layout       = section.settings.layout | default: 'editorial'
  assign content_align = section.settings.content_align | default: 'center'
  assign title_size   = section.settings.title_size | default: 'large'
  assign min_height   = section.settings.min_height | default: 0
  assign pad_top      = section.settings.padding_top | default: 60
  assign pad_bot      = section.settings.padding_bottom | default: 60
  assign enable_parallax = section.settings.enable_parallax
  assign full_width   = section.settings.full_width

  # ── Colors ──
  assign bg_color      = section.settings.bg_color | default: '#0a0a0f'
  assign text_color    = section.settings.text_color | default: '#ffffff'
  assign text_muted    = section.settings.text_muted | default: '#a0a0b0'
  assign accent_1      = section.settings.accent_primary | default: '#9333ea'
  assign accent_2      = section.settings.accent_secondary | default: '#ec4899'

  # ── Content ──
  assign heading       = section.settings.heading | default: ''
  assign subheading    = section.settings.subheading | default: ''
  assign description   = section.settings.description | default: ''
  assign accent_word   = section.settings.accent_word | default: ''

  # ── CTA ──
  assign cta1_text     = section.settings.cta1_text | default: ''
  assign cta1_link     = section.settings.cta1_link | default: ''
  assign cta1_style    = section.settings.cta1_style | default: 'gradient'
  assign cta2_text     = section.settings.cta2_text | default: ''
  assign cta2_link     = section.settings.cta2_link | default: ''
  assign cta2_style    = section.settings.cta2_style | default: 'outline'
  assign cta1_bg       = section.settings.cta1_bg
  assign cta1_text_color = section.settings.cta1_text_color
  assign cta1_radius   = section.settings.cta1_radius | default: 10
  assign cta1_size     = section.settings.cta1_size | default: 'medium'
  assign cta2_bg       = section.settings.cta2_bg
  assign cta2_text_color = section.settings.cta2_text_color
  assign cta2_radius   = section.settings.cta2_radius | default: 10
  assign cta2_size     = section.settings.cta2_size | default: 'medium'

  # ── Media ──
  assign bg_image_d    = section.settings.bg_image_desktop
  assign bg_image_m    = section.settings.bg_image_mobile
  assign bg_video_url  = section.settings.bg_video_url | default: ''
  assign overlay_pct   = section.settings.overlay_opacity | default: 50

  # Resolve images
  assign hero_img_d = bg_image_d
  assign hero_img_m = bg_image_m
  if hero_img_m == blank
    assign hero_img_m = hero_img_d
  endif

  assign has_media = false
  if hero_img_d != blank or bg_video_url != blank
    assign has_media = true
  endif

  # ── Title processing ──
  assign display_title = heading
  if accent_word != blank and heading contains accent_word
    assign parts = heading | split: accent_word
    assign display_title = parts[0] | append: '<span class="casa-home-hero__accent">' | append: accent_word | append: '</span>' | append: parts[1]
  endif

  # ── Collect blocks ──
  assign pills = ''
  assign trust_stats = ''
  assign has_scroll = false
  for block in section.blocks
    case block.type
      when 'announcement_pill'
        assign pills = pills | append: block.id | append: ','
      when 'trust_stat'
        assign trust_stats = trust_stats | append: block.id | append: ','
      when 'scroll_indicator'
        assign has_scroll = true
    endcase
  endfor

  # Title size classes
  assign title_class = 'casa-home-hero__title'
  case title_size
    when 'small'
      assign title_class = title_class | append: ' casa-home-hero__title--sm'
    when 'medium'
      assign title_class = title_class | append: ' casa-home-hero__title--md'
    when 'large'
      assign title_class = title_class | append: ' casa-home-hero__title--lg'
    when 'extra-large'
      assign title_class = title_class | append: ' casa-home-hero__title--xl'
  endcase
-%}

{%- capture section_id -%}casa-home-hero-{{ section.id }}{%- endcapture -%}

<section
  id="{{ section_id }}"
  class="casa-home-hero casa-home-hero--{{ layout }}{% if full_width %} casa-home-hero--full{% endif %}"
  style="
    --chh-bg: {{ bg_color }};
    --chh-text: {{ text_color }};
    --chh-muted: {{ text_muted }};
    --chh-accent1: {{ accent_1 }};
    --chh-accent2: {{ accent_2 }};
    --chh-pad-top: {{ pad_top }}px;
    --chh-pad-bot: {{ pad_bot }}px;
    --chh-min-h: {% if min_height > 0 %}{{ min_height }}px{% else %}auto{% endif %};
    --chh-overlay: {{ overlay_pct | divided_by: 100.0 }};
    --chh-align: {{ content_align }};
  "
  data-layout="{{ layout }}"
>

  {%- comment -%}── MEDIA LAYER ──{%- endcomment -%}
  {%- if layout != 'gradient_mesh' -%}
    <div class="casa-home-hero__media">
      {%- if bg_video_url != blank -%}
        <video
          class="casa-home-hero__video"
          autoplay muted loop playsinline
          {% if hero_img_d %}poster="{{ hero_img_d | image_url: width: 1920 }}"{% endif %}
        >
          <source src="{{ bg_video_url }}" type="video/mp4">
        </video>
      {%- elsif hero_img_d != blank -%}
        <picture>
          {%- if hero_img_m != blank -%}
            <source media="(max-width: 767px)" srcset="{{ hero_img_m | image_url: width: 800 }} 800w, {{ hero_img_m | image_url: width: 1200 }} 1200w" sizes="100vw">
          {%- endif -%}
          <img
            class="casa-home-hero__img{% if enable_parallax %} casa-home-hero__img--parallax{% endif %}"
            src="{{ hero_img_d | image_url: width: 1920 }}"
            srcset="{{ hero_img_d | image_url: width: 1200 }} 1200w, {{ hero_img_d | image_url: width: 1920 }} 1920w, {{ hero_img_d | image_url: width: 2560 }} 2560w"
            sizes="100vw"
            alt="{{ heading | escape }}"
            loading="eager"
            fetchpriority="high"
          >
        </picture>
      {%- endif -%}
      <div class="casa-home-hero__overlay"></div>
    </div>
  {%- endif -%}

  {%- comment -%}── GRADIENT MESH BACKGROUND ──{%- endcomment -%}
  {%- if layout == 'gradient_mesh' -%}
    <div class="casa-home-hero__mesh">
      <div class="casa-home-hero__mesh-blob casa-home-hero__mesh-blob--1"></div>
      <div class="casa-home-hero__mesh-blob casa-home-hero__mesh-blob--2"></div>
      <div class="casa-home-hero__mesh-blob casa-home-hero__mesh-blob--3"></div>
      <div class="casa-home-hero__mesh-blob casa-home-hero__mesh-blob--4"></div>
    </div>
  {%- endif -%}

  {%- comment -%}── MARQUEE BACKGROUND TEXT ──{%- endcomment -%}
  {%- if layout == 'marquee' and heading != blank -%}
    <div class="casa-home-hero__marquee-track" aria-hidden="true">
      <div class="casa-home-hero__marquee-text">
        <span>{{ heading }}&nbsp;&mdash;&nbsp;</span>
        <span>{{ heading }}&nbsp;&mdash;&nbsp;</span>
        <span>{{ heading }}&nbsp;&mdash;&nbsp;</span>
        <span>{{ heading }}&nbsp;&mdash;&nbsp;</span>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%}── SPLIT LAYOUT WRAPPER ──{%- endcomment -%}
  {%- if layout == 'split' -%}
    <div class="casa-home-hero__split-wrap">
      <div class="casa-home-hero__split-media">
        {%- if hero_img_d != blank -%}
          <img
            class="casa-home-hero__split-img"
            src="{{ hero_img_d | image_url: width: 1200 }}"
            srcset="{{ hero_img_d | image_url: width: 800 }} 800w, {{ hero_img_d | image_url: width: 1200 }} 1200w"
            sizes="50vw"
            alt="{{ heading | escape }}"
            loading="eager"
          >
        {%- else -%}
          <div class="casa-home-hero__split-placeholder"></div>
        {%- endif -%}
      </div>
      <div class="casa-home-hero__split-content">
  {%- endif -%}

  {%- comment -%}── CARD WRAPPER (open) ──{%- endcomment -%}
  {%- if layout == 'card' -%}
    <div class="casa-home-hero__card-wrap">
      <div class="casa-home-hero__card">
  {%- endif -%}

  {%- comment -%}── MAIN CONTENT ──{%- endcomment -%}
  <div class="casa-home-hero__content casa-home-hero__content--{{ content_align }}{% if layout == 'editorial' %} casa-home-hero__content--animate{% endif %}">

    {%- comment -%}Announcement Pills{%- endcomment -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'announcement_pill' -%}
        <div class="casa-home-hero__pill" {{ block.shopify_attributes }}>
          {%- if block.settings.pill_icon != blank -%}
            <span class="casa-home-hero__pill-icon">{{ block.settings.pill_icon }}</span>
          {%- endif -%}
          <span class="casa-home-hero__pill-text">{{ block.settings.pill_text }}</span>
        </div>
      {%- endif -%}
    {%- endfor -%}

    {%- comment -%}Subheading / Eyebrow{%- endcomment -%}
    {%- if subheading != blank -%}
      <p class="casa-home-hero__eyebrow">{{ subheading }}</p>
    {%- endif -%}

    {%- comment -%}Heading{%- endcomment -%}
    {%- if heading != blank -%}
      <h1 class="{{ title_class }}">{{ display_title }}</h1>
    {%- endif -%}

    {%- comment -%}Description{%- endcomment -%}
    {%- if description != blank -%}
      <p class="casa-home-hero__desc">{{ description }}</p>
    {%- endif -%}

    {%- comment -%}CTAs{%- endcomment -%}
    {%- if cta1_text != blank or cta2_text != blank -%}
      <div class="casa-home-hero__ctas">
        {%- if cta1_text != blank -%}
          <a href="{{ cta1_link }}" class="casa-home-hero__btn casa-home-hero__btn--{{ cta1_style }} casa-home-hero__btn--{{ cta1_size }}" style="{% if cta1_bg != blank %}background: {{ cta1_bg }};{% endif %}{% if cta1_text_color != blank %}color: {{ cta1_text_color }};{% endif %}border-radius: {{ cta1_radius }}px;">
            {{ cta1_text }}
          </a>
        {%- endif -%}
        {%- if cta2_text != blank -%}
          <a href="{{ cta2_link }}" class="casa-home-hero__btn casa-home-hero__btn--{{ cta2_style }} casa-home-hero__btn--{{ cta2_size }}" style="{% if cta2_bg != blank %}background: {{ cta2_bg }};{% endif %}{% if cta2_text_color != blank %}color: {{ cta2_text_color }};{% endif %}border-radius: {{ cta2_radius }}px;">
            {{ cta2_text }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%}Trust Stats{%- endcomment -%}
    {%- assign has_trust = false -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'trust_stat' -%}
        {%- assign has_trust = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}
    {%- if has_trust -%}
      <div class="casa-home-hero__trust">
        {%- for block in section.blocks -%}
          {%- if block.type == 'trust_stat' -%}
            <div class="casa-home-hero__trust-item" {{ block.shopify_attributes }}>
              <span class="casa-home-hero__trust-icon">
                {%- case block.settings.stat_icon -%}
                  {%- when 'star' -%}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                  {%- when 'truck' -%}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                  {%- when 'shield' -%}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                  {%- when 'heart' -%}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                  {%- when 'clock' -%}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  {%- when 'tag' -%}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.83z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
                  {%- when 'gift' -%}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
                  {%- when 'zap' -%}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                  {%- when 'users' -%}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                  {%- when 'check' -%}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                {%- endcase -%}
              </span>
              <span class="casa-home-hero__trust-text">{{ block.settings.stat_text }}</span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>{%- comment -%}/.casa-home-hero__content{%- endcomment -%}

  {%- comment -%}── CARD WRAPPER (close) ──{%- endcomment -%}
  {%- if layout == 'card' -%}
      </div>{%- comment -%}/.casa-home-hero__card{%- endcomment -%}
    </div>{%- comment -%}/.casa-home-hero__card-wrap{%- endcomment -%}
  {%- endif -%}

  {%- comment -%}── SPLIT LAYOUT (close) ──{%- endcomment -%}
  {%- if layout == 'split' -%}
      </div>{%- comment -%}/.casa-home-hero__split-content{%- endcomment -%}
    </div>{%- comment -%}/.casa-home-hero__split-wrap{%- endcomment -%}
  {%- endif -%}

  {%- comment -%}── SCROLL INDICATOR ──{%- endcomment -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'scroll_indicator' -%}
      <div class="casa-home-hero__scroll" {{ block.shopify_attributes }} aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </div>
    {%- endif -%}
  {%- endfor -%}

  {%- comment -%}── APP BLOCKS ──{%- endcomment -%}
  {%- for block in section.blocks -%}
    {%- if block.type == '@app' -%}
      <div class="casa-home-hero__app-block" {{ block.shopify_attributes }}>
        {% render block %}
      </div>
    {%- endif -%}
  {%- endfor -%}

</section>

{%- comment -%}
  ═══════════════════════════════════════
  STYLES
  ═══════════════════════════════════════
{%- endcomment -%}
<style>
  /* ── Reset & Base ── */
  .casa-home-hero {
    position: relative;
    overflow: hidden;
    background: var(--chh-bg);
    color: var(--chh-text);
    min-height: var(--chh-min-h);
    padding-top: var(--chh-pad-top);
    padding-bottom: var(--chh-pad-bot);
    display: flex;
    flex-direction: column;
    justify-content: center;
    width: 100%;
    box-sizing: border-box;
  }
  .casa-home-hero *,
  .casa-home-hero *::before,
  .casa-home-hero *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  /* ── Media Layer ── */
  .casa-home-hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .casa-home-hero__video,
  .casa-home-hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .casa-home-hero__img--parallax {
    will-change: transform;
  }
  .casa-home-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(10, 10, 15, var(--chh-overlay)) 0%,
      rgba(10, 10, 15, calc(var(--chh-overlay) * 0.6)) 50%,
      rgba(10, 10, 15, var(--chh-overlay)) 100%
    );
    z-index: 1;
  }

  /* ── Content ── */
  .casa-home-hero__content {
    position: relative;
    z-index: 2;
    max-width: 800px;
    padding: 0 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .casa-home-hero:not(.casa-home-hero--split):not(.casa-home-hero--card) > .casa-home-hero__content {
    margin-left: auto;
    margin-right: auto;
    width: 100%;
  }
  .casa-home-hero__content--left { align-items: flex-start; text-align: left; }
  .casa-home-hero__content--center { align-items: center; text-align: center; }
  .casa-home-hero__content--right { align-items: flex-end; text-align: right; }

  /* ── Announcement Pill ── */
  .casa-home-hero__pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 16px;
    border-radius: 999px;
    background: rgba(147, 51, 234, 0.15);
    border: 1px solid rgba(147, 51, 234, 0.3);
    font-size: 13px;
    font-weight: 500;
    color: var(--chh-accent1);
    letter-spacing: 0.02em;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .casa-home-hero__pill-icon { font-size: 14px; line-height: 1; }

  /* ── Eyebrow ── */
  .casa-home-hero__eyebrow {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--chh-accent1);
  }

  /* ── Title ── */
  .casa-home-hero__title {
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: var(--chh-text);
  }
  .casa-home-hero__title--sm { font-size: clamp(1.5rem, 3vw, 2rem); }
  .casa-home-hero__title--md { font-size: clamp(2rem, 4vw, 3rem); }
  .casa-home-hero__title--lg { font-size: clamp(2.5rem, 5.5vw, 4.5rem); }
  .casa-home-hero__title--xl { font-size: clamp(3rem, 7vw, 6rem); }

  /* Accent word gradient */
  .casa-home-hero__accent {
    background: linear-gradient(135deg, var(--chh-accent1), var(--chh-accent2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ── Description ── */
  .casa-home-hero__desc {
    font-size: clamp(0.95rem, 1.4vw, 1.2rem);
    line-height: 1.6;
    color: var(--chh-muted);
    max-width: 560px;
  }

  /* ── CTAs ── */
  .casa-home-hero__ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 8px;
  }
  .casa-home-hero__content--center .casa-home-hero__ctas { justify-content: center; }
  .casa-home-hero__content--right .casa-home-hero__ctas { justify-content: flex-end; }

  .casa-home-hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 13px 28px;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: transform 0.25s ease, box-shadow 0.25s ease, opacity 0.25s ease;
    cursor: pointer;
    border: none;
    line-height: 1;
    white-space: nowrap;
  }
  .casa-home-hero__btn:hover {
    transform: translateY(-2px);
  }
  .casa-home-hero__btn--gradient {
    background: linear-gradient(135deg, var(--chh-accent1), var(--chh-accent2));
    color: #fff;
    box-shadow: 0 4px 20px rgba(147, 51, 234, 0.35);
  }
  .casa-home-hero__btn--gradient:hover {
    box-shadow: 0 8px 30px rgba(147, 51, 234, 0.5);
  }
  .casa-home-hero__btn--solid {
    background: var(--chh-accent1);
    color: #fff;
  }
  .casa-home-hero__btn--outline {
    background: transparent;
    color: var(--chh-text);
    border: 1px solid rgba(255,255,255,0.2);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  .casa-home-hero__btn--outline:hover {
    border-color: rgba(255,255,255,0.4);
    background: rgba(255,255,255,0.05);
  }
  .casa-home-hero__btn--small { padding: 9px 18px; font-size: 12px; }
  .casa-home-hero__btn--medium { padding: 13px 28px; font-size: 14px; }
  .casa-home-hero__btn--large { padding: 16px 36px; font-size: 16px; }

  /* ── Trust Stats ── */
  .casa-home-hero__trust {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    margin-top: 12px;
  }
  .casa-home-hero__content--center .casa-home-hero__trust { justify-content: center; }
  .casa-home-hero__content--right .casa-home-hero__trust { justify-content: flex-end; }

  .casa-home-hero__trust-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--chh-muted);
  }
  .casa-home-hero__trust-icon {
    display: flex;
    align-items: center;
    color: var(--chh-accent1);
    opacity: 0.85;
  }

  /* ══════════════════════════════════════
     LAYOUT: COMPACT
     ══════════════════════════════════════ */
  .casa-home-hero--compact {
    min-height: 0 !important;
    padding-top: 16px;
    padding-bottom: 16px;
  }
  .casa-home-hero--compact .casa-home-hero__content {
    flex-direction: row;
    align-items: center;
    gap: 20px;
    max-width: 1200px;
    flex-wrap: wrap;
  }
  .casa-home-hero--compact .casa-home-hero__title {
    font-size: clamp(1.1rem, 2vw, 1.5rem) !important;
    white-space: nowrap;
  }
  .casa-home-hero--compact .casa-home-hero__desc {
    font-size: 0.9rem;
    flex: 1;
    min-width: 200px;
  }
  .casa-home-hero--compact .casa-home-hero__ctas { margin-top: 0; }
  .casa-home-hero--compact .casa-home-hero__trust { display: none; }
  .casa-home-hero--compact .casa-home-hero__pill { display: none; }
  .casa-home-hero--compact .casa-home-hero__eyebrow { display: none; }

  /* ══════════════════════════════════════
     LAYOUT: EDITORIAL
     ══════════════════════════════════════ */
  .casa-home-hero--editorial {
    min-height: max(80vh, 500px);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .casa-home-hero--editorial .casa-home-hero__content {
    gap: 20px;
  }

  /* Editorial stagger animation */
  .casa-home-hero__content--animate > * {
    opacity: 0;
    transform: translateY(24px);
    animation: chh-fadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .casa-home-hero__content--animate > *:nth-child(1) { animation-delay: 0.1s; }
  .casa-home-hero__content--animate > *:nth-child(2) { animation-delay: 0.2s; }
  .casa-home-hero__content--animate > *:nth-child(3) { animation-delay: 0.35s; }
  .casa-home-hero__content--animate > *:nth-child(4) { animation-delay: 0.5s; }
  .casa-home-hero__content--animate > *:nth-child(5) { animation-delay: 0.6s; }
  .casa-home-hero__content--animate > *:nth-child(6) { animation-delay: 0.7s; }
  .casa-home-hero__content--animate > *:nth-child(7) { animation-delay: 0.8s; }

  @keyframes chh-fadeUp {
    to { opacity: 1; transform: translateY(0); }
  }

  /* ══════════════════════════════════════
     LAYOUT: CARD
     ══════════════════════════════════════ */
  .casa-home-hero--card {
    min-height: max(70vh, 450px);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .casa-home-hero__card-wrap {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: var(--chh-align, center);
    width: 100%;
    padding: 0 24px;
  }
  .casa-home-hero__card {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 48px 40px;
    max-width: 560px;
    width: 100%;
    animation: chh-cardFloat 6s ease-in-out infinite;
  }
  .casa-home-hero__card .casa-home-hero__content {
    padding: 0;
    max-width: none;
  }
  @keyframes chh-cardFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  /* ══════════════════════════════════════
     LAYOUT: MARQUEE
     ══════════════════════════════════════ */
  .casa-home-hero--marquee {
    min-height: max(70vh, 450px);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .casa-home-hero__marquee-track {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    overflow: hidden;
    z-index: 1;
    opacity: 0.06;
    pointer-events: none;
  }
  .casa-home-hero__marquee-text {
    display: flex;
    white-space: nowrap;
    animation: chh-marqueeScroll 25s linear infinite;
    font-size: clamp(6rem, 15vw, 14rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    color: var(--chh-text);
  }
  .casa-home-hero__marquee-text span {
    flex-shrink: 0;
  }
  @keyframes chh-marqueeScroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .casa-home-hero--marquee .casa-home-hero__content {
    z-index: 2;
  }

  /* ══════════════════════════════════════
     LAYOUT: SPLIT
     ══════════════════════════════════════ */
  .casa-home-hero--split {
    padding: 0 !important;
  }
  .casa-home-hero--split .casa-home-hero__media { display: none; }
  .casa-home-hero__split-wrap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: max(70vh, 450px);
    width: 100%;
  }
  .casa-home-hero__split-media {
    position: relative;
    overflow: hidden;
    clip-path: polygon(0 0, 100% 0, 85% 100%, 0 100%);
  }
  .casa-home-hero__split-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .casa-home-hero__split-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--chh-accent1), var(--chh-accent2));
    opacity: 0.3;
  }
  .casa-home-hero__split-content {
    display: flex;
    align-items: center;
    padding: 60px 48px 60px 24px;
  }
  .casa-home-hero__split-content .casa-home-hero__content {
    padding: 0;
    align-items: flex-start;
    text-align: left;
  }

  /* ══════════════════════════════════════
     LAYOUT: GRADIENT MESH
     ══════════════════════════════════════ */
  .casa-home-hero--gradient_mesh {
    min-height: max(70vh, 450px);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .casa-home-hero__mesh {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }
  .casa-home-hero__mesh-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.5;
    will-change: transform;
  }
  .casa-home-hero__mesh-blob--1 {
    width: 45%;
    padding-bottom: 45%;
    background: var(--chh-accent1);
    top: -10%;
    left: -5%;
    animation: chh-meshMove1 18s ease-in-out infinite;
  }
  .casa-home-hero__mesh-blob--2 {
    width: 40%;
    padding-bottom: 40%;
    background: var(--chh-accent2);
    top: 20%;
    right: -10%;
    animation: chh-meshMove2 22s ease-in-out infinite;
  }
  .casa-home-hero__mesh-blob--3 {
    width: 35%;
    padding-bottom: 35%;
    background: var(--chh-accent1);
    bottom: -15%;
    left: 30%;
    opacity: 0.3;
    animation: chh-meshMove3 20s ease-in-out infinite;
  }
  .casa-home-hero__mesh-blob--4 {
    width: 25%;
    padding-bottom: 25%;
    background: var(--chh-accent2);
    top: 50%;
    left: 10%;
    opacity: 0.25;
    animation: chh-meshMove4 24s ease-in-out infinite;
  }
  @keyframes chh-meshMove1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(8%, 12%) scale(1.08); }
    66% { transform: translate(-5%, 5%) scale(0.95); }
  }
  @keyframes chh-meshMove2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(-10%, -8%) scale(1.1); }
    66% { transform: translate(5%, 10%) scale(0.92); }
  }
  @keyframes chh-meshMove3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(12%, -10%) scale(1.05); }
  }
  @keyframes chh-meshMove4 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-8%, -15%) scale(1.12); }
  }

  /* ══════════════════════════════════════
     SCROLL INDICATOR
     ══════════════════════════════════════ */
  .casa-home-hero__scroll {
    position: absolute;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    color: var(--chh-muted);
    opacity: 0.5;
    animation: chh-scrollBounce 2s ease-in-out infinite;
  }
  @keyframes chh-scrollBounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(8px); }
  }

  /* ══════════════════════════════════════
     FULL WIDTH TOGGLE
     ══════════════════════════════════════ */
  .casa-home-hero:not(.casa-home-hero--full) .casa-home-hero__content {
    max-width: min(800px, 100%);
  }
  .casa-home-hero--full .casa-home-hero__content {
    max-width: 1200px;
  }

  /* ══════════════════════════════════════
     RESPONSIVE — MOBILE
     ══════════════════════════════════════ */
  @media (max-width: 767px) {
    .casa-home-hero--editorial,
    .casa-home-hero--marquee,
    .casa-home-hero--gradient_mesh {
      min-height: max(60vh, 400px);
    }
    .casa-home-hero--card {
      min-height: max(55vh, 380px);
    }
    .casa-home-hero__card {
      padding: 32px 24px;
      border-radius: 16px;
      margin: 0 16px;
    }
    .casa-home-hero__content {
      padding: 0 20px;
      gap: 14px;
    }

    /* Split stacks vertically on mobile */
    .casa-home-hero__split-wrap {
      grid-template-columns: 1fr;
      min-height: auto;
    }
    .casa-home-hero__split-media {
      clip-path: polygon(0 0, 100% 0, 100% 90%, 0 100%);
      min-height: 280px;
    }
    .casa-home-hero__split-content {
      padding: 32px 20px 48px;
    }

    /* Compact stacks on mobile */
    .casa-home-hero--compact .casa-home-hero__content {
      flex-direction: column;
      align-items: flex-start;
      gap: 10px;
    }

    /* Marquee smaller text */
    .casa-home-hero__marquee-text {
      font-size: clamp(4rem, 20vw, 8rem);
    }

    /* Trust stats scroll */
    .casa-home-hero__trust {
      gap: 14px;
    }
    .casa-home-hero__trust-item {
      font-size: 12px;
    }

    /* CTAs stack */
    .casa-home-hero__ctas {
      flex-direction: column;
      width: 100%;
    }
    .casa-home-hero__btn {
      width: 100%;
      justify-content: center;
    }

    .casa-home-hero__scroll {
      bottom: 16px;
    }
  }

  /* Tablet adjustments */
  @media (min-width: 768px) and (max-width: 1023px) {
    .casa-home-hero__split-wrap {
      grid-template-columns: 45% 55%;
    }
    .casa-home-hero__split-content {
      padding: 40px 32px;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .casa-home-hero__content--animate > * {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
    .casa-home-hero__marquee-text { animation: none !important; }
    .casa-home-hero__card { animation: none !important; }
    .casa-home-hero__scroll { animation: none !important; }
    .casa-home-hero__mesh-blob { animation: none !important; }
  }
</style>

{%- comment -%}
  ═══════════════════════════════════════
  JAVASCRIPT
  ═══════════════════════════════════════
{%- endcomment -%}
<script>
  (function() {
    var section = document.getElementById('{{ section_id }}');
    if (!section) return;

    /* ── Parallax on scroll ── */
    var parallaxImg = section.querySelector('.casa-home-hero__img--parallax');
    if (parallaxImg) {
      var ticking = false;
      function updateParallax() {
        var rect = section.getBoundingClientRect();
        var viewH = window.innerHeight;
        if (rect.bottom > 0 && rect.top < viewH) {
          var progress = (viewH - rect.top) / (viewH + rect.height);
          var offset = (progress - 0.5) * 60;
          parallaxImg.style.transform = 'translateY(' + offset + 'px) scale(1.08)';
        }
        ticking = false;
      }
      window.addEventListener('scroll', function() {
        if (!ticking) { requestAnimationFrame(updateParallax); ticking = true; }
      }, { passive: true });
      updateParallax();
    }

    /* ── Scroll indicator click ── */
    var scrollBtn = section.querySelector('.casa-home-hero__scroll');
    if (scrollBtn) {
      scrollBtn.style.cursor = 'pointer';
      scrollBtn.addEventListener('click', function() {
        var next = section.nextElementSibling;
        if (next) {
          next.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    }
  })();
</script>

