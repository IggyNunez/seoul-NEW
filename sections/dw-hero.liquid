{% comment %}
  DoingWell Hero Section
  - Split screen option with animated gradient
  - Full mobile/desktop control
  - Background image with mobile override
  - Animated gradient buttons with custom colors
  - Logo block + entrance animations
{% endcomment %}

{%- liquid
  assign mobile_image = section.settings.mobile_image | default: section.settings.image
  assign is_split = section.settings.enable_split
-%}

<section 
  class="dw-hero{% if section.settings.enable_animations %} dw-hero--animate{% endif %}{% if is_split %} dw-hero--split dw-hero--split-{{ section.settings.content_side }}{% endif %}"
  data-animation="{{ section.settings.animation_style }}"
  style="
    --hero-min-height-desktop: {{ section.settings.min_height_desktop }}vh;
    --hero-min-height-mobile: {{ section.settings.min_height_mobile }}vh;
    --hero-padding-top-desktop: {{ section.settings.padding_top_desktop }}px;
    --hero-padding-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;
    --hero-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --hero-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --hero-content-max-width: {{ section.settings.content_max_width }}px;
    --hero-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --hero-text-color: {{ section.settings.text_color }};
    --hero-overlay-color: {{ section.settings.overlay_color }};
    --hero-animation-duration: {{ section.settings.animation_duration }}ms;
    --hero-animation-stagger: {{ section.settings.animation_stagger }}ms;
    --hero-split-ratio: {{ section.settings.split_ratio }};
    --hero-split-ratio-mobile: {{ section.settings.split_ratio_mobile }};
    --hero-content-bg: {{ section.settings.content_bg_color }};
    --hero-glow-color-1: {{ section.settings.glow_color_1 }};
    --hero-glow-color-2: {{ section.settings.glow_color_2 }};
    --hero-glow-color-3: {{ section.settings.glow_color_3 }};
    --hero-glow-bg: {{ section.settings.glow_bg_color }};
    --hero-glow-opacity: {{ section.settings.glow_opacity | divided_by: 100.0 }};
    --hero-glow-blend: {{ section.settings.glow_blend_mode }};
    --hero-image-position-desktop: {{ section.settings.image_position_desktop }};
    --hero-image-position-mobile: {{ section.settings.image_position_mobile }};
  "
>
  {%- if is_split -%}
    <!-- SPLIT LAYOUT -->
    <div class="dw-hero__split-container dw-hero__split-container--mobile-content-{{ section.settings.content_side_mobile }}">
      
      <!-- Content Side -->
      <div class="dw-hero__split-content">
        {%- if section.settings.content_bg_color != blank and section.settings.content_bg_color != 'rgba(0,0,0,0)' -%}
          <div class="dw-hero__content-bg"></div>
        {%- endif -%}
        
        {%- if section.settings.enable_content_glow -%}
          <!-- Animated Glow Behind Content -->
          <div class="dw-hero__glow dw-hero__glow--content dw-hero__glow--{{ section.settings.content_glow_style }}">
            <div class="dw-hero__glow-bg"></div>
            <div class="dw-hero__glow-orb dw-hero__glow-orb--1" style="background: {{ section.settings.content_glow_color_1 }};"></div>
            <div class="dw-hero__glow-orb dw-hero__glow-orb--2" style="background: {{ section.settings.content_glow_color_2 }};"></div>
            <div class="dw-hero__glow-orb dw-hero__glow-orb--3" style="background: {{ section.settings.content_glow_color_3 }};"></div>
          </div>
        {%- endif -%}
        
        <div class="dw-hero__content dw-hero__content--{{ section.settings.text_alignment }} dw-hero__content--mobile-align-{{ section.settings.text_alignment_mobile }}">
          <div class="dw-hero__content-inner">
            {%- assign block_index = 0 -%}
            {%- for block in section.blocks -%}
              {%- case block.type -%}

                {%- when 'logo' -%}
                  {%- assign block_index = block_index | plus: 1 -%}
                  <div 
                    class="dw-hero__logo dw-hero__block"
                    style="
                      --logo-width-desktop: {{ block.settings.width_desktop }}px;
                      --logo-width-mobile: {{ block.settings.width_mobile }}px;
                      --logo-order-mobile: {{ block.settings.order_mobile }};
                      --logo-margin-bottom-desktop: {{ block.settings.margin_bottom_desktop }}px;
                      --logo-margin-bottom-mobile: {{ block.settings.margin_bottom_mobile }}px;
                      --block-index: {{ block_index }};
                    "
                    {{ block.shopify_attributes }}
                  >
                    {%- if block.settings.image != blank -%}
                      <img 
                        src="{{ block.settings.image | image_url: width: 600 }}"
                        alt="{{ block.settings.image.alt | default: 'Logo' | escape }}"
                        loading="eager"
                        width="{{ block.settings.image.width }}"
                        height="{{ block.settings.image.height }}"
                      >
                    {%- else -%}
                      <span class="dw-hero__logo-placeholder">Logo</span>
                    {%- endif -%}
                  </div>

                {%- when 'eyebrow' -%}
                  {%- assign block_index = block_index | plus: 1 -%}
                  <p 
                    class="dw-hero__eyebrow dw-hero__block"
                    style="
                      --eyebrow-size-desktop: {{ block.settings.size_desktop }}px;
                      --eyebrow-size-mobile: {{ block.settings.size_mobile }}px;
                      --eyebrow-margin-desktop: {{ block.settings.margin_bottom_desktop }}px;
                      --eyebrow-margin-mobile: {{ block.settings.margin_bottom_mobile }}px;
                      --eyebrow-order-mobile: {{ block.settings.order_mobile }};
                      --block-index: {{ block_index }};
                    "
                    {{ block.shopify_attributes }}
                  >
                    {{ block.settings.text }}
                  </p>

                {%- when 'heading' -%}
                  {%- assign block_index = block_index | plus: 1 -%}
                  <{{ block.settings.heading_tag }} 
                    class="dw-hero__heading dw-hero__block"
                    style="
                      --heading-size-desktop: {{ block.settings.size_desktop }}px;
                      --heading-size-mobile: {{ block.settings.size_mobile }}px;
                      --heading-line-height: {{ block.settings.line_height }};
                      --heading-font-weight: {{ block.settings.font_weight }};
                      --heading-color: {{ block.settings.color | default: 'inherit' }};
                      --heading-margin-desktop: {{ block.settings.margin_bottom_desktop }}px;
                      --heading-margin-mobile: {{ block.settings.margin_bottom_mobile }}px;
                      --heading-order-mobile: {{ block.settings.order_mobile }};
                      --block-index: {{ block_index }};
                    "
                    {{ block.shopify_attributes }}
                  >
                    {{ block.settings.text | newline_to_br }}
                  </{{ block.settings.heading_tag }}>

                {%- when 'text' -%}
                  {%- assign block_index = block_index | plus: 1 -%}
                  <div 
                    class="dw-hero__text dw-hero__block"
                    style="
                      --text-size-desktop: {{ block.settings.size_desktop }}px;
                      --text-size-mobile: {{ block.settings.size_mobile }}px;
                      --text-max-width: {{ block.settings.max_width }}px;
                      --text-opacity: {{ block.settings.opacity | divided_by: 100.0 }};
                      --text-margin-desktop: {{ block.settings.margin_bottom_desktop }}px;
                      --text-margin-mobile: {{ block.settings.margin_bottom_mobile }}px;
                      --text-order-mobile: {{ block.settings.order_mobile }};
                      --block-index: {{ block_index }};
                    "
                    {{ block.shopify_attributes }}
                  >
                    {{ block.settings.text }}
                  </div>

                {%- when 'list' -%}
                  {%- assign block_index = block_index | plus: 1 -%}
                  {%- assign list_items = block.settings.items | newline_to_br | split: '<br />' -%}
                  <ul 
                    class="dw-hero__list dw-hero__list--{{ block.settings.layout }} dw-hero__block"
                    style="
                      --list-size-desktop: {{ block.settings.size_desktop }}px;
                      --list-size-mobile: {{ block.settings.size_mobile }}px;
                      --list-gap: {{ block.settings.gap }}px;
                      --list-icon-color: {{ block.settings.icon_color }};
                      --list-icon-size: {{ block.settings.icon_size }}px;
                      --list-margin-desktop: {{ block.settings.margin_bottom_desktop }}px;
                      --list-margin-mobile: {{ block.settings.margin_bottom_mobile }}px;
                      --list-order-mobile: {{ block.settings.order_mobile }};
                      --block-index: {{ block_index }};
                    "
                    {{ block.shopify_attributes }}
                  >
                    {%- for item in list_items -%}
                      {%- assign item_text = item | strip -%}
                      {%- if item_text != blank -%}
                        <li class="dw-hero__list-item">
                          <span class="dw-hero__list-icon dw-hero__list-icon--{{ block.settings.icon }}">
                            {%- case block.settings.icon -%}
                              {%- when 'check' -%}
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                              {%- when 'check-circle' -%}
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                              {%- when 'star' -%}
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                              {%- when 'arrow' -%}
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                              {%- when 'dot' -%}
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="5"></circle></svg>
                              {%- when 'plus' -%}
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                              {%- when 'lightning' -%}
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
                              {%- when 'heart' -%}
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                              {%- when 'shield' -%}
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><polyline points="9 12 11 14 15 10"></polyline></svg>
                              {%- when 'leaf' -%}
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17 8c-4 0-8 4-8 8 0 .5 0 1 .1 1.5C6.5 16.5 5 14 5 11c0-5 5-9 12-9 0 4-2 6-2 6h2s0-4 1-6c0 0 3 3 3 8 0 4-2 7-4 7z"></path></svg>
                              {%- when 'custom' -%}
                                {%- if block.settings.custom_icon != blank -%}
                                  <img src="{{ block.settings.custom_icon | image_url: width: 64 }}" alt="" width="{{ block.settings.icon_size }}" height="{{ block.settings.icon_size }}">
                                {%- endif -%}
                            {%- endcase -%}
                          </span>
                          <span class="dw-hero__list-text">{{ item_text }}</span>
                        </li>
                      {%- endif -%}
                    {%- endfor -%}
                  </ul>

                {%- when 'spacer' -%}
                  {%- assign block_index = block_index | plus: 1 -%}
                  <div 
                    class="dw-hero__spacer dw-hero__block"
                    style="
                      --spacer-height-desktop: {{ block.settings.height_desktop }}px;
                      --spacer-height-mobile: {{ block.settings.height_mobile }}px;
                      --spacer-order-mobile: {{ block.settings.order_mobile }};
                      --block-index: {{ block_index }};
                    "
                    {{ block.shopify_attributes }}
                  ></div>

                {%- when 'buttons' -%}
                  {%- assign block_index = block_index | plus: 1 -%}
                  <div 
                    class="dw-hero__buttons dw-hero__block" 
                    style="
                      --buttons-margin-desktop: {{ block.settings.margin_bottom_desktop }}px;
                      --buttons-margin-mobile: {{ block.settings.margin_bottom_mobile }}px;
                      --buttons-order-mobile: {{ block.settings.order_mobile }};
                      --block-index: {{ block_index }};
                    "
                    {{ block.shopify_attributes }}
                  >
                    {%- if block.settings.button_1_label != blank -%}
                      {%- assign btn_1_width_class = '' -%}
                      {%- assign btn_1_width_style = '' -%}
                      {%- if block.settings.button_1_width == 'full' -%}
                        {%- assign btn_1_width_class = ' dw-btn--full' -%}
                      {%- elsif block.settings.button_1_width == 'percent' -%}
                        {%- assign btn_1_width_style = 'width: ' | append: block.settings.button_1_percent | append: '%;' -%}
                      {%- endif -%}
                      <a 
                        href="{{ block.settings.button_1_link }}" 
                        class="dw-btn dw-btn--{{ block.settings.button_1_style }}{% if block.settings.button_1_style == 'gradient' or block.settings.button_1_style == 'gradient-glow' %} dw-btn--gradient-animate{% endif %}{{ btn_1_width_class }}"
                        style="
                          --btn-gradient-1: {{ block.settings.button_1_gradient_1 }};
                          --btn-gradient-2: {{ block.settings.button_1_gradient_2 }};
                          {% if block.settings.button_1_bg != blank %}--btn-bg: {{ block.settings.button_1_bg }};{% endif %}
                          {% if block.settings.button_1_text_color != blank %}--btn-text-color: {{ block.settings.button_1_text_color }};{% endif %}
                          {% if block.settings.button_1_border_color != blank %}--btn-border-color: {{ block.settings.button_1_border_color }};{% endif %}
                          {{ btn_1_width_style }}
                        "
                      >
                        <span>{{ block.settings.button_1_label }}</span>
                      </a>
                    {%- endif -%}
                    {%- if block.settings.button_2_label != blank -%}
                      {%- assign btn_2_width_class = '' -%}
                      {%- assign btn_2_width_style = '' -%}
                      {%- if block.settings.button_2_width == 'full' -%}
                        {%- assign btn_2_width_class = ' dw-btn--full' -%}
                      {%- elsif block.settings.button_2_width == 'percent' -%}
                        {%- assign btn_2_width_style = 'width: ' | append: block.settings.button_2_percent | append: '%;' -%}
                      {%- endif -%}
                      <a 
                        href="{{ block.settings.button_2_link }}" 
                        class="dw-btn dw-btn--{{ block.settings.button_2_style }}{% if block.settings.button_2_style == 'gradient' or block.settings.button_2_style == 'gradient-glow' %} dw-btn--gradient-animate{% endif %}{{ btn_2_width_class }}"
                        style="
                          --btn-gradient-1: {{ block.settings.button_2_gradient_1 }};
                          --btn-gradient-2: {{ block.settings.button_2_gradient_2 }};
                          {% if block.settings.button_2_bg != blank %}--btn-bg: {{ block.settings.button_2_bg }};{% endif %}
                          {% if block.settings.button_2_text_color != blank %}--btn-text-color: {{ block.settings.button_2_text_color }};{% endif %}
                          {% if block.settings.button_2_border_color != blank %}--btn-border-color: {{ block.settings.button_2_border_color }};{% endif %}
                          {{ btn_2_width_style }}
                        "
                      >
                        <span>{{ block.settings.button_2_label }}</span>
                      </a>
                    {%- endif -%}
                  </div>

              {%- endcase -%}
            {%- endfor -%}
          </div>
        </div>
      </div>

      <!-- Media/Glow Side -->
      <div class="dw-hero__split-media">
        {%- if section.settings.image != blank -%}
          <picture class="dw-hero__media dw-hero__media--split">
            {%- if mobile_image != blank -%}
              <source 
                media="(max-width: 749px)" 
                srcset="{{ mobile_image | image_url: width: 750 }},
                        {{ mobile_image | image_url: width: 1500 }} 2x"
              >
            {%- endif -%}
            <source 
              media="(min-width: 750px)" 
              srcset="{{ section.settings.image | image_url: width: 1200 }},
                      {{ section.settings.image | image_url: width: 2400 }} 2x"
            >
            <img 
              src="{{ section.settings.image | image_url: width: 1200 }}" 
              alt="{{ section.settings.image.alt | escape }}"
              loading="eager"
              fetchpriority="high"
              width="{{ section.settings.image.width }}"
              height="{{ section.settings.image.height }}"
            >
          </picture>
        {%- endif -%}
        
        {%- if section.settings.enable_glow -%}
          <!-- Animated Glow Effect -->
          <div class="dw-hero__glow dw-hero__glow--{{ section.settings.glow_style }}{% if section.settings.image != blank %} dw-hero__glow--overlay{% endif %}">
            {%- unless section.settings.image != blank -%}
              <div class="dw-hero__glow-bg"></div>
            {%- endunless -%}
            <div class="dw-hero__glow-orb dw-hero__glow-orb--1"></div>
            <div class="dw-hero__glow-orb dw-hero__glow-orb--2"></div>
            <div class="dw-hero__glow-orb dw-hero__glow-orb--3"></div>
          </div>
        {%- elsif section.settings.image == blank -%}
          <!-- Fallback background if no image and no glow -->
          <div class="dw-hero__glow">
            <div class="dw-hero__glow-bg"></div>
          </div>
        {%- endif -%}
      </div>

    </div>

  {%- else -%}
    <!-- FULL WIDTH LAYOUT -->
    {%- if section.settings.image != blank -%}
      <picture class="dw-hero__media">
        {%- if mobile_image != blank -%}
          <source 
            media="(max-width: 749px)" 
            srcset="{{ mobile_image | image_url: width: 750 }},
                    {{ mobile_image | image_url: width: 1500 }} 2x"
          >
        {%- endif -%}
        <source 
          media="(min-width: 750px)" 
          srcset="{{ section.settings.image | image_url: width: 1920 }},
                  {{ section.settings.image | image_url: width: 3840 }} 2x"
        >
        <img 
          src="{{ section.settings.image | image_url: width: 1920 }}" 
          alt="{{ section.settings.image.alt | escape }}"
          loading="eager"
          fetchpriority="high"
          width="{{ section.settings.image.width }}"
          height="{{ section.settings.image.height }}"
        >
      </picture>
    {%- else -%}
      <div class="dw-hero__media dw-hero__media--placeholder"></div>
    {%- endif -%}

    {%- if section.settings.overlay_opacity > 0 -%}
      <div class="dw-hero__overlay"></div>
    {%- endif -%}

    <div class="dw-hero__content dw-hero__content--{{ section.settings.content_position }} dw-hero__content--align-{{ section.settings.text_alignment }} dw-hero__content--mobile-{{ section.settings.content_position_mobile }} dw-hero__content--mobile-align-{{ section.settings.text_alignment_mobile }}">
      <div class="dw-hero__content-inner">
        {%- assign block_index = 0 -%}
        {%- for block in section.blocks -%}
          {%- case block.type -%}

            {%- when 'logo' -%}
              {%- assign block_index = block_index | plus: 1 -%}
              <div 
                class="dw-hero__logo dw-hero__block"
                style="
                  --logo-width-desktop: {{ block.settings.width_desktop }}px;
                  --logo-width-mobile: {{ block.settings.width_mobile }}px;
                  --logo-order-mobile: {{ block.settings.order_mobile }};
                  --logo-margin-bottom-desktop: {{ block.settings.margin_bottom_desktop }}px;
                  --logo-margin-bottom-mobile: {{ block.settings.margin_bottom_mobile }}px;
                  --block-index: {{ block_index }};
                "
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.image != blank -%}
                  <img 
                    src="{{ block.settings.image | image_url: width: 600 }}"
                    alt="{{ block.settings.image.alt | default: 'Logo' | escape }}"
                    loading="eager"
                    width="{{ block.settings.image.width }}"
                    height="{{ block.settings.image.height }}"
                  >
                {%- else -%}
                  <span class="dw-hero__logo-placeholder">Logo</span>
                {%- endif -%}
              </div>

            {%- when 'eyebrow' -%}
              {%- assign block_index = block_index | plus: 1 -%}
              <p 
                class="dw-hero__eyebrow dw-hero__block"
                style="
                  --eyebrow-size-desktop: {{ block.settings.size_desktop }}px;
                  --eyebrow-size-mobile: {{ block.settings.size_mobile }}px;
                  --eyebrow-margin-desktop: {{ block.settings.margin_bottom_desktop }}px;
                  --eyebrow-margin-mobile: {{ block.settings.margin_bottom_mobile }}px;
                  --eyebrow-order-mobile: {{ block.settings.order_mobile }};
                  --block-index: {{ block_index }};
                "
                {{ block.shopify_attributes }}
              >
                {{ block.settings.text }}
              </p>

            {%- when 'heading' -%}
              {%- assign block_index = block_index | plus: 1 -%}
              <{{ block.settings.heading_tag }} 
                class="dw-hero__heading dw-hero__block"
                style="
                  --heading-size-desktop: {{ block.settings.size_desktop }}px;
                  --heading-size-mobile: {{ block.settings.size_mobile }}px;
                  --heading-line-height: {{ block.settings.line_height }};
                  --heading-font-weight: {{ block.settings.font_weight }};
                  --heading-color: {{ block.settings.color | default: 'inherit' }};
                  --heading-margin-desktop: {{ block.settings.margin_bottom_desktop }}px;
                  --heading-margin-mobile: {{ block.settings.margin_bottom_mobile }}px;
                  --heading-order-mobile: {{ block.settings.order_mobile }};
                  --block-index: {{ block_index }};
                "
                {{ block.shopify_attributes }}
              >
                {{ block.settings.text | newline_to_br }}
              </{{ block.settings.heading_tag }}>

            {%- when 'text' -%}
              {%- assign block_index = block_index | plus: 1 -%}
              <div 
                class="dw-hero__text dw-hero__block"
                style="
                  --text-size-desktop: {{ block.settings.size_desktop }}px;
                  --text-size-mobile: {{ block.settings.size_mobile }}px;
                  --text-max-width: {{ block.settings.max_width }}px;
                  --text-opacity: {{ block.settings.opacity | divided_by: 100.0 }};
                  --text-margin-desktop: {{ block.settings.margin_bottom_desktop }}px;
                  --text-margin-mobile: {{ block.settings.margin_bottom_mobile }}px;
                  --text-order-mobile: {{ block.settings.order_mobile }};
                  --block-index: {{ block_index }};
                "
                {{ block.shopify_attributes }}
              >
                {{ block.settings.text }}
              </div>

            {%- when 'list' -%}
              {%- assign block_index = block_index | plus: 1 -%}
              {%- assign list_items = block.settings.items | newline_to_br | split: '<br />' -%}
              <ul 
                class="dw-hero__list dw-hero__list--{{ block.settings.layout }} dw-hero__block"
                style="
                  --list-size-desktop: {{ block.settings.size_desktop }}px;
                  --list-size-mobile: {{ block.settings.size_mobile }}px;
                  --list-gap: {{ block.settings.gap }}px;
                  --list-icon-color: {{ block.settings.icon_color }};
                  --list-icon-size: {{ block.settings.icon_size }}px;
                  --list-margin-desktop: {{ block.settings.margin_bottom_desktop }}px;
                  --list-margin-mobile: {{ block.settings.margin_bottom_mobile }}px;
                  --list-order-mobile: {{ block.settings.order_mobile }};
                  --block-index: {{ block_index }};
                "
                {{ block.shopify_attributes }}
              >
                {%- for item in list_items -%}
                  {%- assign item_text = item | strip -%}
                  {%- if item_text != blank -%}
                    <li class="dw-hero__list-item">
                      <span class="dw-hero__list-icon dw-hero__list-icon--{{ block.settings.icon }}">
                        {%- case block.settings.icon -%}
                          {%- when 'check' -%}
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                          {%- when 'check-circle' -%}
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                          {%- when 'star' -%}
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                          {%- when 'arrow' -%}
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                          {%- when 'dot' -%}
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="5"></circle></svg>
                          {%- when 'plus' -%}
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                          {%- when 'lightning' -%}
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
                          {%- when 'heart' -%}
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                          {%- when 'shield' -%}
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><polyline points="9 12 11 14 15 10"></polyline></svg>
                          {%- when 'leaf' -%}
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17 8c-4 0-8 4-8 8 0 .5 0 1 .1 1.5C6.5 16.5 5 14 5 11c0-5 5-9 12-9 0 4-2 6-2 6h2s0-4 1-6c0 0 3 3 3 8 0 4-2 7-4 7z"></path></svg>
                          {%- when 'custom' -%}
                            {%- if block.settings.custom_icon != blank -%}
                              <img src="{{ block.settings.custom_icon | image_url: width: 64 }}" alt="" width="{{ block.settings.icon_size }}" height="{{ block.settings.icon_size }}">
                            {%- endif -%}
                        {%- endcase -%}
                      </span>
                      <span class="dw-hero__list-text">{{ item_text }}</span>
                    </li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>

            {%- when 'spacer' -%}
              {%- assign block_index = block_index | plus: 1 -%}
              <div 
                class="dw-hero__spacer dw-hero__block"
                style="
                  --spacer-height-desktop: {{ block.settings.height_desktop }}px;
                  --spacer-height-mobile: {{ block.settings.height_mobile }}px;
                  --spacer-order-mobile: {{ block.settings.order_mobile }};
                  --block-index: {{ block_index }};
                "
                {{ block.shopify_attributes }}
              ></div>

            {%- when 'buttons' -%}
              {%- assign block_index = block_index | plus: 1 -%}
              <div 
                class="dw-hero__buttons dw-hero__block" 
                style="
                  --buttons-margin-desktop: {{ block.settings.margin_bottom_desktop }}px;
                  --buttons-margin-mobile: {{ block.settings.margin_bottom_mobile }}px;
                  --buttons-order-mobile: {{ block.settings.order_mobile }};
                  --block-index: {{ block_index }};
                "
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.button_1_label != blank -%}
                  {%- assign btn_1_width_class = '' -%}
                  {%- assign btn_1_width_style = '' -%}
                  {%- if block.settings.button_1_width == 'full' -%}
                    {%- assign btn_1_width_class = ' dw-btn--full' -%}
                  {%- elsif block.settings.button_1_width == 'percent' -%}
                    {%- assign btn_1_width_style = 'width: ' | append: block.settings.button_1_percent | append: '%;' -%}
                  {%- endif -%}
                  <a 
                    href="{{ block.settings.button_1_link }}" 
                    class="dw-btn dw-btn--{{ block.settings.button_1_style }}{% if block.settings.button_1_style == 'gradient' or block.settings.button_1_style == 'gradient-glow' %} dw-btn--gradient-animate{% endif %}{{ btn_1_width_class }}"
                    style="
                      --btn-gradient-1: {{ block.settings.button_1_gradient_1 }};
                      --btn-gradient-2: {{ block.settings.button_1_gradient_2 }};
                      {% if block.settings.button_1_bg != blank %}--btn-bg: {{ block.settings.button_1_bg }};{% endif %}
                      {% if block.settings.button_1_text_color != blank %}--btn-text-color: {{ block.settings.button_1_text_color }};{% endif %}
                      {% if block.settings.button_1_border_color != blank %}--btn-border-color: {{ block.settings.button_1_border_color }};{% endif %}
                      {{ btn_1_width_style }}
                    "
                  >
                    <span>{{ block.settings.button_1_label }}</span>
                  </a>
                {%- endif -%}
                {%- if block.settings.button_2_label != blank -%}
                  {%- assign btn_2_width_class = '' -%}
                  {%- assign btn_2_width_style = '' -%}
                  {%- if block.settings.button_2_width == 'full' -%}
                    {%- assign btn_2_width_class = ' dw-btn--full' -%}
                  {%- elsif block.settings.button_2_width == 'percent' -%}
                    {%- assign btn_2_width_style = 'width: ' | append: block.settings.button_2_percent | append: '%;' -%}
                  {%- endif -%}
                  <a 
                    href="{{ block.settings.button_2_link }}" 
                    class="dw-btn dw-btn--{{ block.settings.button_2_style }}{% if block.settings.button_2_style == 'gradient' or block.settings.button_2_style == 'gradient-glow' %} dw-btn--gradient-animate{% endif %}{{ btn_2_width_class }}"
                    style="
                      --btn-gradient-1: {{ block.settings.button_2_gradient_1 }};
                      --btn-gradient-2: {{ block.settings.button_2_gradient_2 }};
                      {% if block.settings.button_2_bg != blank %}--btn-bg: {{ block.settings.button_2_bg }};{% endif %}
                      {% if block.settings.button_2_text_color != blank %}--btn-text-color: {{ block.settings.button_2_text_color }};{% endif %}
                      {% if block.settings.button_2_border_color != blank %}--btn-border-color: {{ block.settings.button_2_border_color }};{% endif %}
                      {{ btn_2_width_style }}
                    "
                  >
                    <span>{{ block.settings.button_2_label }}</span>
                  </a>
                {%- endif -%}
              </div>

          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
</section>

<style>
  /* ==========================================
     HERO BASE
     ========================================== */
  
  .dw-hero {
    position: relative;
    display: flex;
    align-items: center;
    min-height: var(--hero-min-height-mobile);
    color: var(--hero-text-color);
    overflow: hidden;
  }

  /* Full bleed on mobile - break out of any container padding */
  @media (max-width: 749px) {
    .dw-hero--split {
      width: 100vw;
      margin-left: calc(-50vw + 50%);
    }
  }

  .dw-hero:not(.dw-hero--split) {
    padding: var(--hero-padding-top-mobile) 20px var(--hero-padding-bottom-mobile);
  }

  @media (min-width: 750px) {
    .dw-hero {
      min-height: var(--hero-min-height-desktop);
    }
    
    .dw-hero:not(.dw-hero--split) {
      padding: var(--hero-padding-top-desktop) 50px var(--hero-padding-bottom-desktop);
    }
  }

  /* ==========================================
     SPLIT LAYOUT
     ========================================== */
  
  .dw-hero__split-container {
    display: flex;
    flex-direction: column;
    width: 100%;
    min-height: inherit;
  }

  @media (min-width: 750px) {
    .dw-hero__split-container {
      flex-direction: row;
    }
  }

  /* Content Side */
  .dw-hero__split-content {
    position: relative;
    display: flex;
    align-items: center;
    padding: var(--hero-padding-top-mobile) 20px var(--hero-padding-bottom-mobile);
    flex: 1;
  }

  @media (min-width: 750px) {
    .dw-hero__split-content {
      flex: 0 0 calc(100% * var(--hero-split-ratio, 0.5));
      padding: var(--hero-padding-top-desktop) 60px var(--hero-padding-bottom-desktop);
    }
  }

  .dw-hero__content-bg {
    position: absolute;
    inset: 0;
    background: var(--hero-content-bg);
    z-index: 0;
  }

  /* Media/Glow Side */
  .dw-hero__split-media {
    position: relative;
    flex: 1;
    min-height: 300px;
    overflow: hidden;
  }

  .dw-hero__split-media .dw-hero__media--split {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .dw-hero__split-media .dw-hero__media--split img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--hero-image-position-mobile);
  }

  @media (min-width: 750px) {
    .dw-hero__split-media {
      flex: 0 0 calc(100% * (1 - var(--hero-split-ratio, 0.5)));
      min-height: auto;
    }

    .dw-hero__split-media .dw-hero__media--split img {
      object-position: var(--hero-image-position-desktop);
    }
  }

  /* Split Direction */
  @media (min-width: 750px) {
    .dw-hero--split-left .dw-hero__split-container {
      flex-direction: row;
    }
    
    .dw-hero--split-right .dw-hero__split-container {
      flex-direction: row-reverse;
    }
  }

  /* Mobile Split Layout */
  @media (max-width: 749px) {
    .dw-hero__split-container--mobile-content-top {
      flex-direction: column;
    }
    
    .dw-hero__split-container--mobile-content-bottom {
      flex-direction: column-reverse;
    }
    
    .dw-hero__split-container--mobile-content-top .dw-hero__split-content,
    .dw-hero__split-container--mobile-content-bottom .dw-hero__split-content {
      flex: 0 0 auto;
    }
    
    .dw-hero__split-container--mobile-content-top .dw-hero__split-media,
    .dw-hero__split-container--mobile-content-bottom .dw-hero__split-media {
      flex: 1 1 0;
      min-height: calc(var(--hero-min-height-mobile) * (1 - var(--hero-split-ratio-mobile, 0.5)));
    }
  }

  /* ==========================================
     ANIMATED GLOW EFFECTS
     ========================================== */
  
  .dw-hero__glow {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .dw-hero__glow-bg {
    position: absolute;
    inset: 0;
    background: var(--hero-glow-bg, #0a0a0a);
  }

  .dw-hero__glow-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.6;
    animation: glow-float 8s ease-in-out infinite;
  }

  .dw-hero__glow-orb--1 {
    width: 60%;
    height: 60%;
    background: var(--hero-glow-color-1, #ff00ff);
    top: -20%;
    left: -10%;
    animation-delay: 0s;
  }

  .dw-hero__glow-orb--2 {
    width: 50%;
    height: 50%;
    background: var(--hero-glow-color-2, #00d4ff);
    bottom: -10%;
    right: -10%;
    animation-delay: -3s;
  }

  .dw-hero__glow-orb--3 {
    width: 40%;
    height: 40%;
    background: var(--hero-glow-color-3, #8b00ff);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    animation-delay: -5s;
  }

  @keyframes glow-float {
    0%, 100% {
      transform: translate(0, 0) scale(1);
      opacity: 0.6;
    }
    25% {
      transform: translate(10%, 10%) scale(1.1);
      opacity: 0.5;
    }
    50% {
      transform: translate(-5%, 15%) scale(0.9);
      opacity: 0.7;
    }
    75% {
      transform: translate(-10%, -5%) scale(1.05);
      opacity: 0.55;
    }
  }

  /* Glow Style Variations */
  .dw-hero__glow--pulse .dw-hero__glow-orb {
    animation: glow-pulse 4s ease-in-out infinite;
  }

  @keyframes glow-pulse {
    0%, 100% {
      opacity: 0.4;
      transform: scale(1);
    }
    50% {
      opacity: 0.8;
      transform: scale(1.2);
    }
  }

  .dw-hero__glow--wave .dw-hero__glow-orb {
    animation: glow-wave 6s ease-in-out infinite;
  }

  @keyframes glow-wave {
    0%, 100% {
      transform: translateY(0) scale(1);
    }
    50% {
      transform: translateY(-20%) scale(1.1);
    }
  }

  .dw-hero__glow--spin .dw-hero__glow-orb {
    animation: glow-spin 15s linear infinite;
  }

  .dw-hero__glow--spin .dw-hero__glow-orb--1 {
    top: 50%;
    left: 50%;
    transform-origin: -50% -50%;
  }

  .dw-hero__glow--spin .dw-hero__glow-orb--2 {
    top: 50%;
    left: 50%;
    transform-origin: 100% 100%;
    animation-direction: reverse;
  }

  .dw-hero__glow--spin .dw-hero__glow-orb--3 {
    animation-duration: 20s;
  }

  @keyframes glow-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* Subtle/Soft glow */
  .dw-hero__glow--soft .dw-hero__glow-orb {
    filter: blur(120px);
    opacity: 0.4;
    animation: glow-soft 10s ease-in-out infinite;
  }

  @keyframes glow-soft {
    0%, 100% {
      opacity: 0.3;
    }
    50% {
      opacity: 0.5;
    }
  }

  /* Glow Overlay Mode (when combined with image) */
  .dw-hero__glow--overlay {
    opacity: var(--hero-glow-opacity, 0.7);
    mix-blend-mode: var(--hero-glow-blend, screen);
  }

  .dw-hero__glow--overlay .dw-hero__glow-orb {
    opacity: 0.8;
  }

  /* Glow Behind Content */
  .dw-hero__glow--content {
    z-index: 0;
  }

  .dw-hero__glow--content .dw-hero__glow-bg {
    background: var(--hero-content-bg, #0a0a0a);
  }

  /* ==========================================
     BACKGROUND IMAGE (Full Width)
     ========================================== */
  
  .dw-hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .dw-hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--hero-image-position-mobile);
  }

  @media (min-width: 750px) {
    .dw-hero__media img {
      object-position: var(--hero-image-position-desktop);
    }
  }

  .dw-hero__media--split {
    position: absolute;
    inset: 0;
  }

  .dw-hero__media--placeholder {
    background: var(--doingwell-black, #1a1a1a);
  }

  /* Overlay */
  .dw-hero__overlay {
    position: absolute;
    inset: 0;
    background: var(--hero-overlay-color);
    opacity: var(--hero-overlay-opacity);
    z-index: 1;
  }

  /* ==========================================
     CONTENT
     ========================================== */
  
  .dw-hero__content {
    position: relative;
    z-index: 2;
    width: 100%;
  }

  .dw-hero:not(.dw-hero--split) .dw-hero__content {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
  }

  .dw-hero__content-inner {
    max-width: var(--hero-content-max-width);
    display: flex;
    flex-direction: column;
  }

  /* Desktop Content Position (Full Width only) */
  @media (min-width: 750px) {
    .dw-hero:not(.dw-hero--split) .dw-hero__content--left { justify-content: flex-start; }
    .dw-hero:not(.dw-hero--split) .dw-hero__content--center { justify-content: center; }
    .dw-hero:not(.dw-hero--split) .dw-hero__content--right { justify-content: flex-end; }
  }

  /* Text Alignment */
  .dw-hero__content--align-left,
  .dw-hero__content--left { text-align: left; }
  .dw-hero__content--align-center,
  .dw-hero__content--center { text-align: center; }
  .dw-hero__content--align-right,
  .dw-hero__content--right { text-align: right; }

  .dw-hero__content--align-center .dw-hero__content-inner,
  .dw-hero__content--center .dw-hero__content-inner {
    align-items: center;
  }

  .dw-hero__content--align-right .dw-hero__content-inner,
  .dw-hero__content--right .dw-hero__content-inner {
    align-items: flex-end;
  }

  .dw-hero__content--align-left .dw-hero__content-inner,
  .dw-hero__content--left .dw-hero__content-inner {
    align-items: flex-start;
  }

  /* Mobile Text Alignment */
  @media (max-width: 749px) {
    .dw-hero__content--mobile-align-left { text-align: left; }
    .dw-hero__content--mobile-align-center { text-align: center; }
    .dw-hero__content--mobile-align-right { text-align: right; }

    .dw-hero__content--mobile-align-center .dw-hero__content-inner {
      align-items: center;
    }

    .dw-hero__content--mobile-align-right .dw-hero__content-inner {
      align-items: flex-end;
    }

    .dw-hero__content--mobile-align-left .dw-hero__content-inner {
      align-items: flex-start;
    }
  }

  /* Mobile Reordering */
  @media (max-width: 749px) {
    .dw-hero__logo { order: var(--logo-order-mobile, 1); }
    .dw-hero__eyebrow { order: var(--eyebrow-order-mobile, 2); }
    .dw-hero__heading { order: var(--heading-order-mobile, 3); }
    .dw-hero__text { order: var(--text-order-mobile, 4); }
    .dw-hero__list { order: var(--list-order-mobile, 5); }
    .dw-hero__spacer { order: var(--spacer-order-mobile, 6); }
    .dw-hero__buttons { order: var(--buttons-order-mobile, 7); }
  }

  /* ==========================================
     BLOCKS
     ========================================== */

  /* Logo */
  .dw-hero__logo {
    margin-bottom: var(--logo-margin-bottom-mobile);
  }

  .dw-hero__logo img {
    width: var(--logo-width-mobile);
    height: auto;
    max-width: 100%;
  }

  @media (min-width: 750px) {
    .dw-hero__logo {
      margin-bottom: var(--logo-margin-bottom-desktop);
    }

    .dw-hero__logo img {
      width: var(--logo-width-desktop);
    }
  }

  .dw-hero__logo-placeholder {
    display: inline-block;
    padding: 20px 40px;
    background: rgba(255,255,255,0.1);
    border: 2px dashed rgba(255,255,255,0.3);
    border-radius: 8px;
    font-size: 14px;
    opacity: 0.6;
  }

  /* Eyebrow */
  .dw-hero__eyebrow {
    font-size: var(--eyebrow-size-mobile);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin: 0 0 var(--eyebrow-margin-mobile, 16px);
    font-weight: 500;
    opacity: 0.9;
  }

  @media (min-width: 750px) {
    .dw-hero__eyebrow {
      font-size: var(--eyebrow-size-desktop);
      margin-bottom: var(--eyebrow-margin-desktop, 20px);
    }
  }

  /* Heading */
  .dw-hero__heading {
    font-size: var(--heading-size-mobile);
    line-height: var(--heading-line-height);
    font-weight: var(--heading-font-weight, 700);
    color: var(--heading-color, inherit);
    margin: 0 0 var(--heading-margin-mobile, 20px);
    letter-spacing: -0.02em;
  }

  @media (min-width: 750px) {
    .dw-hero__heading {
      font-size: var(--heading-size-desktop);
      margin-bottom: var(--heading-margin-desktop, 24px);
    }
  }

  /* Text */
  .dw-hero__text {
    font-size: var(--text-size-mobile);
    line-height: 1.6;
    margin: 0 0 var(--text-margin-mobile, 24px);
    max-width: var(--text-max-width);
    opacity: var(--text-opacity, 0.9);
  }

  @media (min-width: 750px) {
    .dw-hero__text {
      font-size: var(--text-size-desktop);
      margin-bottom: var(--text-margin-desktop, 32px);
    }
  }

  .dw-hero__text p {
    margin: 0;
  }

  /* Icon List */
  .dw-hero__list {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--list-margin-mobile, 24px);
    font-size: var(--list-size-mobile);
  }

  @media (min-width: 750px) {
    .dw-hero__list {
      font-size: var(--list-size-desktop);
      margin-bottom: var(--list-margin-desktop, 32px);
    }
  }

  .dw-hero__list--vertical {
    display: flex;
    flex-direction: column;
    gap: var(--list-gap);
  }

  .dw-hero__list--horizontal {
    display: flex;
    flex-wrap: wrap;
    gap: var(--list-gap) calc(var(--list-gap) * 2);
  }

  .dw-hero__list-item {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .dw-hero__list-icon {
    flex-shrink: 0;
    color: var(--list-icon-color);
    width: var(--list-icon-size);
    height: var(--list-icon-size);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .dw-hero__list-icon svg {
    width: var(--list-icon-size);
    height: var(--list-icon-size);
  }

  .dw-hero__list-icon img {
    width: var(--list-icon-size);
    height: var(--list-icon-size);
    object-fit: contain;
  }

  .dw-hero__list-text {
    flex: 1;
  }

  /* List alignment */
  .dw-hero__content--align-center .dw-hero__list,
  .dw-hero__content--center .dw-hero__list {
    align-items: center;
  }

  .dw-hero__content--align-center .dw-hero__list--horizontal,
  .dw-hero__content--center .dw-hero__list--horizontal {
    justify-content: center;
  }

  @media (max-width: 749px) {
    .dw-hero__content--mobile-align-center .dw-hero__list {
      align-items: center;
    }

    .dw-hero__content--mobile-align-center .dw-hero__list--horizontal {
      justify-content: center;
    }
  }

  /* Spacer */
  .dw-hero__spacer {
    height: var(--spacer-height-mobile);
  }

  @media (min-width: 750px) {
    .dw-hero__spacer {
      height: var(--spacer-height-desktop);
    }
  }

  /* Buttons Container */
  .dw-hero__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: var(--buttons-margin-mobile, 0);
    width: 100%;
  }

  .dw-hero__buttons .dw-btn--full {
    flex: 0 0 100%;
  }

  @media (min-width: 750px) {
    .dw-hero__buttons {
      margin-bottom: var(--buttons-margin-desktop, 0);
    }
  }

  .dw-hero__content--align-center .dw-hero__buttons,
  .dw-hero__content--center .dw-hero__buttons {
    justify-content: center;
  }

  .dw-hero__content--align-right .dw-hero__buttons,
  .dw-hero__content--right .dw-hero__buttons {
    justify-content: flex-end;
  }

  @media (max-width: 749px) {
    .dw-hero__content--mobile-align-center .dw-hero__buttons {
      justify-content: center;
    }

    .dw-hero__content--mobile-align-right .dw-hero__buttons {
      justify-content: flex-end;
    }
  }

  /* ==========================================
     ENTRANCE ANIMATIONS
     ========================================== */
  
  .dw-hero--animate .dw-hero__block {
    opacity: 0;
    animation-fill-mode: forwards;
    animation-duration: var(--hero-animation-duration, 800ms);
    animation-delay: calc(var(--block-index, 1) * var(--hero-animation-stagger, 100ms));
  }

  /* Fade Up */
  .dw-hero--animate[data-animation="fade-up"] .dw-hero__block {
    animation-name: dw-fade-up;
  }

  @keyframes dw-fade-up {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Fade In */
  .dw-hero--animate[data-animation="fade-in"] .dw-hero__block {
    animation-name: dw-fade-in;
  }

  @keyframes dw-fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  /* Slide Left */
  .dw-hero--animate[data-animation="slide-left"] .dw-hero__block {
    animation-name: dw-slide-left;
  }

  @keyframes dw-slide-left {
    from {
      opacity: 0;
      transform: translateX(-50px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* Slide Right */
  .dw-hero--animate[data-animation="slide-right"] .dw-hero__block {
    animation-name: dw-slide-right;
  }

  @keyframes dw-slide-right {
    from {
      opacity: 0;
      transform: translateX(50px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* Scale Up */
  .dw-hero--animate[data-animation="scale-up"] .dw-hero__block {
    animation-name: dw-scale-up;
  }

  @keyframes dw-scale-up {
    from {
      opacity: 0;
      transform: scale(0.9);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  /* Blur In */
  .dw-hero--animate[data-animation="blur-in"] .dw-hero__block {
    animation-name: dw-blur-in;
  }

  @keyframes dw-blur-in {
    from {
      opacity: 0;
      filter: blur(10px);
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      filter: blur(0);
      transform: translateY(0);
    }
  }

  /* Bounce In */
  .dw-hero--animate[data-animation="bounce-in"] .dw-hero__block {
    animation-name: dw-bounce-in;
    animation-timing-function: cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  @keyframes dw-bounce-in {
    from {
      opacity: 0;
      transform: scale(0.3) translateY(50px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }

  /* Glitch In */
  .dw-hero--animate[data-animation="glitch-in"] .dw-hero__block {
    animation-name: dw-glitch-in;
  }

  @keyframes dw-glitch-in {
    0% {
      opacity: 0;
      transform: translateX(-5px);
      filter: blur(4px);
    }
    20% {
      opacity: 0.5;
      transform: translateX(5px);
      filter: blur(2px);
    }
    40% {
      opacity: 0.7;
      transform: translateX(-3px);
      filter: blur(1px);
    }
    60% {
      opacity: 0.9;
      transform: translateX(2px);
      filter: blur(0);
    }
    80% {
      opacity: 1;
      transform: translateX(-1px);
    }
    100% {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* Reduce motion */
  @media (prefers-reduced-motion: reduce) {
    .dw-hero--animate .dw-hero__block,
    .dw-hero__glow-orb {
      animation: none;
      opacity: 1;
    }
  }

  /* ==========================================
     BUTTON STYLES
     ========================================== */

  .dw-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 28px;
    font-size: 20px;
    font-weight: 600;
    text-decoration: none;
    border-radius: 40px;
    transition: all 0.2s ease;
    cursor: pointer;
    border: 2px solid transparent;
    position: relative;
    color: var(--btn-text-color, inherit);
  }

  @media (min-width: 750px) {
    .dw-btn {
      padding: 16px 32px;
      font-size: 20px;
    }
  }

  .dw-btn--primary {
    background: var(--btn-bg, var(--doingwell-lime, #C4D600));
    color: var(--btn-text-color, var(--doingwell-black, #1a1a1a));
    border-color: var(--btn-border-color, var(--btn-bg, var(--doingwell-lime, #C4D600)));
  }

  .dw-btn--primary:hover {
    filter: brightness(0.9);
  }

  .dw-btn--secondary {
    background: var(--btn-bg, transparent);
    color: var(--btn-text-color, currentColor);
    border-color: var(--btn-border-color, var(--btn-text-color, currentColor));
  }

  .dw-btn--secondary:hover {
    background: var(--btn-bg, rgba(255,255,255,0.1));
    filter: brightness(1.1);
  }

  .dw-btn--white {
    background: var(--btn-bg, #fff);
    color: var(--btn-text-color, var(--doingwell-black, #1a1a1a));
    border-color: var(--btn-border-color, var(--btn-bg, #fff));
  }

  .dw-btn--white:hover {
    filter: brightness(0.95);
  }

  /* Button Width */
  .dw-btn--full {
    width: 100%;
  }

  /* Animated Gradient Button */
  .dw-btn--gradient {
    background: transparent;
    color: #fff;
    border: none;
    position: relative;
    z-index: 1;
    border-radius: 6px;
    overflow: hidden;
  }

  .dw-btn--gradient::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 6px;
    padding: 2px;
    background: linear-gradient(
      90deg,
      var(--btn-gradient-1, #ff00ff),
      var(--btn-gradient-2, #00d4ff),
      var(--btn-gradient-1, #ff00ff),
      var(--btn-gradient-2, #00d4ff)
    );
    background-size: 300% 100%;
    -webkit-mask: 
      linear-gradient(#fff 0 0) content-box, 
      linear-gradient(#fff 0 0);
    mask: 
      linear-gradient(#fff 0 0) content-box, 
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    z-index: -1;
  }

  .dw-btn--gradient-animate::before {
    animation: gradient-shift 3s linear infinite;
  }

  .dw-btn--gradient:hover::before {
    animation: gradient-shift 1.5s linear infinite;
  }

  .dw-btn--gradient span {
    position: relative;
    z-index: 2;
  }

  .dw-btn--gradient::after {
    content: '';
    position: absolute;
    inset: 2px;
    border-radius: 4px;
    background: var(--btn-bg, #0a0a0a);
    z-index: -1;
    transition: background 0.3s ease;
  }

  /* Gradient Glow */
  .dw-btn--gradient-glow {
    background: transparent;
    color: #fff;
    border: none;
    position: relative;
    z-index: 1;
    border-radius: 6px;
    overflow: visible;
  }

  .dw-btn--gradient-glow::before {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 8px;
    background: linear-gradient(
      90deg,
      var(--btn-gradient-1, #ff00ff),
      var(--btn-gradient-2, #00d4ff),
      var(--btn-gradient-1, #ff00ff),
      var(--btn-gradient-2, #00d4ff)
    );
    background-size: 300% 100%;
    z-index: -2;
    animation: gradient-shift 3s linear infinite;
    filter: blur(8px);
    opacity: 0.7;
  }

  .dw-btn--gradient-glow::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 6px;
    background: var(--btn-bg, #0a0a0a);
    z-index: -1;
  }

  .dw-btn--gradient-glow:hover::before {
    filter: blur(12px);
    opacity: 1;
    animation: gradient-shift 1.5s linear infinite;
  }

  .dw-btn--gradient-glow span {
    position: relative;
    z-index: 2;
  }

  @keyframes gradient-shift {
    0% { background-position: 0% 50%; }
    100% { background-position: 300% 50%; }
  }
</style>

