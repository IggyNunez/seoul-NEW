{%- liquid
  assign title = section.settings.title | default: "Can't decide? <em>We'll help.</em>"
  assign subtitle = section.settings.subtitle | default: 'Take our 60-second style quiz and discover the perfect infinity mirror for your space.'
  assign button_text = section.settings.button_text | default: 'Take the Quiz →'
  assign button_link = section.settings.button_link | default: '#'
  assign padding_top = section.settings.padding_top | default: 80
  assign padding_bottom = section.settings.padding_bottom | default: 80

  # Color settings
  assign bg_color = section.settings.bg_color | default: '#0a0a0f'
  assign text_primary = section.settings.text_primary | default: '#ffffff'
  assign accent_primary = section.settings.accent_primary | default: '#9333ea'
  assign accent_secondary = section.settings.accent_secondary | default: '#ec4899'
-%}

<section
  class="casa-col-cta"
  style="--cccta-pt: {{ padding_top }}px; --cccta-pb: {{ padding_bottom }}px; --cccta-bg: {{ bg_color }}; --cccta-text: {{ text_primary }}; --cccta-accent-1: {{ accent_primary }}; --cccta-accent-2: {{ accent_secondary }};"
>
  <div class="casa-col-cta__glow"></div>

  <div class="casa-col-cta__container">
    <h2 class="casa-col-cta__title">{{ title }}</h2>
    {%- if subtitle != blank -%}
      <p class="casa-col-cta__subtitle">{{ subtitle }}</p>
    {%- endif -%}
    {%- if button_text != blank -%}
      <a href="{{ button_link }}" class="casa-col-cta__btn">
        {{ button_text }}
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Casa Collection CTA",
  "tag": "section",
  "class": "casa-collection-cta-section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "html",
      "id": "title",
      "label": "Title (supports HTML)",
      "default": "Can't decide? <em>We'll help.</em>"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Take our 60-second style quiz and discover the perfect infinity mirror for your space."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Take the Quiz →"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#0a0a0f"
    },
    {
      "type": "color",
      "id": "text_primary",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_primary",
      "label": "Primary accent",
      "default": "#9333ea"
    },
    {
      "type": "color",
      "id": "accent_secondary",
      "label": "Secondary accent",
      "default": "#ec4899"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 80,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Casa Collection CTA"
    }
  ]
}
{% endschema %}

{% stylesheet %}
.casa-col-cta {
  position: relative;
  background: var(--cccta-bg);
  padding: var(--cccta-pt) 60px var(--cccta-pb);
  text-align: center;
  overflow: hidden;
}

.casa-col-cta__glow {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 800px;
  height: 400px;
  background: radial-gradient(ellipse, rgba(147, 51, 234, 0.15) 0%, rgba(236, 72, 153, 0.08) 40%, transparent 70%);
  pointer-events: none;
}

.casa-col-cta__container {
  position: relative;
  z-index: 1;
  max-width: 600px;
  margin: 0 auto;
}

.casa-col-cta__title {
  font-size: 42px;
  font-weight: 300;
  color: var(--cccta-text);
  margin: 0 0 16px 0;
  letter-spacing: -0.5px;
  line-height: 1.2;
}

.casa-col-cta__title em {
  font-style: normal;
  background: linear-gradient(135deg, var(--cccta-accent-1), var(--cccta-accent-2));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: 400;
}

.casa-col-cta__subtitle {
  font-size: 16px;
  line-height: 1.6;
  color: var(--cccta-text);
  opacity: 0.6;
  margin: 0 0 32px 0;
  max-width: 480px;
  margin-left: auto;
  margin-right: auto;
}

.casa-col-cta__btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 16px 32px;
  background: linear-gradient(135deg, var(--cccta-accent-1), var(--cccta-accent-2));
  color: var(--cccta-text);
  font-size: 16px;
  font-weight: 600;
  text-decoration: none;
  border-radius: 50px;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.casa-col-cta__btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 12px 40px rgba(147, 51, 234, 0.4);
}

/* Responsive */
@media (max-width: 900px) {
  .casa-col-cta {
    padding-left: 24px;
    padding-right: 24px;
  }

  .casa-col-cta__title {
    font-size: 32px;
  }
}

@media (max-width: 480px) {
  .casa-col-cta {
    padding-left: 16px;
    padding-right: 16px;
  }

  .casa-col-cta__title {
    font-size: 26px;
  }

  .casa-col-cta__subtitle {
    font-size: 14px;
  }

  .casa-col-cta__btn {
    padding: 14px 28px;
    font-size: 14px;
  }

  .casa-col-cta__glow {
    width: 400px;
    height: 200px;
  }
}
{% endstylesheet %}
