{%- comment -%}
  Seoul Glow Lab — Lookbook Split Section
  Image + rich text two-column layout for lookbook pages.
  Supports alternating layout, glassmorphic borders, mobile stacking.
{%- endcomment -%}

{%- liquid
  assign image_pos  = section.settings.image_position | default: 'left'
  assign img_width  = section.settings.image_width | default: 50
  assign img_radius = section.settings.image_radius | default: 0
  assign img_border = section.settings.image_border | default: 'none'
  assign v_align    = section.settings.content_vertical_align | default: 'center'
  assign bg_color   = section.settings.bg_color | default: '#0a0a0a'
  assign text_color  = section.settings.text_color | default: '#f5f5f5'
  assign accent      = section.settings.accent_color | default: '#9333ea'
  assign pad_top     = section.settings.padding_top | default: 80
  assign pad_bottom  = section.settings.padding_bottom | default: 80
  assign content_width = 100 | minus: img_width

  comment
    Alternating layout: flip image side on even section indices
  endcomment
  if section.settings.alternate_layout
    assign idx = section.index | modulo: 2
    if idx == 0
      if image_pos == 'left'
        assign image_pos = 'right'
      else
        assign image_pos = 'left'
      endif
    endif
  endif

  assign flex_dir = 'row'
  if image_pos == 'right'
    assign flex_dir = 'row-reverse'
  endif
-%}

<section
  id="casa-lb-split-{{ section.id }}"
  class="casa-lb-split"
  style="
    --clbs-bg: {{ bg_color }};
    --clbs-text: {{ text_color }};
    --clbs-accent: {{ accent }};
    --clbs-pad-top: {{ pad_top }}px;
    --clbs-pad-bottom: {{ pad_bottom }}px;
    --clbs-img-width: {{ img_width }}%;
    --clbs-content-width: {{ content_width }}%;
    --clbs-img-radius: {{ img_radius }}px;
    --clbs-flex-dir: {{ flex_dir }};
    --clbs-v-align: {% case v_align %}{% when 'top' %}flex-start{% when 'bottom' %}flex-end{% else %}center{% endcase %};
  "
>
  <div class="casa-lb-split__inner">
    {%- comment -%} IMAGE COLUMN {%- endcomment -%}
    <div class="casa-lb-split__image-col">
      <div class="casa-lb-split__image-wrap{% if img_border == 'subtle' %} casa-lb-split__image-wrap--border-subtle{% elsif img_border == 'glassmorphic' %} casa-lb-split__image-wrap--border-glass{% endif %}">
        {%- if section.settings.image != blank -%}
          <picture>
            {%- if section.settings.mobile_image != blank -%}
              <source
                media="(max-width: 749px)"
                srcset="{{ section.settings.mobile_image | image_url: width: 800 }} 800w,
                        {{ section.settings.mobile_image | image_url: width: 600 }} 600w"
                sizes="100vw"
              >
            {%- endif -%}
            <img
              src="{{ section.settings.image | image_url: width: 1200 }}"
              srcset="{{ section.settings.image | image_url: width: 600 }} 600w,
                      {{ section.settings.image | image_url: width: 900 }} 900w,
                      {{ section.settings.image | image_url: width: 1200 }} 1200w"
              sizes="(min-width: 750px) {{ img_width }}vw, 100vw"
              alt="{{ section.settings.image.alt | default: section.settings.image_alt | escape }}"
              loading="lazy"
              width="{{ section.settings.image.width }}"
              height="{{ section.settings.image.height }}"
              class="casa-lb-split__img"
            >
          </picture>
        {%- else -%}
          <div class="casa-lb-split__placeholder">
            {{ 'lifestyle-1' | placeholder_svg_tag: 'casa-lb-split__placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} CONTENT COLUMN {%- endcomment -%}
    <div class="casa-lb-split__content-col">
      <div class="casa-lb-split__content">
        {%- for block in section.blocks -%}
          {%- case block.type -%}

            {%- when 'subheading' -%}
              <p class="casa-lb-split__subheading" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </p>

            {%- when 'heading' -%}
              <{{ block.settings.tag | default: 'h2' }}
                class="casa-lb-split__heading"
                {{ block.shopify_attributes }}
              >
                {{ block.settings.text }}
              </{{ block.settings.tag | default: 'h2' }}>

            {%- when 'text' -%}
              <div class="casa-lb-split__richtext" {{ block.shopify_attributes }}>
                {{ block.settings.richtext }}
              </div>

            {%- when 'button' -%}
              {%- if block.settings.text != blank -%}
                <a
                  href="{{ block.settings.url | default: '#' }}"
                  class="casa-lb-split__btn casa-lb-split__btn--{{ block.settings.style | default: 'primary' }}"
                  {{ block.shopify_attributes }}
                >
                  {{ block.settings.text }}
                </a>
              {%- endif -%}

            {%- when 'spacer' -%}
              <div
                class="casa-lb-split__spacer"
                style="height: {{ block.settings.height | default: 24 }}px;"
                {{ block.shopify_attributes }}
              ></div>

          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<style>
  /* ===== Casa Lookbook Split ===== */
  .casa-lb-split {
    background: var(--clbs-bg, #0a0a0a);
    color: var(--clbs-text, #f5f5f5);
    padding-top: var(--clbs-pad-top, 80px);
    padding-bottom: var(--clbs-pad-bottom, 80px);
    overflow: hidden;
  }

  .casa-lb-split__inner {
    display: flex;
    flex-direction: var(--clbs-flex-dir, row);
    align-items: stretch;
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 60px);
    gap: clamp(24px, 4vw, 64px);
  }

  /* --- Image Column --- */
  .casa-lb-split__image-col {
    flex: 0 0 var(--clbs-img-width, 50%);
    max-width: var(--clbs-img-width, 50%);
    display: flex;
    align-items: center;
  }

  .casa-lb-split__image-wrap {
    width: 100%;
    border-radius: var(--clbs-img-radius, 0);
    overflow: hidden;
    position: relative;
  }

  .casa-lb-split__image-wrap--border-subtle {
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .casa-lb-split__image-wrap--border-glass {
    border: 1px solid rgba(255, 255, 255, 0.15);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.05),
      0 8px 32px rgba(0, 0, 0, 0.3),
      inset 0 0 0 1px rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
  }

  .casa-lb-split__img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .casa-lb-split__placeholder {
    background: rgba(255, 255, 255, 0.03);
    aspect-ratio: 3/4;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px;
  }

  .casa-lb-split__placeholder-svg {
    width: 100%;
    height: auto;
    opacity: 0.2;
  }

  /* --- Content Column --- */
  .casa-lb-split__content-col {
    flex: 0 0 var(--clbs-content-width, 50%);
    max-width: var(--clbs-content-width, 50%);
    display: flex;
    align-items: var(--clbs-v-align, center);
    justify-content: center;
  }

  .casa-lb-split__content {
    width: 100%;
    max-width: 560px;
    padding: 24px 0;
  }

  /* --- Subheading --- */
  .casa-lb-split__subheading {
    font-size: clamp(0.7rem, 0.8vw, 0.8rem);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--clbs-accent, #9333ea);
    margin: 0 0 16px;
    font-weight: 500;
  }

  /* --- Heading --- */
  .casa-lb-split__heading {
    font-size: clamp(1.75rem, 3vw, 3rem);
    line-height: 1.15;
    font-weight: 300;
    letter-spacing: -0.01em;
    margin: 0 0 24px;
    color: inherit;
  }

  /* --- Rich Text --- */
  .casa-lb-split__richtext {
    font-size: clamp(0.95rem, 1.1vw, 1.1rem);
    line-height: 1.7;
    color: rgba(245, 245, 245, 0.7);
    margin: 0 0 20px;
  }

  .casa-lb-split__richtext p {
    margin: 0 0 1em;
  }

  .casa-lb-split__richtext p:last-child {
    margin-bottom: 0;
  }

  .casa-lb-split__richtext a {
    color: var(--clbs-accent, #9333ea);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .casa-lb-split__richtext a:hover {
    opacity: 0.8;
  }

  /* --- Buttons --- */
  .casa-lb-split__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 36px;
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 4px;
    font-weight: 500;
    transition: all 0.3s ease;
    cursor: pointer;
    margin-top: 8px;
  }

  .casa-lb-split__btn--primary {
    background: var(--clbs-accent, #9333ea);
    color: #fff;
    border: 1px solid var(--clbs-accent, #9333ea);
  }

  .casa-lb-split__btn--primary:hover {
    background: transparent;
    color: var(--clbs-accent, #9333ea);
  }

  .casa-lb-split__btn--outline {
    background: transparent;
    color: var(--clbs-text, #f5f5f5);
    border: 1px solid rgba(255, 255, 255, 0.25);
  }

  .casa-lb-split__btn--outline:hover {
    border-color: var(--clbs-accent, #9333ea);
    color: var(--clbs-accent, #9333ea);
  }

  .casa-lb-split__btn--ghost {
    background: transparent;
    color: var(--clbs-accent, #9333ea);
    border: none;
    padding-left: 0;
    padding-right: 0;
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .casa-lb-split__btn--ghost:hover {
    opacity: 0.75;
  }

  /* --- Spacer --- */
  .casa-lb-split__spacer {
    width: 100%;
  }

  /* ===== Mobile (< 750px): stack vertically, image on top ===== */
  @media (max-width: 749px) {
    .casa-lb-split__inner {
      flex-direction: column;
      gap: 32px;
    }

    .casa-lb-split__image-col,
    .casa-lb-split__content-col {
      flex: 0 0 100%;
      max-width: 100%;
    }

    .casa-lb-split__image-col {
      order: -1;
    }

    .casa-lb-split__content {
      max-width: 100%;
      padding: 0;
    }

    .casa-lb-split__heading {
      font-size: clamp(1.5rem, 6vw, 2.25rem);
    }

    .casa-lb-split__btn {
      width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "Lookbook Split",
  "tag": "section",
  "class": "casa-lb-split-section",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image",
      "info": "Optional. Falls back to desktop image."
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "info": "Overrides the image's built-in alt text."
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "image_width",
      "label": "Image width",
      "min": 40,
      "max": 60,
      "step": 5,
      "default": 50,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "image_border",
      "label": "Image border style",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "subtle", "label": "Subtle" },
        { "value": "glassmorphic", "label": "Glassmorphic" }
      ],
      "default": "none"
    },
    {
      "type": "checkbox",
      "id": "alternate_layout",
      "label": "Alternate image side",
      "info": "When used multiple times on a page, auto-alternates the image between left and right.",
      "default": false
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "select",
      "id": "content_vertical_align",
      "label": "Content vertical alignment",
      "options": [
        { "value": "top", "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#0a0a0a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#9333ea"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 160,
      "step": 8,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 160,
      "step": 8,
      "default": 80,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "subheading",
      "name": "Subheading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Subheading",
          "default": "The Collection"
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Heading",
          "default": "Why We Love This Space"
        },
        {
          "type": "select",
          "id": "tag",
          "label": "Heading tag",
          "options": [
            { "value": "h1", "label": "H1" },
            { "value": "h2", "label": "H2" },
            { "value": "h3", "label": "H3" }
          ],
          "default": "h2"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "limit": 2,
      "settings": [
        {
          "type": "richtext",
          "id": "richtext",
          "label": "Content",
          "default": "<p>Every curve and contour has been considered. This collection embodies the intersection of sculptural form and ambient warmth, designed for spaces that speak quietly but leave a lasting impression.</p>"
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "limit": 2,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Button text",
          "default": "Explore Collection"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        },
        {
          "type": "select",
          "id": "style",
          "label": "Style",
          "options": [
            { "value": "primary", "label": "Primary (filled)" },
            { "value": "outline", "label": "Outline" },
            { "value": "ghost", "label": "Ghost (underline)" }
          ],
          "default": "primary"
        }
      ]
    },
    {
      "type": "spacer",
      "name": "Spacer",
      "settings": [
        {
          "type": "range",
          "id": "height",
          "label": "Height",
          "min": 8,
          "max": 80,
          "step": 4,
          "default": 24,
          "unit": "px"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lookbook Split",
      "blocks": [
        { "type": "subheading", "settings": { "text": "The Collection" } },
        { "type": "heading", "settings": { "text": "Why We Love This Space", "tag": "h2" } },
        { "type": "text", "settings": { "richtext": "<p>Every curve and contour has been considered. This collection embodies the intersection of sculptural form and ambient warmth, designed for spaces that speak quietly but leave a lasting impression.</p>" } },
        { "type": "spacer", "settings": { "height": 8 } },
        { "type": "button", "settings": { "text": "Explore Collection", "style": "primary" } }
      ]
    }
  ],
  "templates": ["page"]
}
{% endschema %}
